---
// src/layouts/BaseLayout.astro

import { pwaInfo } from "virtual:pwa-info";
import Loader from "../components/Loader.astro";
import Navbar from "../components/Nadbar.astro";
import FondoGlobal from "../components/FondoGlobal.astro";
import DockMenu from "../components/DockMenu.astro";

const {
  title = "Mi sitio",
  currentLang = "es",
  moveLogoMobile = false,
  pwaIcon = "/pwa-192x192.png",
  showAdminSidebar = true,
  useAdminOffset = true,
} = Astro.props;

const cspNonce = Astro.locals?.cspNonce || "";

let isAdmin = false;
let isSuperAdmin = false;
try {
  const trustedSession = Astro.locals?.user || null;
  const roleRaw = String(trustedSession?.rol || "").trim().toLowerCase();
  if (roleRaw) {
    const compactRole = roleRaw.replace(/[\s_-]/g, "");
    const role = compactRole === "superusuario" || compactRole === "superuser" || compactRole === "superadmin"
      ? "superusuario"
      : compactRole === "admin"
        ? "admin"
        : roleRaw;
    isAdmin = role === "admin" || role === "superusuario";
    isSuperAdmin = role === "superusuario";
  }
} catch (error) {
  isAdmin = false;
  isSuperAdmin = false;
}

const canShowAdminSidebar = isAdmin && showAdminSidebar;
const supportWhatsappNumber = "5255123456789";
const supportEmail = "soporte@goecomers.com";
const feedbackPageHref = `/${currentLang}/quejas-sugerencias`;
const whatsappSupportHref = `https://wa.me/${supportWhatsappNumber}?text=Hola%2C%20quiero%20reportar%20un%20fallo%20o%20queja.`;
const mailSupportHref = `mailto:${supportEmail}?subject=Reporte%20de%20fallo%20o%20queja`;
---

<!doctype html>
<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#090909" />

    <title>{title}</title>

<link rel="preload" href="/fonts/SF-Pro.ttf" as="font" type="font/ttf" crossorigin />
<link rel="preload" href="/fonts/NeueMontreal-Medium.otf" as="font" type="font/otf" crossorigin />

    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dfuzfdrat/image/upload/v1772744553/logob_pw3jsd.png" />
    <link rel="apple-touch-icon" href={pwaIcon} />

    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}

    <!-- Google Analytics 4 -->
    {import.meta.env.PUBLIC_GA4_MEASUREMENT_ID && (
      <>
        <script nonce={cspNonce} is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA4_MEASUREMENT_ID}`}></script>
        <script nonce={cspNonce} is:inline define:vars={{ GA4_ID: import.meta.env.PUBLIC_GA4_MEASUREMENT_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA4_ID, { anonymize_ip: true });
        </script>
      </>
    )}

    <!-- Meta Pixel (Facebook / Instagram Ads) -->
    {import.meta.env.PUBLIC_META_PIXEL_ID && (
      <script nonce={cspNonce} is:inline define:vars={{ META_PIXEL_ID: import.meta.env.PUBLIC_META_PIXEL_ID }}>
        !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
        n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
        document,'script','https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', META_PIXEL_ID);
        fbq('track', 'PageView');
      </script>
    )}

    <script nonce={cspNonce} is:inline>
      (function () {
        try {
          const t = localStorage.getItem("theme");
          if (t === "dark") document.documentElement.classList.add("dark");
        } catch (e) {}
      })();
    </script>

    <script nonce={cspNonce} is:inline>
      (function () {
        if (typeof window === "undefined") return;
        if (window.__goCsrfFetchPatched) return;
        window.__goCsrfFetchPatched = true;

        function getCsrfTokenFromCookie() {
          var match = document.cookie.match(/(?:^|;\s*)go_csrf=([^;]+)/);
          return match ? decodeURIComponent(match[1]) : "";
        }

        var originalFetch = window.fetch.bind(window);

        window.fetch = function (input, init) {
          try {
            var requestLike = input instanceof Request ? input : null;
            var method = String((init && init.method) || (requestLike && requestLike.method) || "GET").toUpperCase();
            var isMutating = method === "POST" || method === "PUT" || method === "DELETE" || method === "PATCH";

            if (isMutating) {
              var reqUrl = requestLike
                ? new URL(requestLike.url, window.location.origin)
                : new URL(String(input), window.location.origin);

              if (reqUrl.origin === window.location.origin) {
                var csrf = getCsrfTokenFromCookie();
                if (csrf) {
                  var headers = new Headers((init && init.headers) || (requestLike && requestLike.headers) || {});
                  if (!headers.has("x-csrf-token")) {
                    headers.set("x-csrf-token", csrf);
                  }
                  init = Object.assign({}, init || {}, { headers: headers });
                }
              }
            }
          } catch (e) {
            // No-op: if anything fails in the patching logic, fallback to native fetch.
          }

          return originalFetch(input, init);
        };
      })();
    </script>

    <style is:global>
      @import "../styles/typography.css";
      @import "../styles/app-reset.css";
      @import "../styles/backgrounds.css";

      :root {
        --header-height: 72px;
        --surface-0: #070709;
        --surface-1: #111114;
        --surface-2: #17171d;
        --surface-soft: rgba(255, 255, 255, 0.06);
        --line-soft: rgba(255, 255, 255, 0.12);
        --text-strong: #f8f8fa;
        --text-body: rgba(241, 241, 246, 0.9);
        --text-muted: rgba(205, 205, 214, 0.76);
        --brand-accent: #7a2532;
        --brand-gold: #263a72;
        --shadow-soft: 0 16px 36px rgba(0, 0, 0, 0.32);
        --shadow-elevated: 0 24px 56px rgba(0, 0, 0, 0.42);
        --radius-sm: 10px;
        --radius-md: 16px;
        --radius-lg: 22px;
        --grid-gap: 24px;
      }

      html,
      body {
        background:
          radial-gradient(circle at 0% -10%, rgba(251, 140, 55, 0.09), transparent 46%),
          radial-gradient(circle at 100% -20%, rgba(214, 166, 81, 0.08), transparent 48%),
          linear-gradient(180deg, #08080a 0%, #0b0b0f 48%, #09090d 100%);
        color: var(--text-body);
      }

      body {
        font-family: "SF Pro Display", "Inter", "Segoe UI", sans-serif;
        text-rendering: optimizeLegibility;
      }

      .app-content {
        width: 100%;
        padding-top: calc(var(--header-height) + 24px);
      }

      .premium-shell {
        width: min(1320px, calc(100% - 32px));
        margin: 0 auto;
      }

      .premium-hero {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--grid-gap);
        align-items: center;
        padding: 32px 0 48px;
      }

      .premium-hero__title {
        margin: 0;
        font-size: clamp(2rem, 5vw, 4rem);
        line-height: 1.02;
        letter-spacing: -0.03em;
        color: var(--text-strong);
      }

      .premium-hero__lead {
        margin: 16px 0 0;
        max-width: 64ch;
        color: var(--text-muted);
        font-size: clamp(1rem, 1.4vw, 1.12rem);
      }

      .premium-cta {
        margin-top: 24px;
        min-height: 48px;
        padding: 0 22px;
        border-radius: 999px;
        border: 1px solid rgba(251, 140, 55, 0.55);
        color: #fff;
        text-decoration: none;
        font-weight: 650;
        font-size: 0.95rem;
        letter-spacing: 0.01em;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(130deg, rgba(251, 140, 55, 0.92), rgba(214, 166, 81, 0.88));
        box-shadow: 0 0 0 1px rgba(251, 140, 55, 0.42), 0 12px 28px rgba(251, 140, 55, 0.28);
        transition: transform 180ms ease, box-shadow 180ms ease, filter 180ms ease;
      }

      .premium-cta:hover {
        transform: translateY(-1px);
        filter: brightness(1.03);
        box-shadow: 0 0 0 1px rgba(251, 140, 55, 0.65), 0 16px 36px rgba(251, 140, 55, 0.34);
      }

      .premium-grid {
        display: grid;
        gap: var(--grid-gap);
        grid-template-columns: repeat(12, minmax(0, 1fr));
      }

      .premium-card {
        background: linear-gradient(160deg, rgba(21, 21, 27, 0.96), rgba(11, 11, 15, 0.94));
        border: 1px solid var(--line-soft);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-soft);
        transition: transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
      }

      .premium-card:hover {
        transform: translateY(-3px);
        border-color: rgba(251, 140, 55, 0.38);
        box-shadow: var(--shadow-elevated);
      }

      .product-showcase {
        display: grid;
        gap: var(--grid-gap);
        grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
      }

      .tech-accordion {
        border: 1px solid var(--line-soft);
        border-radius: var(--radius-sm);
        background: rgba(255, 255, 255, 0.02);
        overflow: hidden;
      }

      .tech-accordion summary {
        min-height: 52px;
        padding: 0 16px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: var(--text-strong);
        font-weight: 620;
      }

      .tech-accordion[open] summary {
        border-bottom: 1px solid var(--line-soft);
      }

      .tech-accordion__content {
        padding: 14px 16px 18px;
        color: var(--text-muted);
        line-height: 1.65;
      }

      .fade-slide-in {
        animation: fadeSlideIn 320ms ease both;
      }

      @keyframes fadeSlideIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      html:not(.dark) {
        --surface-0: #f8fafc;
        --surface-1: #ffffff;
        --surface-2: #f2f5f9;
        --surface-soft: rgba(15, 23, 42, 0.05);
        --line-soft: rgba(15, 23, 42, 0.12);
        --text-strong: #0f172a;
        --text-body: rgba(15, 23, 42, 0.9);
        --text-muted: rgba(51, 65, 85, 0.84);
        --shadow-soft: 0 12px 30px rgba(15, 23, 42, 0.08);
        --shadow-elevated: 0 20px 38px rgba(15, 23, 42, 0.12);
      }

      html:not(.dark) body {
        background:
          radial-gradient(circle at 0% -10%, rgba(251, 140, 55, 0.1), transparent 48%),
          radial-gradient(circle at 100% -20%, rgba(214, 166, 81, 0.08), transparent 50%),
          linear-gradient(180deg, #f8fafc 0%, #f4f6fb 50%, #f8fafc 100%);
      }

      html:not(.dark) .premium-card {
        background: linear-gradient(160deg, rgba(255, 255, 255, 0.96), rgba(247, 250, 255, 0.94));
      }

      @media (max-width: 960px) {
        .app-content {
          padding-top: calc(var(--header-height) + 16px);
        }

        .premium-shell {
          width: min(1320px, calc(100% - 20px));
        }

        .product-showcase {
          grid-template-columns: 1fr;
        }

        .premium-hero {
          padding-top: 20px;
          padding-bottom: 32px;
          gap: 16px;
        }

        :root {
          --grid-gap: 16px;
        }
      }

      .home-curtain {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 99999;
        pointer-events: none;
        background: var(--slide-gradient);
        clip-path: polygon(0 0, 100% 0, 100% 0, 0 0);
      }

      .home-curtain.active {
        pointer-events: all;
        animation: 2.2s cubic-bezier(0.25, 1, 0.3, 1) wipe-in-top-down both;
      }

      @keyframes wipe-in-top-down {
        from { clip-path: polygon(0 0, 100% 0, 100% 0, 0 0); }
        to   { clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%); }
      }

      #dock-menu-wrapper {
        display: block;
      }
      @media all and (display-mode: standalone) {
        #dock-menu-wrapper {
          display: block !important;
        }
      }

      #admin-panel-root {
        pointer-events: none;
      }
      #admin-panel-root > * {
        pointer-events: auto;
      }

      * {
        -webkit-tap-highlight-color: transparent;
      }

      a,
      button,
      [role="button"],
      label,
      input[type="button"],
      input[type="submit"],
      input[type="reset"],
      select,
      summary {
        -webkit-user-select: none;
        -moz-user-select: none;
        user-select: none;
        outline: none;
      }

      section,
      article,
      .card,
      .btn,
      [class*="container"],
      [class*="wrapper"],
      [class*="section"],
      [class*="block"],
      [class*="tile"],
      [class*="item"],
      [class*="box"],
      nav,
      header,
      footer,
      aside {
        -webkit-user-select: none;
        -moz-user-select: none;
        user-select: none;
      }

      p,
      span,
      h1, h2, h3, h4, h5, h6,
      input[type="text"],
      input[type="email"],
      input[type="password"],
      input[type="search"],
      input[type="number"],
      textarea {
        -webkit-user-select: text;
        -moz-user-select: text;
        user-select: text;
      }

      .app-content.with-admin-offset {
        box-sizing: border-box;
        width: 100%;
        padding-left: 252px;
        transition: padding-left 0.22s ease;
      }

      body.admin-sidebar-collapsed .app-content.with-admin-offset {
        padding-left: 0;
      }

      .admin-sidebar {
        position: fixed;
        top: 92px;
        left: 16px;
        bottom: 24px;
        width: 220px;
        z-index: 9000;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 16px;
        background: linear-gradient(180deg, rgba(20, 20, 20, 0.96), rgba(10, 10, 10, 0.9));
        backdrop-filter: blur(8px);
        padding: 14px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transition: transform 0.24s ease, opacity 0.24s ease;
      }

      .admin-sidebar__scroll-area {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
        padding-right: 4px;
        scrollbar-width: thin;
        scrollbar-color: rgba(122, 37, 50, 0.82) rgba(255, 255, 255, 0.08);
      }

      .admin-sidebar__scroll-area::-webkit-scrollbar {
        width: 10px;
      }

      .admin-sidebar__scroll-area::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.08);
        border-radius: 999px;
      }

      .admin-sidebar__scroll-area::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg, rgba(122, 37, 50, 0.92), rgba(245, 158, 11, 0.88));
        border-radius: 999px;
        border: 2px solid rgba(10, 10, 10, 0.6);
      }

      .admin-sidebar-scroll {
        margin-top: 12px;
        padding-top: 10px;
        border-top: 1px solid rgba(255, 255, 255, 0.12);
        display: flex;
        justify-content: center;
        gap: 8px;
      }

      .admin-sidebar-scroll__btn {
        width: 34px;
        height: 34px;
        border-radius: 999px;
        border: 1px solid rgba(122, 37, 50, 0.5);
        background: linear-gradient(160deg, rgba(122, 37, 50, 0.18), rgba(15, 23, 42, 0.75));
        color: rgba(255, 255, 255, 0.95);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 0.92rem;
        font-weight: 700;
        line-height: 1;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
      }

      .admin-sidebar-scroll__btn:hover {
        transform: translateY(-1px);
        border-color: rgba(122, 37, 50, 0.85);
        box-shadow: 0 0 0 3px rgba(122, 37, 50, 0.18);
      }

      .admin-sidebar-scroll__btn:active {
        transform: translateY(0);
      }

      .admin-sidebar.is-collapsed {
        transform: translateX(-118%);
        opacity: 0;
        pointer-events: none;
      }

      .admin-sidebar__head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
      }

      .admin-sidebar__close {
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(255, 255, 255, 0.04);
        color: rgba(255, 255, 255, 0.86);
        border-radius: 8px;
        width: 30px;
        height: 30px;
        font-size: 1rem;
        line-height: 1;
        cursor: pointer;
      }

      .admin-sidebar__title {
        margin: 0 0 2px;
        font-size: 0.86rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.88);
      }

      .admin-sidebar__subtitle {
        margin: 0 0 14px;
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.58);
      }

      .admin-sidebar__list {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .admin-sidebar__link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 10px;
        text-decoration: none;
        color: rgba(255, 255, 255, 0.85);
        font-size: 0.82rem;
        background: rgba(255, 255, 255, 0.03);
        transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
      }

      .admin-sidebar__link--pending {
        position: relative;
      }

      .admin-sidebar__badge {
        margin-left: auto;
        min-width: 20px;
        height: 20px;
        padding: 0 6px;
        border-radius: 7px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.69rem;
        font-weight: 750;
        letter-spacing: 0;
        color: #fbbf24;
        background: rgba(245, 158, 11, 0.14);
        border: 1px solid rgba(245, 158, 11, 0.38);
        animation: sidebarBadgeGlow 2.8s ease-in-out infinite;
      }

      @keyframes sidebarBadgeGlow {
        0%, 100% { box-shadow: 0 0 4px rgba(245, 158, 11, 0.14); }
        50%       { box-shadow: 0 0 10px rgba(245, 158, 11, 0.32); }
      }

      .admin-sidebar__link:hover {
        background: rgba(122, 37, 50, 0.12);
        border-color: rgba(122, 37, 50, 0.42);
        transform: translateX(2px);
      }

      .admin-sidebar__dot {
        width: 7px;
        height: 7px;
        border-radius: 999px;
        background: #7a2532;
        box-shadow: 0 0 8px rgba(122, 37, 50, 0.65);
      }

      /* ─── Admin Toggle v2 — "Command Center" ─── */
      .admin-sidebar-toggle {
        display: inline-flex;
        position: fixed;
        left: 14px;
        bottom: 88px;
        z-index: 9001;
        align-items: center;
        gap: 9px;
        padding: 9px 13px 9px 10px;
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(13, 13, 17, 0.86);
        backdrop-filter: blur(14px) saturate(1.5);
        color: rgba(255, 255, 255, 0.84);
        font-size: 0.79rem;
        font-weight: 550;
        letter-spacing: 0.01em;
        cursor: pointer;
        box-shadow: 0 4px 18px rgba(0, 0, 0, 0.32);
        transition:
          transform 200ms cubic-bezier(0.34, 1.56, 0.64, 1),
          box-shadow 220ms ease,
          border-color 220ms ease,
          background 220ms ease,
          opacity 200ms ease;
      }

      .admin-sidebar-toggle:hover {
        transform: translateY(-2px) scale(1.012);
        border-color: rgba(255, 255, 255, 0.14);
        box-shadow: 0 8px 26px rgba(0, 0, 0, 0.38), 0 0 0 1px rgba(255, 255, 255, 0.05);
      }

      .admin-sidebar-toggle:active {
        transform: scale(0.974);
        transition-duration: 80ms;
      }

      .admin-sidebar-toggle__icon {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.22);
        flex: 0 0 auto;
        transition: background 300ms ease, box-shadow 300ms ease;
      }

      .admin-sidebar-toggle__label {
        line-height: 1;
        color: rgba(255, 255, 255, 0.82);
      }

      .admin-sidebar-toggle__badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 20px;
        height: 20px;
        padding: 0 6px;
        border-radius: 8px;
        font-size: 0.69rem;
        font-weight: 750;
        letter-spacing: 0;
        color: #fbbf24;
        background: rgba(245, 158, 11, 0.16);
        border: 1px solid rgba(245, 158, 11, 0.38);
        transition: all 250ms ease;
      }

      /* Prevent display:inline-flex from overriding [hidden] */
      .admin-sidebar-toggle__badge[hidden],
      .admin-sidebar__badge[hidden] {
        display: none !important;
      }

      /* Badge pop-in when revealed */
      @keyframes badgePopIn {
        0%   { transform: scale(0.4); opacity: 0; }
        70%  { transform: scale(1.18); opacity: 1; }
        100% { transform: scale(1); opacity: 1; }
      }

      .admin-sidebar-toggle__badge.is-entering {
        animation: badgePopIn 280ms cubic-bezier(0.34, 1.56, 0.64, 1) both;
      }

      /* Button shake when new pending items arrive */
      @keyframes adminToggleShake {
        0%   { transform: translateX(0); }
        15%  { transform: translateX(-3px) rotate(-0.8deg); }
        30%  { transform: translateX(3px) rotate(0.8deg); }
        45%  { transform: translateX(-2px); }
        60%  { transform: translateX(2px); }
        75%  { transform: translateX(-1px); }
        100% { transform: translateX(0); }
      }

      .admin-sidebar-toggle.is-shaking {
        animation: adminToggleShake 380ms ease both;
      }

      /* ── has-alert: breathing glow ── */
      .admin-sidebar-toggle.has-alert {
        border-color: rgba(245, 158, 11, 0.26);
        animation: adminToggleBreathe 3s ease-in-out infinite;
      }

      .admin-sidebar-toggle.has-alert .admin-sidebar-toggle__icon {
        background: #f59e0b;
        animation: adminDotPulse 2.4s ease-in-out infinite;
      }

      .admin-sidebar-toggle.has-alert .admin-sidebar-toggle__badge {
        color: #fbbf24;
        background: rgba(245, 158, 11, 0.2);
        border-color: rgba(245, 158, 11, 0.55);
        box-shadow: 0 0 8px rgba(245, 158, 11, 0.22);
        animation: adminBadgeBreathe 3s ease-in-out infinite;
      }

      /* ── is-urgent: 5+ items → coral escalation ── */
      .admin-sidebar-toggle.has-alert.is-urgent {
        border-color: rgba(244, 63, 94, 0.32);
        animation: adminToggleBreatheUrgent 2.2s ease-in-out infinite;
      }

      .admin-sidebar-toggle.has-alert.is-urgent .admin-sidebar-toggle__icon {
        background: #f43f5e;
        animation: adminDotPulseUrgent 2s ease-in-out infinite;
      }

      .admin-sidebar-toggle.has-alert.is-urgent .admin-sidebar-toggle__badge {
        color: #fda4af;
        background: rgba(244, 63, 94, 0.18);
        border-color: rgba(244, 63, 94, 0.52);
        box-shadow: 0 0 10px rgba(244, 63, 94, 0.26);
        animation: adminBadgeBreatheUrgent 2.2s ease-in-out infinite;
      }

      /* ── interaction-cooling: pauses all animations on interaction ── */
      .admin-sidebar-toggle.interaction-cooling,
      .admin-sidebar-toggle.interaction-cooling .admin-sidebar-toggle__icon,
      .admin-sidebar-toggle.interaction-cooling .admin-sidebar-toggle__badge {
        animation-play-state: paused;
      }

      /* ── Keyframes ── */
      @keyframes adminToggleBreathe {
        0%, 100% {
          box-shadow: 0 4px 18px rgba(0, 0, 0, 0.32), 0 0 0 0 rgba(245, 158, 11, 0);
        }
        50% {
          box-shadow: 0 6px 22px rgba(0, 0, 0, 0.36), 0 0 0 3px rgba(245, 158, 11, 0.09), 0 0 18px rgba(245, 158, 11, 0.11);
        }
      }

      @keyframes adminToggleBreatheUrgent {
        0%, 100% {
          box-shadow: 0 4px 18px rgba(0, 0, 0, 0.32), 0 0 0 0 rgba(244, 63, 94, 0);
        }
        50% {
          box-shadow: 0 6px 22px rgba(0, 0, 0, 0.36), 0 0 0 3px rgba(244, 63, 94, 0.12), 0 0 18px rgba(244, 63, 94, 0.14);
        }
      }

      @keyframes adminDotPulse {
        0%   { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.52); }
        65%  { box-shadow: 0 0 0 6px rgba(245, 158, 11, 0); }
        100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0); }
      }

      @keyframes adminDotPulseUrgent {
        0%   { box-shadow: 0 0 0 0 rgba(244, 63, 94, 0.52); }
        65%  { box-shadow: 0 0 0 6px rgba(244, 63, 94, 0); }
        100% { box-shadow: 0 0 0 0 rgba(244, 63, 94, 0); }
      }

      @keyframes adminBadgeBreathe {
        0%, 100% { transform: scale(1); box-shadow: 0 0 6px rgba(245, 158, 11, 0.16); }
        50%       { transform: scale(1.06); box-shadow: 0 0 12px rgba(245, 158, 11, 0.32); }
      }

      @keyframes adminBadgeBreatheUrgent {
        0%, 100% { transform: scale(1); box-shadow: 0 0 6px rgba(244, 63, 94, 0.16); }
        50%       { transform: scale(1.06); box-shadow: 0 0 12px rgba(244, 63, 94, 0.32); }
      }

