    <!--
      ⚡ AdminPanel — carga LAZY, solo al pulsar Ctrl+9
      El componente React NO se incluye en el bundle inicial.
      El div wrapper tiene pointer-events:none para no
      interferir con el cursor cuando el panel está cerrado.
    -->
    <div id="admin-panel-root"></div>

    <script src="/scripts/theme-toggle.js" defer></script>

    <!-- ⚡ PWA Service Worker — defer para no bloquear -->
    <script>
      import { registerSW } from "virtual:pwa-register";
      registerSW({ immediate: false }); // immediate:false → no bloquea el hilo principal
    </script>

    <!-- ⚡ Loader oculto con requestAnimationFrame → no bloquea el paint -->
    <script is:inline>
      window.addEventListener("load", () => {
        requestAnimationFrame(() => {
          const loader = document.getElementById("loader-wrapper");
          if (loader) {
            loader.style.transition = "opacity 0.5s ease";
            loader.style.opacity = "0";
            setTimeout(() => { loader.style.display = "none"; }, 500);
          }
        });
      });
    </script>

    <!--
      ⚡ AdminPanel — lazy import solo cuando el usuario pulsa Ctrl+9
      React + el componente se descargan únicamente en ese momento,
      ahorrando ~150-400 KB del bundle inicial.
    -->
    <script>
      const isAdminSession = document.body?.dataset?.admin === "1";
      const isSuperAdminSession = document.body?.dataset?.superadmin === "1";
      let adminMounted = false;
      const sidebarStorageKey = "adminSidebarCollapsed";

      const toggleButton = document.getElementById("admin-sidebar-toggle");
      const sidebar = document.getElementById("admin-sidebar");
      const sidebarScrollArea = document.getElementById("admin-sidebar-scroll-area");
      const closeSidebarButton = document.getElementById("admin-sidebar-close");
      const sidebarScrollUp = document.getElementById("admin-sidebar-scroll-up");
      const sidebarScrollDown = document.getElementById("admin-sidebar-scroll-down");
      const toggleLabel = toggleButton?.querySelector(".admin-sidebar-toggle__label");
      const toggleCount = document.getElementById("admin-sidebar-toggle-count");
      const pendingProductsBadge = document.getElementById("admin-pending-products");
      const pendingEmpresasBadge = document.getElementById("admin-pending-empresas");

      const setBadgeCount = (el: HTMLElement | null, count: number) => {
        if (!(el instanceof HTMLElement)) return;
        if (count > 0) {
          const wasHidden = el.hidden;
          el.textContent = String(count);
          el.hidden = false;
          // Pop-in animation only when badge transitions from hidden to visible
          if (wasHidden) {
            el.classList.remove("is-entering");
            // Force reflow so animation restarts cleanly
            void el.offsetWidth;
            el.classList.add("is-entering");
            el.addEventListener("animationend", () => el.classList.remove("is-entering"), { once: true });
          }
          return;
        }
        el.hidden = true;
      };

      let _prevTotal = 0;

      const updateAdminPendingUI = ({ products = 0, empresas = 0 }) => {
        const total = Math.max(0, Number(products || 0)) + Math.max(0, Number(empresas || 0));

        setBadgeCount(pendingProductsBadge, products);
        setBadgeCount(pendingEmpresasBadge, empresas);
        setBadgeCount(toggleCount, total);

        if (toggleButton instanceof HTMLElement) {
          toggleButton.classList.toggle("has-alert", total > 0);
          toggleButton.classList.toggle("is-urgent", total >= 5);
          toggleButton.setAttribute("aria-label", total > 0
            ? `Panel admin. ${total} pendiente${total === 1 ? "" : "s"} por aprobar`
            : "Panel admin");

          // Shake when new items appear (transition from 0 or total grows)
          if (total > 0 && total > _prevTotal) {
            toggleButton.classList.remove("is-shaking");
            void (toggleButton as HTMLElement).offsetWidth; // reflow
            toggleButton.classList.add("is-shaking");
            toggleButton.addEventListener("animationend", () => toggleButton.classList.remove("is-shaking"), { once: true });
          }
        }

        _prevTotal = total;
      };

      const fetchAdminPendings = async () => {
        if (!isSuperAdminSession) return;
        try {
          const [productsRes, empresasRes] = await Promise.all([
            fetch("/api/admin/productos/aprobaciones", { credentials: "include" }),
            fetch("/api/admin/empresas", { credentials: "include" }),
          ]);

          const productsData = await productsRes.json().catch(() => ({}));
          const empresasData = await empresasRes.json().catch(() => ({}));

          const products = Array.isArray(productsData?.productos) ? productsData.productos.length : 0;
          const empresas = Array.isArray(empresasData?.empresas)
            ? empresasData.empresas.filter((e: { Estado?: string }) => String(e?.Estado || "").toLowerCase() === "pendiente").length
            : 0;

          updateAdminPendingUI({ products, empresas });
        } catch (error) {
          console.error("[admin-sidebar] Error obteniendo pendientes:", error);
        }
      };

      const isMobile = () => window.matchMedia("(max-width: 1024px)").matches;

      const updateToggleLabel = () => {
        if (!toggleButton || !sidebar) return;
        if (isMobile()) {
          const label = sidebar.classList.contains("is-open")
            ? "Cerrar panel admin"
            : "Panel admin";
          if (toggleLabel instanceof HTMLElement) {
            toggleLabel.textContent = label;
          } else {
            toggleButton.textContent = label;
          }
          return;
        }

        const label = sidebar.classList.contains("is-collapsed")
          ? "Mostrar panel admin"
          : "Ocultar panel admin";
        if (toggleLabel instanceof HTMLElement) {
          toggleLabel.textContent = label;
        } else {
          toggleButton.textContent = label;
        }
      };

      const syncToggleVisibility = () => {
        if (!toggleButton || !sidebar) return;
        const shouldHide = isMobile()
          ? sidebar.classList.contains("is-open")
          : !sidebar.classList.contains("is-collapsed");
        toggleButton.classList.toggle("is-hidden", shouldHide);
      };

      const setDesktopCollapsed = (collapsed: boolean) => {
        if (!sidebar) return;
        sidebar.classList.toggle("is-collapsed", collapsed);
        document.body.classList.toggle("admin-sidebar-collapsed", collapsed);
        try {
          localStorage.setItem(sidebarStorageKey, collapsed ? "1" : "0");
        } catch {}
        updateToggleLabel();
        syncToggleVisibility();
      };

      let coolingTimer: number | null = null;

      if (toggleButton && sidebar) {
        toggleButton.addEventListener("click", () => {
          // Pause breathing animations briefly — UX feedback that user noticed
          if (toggleButton instanceof HTMLElement) {
            toggleButton.classList.add("interaction-cooling");
            if (coolingTimer !== null) clearTimeout(coolingTimer);
            coolingTimer = window.setTimeout(() => {
              toggleButton.classList.remove("interaction-cooling");
            }, 28000);
          }

          if (isMobile()) {
            sidebar.classList.toggle("is-open");
            updateToggleLabel();
            syncToggleVisibility();
            return;
          }

          const collapsed = !sidebar.classList.contains("is-collapsed");
          setDesktopCollapsed(collapsed);
        });
      }

      if (closeSidebarButton && sidebar) {
        closeSidebarButton.addEventListener("click", () => {
          if (isMobile()) {
            sidebar.classList.remove("is-open");
            updateToggleLabel();
            syncToggleVisibility();
            return;
          }

          setDesktopCollapsed(true);
        });
      }

      if (sidebarScrollArea && sidebarScrollUp) {
        sidebarScrollUp.addEventListener("click", () => {
          sidebarScrollArea.scrollBy({ top: -220, behavior: "smooth" });
        });
      }

      if (sidebarScrollArea && sidebarScrollDown) {
        sidebarScrollDown.addEventListener("click", () => {
          sidebarScrollArea.scrollBy({ top: 220, behavior: "smooth" });
        });
      }

      if (sidebar) {
        if (isMobile()) {
          sidebar.classList.remove("is-collapsed");
          document.body.classList.remove("admin-sidebar-collapsed");
        } else {
          try {
            const stored = localStorage.getItem(sidebarStorageKey) === "1";
            setDesktopCollapsed(stored);
          } catch {
            setDesktopCollapsed(false);
          }
        }
        updateToggleLabel();
        syncToggleVisibility();
      }

      if (isSuperAdminSession) {
        fetchAdminPendings();
        window.setInterval(fetchAdminPendings, 45000);
      }

      window.addEventListener("resize", () => {
        if (!sidebar) return;
        if (isMobile()) {
          document.body.classList.remove("admin-sidebar-collapsed");
          sidebar.classList.remove("is-collapsed");
        } else {
          const storedCollapsed = (() => {
            try {
              return localStorage.getItem(sidebarStorageKey) === "1";
            } catch {
              return false;
            }
          })();
          sidebar.classList.remove("is-open");
          setDesktopCollapsed(storedCollapsed);
        }
        updateToggleLabel();
        syncToggleVisibility();
      });

      document.addEventListener("keydown", async (e) => {
        if (!isAdminSession) return;

        // Activar con Ctrl+9
        if (e.ctrlKey && e.key === "9") {
          e.preventDefault();

          const root = document.getElementById("admin-panel-root");
          if (!root) return;

          if (!adminMounted) {
            adminMounted = true;

            try {
              // Importa React y el componente solo en este momento
              const [{ default: React }, { createRoot }, { default: AdminPanel }] =
                await Promise.all([
                  import("react"),
                  import("react-dom/client"),
                  import("../components/AdminPanel.jsx"),
                ]);

              // Activa pointer-events ahora que el panel existe
              root.style.pointerEvents = "none"; // el wrapper sigue sin capturar

              const reactRoot = createRoot(root);
              reactRoot.render(
                React.createElement(AdminPanel, { defaultOpen: true })
              );
            } catch (err) {
              console.error("[AdminPanel] Error al cargar:", err);
              adminMounted = false; // permite reintentar
            }
          }
        }
      });
    </script>
    <script src="/scripts/modal.js" defer></script>
    <script is:inline>
      (function () {
        var launcher = document.getElementById("support-launcher");
        var modal = document.getElementById("support-modal");
        var closeBtn = document.getElementById("support-modal-close");
        var form = document.getElementById("support-form");
        var status = document.getElementById("support-status");
        var submitBtn = document.getElementById("support-submit");

        if (!(launcher instanceof HTMLElement) || !(modal instanceof HTMLElement)) return;

        function setStatus(text, type) {
          if (!(status instanceof HTMLElement)) return;
          status.textContent = text;
          status.dataset.type = type || "info";
        }

        function openModal() {
          modal.hidden = false;
          launcher.setAttribute("aria-expanded", "true");
          var asunto = document.getElementById("support-asunto");
          if (asunto instanceof HTMLElement) asunto.focus();
        }

        function closeModal() {
          modal.hidden = true;
          launcher.setAttribute("aria-expanded", "false");
          launcher.focus();
        }

        launcher.addEventListener("click", openModal);
        closeBtn?.addEventListener("click", closeModal);

        modal.addEventListener("click", function (ev) {
          if (ev.target === modal) closeModal();
        });

        document.addEventListener("keydown", function (ev) {
          if (ev.key === "Escape" && !modal.hidden) closeModal();
        });

        form?.addEventListener("submit", async function (ev) {
          ev.preventDefault();

          var tipo = document.getElementById("support-tipo");
          var categoria = document.getElementById("support-categoria");
          var canal = document.getElementById("support-canal");
          var asunto = document.getElementById("support-asunto");
          var mensaje = document.getElementById("support-mensaje");

          var payload = {
            tipo: tipo instanceof HTMLSelectElement ? tipo.value : "queja",
            categoria: categoria instanceof HTMLSelectElement ? categoria.value : "general",
            canalRespuesta: canal instanceof HTMLSelectElement ? canal.value : "ticket",
            asunto: asunto instanceof HTMLInputElement ? asunto.value.trim() : "",
            mensaje: mensaje instanceof HTMLTextAreaElement ? mensaje.value.trim() : "",
          };

          if (submitBtn instanceof HTMLButtonElement) {
            submitBtn.disabled = true;
            submitBtn.textContent = "Enviando...";
          }

          try {
            var response = await fetch("/api/feedback", {
              method: "POST",
              credentials: "include",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
            });

            var data = await response.json().catch(function () { return {}; });

            if (!response.ok || !data?.success) {
              if (response.status === 401) {
                setStatus("Inicia sesión para registrar tu reporte y obtener folio.", "error");
              } else {
                setStatus(data?.error || "No se pudo enviar el reporte.", "error");
              }
              return;
            }

            var folio = data?.feedback?.folio || "Sin folio";
            setStatus("Reporte enviado. Folio: " + folio + ".", "success");
            if (asunto instanceof HTMLInputElement) asunto.value = "";
            if (mensaje instanceof HTMLTextAreaElement) mensaje.value = "";
          } catch (error) {
            setStatus("Error de red. Intenta nuevamente.", "error");
          } finally {
            if (submitBtn instanceof HTMLButtonElement) {
              submitBtn.disabled = false;
              submitBtn.textContent = "Enviar reporte";
            }
          }
        });
      })();
    </script>
  </body>
</html>


