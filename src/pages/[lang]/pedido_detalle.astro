---
// src/pages/[lang]/mi-cuenta/pedido/[id].astro
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}

const currentLang = "es";
const cspNonce = Astro.locals?.cspNonce || "";

const sessionRole = String(Astro.locals?.user?.rol || "").toLowerCase();
---

<BaseLayout title="Detalle del Pedido" currentLang={currentLang}>

<main class="od-page" data-role={sessionRole}>

  <!-- HEADER -->
  <div class="od-header">
    <a href={`/${currentLang}/mi-cuenta`} class="od-back">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      Mis pedidos
    </a>
    <div class="od-title-wrap">
      <h1 class="od-title">Detalle del Pedido</h1>
      <div id="od-order-badge" class="od-order-badge"></div>
    </div>
  </div>

  <!-- LOADING -->
  <div id="od-loading" class="od-loading">
    <div class="od-spinner"></div>
    <p>Cargando detalle…</p>
  </div>

  <!-- ERROR -->
  <div id="od-error" class="od-error" hidden>
    <span class="od-error-icon">⚠️</span>
    <p id="od-error-msg">No se pudo cargar el pedido.</p>
    <a href={`/${currentLang}/mi-cuenta`} class="od-btn-back">Volver a mis pedidos</a>
  </div>

  <!-- CONTENT -->
  <div id="od-content" hidden>

    <!-- TOP META BAR -->
    <div class="od-meta-bar">
      <div class="od-meta-item">
        <span class="od-meta-label">Fecha</span>
        <strong id="od-fecha"></strong>
      </div>
      <div class="od-meta-sep"></div>
      <div class="od-meta-item">
        <span class="od-meta-label">Estado</span>
        <span id="od-estado-chip" class="od-estado-chip"></span>
      </div>
      <div class="od-meta-sep"></div>
      <div class="od-meta-item">
        <span class="od-meta-label">Total</span>
        <strong id="od-total-top" class="od-total-top"></strong>
      </div>
      <div class="od-meta-sep"></div>
      <div class="od-meta-item od-meta-item--action">
        <button id="od-facturar-toggle" class="od-meta-action-btn" type="button">Facturar pedido</button>
      </div>
    </div>

    <!-- GRID PRINCIPAL -->
    <div class="od-grid">

      <!-- ── IZQUIERDA ── -->
      <div class="od-left">

        <!-- PRODUCTOS -->
        <section class="od-card">
          <div class="od-card-head">
            <span class="od-card-icon">📦</span>
            <h2>Productos comprados</h2>
          </div>
          <div id="od-items" class="od-items"></div>
        </section>

        <!-- ENVÍO -->
        <section class="od-card" id="od-ship-card">
          <div class="od-card-head">
            <span class="od-card-icon">🚚</span>
            <h2>Información de Envío</h2>
          </div>
          <div id="od-envio" class="od-envio-body"></div>
        </section>

        <!-- NOTAS -->
        <section class="od-card" id="od-notes-card" hidden>
          <div class="od-card-head">
            <span class="od-card-icon">✎</span>
            <h2>Notas del pedido</h2>
          </div>
          <p id="od-notas" class="od-notas-text"></p>
        </section>

        <section class="od-card" id="od-claim-card">
          <div class="od-card-head">
            <span class="od-card-icon">⚠️</span>
            <h2>Reportar fallo del producto</h2>
          </div>
          <div class="od-claim-wrap">
            <p id="od-claim-status" class="od-claim-status">Validando elegibilidad del pedido...</p>
            <p id="od-claim-feedback" class="od-claim-feedback" hidden></p>

            <form id="od-claim-form" class="od-claim-form" hidden>
              <label class="od-claim-field">
                <span>Motivo del fallo</span>
                <select id="od-claim-motivo" required>
                  <option value="">Selecciona un motivo</option>
                  <option value="llego_roto">Llegó roto</option>
                  <option value="producto_incorrecto">Producto incorrecto</option>
                  <option value="faltante">Faltante en el pedido</option>
                  <option value="defecto_fabricacion">Defecto de fabricación</option>
                  <option value="otro">Otro</option>
                </select>
              </label>

              <label class="od-claim-field">
                <span>Prioridad de la queja</span>
                <select id="od-claim-priority" required>
                  <option value="media">Media - faltante parcial o defecto moderado</option>
                  <option value="alta">Alta - roto grave / producto inutilizable</option>
                  <option value="baja">Baja - detalle menor</option>
                </select>
              </label>

              <label class="od-claim-field">
                <span>Descripción del fallo</span>
                <textarea id="od-claim-desc" minlength="20" maxlength="2500" rows="4" placeholder="Describe exactamente cómo llegó el producto y qué problema presenta." required></textarea>
              </label>

              <label class="od-claim-field">
                <span>Fotos de evidencia (obligatorio)</span>
                <input id="od-claim-photos" type="file" accept="image/jpeg,image/png,image/webp" multiple required />
                <small>Adjunta de 1 a 5 fotos. Formatos permitidos: JPG, PNG, WEBP. Máximo 8MB por foto.</small>
              </label>

              <button id="od-claim-submit" type="submit">Enviar reporte de fallo</button>
            </form>

            <div id="od-claim-history" class="od-claim-history"></div>
          </div>
        </section>

      </div>

      <!-- ── DERECHA ── -->
      <div class="od-right">

        <!-- RESUMEN DE COSTOS -->
        <section class="od-card od-sticky-card">
          <div class="od-card-head">
            <span class="od-card-icon">🧾</span>
            <h2>Resumen de costos</h2>
          </div>
          <div class="od-cost-lines">
            <div class="od-cost-line">
              <span>Subtotal productos</span>
              <strong id="od-subtotal"></strong>
            </div>
            <div class="od-cost-line">
              <span>Costo de envío</span>
              <strong id="od-costo-envio"></strong>
            </div>
            <div class="od-cost-divider"></div>
            <div class="od-cost-line od-cost-total">
              <span>Total pagado</span>
              <strong id="od-total-sum"></strong>
            </div>
          </div>
        </section>

        <!-- PAGO -->
        <section class="od-card" id="od-pay-card">
          <div class="od-card-head">
            <span class="od-card-icon">💳</span>
            <h2>Método de pago</h2>
          </div>
          <div id="od-pago" class="od-pago-body"></div>
        </section>

        <!-- DIRECCIÓN -->
        <section class="od-card">
          <div class="od-card-head">
            <span class="od-card-icon">📍</span>
            <h2>Dirección de entrega</h2>
          </div>
          <div id="od-direccion" class="od-direccion-body"></div>
        </section>

        <!-- FACTURA ELECTRÓNICA -->
        <section class="od-card" id="od-factura-card" hidden>
          <div class="od-card-head">
            <span class="od-card-icon">🧾</span>
            <h2>Factura Electrónica (CFDI)</h2>
          </div>
          <div id="od-factura-body" class="od-factura-body"></div>
        </section>

      </div>
    </div>
  </div>

</main>

<!-- ── MODAL FACTURA ── -->
<div id="od-fac-modal" class="od-fac-modal" hidden aria-modal="true" role="dialog" aria-labelledby="od-fac-title">
  <div class="od-fac-backdrop" id="od-fac-backdrop"></div>
  <div class="od-fac-box">
    <button class="od-fac-close" id="od-fac-close" aria-label="Cerrar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="od-fac-box-head">
      <span class="od-fac-box-icon">📄</span>
      <h3 id="od-fac-title">Solicitar Factura Electrónica</h3>
      <p>Ingresa tus datos fiscales para generar tu CFDI 4.0</p>
    </div>
    <form id="od-fac-form" class="od-fac-form" novalidate>
      <label class="od-fac-field">
        <span>RFC <em>*</em></span>
        <input id="od-fac-rfc" type="text" maxlength="13" placeholder="XAXX010101000" autocomplete="off" spellcheck="false" />
        <small>Persona moral: 12 caracteres · Persona física: 13 · Público en general: XAXX010101000</small>
      </label>
      <label class="od-fac-field">
        <span>Razón social / Nombre completo <em>*</em></span>
        <input id="od-fac-nombre" type="text" maxlength="254" placeholder="JUAN PEREZ GARCIA" />
      </label>
      <div class="od-fac-row-2">
        <label class="od-fac-field">
          <span>Uso del CFDI</span>
          <select id="od-fac-uso">
            <option value="G01">G01 — Adquisición de mercancias</option>
            <option value="G03" selected>G03 — Gastos en general</option>
            <option value="D01">D01 — Honorarios médicos</option>
            <option value="I01">I01 — Construcciones</option>
            <option value="S01">S01 — Sin efectos fiscales</option>
          </select>
        </label>
        <label class="od-fac-field">
          <span>CP fiscal</span>
          <input id="od-fac-cp" type="text" maxlength="5" pattern="[0-9]{5}" placeholder="64000" />
        </label>
      </div>
      <label class="od-fac-field">
        <span>Régimen fiscal del receptor</span>
        <select id="od-fac-regimen">
          <option value="601" selected>601 — General de Ley Personas Morales</option>
          <option value="603">603 — Personas Morales con Fines no Lucrativos</option>
          <option value="605">605 — Sueldos y Salarios e Ingresos Asimilados</option>
          <option value="606">606 — Arrendamiento</option>
          <option value="612">612 — Personas Físicas con Actividades Empresariales</option>
          <option value="616">616 — Sin obligaciones fiscales (→ UsoCFDI S01)</option>
          <option value="625">625 — Actividades Vía Plataformas Tecnológicas</option>
          <option value="626">626 — RESICO (Régimen Simplificado de Confianza)</option>
        </select>
      </label>
      <p id="od-fac-error" class="od-fac-error" hidden></p>
      <button type="submit" id="od-fac-submit" class="od-fac-submit-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="12" x2="12" y2="18"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
        <span id="od-fac-submit-txt">Generar Factura</span>
      </button>
    </form>
  </div>
</div>

<!-- ── MODAL CANCELAR FACTURA ── -->
<div id="od-fac-cancel-modal" class="od-fac-modal" hidden aria-modal="true" role="dialog" aria-labelledby="od-fcc-title">
  <div class="od-fac-backdrop" id="od-fcc-backdrop"></div>
  <div class="od-fac-box" style="max-width:460px">
    <button class="od-fac-close" id="od-fcc-close" aria-label="Cerrar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="od-fac-box-head">
      <span class="od-fac-box-icon" style="font-size:2rem">⚠️</span>
      <h3 id="od-fcc-title">Cancelar Factura Electrónica</h3>
      <p>Esta acción es irreversible ante el SAT. Selecciona el motivo correcto.</p>
    </div>
    <div style="padding:0 1.5rem 1.5rem">
      <label class="od-fac-field">
        <span>Motivo SAT</span>
        <select id="od-fcc-motivo">
          <option value="02" selected>02 — Comprobante emitido con errores sin relación</option>
          <option value="01">01 — Comprobante emitido con errores con relación</option>
          <option value="03">03 — No se llevó a cabo la operación</option>
          <option value="04">04 — Operación nominativa en factura global</option>
        </select>
      </label>
      <label class="od-fac-field" id="od-fcc-folio-wrap" style="display:none;margin-top:.5rem">
        <span>UUID del CFDI sustituto (motivo 01)</span>
        <input id="od-fcc-folio" type="text" maxlength="36" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" />
      </label>
      <p id="od-fcc-error" class="od-fac-error" hidden></p>
      <button type="button" id="od-fcc-submit" class="od-fac-submit-btn" style="background:linear-gradient(135deg,#c83250,#a0243e);margin-top:.75rem">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
        <span id="od-fcc-submit-txt">Confirmar Cancelación</span>
      </button>
    </div>
  </div>
</div>

<script nonce={cspNonce} is:inline define:vars={{ currentLang }}>
(function () {

  // ── Utils ──
  const $ = (id) => document.getElementById(id);
  const fmt = (v) =>
    `$${Number(v || 0).toLocaleString("es-MX", {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    })} MXN`;

  function fmtDate(str) {
    if (!str) return "—";
    try {
      return new Date(str).toLocaleDateString("es-MX", {
        year: "numeric", month: "long", day: "numeric",
      });
    } catch { return str; }
  }

  function fmtDateShort(str) {
    if (!str) return "—";
    try {
      return new Date(str).toLocaleDateString("es-MX", {
        weekday: "short", month: "short", day: "numeric",
      });
    } catch { return str; }
  }

  // ── Estado chip ──
  const ESTADO_MAP = {
    pagado:      { label: "Pagado",      cls: "chip-green"  },
    enviado:     { label: "Enviado",     cls: "chip-blue"   },
    entregado:   { label: "Entregado",   cls: "chip-green"  },
    cancelado:   { label: "Cancelado",   cls: "chip-red"    },
    pendiente:   { label: "Pendiente",   cls: "chip-yellow" },
    procesando:  { label: "Procesando",  cls: "chip-yellow" },
    reembolsado: { label: "Reembolsado", cls: "chip-gray"   },
    error_batch: { label: "Error",       cls: "chip-red"    },
  };

  const ENVIO_ESTADO_MAP = {
    creado:    { label: "Guía generada", cls: "chip-blue",   icon: "📋" },
    enviado:   { label: "En camino",     cls: "chip-blue",   icon: "🚚" },
    entregado: { label: "Entregado",     cls: "chip-green",  icon: "✅" },
    pendiente: { label: "Pendiente",     cls: "chip-yellow", icon: "⏳" },
  };

  function priorityClass(priority) {
    var map = { alta: "is-high", media: "is-medium", baja: "is-low" };
    return map[String(priority || "")] || "is-medium";
  }

  function priorityLabel(priority) {
    var map = {
      alta: "Alta · roto grave",
      media: "Media · faltante parcial",
      baja: "Baja · detalle menor",
    };
    return map[String(priority || "")] || "Media · faltante parcial";
  }

  function actionLabel(action) {
    var map = {
      creada: "Incidencia creada",
      dictamen_aprobado: "Veredicto aprobado",
      dictamen_rechazado: "Veredicto rechazado",
      notificacion_fallida: "Fallo de notificacion",
    };
    return map[String(action || "")] || String(action || "Accion");
  }

  function setClaimFeedback(text, type) {
    var box = $("od-claim-feedback");
    if (!(box instanceof HTMLElement)) return;
    var safeType = type === "success" ? "success" : "error";
    box.hidden = !text;
    box.textContent = text || "";
    box.className = "od-claim-feedback " + (text ? ("is-" + safeType) : "");
  }

  function renderClaimHistory(items) {
    const wrap = $("od-claim-history");
    if (!wrap) return;
    if (!Array.isArray(items) || !items.length) {
      wrap.innerHTML = "";
      return;
    }

    wrap.innerHTML = items.map(function (item) {
      var imgs = Array.isArray(item.imagenes) ? item.imagenes : [];
      var imagesHtml = imgs.length
        ? '<div class="od-claim-images">' + imgs.map(function (url) { return '<a href="' + url + '" target="_blank" rel="noopener"><img src="' + url + '" alt="Evidencia" loading="lazy" /></a>'; }).join("") + '</div>'
        : "";
      var verdict = item.veredicto ? '<p class="od-claim-verdict">Veredicto: ' + item.veredicto + '</p>' : "";
      var comment = item.comentarioVeredicto ? '<p class="od-claim-comment">' + item.comentarioVeredicto + '</p>' : "";
      var logs = Array.isArray(item.bitacora) ? item.bitacora : [];
      var logsHtml = logs.length
        ? '<div class="od-claim-log"><h4>Bitacora</h4>' + logs.map(function (entry) {
            var actor = entry.actorNombre || 'Sistema';
            var role = entry.actorRol ? ' (' + entry.actorRol + ')' : '';
            var detail = entry.detalle ? '<p>' + entry.detalle + '</p>' : '';
            return '<article><header><strong>' + actionLabel(entry.accion) + '</strong><span>' + fmtDate(entry.fecha) + '</span></header><small>' + actor + role + '</small>' + detail + '</article>';
          }).join('') + '</div>'
        : '';

      return (
        '<article class="od-claim-item">' +
          '<header><strong>' + (item.folio || "Incidencia") + '</strong><span>' + (item.estado || "pendiente") + '</span></header>' +
          '<p class="od-claim-priority ' + priorityClass(item.prioridad) + '">' + priorityLabel(item.prioridad) + '</p>' +
          '<p>' + (item.descripcion || "") + '</p>' +
          imagesHtml +
          verdict +
          comment +
          logsHtml +
        '</article>'
      );
    }).join("");
  }

  async function loadClaimPanel(orderId) {
    const status = $("od-claim-status");
    const form = $("od-claim-form");
    if (!status || !form) return;

    status.textContent = "Validando elegibilidad del pedido...";
    form.hidden = true;
    setClaimFeedback("", "success");

    try {
      const res = await fetch(`/api/me/pedidos/${orderId}/incidencias`, { credentials: "include" });
      const data = await res.json().catch(function () { return {}; });

      if (!res.ok || !data?.success) {
        status.textContent = data?.error || "No se pudo validar el reporte de fallos.";
        renderClaimHistory([]);
        return;
      }

      var eligibility = data?.eligibility || {};
      status.textContent = eligibility.reason || "";
      if (eligibility.isTestOverride) {
        setClaimFeedback("Modo pruebas habilitado: como superusuario puedes reportar pedidos no entregados.", "success");
      }

      if (eligibility.canReport) {
        var remaining = Number(eligibility.remainingDays || 0);
        status.textContent = eligibility.isTestOverride
          ? "Pruebas activas: reporte permitido sin estado entregado."
          : "Puedes reportar este pedido. Días restantes: " + remaining + ".";
        form.hidden = false;
      }

      renderClaimHistory(data?.incidencias || []);
    } catch (e) {
      status.textContent = "Error de red validando incidencias.";
      renderClaimHistory([]);
    }
  }

  // ── Obtener ID de la URL ──
  function getOrderId() {
    return new URLSearchParams(window.location.search).get("id");
  }

  // ── Render ──
  function renderItems(items) {
    const container = $("od-items");
    if (!container) return;
    container.innerHTML = "";
    items.forEach((item, i) => {
      const el = document.createElement("div");
      el.className = "od-item";
      el.style.animationDelay = `${i * 60}ms`;
      const imgHTML = item.imagen
        ? `<img src="${item.imagen}" alt="${item.nombre}" class="od-item-img" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">`
        : "";
      const placeholderStyle = item.imagen ? "display:none" : "";
      el.innerHTML = `
        ${imgHTML}
        <div class="od-item-placeholder" style="${placeholderStyle}">
          <span>📦</span>
        </div>
        <div class="od-item-info">
          <div class="od-item-name">${item.nombre}</div>
          ${item.descripcion ? `<div class="od-item-desc">${item.descripcion.slice(0, 80)}${item.descripcion.length > 80 ? "…" : ""}</div>` : ""}
          <div class="od-item-meta">
            <span class="od-item-qty">× ${item.cantidad}</span>
            <span class="od-item-unit">${fmt(item.precioUnitario)} c/u</span>
          </div>
        </div>
        <div class="od-item-subtotal">${fmt(item.subtotal)}</div>
      `;
      container.appendChild(el);
    });
  }

  function renderEnvio(envio, pedido) {
    const container = $("od-envio");
    if (!container) return;
    if (!envio) {
      container.innerHTML = `<p class="od-muted">Sin información de envío disponible.</p>`;
      return;
    }
    const estadoInfo = ENVIO_ESTADO_MAP[envio.estado?.toLowerCase()] || { label: envio.estado, cls: "chip-gray", icon: "📦" };
    const esGuiaReal = envio.guia && envio.guia !== "PENDIENTE";
    container.innerHTML = `
      <div class="od-envio-grid">
        <div class="od-envio-row">
          <span class="od-envio-label">Estado</span>
          <span class="od-estado-chip ${estadoInfo.cls}">${estadoInfo.icon} ${estadoInfo.label}</span>
        </div>
        <div class="od-envio-row">
          <span class="od-envio-label">Número de guía</span>
          <span class="od-envio-val ${esGuiaReal ? "od-guia" : "od-muted"}">${envio.guia || "—"}</span>
        </div>
        ${envio.fechaEnvio ? `
        <div class="od-envio-row">
          <span class="od-envio-label">Fecha de envío</span>
          <span class="od-envio-val">${fmtDate(envio.fechaEnvio)}</span>
        </div>` : ""}
        ${pedido.fechaEntregaEstimada ? `
        <div class="od-envio-row">
          <span class="od-envio-label">Entrega estimada</span>
          <span class="od-envio-val od-highlight">${fmtDateShort(pedido.fechaEntregaEstimada)}</span>
        </div>` : ""}
        ${envio.fechaEntrega ? `
        <div class="od-envio-row">
          <span class="od-envio-label">Entregado el</span>
          <span class="od-envio-val od-green">${fmtDate(envio.fechaEntrega)}</span>
        </div>` : ""}
      </div>
      ${esGuiaReal ? `
      <div class="od-track-hint">
        <span>🔍</span>
        <span>Usa el número de guía para rastrear tu paquete en el sitio del carrier.</span>
      </div>` : ""}
    `;
  }

  function renderPago(pago) {
    const container = $("od-pago");
    if (!container) return;
    if (!pago) {
      container.innerHTML = `<p class="od-muted">Sin información de pago.</p>`;
      return;
    }
    const marca = (pago.marca || "Tarjeta").toUpperCase();
    const last4 = pago.ultimos4 ? `•••• ${pago.ultimos4}` : "••••";
    const tipoFin = pago.tipoFinanciamiento === "no_definido" ? null : pago.tipoFinanciamiento;
    container.innerHTML = `
      <div class="od-card-visual">
        <div class="od-card-visual-inner">
          <div class="od-card-brand">${marca}</div>
          <div class="od-card-num">${last4}</div>
          <div class="od-card-bottom">
            <span>${pago.titular || ""}</span>
            <span>${pago.vencimiento || ""}</span>
          </div>
        </div>
      </div>
      <div class="od-pago-details">
        ${tipoFin ? `<div class="od-pago-row"><span>Tipo</span><span>${tipoFin}</span></div>` : ""}
        <div class="od-pago-row"><span>Estado</span><span class="od-estado-chip chip-green" style="font-size:11px;padding:3px 8px">${pago.estado}</span></div>
        <div class="od-pago-row"><span>Fecha</span><span>${fmtDate(pago.fecha)}</span></div>
        ${pago.transaccion ? `<div class="od-pago-row od-txn"><span>ID transacción</span><span class="od-txn-id">${pago.transaccion.slice(0, 20)}…</span></div>` : ""}
      </div>
    `;
  }

  function renderDireccion(dir) {
    const container = $("od-direccion");
    if (!container) return;
    container.innerHTML = `
      <div class="od-dir-lines">
        ${dir.nombre ? `<div class="od-dir-name">${dir.nombre}</div>` : ""}
        <div class="od-dir-line">${dir.calle}</div>
        <div class="od-dir-line">${dir.ciudad}, ${dir.estado}</div>
        <div class="od-dir-line">CP ${dir.cp} — ${dir.pais}</div>
      </div>
    `;
  }

  // ── Load ──
  async function loadOrder() {
    const orderId = getOrderId();
    if (!orderId) {
      $("od-loading").hidden = true;
      $("od-error-msg").textContent = "ID de pedido no encontrado en la URL.";
      $("od-error").hidden = false;
      return;
    }

    try {
      const res = await fetch(`/api/pedidos/${orderId}`, { credentials: "include" });
      const data = await res.json().catch(() => ({}));

      $("od-loading").hidden = true;

      if (res.status === 401) {
        window.location.href = `/${currentLang}/login`;
        return;
      }
      if (!res.ok || !data.success) {
        $("od-error-msg").textContent = data.error || "No se pudo cargar el pedido.";
        $("od-error").hidden = false;
        return;
      }

      const p = data.pedido;

      // Badge número
      const badge = $("od-order-badge");
      if (badge) badge.textContent = `#${p.numero}`;

      // Meta bar
      $("od-fecha").textContent = fmtDate(p.fecha);
      const estadoInfo = ESTADO_MAP[p.estado?.toLowerCase()] || { label: p.estado, cls: "chip-gray" };
      const estadoChip = $("od-estado-chip");
      estadoChip.textContent = estadoInfo.label;
      estadoChip.className = `od-estado-chip ${estadoInfo.cls}`;
      $("od-total-top").textContent = fmt(p.total);

      // Costos
      $("od-subtotal").textContent = fmt(p.subtotalProductos);
      $("od-costo-envio").textContent = p.costoEnvio === 0 ? "GRATIS" : fmt(p.costoEnvio);
      $("od-total-sum").textContent = fmt(p.total);

      // Items
      renderItems(p.items);

      // Envío
      renderEnvio(p.envio, p);

      // Pago
      if (p.pago) renderPago(p.pago);
      else $("od-pay-card").hidden = true;

      // Dirección
      renderDireccion(p.direccion);

      // Notas
      if (p.notasCliente) {
        $("od-notas").textContent = p.notasCliente;
        $("od-notes-card").hidden = false;
      }

      // Mostrar contenido
      $("od-content").hidden = false;

      await loadClaimPanel(p.id);
      setupFacturaToggle(p);

    } catch (err) {
      console.error(err);
      $("od-loading").hidden = true;
      $("od-error-msg").textContent = "Error de conexión. Intenta de nuevo.";
      $("od-error").hidden = false;
    }
  }

  $("od-claim-form")?.addEventListener("submit", async function (ev) {
    ev.preventDefault();

    var orderId = getOrderId();
    var motivoEl = $("od-claim-motivo");
    var descEl = $("od-claim-desc");
    var photosEl = $("od-claim-photos");
    var priorityEl = $("od-claim-priority");
    var statusEl = $("od-claim-status");
    var submitBtn = $("od-claim-submit");

    if (!(motivoEl instanceof HTMLSelectElement) || !(priorityEl instanceof HTMLSelectElement) || !(descEl instanceof HTMLTextAreaElement) || !(photosEl instanceof HTMLInputElement) || !(statusEl instanceof HTMLElement)) {
      return;
    }

    const files = Array.from(photosEl.files || []);
    if (!files.length) {
      setClaimFeedback("Debes adjuntar al menos una foto del fallo.", "error");
      return;
    }

    if (files.length > 5) {
      setClaimFeedback("Solo puedes adjuntar hasta 5 fotos.", "error");
      return;
    }

    const formData = new FormData();
    formData.append("motivo", motivoEl.value || "");
    formData.append("prioridad", priorityEl.value || "media");
    formData.append("descripcion", descEl.value || "");
    files.forEach(function (file) { formData.append("fotos", file); });

    if (submitBtn instanceof HTMLButtonElement) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Enviando reporte...";
    }

    try {
      const res = await fetch(`/api/me/pedidos/${orderId}/incidencias`, {
        method: "POST",
        credentials: "include",
        body: formData,
      });
      const data = await res.json().catch(function () { return {}; });

      if (!res.ok || !data?.success) {
        setClaimFeedback(data?.error || "No se pudo enviar el reporte.", "error");
        return;
      }

      setClaimFeedback(data?.message || ("Reporte enviado correctamente. Folio: " + (data?.incidencia?.folio || "N/A")), "success");
      motivoEl.value = "";
      priorityEl.value = "media";
      descEl.value = "";
      photosEl.value = "";
      await loadClaimPanel(orderId);
    } catch (e) {
      setClaimFeedback("Error de red al enviar la incidencia.", "error");
    } finally {
      if (submitBtn instanceof HTMLButtonElement) {
        submitBtn.disabled = false;
        submitBtn.textContent = "Enviar reporte de fallo";
      }
    }
  });

  // ── Factura Electrónica ────────────────────────────────────────────────────

  function setFacturaError(msg) {
    var el = $("od-fac-error");
    if (!el) return;
    el.textContent = msg || "";
    el.hidden = !msg;
  }

  function normalizeInvoiceText(v) {
    return String(v || "")
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "");
  }

  function isBlockedInvoiceStatus(estado) {
    var s = normalizeInvoiceText(estado);
    return (
      s.includes("cancel") ||
      s.includes("devol") ||
      s.includes("reembols") ||
      s.includes("refund")
    );
  }

  function setFacturaToggleText(text, action) {
    var btn = $("od-facturar-toggle");
    if (!btn) return;
    btn.textContent = text;
    btn.dataset.action = action || "view";
  }

  var savedFiscalProfile = null;

  function isSavedFiscalComplete(data) {
    if (!data) return false;
    var rfc = String(data.rfcFiscal || "").trim();
    var nombre = String(data.razonSocialFiscal || "").trim();
    var regimen = String(data.regimenFiscal || "").trim();
    var cp = String(data.codigoPostalFiscal || "").trim();
    return (rfc.length >= 12 && rfc.length <= 13 && nombre.length >= 3 && regimen && /^\d{5}$/.test(cp));
  }

  function prefillFacturaFormFromProfile() {
    if (!savedFiscalProfile) return;
    var rfcEl = $("od-fac-rfc");
    var nombreEl = $("od-fac-nombre");
    var usoEl = $("od-fac-uso");
    var regimenEl = $("od-fac-regimen");
    var cpEl = $("od-fac-cp");

    if (rfcEl instanceof HTMLInputElement) rfcEl.value = String(savedFiscalProfile.rfcFiscal || "");
    if (nombreEl instanceof HTMLInputElement) nombreEl.value = String(savedFiscalProfile.razonSocialFiscal || "");
    if (usoEl instanceof HTMLSelectElement) usoEl.value = String(savedFiscalProfile.usoCfdi || "G03");
    if (regimenEl instanceof HTMLSelectElement) regimenEl.value = String(savedFiscalProfile.regimenFiscal || "601");
    if (cpEl instanceof HTMLInputElement) cpEl.value = String(savedFiscalProfile.codigoPostalFiscal || "");
  }

  async function submitFacturaRequest(orderId, payload) {
    var submitBtn = $("od-fac-submit");
    var submitTxt = $("od-fac-submit-txt");
    if (submitBtn instanceof HTMLButtonElement) submitBtn.disabled = true;
    if (submitTxt instanceof HTMLElement) submitTxt.textContent = "Generando...";

    try {
      var res = await fetch("/api/me/pedidos/" + orderId + "/factura", {
        method: "POST",
        credentials: "include",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      var data = await res.json().catch(function () { return {}; });

      if (!res.ok || !data.success) {
        setFacturaError(data?.error || "No se pudo generar la factura. Verifica tus datos fiscales.");
        return false;
      }

      closeFacturaModal();
      descargarFactura(orderId, "pdf");
      await loadFactura(orderId);
      return true;
    } catch (err) {
      setFacturaError("Error de red al generar la factura. Intenta de nuevo.");
      return false;
    } finally {
      if (submitBtn instanceof HTMLButtonElement) submitBtn.disabled = false;
      if (submitTxt instanceof HTMLElement) submitTxt.textContent = "Generar Factura";
    }
  }

  function openFacturaModal() {
    var modal = $("od-fac-modal");
    if (modal) { modal.hidden = false; document.body.style.overflow = "hidden"; }
    prefillFacturaFormFromProfile();
  }

  function closeCancelModal() {
    var modal = $("od-fac-cancel-modal");
    if (modal) { modal.hidden = true; document.body.style.overflow = ""; }
  }

  function openInlineCancelFactura(/* body param kept for compat, no longer used */) {
    // Reset modal fields
    var motivoEl  = $("od-fcc-motivo");
    var folioWrap = $("od-fcc-folio-wrap");
    var folioEl   = $("od-fcc-folio");
    var errEl     = $("od-fcc-error");
    var submitBtn = $("od-fcc-submit");
    var submitTxt = $("od-fcc-submit-txt");

    if (motivoEl) {
      motivoEl.value = "02";
      motivoEl.onchange = function () {
        if (folioWrap) folioWrap.style.display = this.value === "01" ? "" : "none";
      };
    }
    if (folioWrap) folioWrap.style.display = "none";
    if (folioEl)   folioEl.value = "";
    if (errEl)     errEl.hidden = true;

    if (submitBtn) {
      submitBtn.disabled = false;
      if (submitTxt) submitTxt.textContent = "Confirmar Cancelación";
      submitBtn.onclick = async function () {
        var motivo = $("od-fcc-motivo")?.value || "02";
        var folio  = $("od-fcc-folio")?.value.trim() || null;
        if (motivo === "01" && !folio) {
          if (errEl) { errEl.textContent = "El motivo 01 requiere el UUID del CFDI sustituto"; errEl.hidden = false; }
          return;
        }
        if (errEl) errEl.hidden = true;
        submitBtn.disabled = true;
        if (submitTxt) submitTxt.textContent = "Cancelando…";
        try {
          var res = await fetch("/api/me/pedidos/" + getOrderId() + "/factura", {
            method: "DELETE",
            credentials: "include",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ motivo, folioSustitucion: folio }),
          });
          var data = await res.json().catch(function () { return {}; });
          if (!data.success) {
            if (errEl) { errEl.textContent = data.error || "Error al cancelar"; errEl.hidden = false; }
            return;
          }
          closeCancelModal();
          await loadFactura(getOrderId());
        } catch (err) {
          if (errEl) { errEl.textContent = "Error de red: " + err.message; errEl.hidden = false; }
        } finally {
          submitBtn.disabled = false;
          if (submitTxt) submitTxt.textContent = "Confirmar Cancelación";
        }
      };
    }

    var modal = $("od-fac-cancel-modal");
    if (modal) { modal.hidden = false; document.body.style.overflow = "hidden"; }
  }

  function setupFacturaToggle(order) {
    var orderId = order?.id;
    var card = $("od-factura-card");
    var body = $("od-factura-body");
    var btn = $("od-facturar-toggle");
    if (!card || !body || !btn) return;

    var pageRole = String(document.querySelector(".od-page")?.dataset?.role || "").toLowerCase();
    var isSuperuser = pageRole === "superusuario" || pageRole === "admin";

    // Hide button for any cancelled / returned / refunded state across all fields
    var estados = [
      order?.estado,
      order?.estadoPedido,
      order?.pago?.estado,
      order?.envio?.estado,
      order?.devolucion?.estado,
    ];
    if (estados.some(isBlockedInvoiceStatus)) {
      btn.hidden = true;
      card.hidden = true;
      return;
    }

    // Only show button once order is entregado; superusuario/admin can always see it for testing
    var estadoNorm = normalizeInvoiceText(order?.estado || "");
    if (!estadoNorm.includes("entregado") && !isSuperuser) {
      btn.hidden = true;
      card.hidden = true;
      return;
    }

    btn.hidden = true; // hidden until invoice state is known
    card.hidden = true;
    setFacturaToggleText("Facturar pedido", "emit");

    // Fetch invoice state before showing button — so text is ALWAYS correct on first render
    fetch("/api/me/pedidos/" + orderId + "/factura", { credentials: "include" })
      .then(function (r) { return r.ok ? r.json() : Promise.reject(); })
      .then(function (d) {
        if (d.success && d.factura) {
          if (d.factura.estado === "vigente")        setFacturaToggleText("Cancelar factura", "cancel");
          else if (d.factura.estado === "cancelada") setFacturaToggleText("Factura cancelada", "view");
          // else factura null → keep "Facturar pedido"
        }
        btn.hidden = false;
      })
      .catch(function () { btn.hidden = false; }); // on error show default

    var facturaLoaded = false;

    btn.onclick = async function () {
      var action = btn.dataset.action || "emit";
      card.hidden = false;

      if (!facturaLoaded) {
        facturaLoaded = true;
        body.innerHTML =
          '<div style="padding:18px 20px;display:flex;justify-content:center">' +
            '<div class="od-spinner" style="width:22px;height:22px;margin:0"></div>' +
          '</div>';
        await loadFactura(orderId);
        // renderFactura has now run — trigger the action that caused the click
        if (action === "emit") {
          var quickBtnOnLoad = $("od-fac-generate-saved");
          if (quickBtnOnLoad) quickBtnOnLoad.click();
          else if ($("od-fac-open-modal")) openFacturaModal();
        } else if (action === "cancel") {
          openInlineCancelFactura(body);
        }
        return;
      }

      // Already loaded — act immediately
      if (action === "emit") {
        var quickBtn = $("od-fac-generate-saved");
        if (quickBtn) quickBtn.click();
        else openFacturaModal();
      } else if (action === "cancel") {
        var cancelBtnEl = $("od-fac-cancel-btn");
        if (cancelBtnEl) cancelBtnEl.click();
        else openInlineCancelFactura(body);
      }
    };
  }

  function renderFactura(data) {
    var body = $("od-factura-body");
    if (!body) return;
    var orderId = getOrderId();
    savedFiscalProfile = data?.datosFiscales || null;

    if (data.factura) {
      var f = data.factura;
      if (f.estado === "vigente") setFacturaToggleText("Cancelar factura", "cancel");
      else if (f.estado === "cancelada") setFacturaToggleText("Factura cancelada", "view");
      var uuidHtml = f.uuid
        ? '<div class="od-fac-info-row"><span>UUID</span><code class="od-fac-uuid">' + f.uuid + '</code></div>'
        : "";
      var cancelBtn = f.estado === "vigente"
        ? '<button class="od-fac-dl od-fac-dl-cancel" id="od-fac-cancel-btn" type="button" style="background:rgba(200,50,80,.1);color:#e87;border-color:rgba(200,50,80,.3)">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M18 6L6 18M6 6l12 12"/></svg>' +
            ' Cancelar' +
          '</button>'
        : "";
      body.innerHTML =
        '<div class="od-fac-exists">' +
          '<div class="od-fac-vigente-badge">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="14" height="14"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>' +
            " " + (f.estado === "cancelada" ? "Factura cancelada" : "Factura vigente") +
          "</div>" +
          '<div class="od-fac-info">' +
            '<div class="od-fac-info-row"><span>RFC</span><strong>' + f.rfcReceptor + "</strong></div>" +
            '<div class="od-fac-info-row"><span>Receptor</span><strong>' + f.nombreReceptor + "</strong></div>" +
            uuidHtml +
            '<div class="od-fac-info-row"><span>Total</span><strong>' + fmt(f.total) + "</strong></div>" +
            '<div class="od-fac-info-row"><span>Emitida</span><strong>' + fmtDate(f.fechaEmision) + "</strong></div>" +
          "</div>" +
          (f.estado !== "cancelada"
            ? '<div class="od-fac-dl-row">' +
                '<a href="/api/me/pedidos/' + orderId + '/factura?download=pdf" class="od-fac-dl od-fac-dl-pdf" target="_blank" rel="noopener">' +
                  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>' +
                  " PDF" +
                "</a>" +
                '<a href="/api/me/pedidos/' + orderId + '/factura?download=xml" class="od-fac-dl od-fac-dl-xml" target="_blank" rel="noopener">' +
                  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>' +
                  " XML" +
                "</a>" +
                cancelBtn +
              "</div>"
            : ""
          ) +
        "</div>";

      // Wire cancel button — inline expansion
      var cancelBtnEl = $("od-fac-cancel-btn");
      if (cancelBtnEl) {
        cancelBtnEl.onclick = function() {
          openInlineCancelFactura(body);
        };
      }
      return;
    }

    if (!data.canRequest) {
      setFacturaToggleText("Facturacion no disponible", "view");
      body.innerHTML =
        '<div class="od-fac-pending">' +
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="32" height="32"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' +
          "<p>" + (data.reason || "Disponible cuando el pedido sea entregado.") + "</p>" +
        "</div>";
      return;
    }

    setFacturaToggleText("Facturar pedido", "emit");

    var testBadge = data.isTestOverride
      ? '<span class="od-fac-test-badge">Modo pruebas activo</span>'
      : "";
    var canAutoGenerate = isSavedFiscalComplete(savedFiscalProfile);
    var autoGenerateHtml = canAutoGenerate
      ? '<button class="od-fac-cta-btn" id="od-fac-generate-saved" type="button" style="margin-top:.55rem">' +
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="17" height="17"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M8 15h8"/></svg>' +
          ' Generar con mi perfil fiscal guardado' +
        '</button>'
      : "";
    var profileHintHtml = canAutoGenerate
      ? '<p class="od-fac-hint" style="margin-top:.5rem">Tus datos fiscales guardados se usarán automáticamente.</p>'
      : "";
    body.innerHTML =
      '<div class="od-fac-cta">' +
        testBadge +
        '<p class="od-fac-cta-label">¿Necesitas comprobante fiscal para este pedido?</p>' +
        '<button class="od-fac-cta-btn" id="od-fac-open-modal" type="button">' +
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="17" height="17"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="12" x2="12" y2="18"/><line x1="9" y1="15" x2="15" y2="15"/></svg>' +
          " Solicitar Factura Electrónica" +
        "</button>" +
        autoGenerateHtml +
        profileHintHtml +
      "</div>";

    var openBtn = $("od-fac-open-modal");
    if (openBtn) {
      openBtn.addEventListener("click", function () {
        openFacturaModal();
      });
    }

    var quickBtn = $("od-fac-generate-saved");
    if (quickBtn) {
      quickBtn.addEventListener("click", async function () {
        if (!isSavedFiscalComplete(savedFiscalProfile)) {
          openFacturaModal();
          return;
        }
        var payload = {
          rfc: String(savedFiscalProfile.rfcFiscal || "").trim().toUpperCase(),
          nombre: String(savedFiscalProfile.razonSocialFiscal || "").trim().toUpperCase(),
          usoCfdi: String(savedFiscalProfile.usoCfdi || "G03"),
          regimenFiscal: String(savedFiscalProfile.regimenFiscal || "616"),
          cpFiscal: String(savedFiscalProfile.codigoPostalFiscal || "64000"),
          saveFiscalData: true,
        };
        await submitFacturaRequest(orderId, payload);
      });
    }
  }

  async function loadFactura(orderId) {
    var body = $("od-factura-body");
    if (!body) return;
    try {
      var res = await fetch("/api/me/pedidos/" + orderId + "/factura", { credentials: "include" });
      var data = await res.json().catch(function () { return {}; });
      if (!res.ok || !data.success) {
        body.innerHTML = '<p class="od-muted" style="padding:14px 20px">No disponible en este momento.</p>';
        return;
      }
      renderFactura(data);
    } catch (e) {
      body.innerHTML = '<p class="od-muted" style="padding:14px 20px">Error al cargar información de factura.</p>';
    }
  }

  function descargarFactura(orderId, tipo) {
    var t = (tipo === "xml") ? "xml" : "pdf";
    var a = document.createElement("a");
    a.href = "/api/me/pedidos/" + orderId + "/factura?download=" + t;
    a.rel = "noopener";
    a.style.display = "none";
    document.body.appendChild(a);
    a.click();
    a.remove();
  }

  function closeFacturaModal() {
    var modal = $("od-fac-modal");
    if (modal) { modal.hidden = true; document.body.style.overflow = ""; }
    setFacturaError("");
  }

  document.addEventListener("click", function (e) {
    if (e.target) {
      if (e.target.id === "od-fac-close" || e.target.closest?.("#od-fac-close")) closeFacturaModal();
      if (e.target.id === "od-fac-backdrop") closeFacturaModal();
      if (e.target.id === "od-fcc-close" || e.target.closest?.("#od-fcc-close")) closeCancelModal();
      if (e.target.id === "od-fcc-backdrop") closeCancelModal();
    }
  });

  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape") { closeFacturaModal(); closeCancelModal(); }
  });

  // Auto-sugerir régimen fiscal según longitud del RFC
  document.addEventListener("input", function (e) {
    if (!e.target || e.target.id !== "od-fac-rfc") return;
    var rfc = e.target.value.trim().toUpperCase();
    var regimenEl = $("od-fac-regimen");
    if (!(regimenEl instanceof HTMLSelectElement)) return;
    if (rfc.length === 12) regimenEl.value = "601"; // Persona Moral
    else if (rfc.length === 13) regimenEl.value = "612"; // Persona Física
  });

  document.addEventListener("submit", async function (e) {
    if (!e.target || e.target.id !== "od-fac-form") return;
    e.preventDefault();

    var orderId   = getOrderId();
    var rfcEl     = $("od-fac-rfc");
    var nombreEl  = $("od-fac-nombre");
    var usoEl     = $("od-fac-uso");
    var regimenEl = $("od-fac-regimen");
    var cpEl      = $("od-fac-cp");
    if (!(rfcEl instanceof HTMLInputElement) || !(nombreEl instanceof HTMLInputElement)) return;

    var rfc    = rfcEl.value.trim().toUpperCase().replace(/\s+/g, "");
    var nombre = nombreEl.value.trim();

    if (rfc.length < 12 || rfc.length > 13) {
      setFacturaError("El RFC debe tener 12 caracteres (persona moral) o 13 (persona física).");
      return;
    }
    if (nombre.length < 3) {
      setFacturaError("Ingresa tu nombre o razón social completo.");
      return;
    }

    setFacturaError("");
    await submitFacturaRequest(orderId, {
      rfc,
      nombre,
      usoCfdi:       usoEl     instanceof HTMLSelectElement ? usoEl.value     : "G03",
      regimenFiscal: regimenEl instanceof HTMLSelectElement ? regimenEl.value  : "616",
      cpFiscal:      cpEl      instanceof HTMLInputElement  ? (cpEl.value.trim() || "64000") : "64000",
      saveFiscalData: true,
    });
  });

  loadOrder();
})();
</script>

