---
import "../../styles/home.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import { GET as getCategorias } from '../api/categorias/index.js';
import { getTodosLosProductos } from "../../lib/productos-service.js";
import { getSessionUserId } from "../../lib/product-visibility.js";
import { getSponsoredProducts } from "../../lib/publicidad.js";
import { expireEmpresaProfilePayments } from "../../lib/empresa-profile.js";
import { createClient } from "@libsql/client";
import "dotenv/config";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}
const currentLang = "es";
const userId = getSessionUserId(Astro.cookies) ?? 0;

function getDb() {
  return createClient({
    url: String(process.env.ECOMERS_DATABASE_URL ?? ""),
    authToken: String(process.env.ECOMERS_AUTH_TOKEN ?? ""),
  });
}

async function getPopularProductIds(db: any, limit = 8, excludeIds: number[] = []) {
  const safeLimit = Math.max(1, Math.min(12, Number(limit) || 8));
  const cleanExclude = excludeIds
    .map((id) => Number(id))
    .filter((id) => Number.isFinite(id) && id > 0);

  const excludeSql = cleanExclude.length
    ? ` AND p.Id_Producto NOT IN (${cleanExclude.map(() => "?").join(",")})`
    : "";

  const result = await db.execute({
    sql: `
      SELECT
        p.Id_Producto,
        COALESCE(SUM(dp.Cantidad), 0) AS vendidos
      FROM Producto p
      LEFT JOIN DetallePedido dp ON dp.Id_Producto = p.Id_Producto
      WHERE COALESCE(p.Activo, 1) = 1
        ${excludeSql}
      GROUP BY p.Id_Producto
      ORDER BY vendidos DESC, p.Fecha_Creacion DESC, p.Id_Producto DESC
      LIMIT ?
    `,
    args: [...cleanExclude, safeLimit],
  });

  return result.rows
    .map((row: any) => Number(row.Id_Producto))
    .filter((id: number) => Number.isFinite(id) && id > 0);
}

async function getRecommendedProductIds(userIdParam: number, limit = 8) {
  const safeUserId = Number(userIdParam || 0);
  const db = getDb();
  const safeLimit = Math.max(1, Math.min(12, Number(limit) || 8));

  if (!safeUserId || safeUserId <= 0) {
    const ids = await getPopularProductIds(db, safeLimit);
    return { basedOnHistory: false, ids };
  }

  try {
    const purchasedResult = await db.execute({
      sql: `
        SELECT dp.Id_Producto, SUM(dp.Cantidad) AS totalCantidad
        FROM Pedido p
        JOIN DetallePedido dp ON dp.Id_Pedido = p.Id_Pedido
        WHERE p.Id_Usuario = ?
        GROUP BY dp.Id_Producto
        ORDER BY totalCantidad DESC
      `,
      args: [safeUserId],
    });

    const purchasedIds = purchasedResult.rows
      .map((row: any) => Number(row.Id_Producto))
      .filter((id: number) => Number.isFinite(id) && id > 0);

    if (!purchasedIds.length) {
      const ids = await getPopularProductIds(db, safeLimit);
      return { basedOnHistory: false, ids };
    }

    const topCategoriesResult = await db.execute({
      sql: `
        SELECT pc.Id_Categoria, SUM(dp.Cantidad) AS totalCantidad
        FROM Pedido p
        JOIN DetallePedido dp ON dp.Id_Pedido = p.Id_Pedido
        JOIN ProductoCategoria pc ON pc.Id_Producto = dp.Id_Producto
        WHERE p.Id_Usuario = ?
        GROUP BY pc.Id_Categoria
        ORDER BY totalCantidad DESC
        LIMIT 4
      `,
      args: [safeUserId],
    });

    const topCategoryIds = topCategoriesResult.rows
      .map((row: any) => Number(row.Id_Categoria))
      .filter((id: number) => Number.isFinite(id) && id > 0);

    let recommendedIds: number[] = [];
    if (topCategoryIds.length) {
      const catPlaceholders = topCategoryIds.map(() => "?").join(",");
      const purchasedPlaceholders = purchasedIds.map(() => "?").join(",");

      const relatedResult = await db.execute({
        sql: `
          SELECT
            p.Id_Producto,
            COALESCE(SUM(dp2.Cantidad), 0) AS vendidos
          FROM Producto p
          JOIN ProductoCategoria pc ON pc.Id_Producto = p.Id_Producto
          LEFT JOIN DetallePedido dp2 ON dp2.Id_Producto = p.Id_Producto
          WHERE COALESCE(p.Activo, 1) = 1
            AND pc.Id_Categoria IN (${catPlaceholders})
            AND p.Id_Producto NOT IN (${purchasedPlaceholders})
          GROUP BY p.Id_Producto
          ORDER BY vendidos DESC, p.Fecha_Creacion DESC, p.Id_Producto DESC
          LIMIT ?
        `,
        args: [...topCategoryIds, ...purchasedIds, safeLimit],
      });

      recommendedIds = relatedResult.rows
        .map((row: any) => Number(row.Id_Producto))
        .filter((id: number) => Number.isFinite(id) && id > 0);
    }

    if (recommendedIds.length < safeLimit) {
      const fillIds = await getPopularProductIds(db, safeLimit - recommendedIds.length, [
        ...recommendedIds,
        ...purchasedIds,
      ]);
      recommendedIds = [...recommendedIds, ...fillIds];
    }

    return { basedOnHistory: true, ids: recommendedIds.slice(0, safeLimit) };
  } catch (error) {
    console.error("Error building home recommendations:", error);
    const ids = await getPopularProductIds(db, safeLimit);
    return { basedOnHistory: false, ids };
  }
}

async function getFeaturedCompanies(db: any, limit = 6) {
  const safeLimit = Math.max(1, Math.min(12, Number(limit) || 6));
  const nowIso = new Date().toISOString();

  await expireEmpresaProfilePayments(db);

  const result = await db.execute({
    sql: `
      SELECT
        e.Id_Empresa,
        e.Nombre_Empresa,
        e.Nombre_Comercial,
        e.Logo_URL,
        e.Descripcion,
        COUNT(DISTINCT p.Id_Producto) AS TotalProductos,
        MAX(ep.Monto) AS MontoDestacado,
        (
          SELECT ip.Url
          FROM Producto p2
          LEFT JOIN Imagen_Producto ip ON ip.Id_Producto = p2.Id_Producto
          WHERE p2.Id_Empresa = e.Id_Empresa
            AND COALESCE(p2.Activo, 1) = 1
          ORDER BY ip.Id_Imagen ASC
          LIMIT 1
        ) AS ImagenProducto
      FROM EmpresaPerfilPago ep
      JOIN Empresa e ON e.Id_Empresa = ep.Id_Empresa
      LEFT JOIN Producto p ON p.Id_Empresa = e.Id_Empresa
      WHERE ep.Estado = 'activa'
        AND (ep.Fecha_Inicio IS NULL OR ep.Fecha_Inicio <= ?)
        AND (ep.Fecha_Fin IS NULL OR ep.Fecha_Fin > ?)
        AND COALESCE(e.Perfil_Publico_Activo, 0) = 1
      GROUP BY e.Id_Empresa
      ORDER BY MontoDestacado DESC, TotalProductos DESC, e.Id_Empresa DESC
      LIMIT ?
    `,
    args: [nowIso, nowIso, safeLimit],
  });

  return result.rows.map((row: any) => ({
    id: Number(row.Id_Empresa),
    nombre: String(row.Nombre_Comercial || row.Nombre_Empresa || 'Empresa'),
    logo: row.Logo_URL ? String(row.Logo_URL) : (row.ImagenProducto ? String(row.ImagenProducto) : '/images/logo/logo.png'),
    descripcion: String(row.Descripcion || 'Proveedor destacado en Nexus.'),
    totalProductos: Number(row.TotalProductos || 0),
    montoDestacado: Number(row.MontoDestacado || 0),
  }));
}

function formatPrice(value: number | null) {
  if (value == null || Number.isNaN(Number(value))) return "Precio bajo cotizacion";
  return new Intl.NumberFormat("es-MX", {
    style: "currency",
    currency: "MXN",
    maximumFractionDigits: 2,
  }).format(Number(value));
}

function resolveDisplayPrice(item: any) {
  const hasDiscount = item?.descuento?.vigente && Number.isFinite(Number(item?.descuento?.precioFinal));
  return hasDiscount ? Number(item.descuento.precioFinal) : (item?.precio ?? null);
}

function getDiscountBadge(item: any) {
  if (!item?.descuento?.vigente) return null;
  if (String(item.descuento.tipo || "") === "porcentaje") {
    const pct = Number(item.descuento.valor || 0);
    return pct > 0 ? `-${pct}%` : null;
  }
  return null;
}

function getSavingsAmount(item: any) {
  if (!item?.descuento?.vigente) return null;
  const base = Number(item?.precio);
  const finalPrice = Number(resolveDisplayPrice(item));
  if (!Number.isFinite(base) || !Number.isFinite(finalPrice)) return null;
  const savings = Math.max(0, Number((base - finalPrice).toFixed(2)));
  return savings > 0 ? savings : null;
}

function getSavingsText(item: any) {
  const amount = getSavingsAmount(item);
  return amount ? `Ahorro de ${formatPrice(amount)}` : null;
}

const MAX_CATEGORIAS = 8;
let allCategorias: any[] = [];

try {
  const res  = await getCategorias();
  const data = await res.json();
  allCategorias = data.categorias ?? [];
} catch (e) {
  console.error('Error cargando categorías en home:', e);
}

const categoriasVisible = allCategorias.slice(0, MAX_CATEGORIAS);
const allProducts = await getTodosLosProductos({ userId });
const productById = new Map<number, any>();
for (const prod of allProducts) {
  const id = Number((prod as any)?.id);
  if (Number.isFinite(id) && id > 0) {
    productById.set(id, prod);
  }
}
const sponsoredSlots = await getSponsoredProducts({ gridLimit: 9 }).catch(() => ({
  hero: null,
  top1: null,
  grid: [],
  allCampaignIds: [],
  all: [],
}));
const featuredCompanies = await getFeaturedCompanies(getDb(), 6).catch(() => []);

const sponsoredAllItems = Array.isArray(sponsoredSlots.all) && sponsoredSlots.all.length
  ? sponsoredSlots.all
  : [sponsoredSlots.hero, sponsoredSlots.top1, ...(sponsoredSlots.grid || [])].filter(Boolean);

const sponsoredPriorityItems = [...sponsoredAllItems].sort((a: any, b: any) => {
  const amountA = Number(a?.montoPagado || 0);
  const amountB = Number(b?.montoPagado || 0);
  if (amountB !== amountA) return amountB - amountA;

  const prioA = Number(a?.prioridad || 0);
  const prioB = Number(b?.prioridad || 0);
  if (prioB !== prioA) return prioB - prioA;

  const createdA = Date.parse(String(a?.fechaCreacion || ""));
  const createdB = Date.parse(String(b?.fechaCreacion || ""));
  const tsA = Number.isFinite(createdA) ? createdA : 0;
  const tsB = Number.isFinite(createdB) ? createdB : 0;
  return tsB - tsA;
});

const paidDiscountOffers = (() => {
  const seen = new Set<number>();
  const list: any[] = [];

  for (const item of sponsoredPriorityItems) {
    const id = Number(item?.id);
    if (!Number.isFinite(id) || id <= 0 || seen.has(id)) continue;

    const precio = Number(item?.precio);
    const precioFinal = Number(resolveDisplayPrice(item));
    if (!Number.isFinite(precio) || !Number.isFinite(precioFinal) || precioFinal >= precio) continue;

    const ahorro = Number((precio - precioFinal).toFixed(2));
    if (!(ahorro > 0)) continue;

    const porcentaje = String(item?.descuento?.tipo || "") === "porcentaje"
      ? Math.round(Number(item?.descuento?.valor || 0))
      : Math.max(1, Math.round((ahorro / precio) * 100));

    seen.add(id);
    list.push({
      id,
      nombre: String(item?.nombre || "Producto"),
      imagen: String(item?.imagen || "/images/logo/logo.png"),
      precio,
      precioFinal,
      ahorro,
      porcentaje,
      campaignId: Number(item?.campaignId || 0),
      position: String(item?.posicion || "grid"),
    });
  }

  return list.slice(0, 8);
})();

const sponsoredProductIds = new Set<number>(
  [sponsoredSlots.hero?.id, sponsoredSlots.top1?.id, ...(sponsoredSlots.grid || []).map((p: any) => p?.id)]
    .map((id) => Number(id))
    .filter((id) => Number.isFinite(id) && id > 0)
);

const sponsoredByProductId = new Map<number, any>();
for (const item of sponsoredPriorityItems) {
  const id = Number(item?.id);
  if (Number.isFinite(id) && id > 0) {
    sponsoredByProductId.set(id, item);
  }
}

const sponsoredProductsSorted = sponsoredPriorityItems
  .map((item: any) => productById.get(Number(item?.id)))
  .filter(Boolean);

const sponsoredPriorityProducts = sponsoredPriorityItems
  .map((item: any) => {
    const id = Number(item?.id);
    const product = productById.get(id);
    if (!product) return null;
    return { product, meta: item };
  })
  .filter(Boolean);

const recResult = await getRecommendedProductIds(userId, 8);
let recommendedProducts = recResult.ids
  .map((id: number) => productById.get(Number(id)))
  .filter(Boolean);

if (!recommendedProducts.length && allProducts.length) {
  recommendedProducts = allProducts.filter((prod: any) => !sponsoredProductIds.has(Number(prod.id))).slice(0, 8);
}

// Ensure paid campaigns appear first in the main "Lo mas popular" selection.
if (sponsoredProductsSorted.length > 0) {
  const merged = [...sponsoredProductsSorted, ...recommendedProducts, ...allProducts];
  const seen = new Set<number>();
  recommendedProducts = merged.filter((prod: any) => {
    const id = Number(prod?.id);
    if (!Number.isFinite(id) || id <= 0 || seen.has(id)) return false;
    seen.add(id);
    return true;
  }).slice(0, 12);
}

// Boost products from featured companies to the top of recommendations
const featuredCompanyIdSet = new Set<number>(featuredCompanies.map((c: any) => Number(c.id)));
if (featuredCompanyIdSet.size > 0) {
  const fromFeatured = allProducts.filter((p: any) =>
    featuredCompanyIdSet.has(Number((p as any).empresaId)) &&
    !sponsoredProductIds.has(Number(p.id)) &&
    !recommendedProducts.find((r: any) => r.id === p.id)
  );
  if (fromFeatured.length > 0) {
    // Merge: featured company products first, then regular recommendations, deduplicated
    const merged = [...fromFeatured, ...recommendedProducts];
    const seen = new Set<number>();
    recommendedProducts = merged.filter((p: any) => {
      const id = Number(p.id);
      if (seen.has(id)) return false;
      seen.add(id);
      return true;
    }).slice(0, 9);
  }
}

const recommendationTitle = recResult.basedOnHistory
  ? "Basado en tus compras anteriores"
  : "Lo mas popular en Nexus";

const sponsoredRecommendedCount = recommendedProducts.filter((prod: any) =>
  sponsoredByProductId.has(Number(prod?.id))
).length;

const featuredCategories = categoriasVisible.slice(0, 6);
const hasFeaturedCategories = featuredCategories.length > 0;
const quickStats = [
  { label: "SKUs activos", value: allProducts.length || 0 },
  { label: "Categorias", value: allCategorias.length || 0 },
  { label: "Recomendaciones", value: recommendedProducts.length || 0 },
];
const paidSpotlight = sponsoredSlots.hero || sponsoredSlots.top1 || sponsoredSlots.grid[0] || null;
const heroSpotlightProduct = paidSpotlight
  ? {
      id: Number(paidSpotlight.id),
      nombre: String(paidSpotlight.nombre || "Producto patrocinado"),
      imagen: String(paidSpotlight.imagen || "/images/logo/logo.png"),
      precio: resolveDisplayPrice(paidSpotlight),
      descuento: paidSpotlight.descuento || null,
    }
  : (recommendedProducts[0] || null);
const featuredProduct = recommendedProducts[0] || null;
const secondaryRecommendations = recommendedProducts.slice(1, 9);
const promiseTape = [
  "Busqueda instantanea",
  "Recompra inteligente",
  "Inventario confiable",
  "UI enfocada en conversion",
  "Checkout sin friccion",
  "Soporte operativo",
];

const b2bServices = [
  {
    title: "Logistica de fleteras",
    text: "Red de fleteras aliadas para rutas nacionales, consolidacion y entregas empresariales.",
  },
  {
    title: "Fulfillment B2B",
    text: "Cross-dock, surtido por lote y despacho programado para pedidos de alto volumen.",
  },
  {
    title: "Abasto recurrente",
    text: "Acuerdos de suministro continuo con forecast y reposicion automatizada.",
  },
];
type SpotlightItem = {
  id: number;
  name: string;
  image: string;
  price: string;
  href: string;
  badge: string;
};

const spotlightItems: SpotlightItem[] = (() => {
  const items: SpotlightItem[] = [];
  const seen = new Set<number>();

  if (paidSpotlight) {
    const paidId = Number(paidSpotlight.id);
    if (Number.isFinite(paidId) && paidId > 0) {
      seen.add(paidId);
      items.push({
        id: paidId,
        name: String(paidSpotlight.nombre || "Producto patrocinado"),
        image: String(paidSpotlight.imagen || "/images/logo/logo.png"),
        price: formatPrice(resolveDisplayPrice(paidSpotlight)),
        href: `/${currentLang}/productos/detalle/${paidId}`,
        badge: getDiscountBadge(paidSpotlight) || "Patrocinado",
      });
    }
  }

  for (const prod of recommendedProducts) {
    if (items.length >= 5) break;
    const id = Number(prod.id);
    if (!Number.isFinite(id) || id <= 0 || seen.has(id)) continue;
    seen.add(id);
    items.push({
      id,
      name: String(prod.nombre || "Producto"),
      image: String(prod.imagen || "/images/logo/logo.png"),
      price: formatPrice(prod.precio ?? null),
      href: `/${currentLang}/productos/detalle/${id}`,
      badge: prod.descuento?.porcentaje ? `-${prod.descuento.porcentaje}%` : "Top Pick",
    });
  }

  return items;
})();
---

<BaseLayout title="Nexus | Ecommerce" currentLang={currentLang}>
  <div class="nx-redesign">
  <section class="nx-hero nx-reveal" data-reveal>
    <div class="nx-hero__bg" aria-hidden="true"></div>
    <div class="nx-hero__grain" aria-hidden="true"></div>
    <div class="nx-container nx-hero__inner nx-hero-grid">
      <div class="nx-hero-copy">
        <p class="nx-kicker">Nexus eCommerce</p>
        <h1>Compra industrial en minutos, no en pestañas.</h1>
        <p class="nx-lead">
          Productos clave, precio visible y accion directa desde el primer scroll para equipos que compran por volumen.
        </p>
        <div class="nx-hero__actions">
          <a href={`/${currentLang}/productos/todos`} class="nx-btn nx-btn--primary">Ver productos</a>
          <a href={`/${currentLang}/descuentos`} class="nx-btn nx-btn--ghost">Ver descuentos activos</a>
        </div>
        <div class="nx-hero__chips" aria-label="Tendencias de busqueda">
          <a href={`/${currentLang}/productos/todos?busqueda=rafia`}>Rafia</a>
          <a href={`/${currentLang}/productos/todos?busqueda=stretch`}>Film stretch</a>
          <a href={`/${currentLang}/productos/todos?busqueda=saco`}>Sacos</a>
          <a href={`/${currentLang}/productos/todos?busqueda=cuerda`}>Cuerdas</a>
        </div>
      </div>

      <aside class="nx-hero-panel" data-parallax-card>
        <p class="nx-hero-panel__kicker">Nexus Command View</p>
        <div class="nx-hero-panel__stats">
          {quickStats.map((item, idx) => (
            <article style={`--panel-delay:${idx * 90}ms`}>
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </article>
          ))}
        </div>

        {heroSpotlightProduct && (
          <div class="nx-hero-panel__showcase" data-showcase-root>
            <a id="nxSpotlightLink" class="nx-hero-panel__spotlight" href={`/${currentLang}/productos/detalle/${heroSpotlightProduct.id}`}>
              <img id="nxSpotlightImage" src={heroSpotlightProduct.imagen || "/images/logo/logo.png"} alt={heroSpotlightProduct.nombre} loading="lazy" decoding="async" />
              <div>
                <p>Recomendado hoy</p>
                <h2 id="nxSpotlightName">{heroSpotlightProduct.nombre}</h2>
                <span id="nxSpotlightPrice">{formatPrice(heroSpotlightProduct.precio ?? null)}</span>
              </div>
              <i id="nxSpotlightBadge" class="nx-showcase-badge">{heroSpotlightProduct.descuento?.porcentaje ? `-${heroSpotlightProduct.descuento.porcentaje}%` : "Top Pick"}</i>
            </a>

            {spotlightItems.length > 1 && (
              <div class="nx-hero-panel__controls" aria-label="Control de recomendados">
                <button type="button" id="nxSpotlightPrev" class="nx-showcase-nav" aria-label="Anterior">&larr;</button>
                <div id="nxSpotlightDots" class="nx-showcase-dots">
                  {spotlightItems.map((_, idx) => (
                    <button
                      type="button"
                      class={`nx-showcase-dot ${idx === 0 ? "is-active" : ""}`}
                      data-dot-index={idx}
                      aria-label={`Ver destacado ${idx + 1}`}
                    ></button>
                  ))}
                </div>
                <button type="button" id="nxSpotlightNext" class="nx-showcase-nav" aria-label="Siguiente">&rarr;</button>
              </div>
            )}

            <span id="nxSpotlightProgress" class="nx-showcase-progress"></span>
          </div>
        )}
      </aside>
    </div>
  </section>

  {paidDiscountOffers.length > 0 && (
    <section class="nx-offers-priority nx-reveal" data-reveal>
      <div class="nx-container">
        <div class="nx-offers-priority__head">
          <h2>
            <span>⚡</span>
            OFERTAS DISPONIBLES
          </h2>
          <span class="nx-offers-priority__count">{paidDiscountOffers.length} productos</span>
        </div>

        <div class="nx-offers-priority__grid" aria-label="Publicidad con descuento activo">
          {paidDiscountOffers.map((item: any, index: number) => (
            <a
              class="nx-offer-card"
              href={`/${currentLang}/productos/detalle/${item.id}`}
              data-sponsored-link
              data-campaign-id={item.campaignId}
              data-position={item.position}
              style={`--delay:${index * 80}ms`}
            >
              <div class="nx-offer-card__badges">
                <span class="nx-offer-badge nx-offer-badge--discount">-{item.porcentaje}%</span>
                {index === 0 ? <span class="nx-offer-badge nx-offer-badge--top">Top Pick</span> : null}
              </div>

              <div class="nx-offer-card__media">
                <img src={item.imagen} alt={item.nombre} loading="lazy" decoding="async" />
              </div>

              <div class="nx-offer-card__body">
                <p class="nx-offer-card__label">producto:</p>
                <h3>{item.nombre}</h3>

                <div class="nx-offer-card__prices">
                  <span class="nx-offer-card__old">{formatPrice(item.precio)}</span>
                  <strong class="nx-offer-card__now">{formatPrice(item.precioFinal)}</strong>
                </div>

                <div class="nx-offer-card__saving">
                  <span>✓</span>
                  Ahorras <strong>{formatPrice(item.ahorro)} MXN</strong>
                </div>

                <div class="nx-offer-card__cta">Ver producto <span>→</span></div>
              </div>

              <span class="nx-offer-card__rank">#{index + 1}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="nx-tape nx-reveal" data-reveal aria-label="Ventajas Nexus">
    <div class="nx-tape__track">
      {[...promiseTape, ...promiseTape].map((item, idx) => (
        <span>{item}{idx < promiseTape.length * 2 - 1 ? " •" : ""}</span>
      ))}
    </div>
  </section>

  {(sponsoredSlots.hero || sponsoredSlots.top1 || sponsoredSlots.grid.length > 0) && (
    <section class="nx-sponsored nx-reveal" data-reveal>
      <div class="nx-container">
        <div class="nx-sponsored__head">
          <div>
            <p class="nx-sponsored__kicker">Espacios Premium</p>
            <h2>Productos patrocinados por marca</h2>
          </div>
          <div class="nx-sponsored__actions">
            <span class="nx-sponsored__badge">Publicidad activa</span>
            <a class="nx-sponsored__cta" href={`/${currentLang}/publicidad`}>Promocionar mi producto</a>
          </div>
        </div>

        <div class="nx-sponsored__slots">
          {sponsoredSlots.hero && (
            <article class="nx-sponsored-card nx-sponsored-card--hero" data-reveal-card>
              <a
