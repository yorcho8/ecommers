  <script is:inline define:vars={{ spotlightItems, currentLang }}>
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const revealTargets = Array.from(document.querySelectorAll("[data-reveal]"));
    const parallaxCard = document.querySelector("[data-parallax-card]");

    // Keep first paint immediate: no delayed reveal observer.
    revealTargets.forEach((el) => el.classList.add("is-visible"));

    if (!prefersReducedMotion && parallaxCard instanceof HTMLElement) {
      const onMove = (event) => {
        const bounds = parallaxCard.getBoundingClientRect();
        const x = ((event.clientX - bounds.left) / bounds.width - 0.5) * 2;
        const y = ((event.clientY - bounds.top) / bounds.height - 0.5) * 2;
        parallaxCard.style.setProperty("--rx", `${(-y * 3).toFixed(2)}deg`);
        parallaxCard.style.setProperty("--ry", `${(x * 4).toFixed(2)}deg`);
      };

      const onLeave = () => {
        parallaxCard.style.setProperty("--rx", "0deg");
        parallaxCard.style.setProperty("--ry", "0deg");
      };

      parallaxCard.addEventListener("mousemove", onMove);
      parallaxCard.addEventListener("mouseleave", onLeave);
    }

    const showcaseRoot = document.querySelector("[data-showcase-root]");
    const spotlightLink = document.getElementById("nxSpotlightLink");
    const spotlightImage = document.getElementById("nxSpotlightImage");
    const spotlightName = document.getElementById("nxSpotlightName");
    const spotlightPrice = document.getElementById("nxSpotlightPrice");
    const spotlightBadge = document.getElementById("nxSpotlightBadge");
    const spotlightDots = Array.from(document.querySelectorAll(".nx-showcase-dot"));
    const spotlightPrev = document.getElementById("nxSpotlightPrev");
    const spotlightNext = document.getElementById("nxSpotlightNext");
    const spotlightProgress = document.getElementById("nxSpotlightProgress");

    if (
      Array.isArray(spotlightItems) &&
      spotlightItems.length > 1 &&
      showcaseRoot instanceof HTMLElement &&
      spotlightLink instanceof HTMLAnchorElement &&
      spotlightImage instanceof HTMLImageElement &&
      spotlightName instanceof HTMLElement &&
      spotlightPrice instanceof HTMLElement &&
      spotlightBadge instanceof HTMLElement
    ) {
      let spotlightIndex = 0;
      let timer = null;
      const SHOWCASE_DELAY = 4800;

      const renderSpotlight = (index, animated = true) => {
        const item = spotlightItems[index];
        if (!item) return;

        if (animated) {
          showcaseRoot.classList.remove("is-switching");
          requestAnimationFrame(() => showcaseRoot.classList.add("is-switching"));
        }

        spotlightLink.href = item.href;
        spotlightImage.src = item.image;
        spotlightImage.alt = item.name;
        spotlightName.textContent = item.name;
        spotlightPrice.textContent = item.price;
        spotlightBadge.textContent = item.badge;

        spotlightDots.forEach((dot, dotIndex) => {
          dot.classList.toggle("is-active", dotIndex === index);
        });

        if (spotlightProgress instanceof HTMLElement) {
          spotlightProgress.style.animation = "none";
          spotlightProgress.offsetHeight;
          spotlightProgress.style.animation = `nx-showcase-progress ${SHOWCASE_DELAY}ms linear forwards`;
        }
      };

      const nextSpotlight = () => {
        spotlightIndex = (spotlightIndex + 1) % spotlightItems.length;
        renderSpotlight(spotlightIndex, true);
      };

      const startAuto = () => {
        if (prefersReducedMotion) return;
        if (timer) window.clearInterval(timer);
        timer = window.setInterval(nextSpotlight, SHOWCASE_DELAY);
      };

      const stopAuto = () => {
        if (timer) {
          window.clearInterval(timer);
          timer = null;
        }
      };

      spotlightPrev?.addEventListener("click", () => {
        spotlightIndex = (spotlightIndex - 1 + spotlightItems.length) % spotlightItems.length;
        renderSpotlight(spotlightIndex, true);
        startAuto();
      });

      spotlightNext?.addEventListener("click", () => {
        nextSpotlight();
        startAuto();
      });

      spotlightDots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const dotIndex = Number(dot.getAttribute("data-dot-index"));
          if (!Number.isFinite(dotIndex)) return;
          spotlightIndex = dotIndex;
          renderSpotlight(spotlightIndex, true);
          startAuto();
        });
      });

      showcaseRoot.addEventListener("mouseenter", stopAuto);
      showcaseRoot.addEventListener("mouseleave", startAuto);
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) stopAuto();
        else startAuto();
      });

      renderSpotlight(spotlightIndex, false);
      startAuto();
    }

    const sponsoredLinks = Array.from(document.querySelectorAll("[data-sponsored-link]"));
    const sentImpressions = new Set();

    const sendTrack = (payload) => {
      try {
        fetch("/api/publicidad/track", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
          keepalive: true,
        }).catch(() => {});
      } catch {
        // no-op: metrics should never break the page
      }
    };

    sponsoredLinks.forEach((link) => {
      if (!(link instanceof HTMLAnchorElement)) return;
      const campaignId = Number(link.dataset.campaignId || 0);
      const posicion = String(link.dataset.position || "grid");
      if (!Number.isFinite(campaignId) || campaignId <= 0) return;

      if (!sentImpressions.has(campaignId)) {
        sendTrack({ campaignId, tipo: "impresion", posicion, page: "home", lang: currentLang });
        sentImpressions.add(campaignId);
      }

      link.addEventListener(
        "click",
        () => {
          sendTrack({ campaignId, tipo: "click", posicion, page: "home", lang: currentLang });
        },
        { once: true }
      );
    });
  </script>
