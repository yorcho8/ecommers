---
// src/pages/[lang]/register.astro
import AuthLayout from "../../layouts/AuthLayout.astro";
export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}

const currentLang = "es";
---

<AuthLayout title={`Registrarse - NEXUS`} currentLang={currentLang}> 

<section class="register-section">
  <div class="register-container">
    <div class="register-header">
      <span class="register-logo-text">NEXUS</span>
      <h1 class="register-title">Crear Cuenta</h1>
      <p class="register-subtitle">Crea tu cuenta y comienza hoy</p>
    </div>

    <form class="register-form">
      <div class="form-row">
        <div class="form-group">
          <label for="nombre" class="form-label">Nombre *</label>
          <input type="text" id="nombre" name="nombre" class="form-input" required>
        </div>
        <div class="form-group">
          <label for="apellido_paterno" class="form-label">Apellido Paterno *</label>
          <input type="text" id="apellido_paterno" name="apellido_paterno" class="form-input" required>
        </div>
      </div>

      <div class="form-group">
        <label for="apellido_materno" class="form-label">Apellido Materno</label>
        <input type="text" id="apellido_materno" name="apellido_materno" class="form-input">
      </div>

      <div class="form-group">
        <label for="correo" class="form-label">Correo electrónico *</label>
        <input type="email" id="correo" name="correo" class="form-input" required>
      </div>

      <div class="form-group">
        <label for="contrasena" class="form-label">Contraseña *</label>
        <input type="password" id="contrasena" name="contrasena" class="form-input" placeholder="Mínimo 8 caracteres" required minlength="8">
        <p class="form-hint">Mínimo 8 caracteres, incluir mayúsculas, minúsculas y números</p>
      </div>

      <div class="form-group">
        <label for="confirmacion_contrasena" class="form-label">Confirmar Contraseña *</label>
        <input type="password" id="confirmacion_contrasena" name="confirmacion_contrasena" class="form-input" required minlength="8">
      </div>

      <div class="form-group">
        <label for="telefono" class="form-label">Teléfono</label>
        <input type="tel" id="telefono" name="telefono" class="form-input" placeholder="+52 (123) 456-7890">
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="numero_casa" class="form-label">Número de casa *</label>
          <input type="number" id="numero_casa" name="numero_casa" class="form-input" min="1" required>
        </div>
        <div class="form-group">
          <label for="codigo_postal" class="form-label">Código postal *</label>
          <input type="number" id="codigo_postal" name="codigo_postal" class="form-input" min="1" required>
        </div>
      </div>

      <div class="form-group">
        <label for="calle" class="form-label">Calle *</label>
        <input type="text" id="calle" name="calle" class="form-input" required>
      </div>

      <div class="form-group">
        <label for="pais" class="form-label">País *</label>
        <select id="pais" name="pais" class="form-input" required>
          <option value="">Cargando países…</option>
        </select>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="provincia" class="form-label">Estado / Provincia *</label>
          <select id="provincia" name="provincia" class="form-input" required disabled>
            <option value="">Primero selecciona un país</option>
          </select>
        </div>
        <div class="form-group">
          <label for="ciudad" class="form-label">Municipio / Ciudad *</label>
          <select id="ciudad" name="ciudad" class="form-input" required disabled>
            <option value="">Primero selecciona un estado</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label class="checkbox-label full-width">
          <input type="checkbox" name="terminos" class="checkbox-input" required>
          <span class="checkbox-text">Acepto los <a href={`/${currentLang}/terminos`} target="_blank" class="terms-link">términos y condiciones</a> *</span>
        </label>
      </div>

      <button type="submit" class="btn btn--solid btn--full" id="submit-btn">
        <span id="submit-btn-text">Crear Cuenta</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>
    </form>

    <div class="register-footer">
      <p>¿Ya tienes cuenta? <a href={`/${currentLang}/login`} class="login-link">Inicia sesión aquí</a></p>
    </div>
  </div>
</section>

<style>
.register-section {
  --rg-bg-1: #2b1119;
  --rg-bg-2: #1e2138;
  --rg-bg-3: #131623;
  --rg-surface: rgba(10, 12, 19, 0.72);
  --rg-surface-strong: rgba(12, 15, 25, 0.9);
  --rg-border: rgba(255, 255, 255, 0.14);
  --rg-border-soft: rgba(255, 255, 255, 0.09);
  --rg-text: #f7f9ff;
  --rg-text-dim: #b9c0d6;
  --rg-accent: #7a2532;
  --rg-accent-2: #263a72;
  --rg-success: #39d98a;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(1200px 540px at -8% 0%, rgba(122, 37, 50, 0.44), transparent 58%),
    radial-gradient(980px 520px at 108% 100%, rgba(38, 58, 114, 0.48), transparent 58%),
    linear-gradient(112deg, var(--rg-bg-1) 0%, var(--rg-bg-2) 56%, var(--rg-bg-3) 100%);
  padding: 2rem;
  position: relative;
  overflow: hidden;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
}

.register-section::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
  background-size: 34px 34px;
  pointer-events: none;
  opacity: 0.48;
}

.register-container {
  background: linear-gradient(170deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.015));
  border: 1px solid var(--rg-border);
  backdrop-filter: blur(18px);
  border-radius: 20px;
  box-shadow:
    0 24px 80px rgba(0, 0, 0, 0.55),
    inset 0 1px 0 rgba(255, 255, 255, 0.12);
  padding: 2.5rem;
  max-width: 760px;
  width: 100%;
  color: var(--rg-text);
  text-align: left;
  position: relative;
  z-index: 1;
}

.register-header {
  margin-bottom: 1.5rem;
  text-align: center;
}

.register-logo-text {
  display: inline-block;
  margin-bottom: 0.8rem;
  padding: 0.4rem 0.85rem;
  border-radius: 999px;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #ecedf4;
  background: linear-gradient(120deg, rgba(122, 37, 50, 0.3), rgba(38, 58, 114, 0.3));
  border: 1px solid rgba(255, 255, 255, 0.18);
}

.register-title {
  font-size: clamp(1.75rem, 3vw, 2.35rem);
  line-height: 1.05;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--rg-text);
  margin-bottom: 0.35rem;
}

.register-subtitle {
  color: var(--rg-text-dim);
  font-size: 0.98rem;
}

.register-form {
  margin-bottom: 1.75rem;
  text-align: left;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.form-group {
  margin-bottom: 1rem;
}

.form-label {
  display: block;
  margin-bottom: 0.42rem;
  font-weight: 500;
  color: #d8deef;
  font-size: 0.88rem;
  letter-spacing: 0.02em;
}

.form-input {
  width: 100%;
  padding: 0.78rem 0.82rem;
  border: 1px solid var(--rg-border-soft);
  border-radius: 12px;
  font-size: 0.95rem;
  line-height: 1.4;
  transition: border-color 0.24s ease, box-shadow 0.24s ease, background-color 0.24s ease, transform 0.24s ease;
  box-sizing: border-box;
  background: var(--rg-surface);
  color: #eff3ff;
}

.form-input::placeholder {
  color: #8e96ad;
}

.form-input:disabled {
  opacity: 0.65;
  cursor: not-allowed;
}

.form-input:focus {
  outline: none;
  border-color: rgba(196, 214, 255, 0.5);
  background: var(--rg-surface-strong);
  box-shadow: 0 0 0 3px rgba(95, 117, 182, 0.3);
  transform: translateY(-1px);
}

.form-hint {
  font-size: 0.8rem;
  color: #95a1c0;
  margin-top: 0.3rem;
}

.checkbox-label {
  display: flex;
  align-items: flex-start;
  cursor: pointer;
}

.checkbox-label.full-width {
  width: 100%;
}

.checkbox-input {
  margin-right: 0.5rem;
  margin-top: 0.25rem;
  cursor: pointer;
  accent-color: #4d67b8;
}

.checkbox-text {
  font-size: 0.9rem;
  color: #c0c7da;
  line-height: 1.4;
}

.terms-link {
  color: #9eb3ff;
  text-decoration: none;
}

.terms-link:hover {
  text-decoration: underline;
}

.register-form .btn {
  min-height: 50px;
  border-radius: 12px;
  border: 1px solid rgba(185, 204, 255, 0.28);
  background: linear-gradient(110deg, #6b202d 0%, #2f427f 100%);
  color: #fbfdff;
  font-weight: 600;
  letter-spacing: 0.015em;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  box-shadow: 0 10px 28px rgba(8, 10, 16, 0.56), 0 1px 0 rgba(255, 255, 255, 0.2) inset;
  transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
}

.register-form .btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 14px 34px rgba(7, 10, 18, 0.64);
  filter: brightness(1.04);
}

.register-form .btn:active {
  transform: translateY(0);
}

.register-form .btn:disabled {
  opacity: 0.68;
  cursor: not-allowed;
  transform: none;
  filter: grayscale(0.1);
}

.btn--full {
  width: 100%;
  margin-top: 0.35rem;
}

.register-footer {
  border-top: 1px solid var(--rg-border-soft);
  padding-top: 1.1rem;
  font-size: 0.9rem;
  color: #aab4ce;
  text-align: center;
}

.login-link {
  color: #bdd0ff;
  text-decoration: none;
  font-weight: 500;
}

.login-link:hover {
  text-decoration: underline;
}

.register-container,
.form-group,
.register-footer {
  animation: rg-fade-up 0.55s ease both;
}

.form-group:nth-child(2) { animation-delay: 0.03s; }
.form-group:nth-child(3) { animation-delay: 0.06s; }
.form-group:nth-child(4) { animation-delay: 0.09s; }
.form-group:nth-child(5) { animation-delay: 0.12s; }

@keyframes rg-fade-up {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (max-width: 480px) {
  .register-section {
    padding: 1rem;
  }

  .register-container {
    padding: 1.3rem;
    border-radius: 16px;
  }

  .register-title {
    font-size: 1.5rem;
  }

  .form-row {
    grid-template-columns: 1fr;
  }
}
</style>

<script is:inline>
(function(){
  const currentLang = "${currentLang}";

  const paisSelect     = document.getElementById('pais');
  const provinciaSelect = document.getElementById('provincia');
  const ciudadSelect    = document.getElementById('ciudad');

  // ── helpers ──────────────────────────────────────────────────────────────
  function setOptions(select, items, placeholder) {
    select.innerHTML = '';
    const ph = document.createElement('option');
    ph.value = ''; ph.textContent = placeholder;
    select.appendChild(ph);
    items.forEach((item) => {
      const opt = document.createElement('option');
      opt.value = item; opt.textContent = item;
      select.appendChild(opt);
    });
  }

  function disableSelect(select, placeholder) {
    select.innerHTML = `<option value="">${placeholder}</option>`;
    select.disabled = true;
  }

  // ── load countries ───────────────────────────────────────────────────────
  async function loadCountries() {
    try {
      const res = await fetch('/api/locations?action=countries');
      const data = await res.json();
      if (!data.success) throw new Error(data.error);
      const names = data.data.map((c) => c.name);
      setOptions(paisSelect, names, 'Selecciona un país');
      paisSelect.disabled = false;
    } catch (err) {
      console.error('locations countries error', err);
      disableSelect(paisSelect, 'Error cargando países');
    }
  }

  // ── on country change → load states ──────────────────────────────────────
  async function onCountryChange() {
    const country = paisSelect.value;
    disableSelect(provinciaSelect, 'Cargando estados…');
    provinciaSelect.disabled = true;
    disableSelect(ciudadSelect, 'Primero selecciona un estado');
    if (!country) {
      disableSelect(provinciaSelect, 'Primero selecciona un país');
      return;
    }
    try {
      const res = await fetch(`/api/locations?action=states&country=${encodeURIComponent(country)}`);
      const data = await res.json();
      if (!data.success) throw new Error(data.error);
      setOptions(provinciaSelect, data.data, 'Selecciona un estado');
      provinciaSelect.disabled = false;
    } catch (err) {
      console.error('locations states error', err);
      disableSelect(provinciaSelect, 'Error cargando estados');
    }
  }

  // ── on state change → load cities ────────────────────────────────────────
  async function onStateChange() {
    const country = paisSelect.value;
    const state   = provinciaSelect.value;
    disableSelect(ciudadSelect, 'Cargando municipios…');
    if (!state) {
      disableSelect(ciudadSelect, 'Primero selecciona un estado');
      return;
    }
    try {
      const res = await fetch(`/api/locations?action=cities&country=${encodeURIComponent(country)}&state=${encodeURIComponent(state)}`);
      const data = await res.json();
      if (!data.success) throw new Error(data.error);
      setOptions(ciudadSelect, data.data, 'Selecciona un municipio');
      ciudadSelect.disabled = false;
    } catch (err) {
      console.error('locations cities error', err);
      disableSelect(ciudadSelect, 'Error cargando municipios');
    }
  }

  async function initLocationSelectors() {
    await loadCountries();
    paisSelect.addEventListener('change', onCountryChange);
    provinciaSelect.addEventListener('change', onStateChange);
  }

  const submitBtnText    = document.getElementById('submit-btn-text');

  // ── Submit ────────────────────────────────────────────
  const form = document.querySelector('.register-form');
  initLocationSelectors();
  if (!form) return;

  form.addEventListener('submit', async function(e) {
    e.preventDefault();

    const password  = document.getElementById('contrasena').value;
    const confirm   = document.getElementById('confirmacion_contrasena').value;

    if (password !== confirm) {
      alert('Las contraseñas no coinciden');
      return;
    }

    const submitBtn = document.getElementById('submit-btn');
    submitBtn.disabled = true;
    submitBtnText.textContent = 'Registrando...';

    const endpoint = '/api/register';

    try {
      const formData = new FormData(form);
      const response = await fetch(endpoint, { method: 'POST', body: formData });
      const data = await response.json();

      if (response.ok) {
        alert('✅ ¡Registro exitoso! Redirigiendo a inicio de sesión...');
        window.location.href = `/${currentLang}/login`;
      } else {
        const errorMessage = Array.isArray(data.details)
          ? data.details.join('\n')
          : data.error || 'Error al registrar';
        alert(errorMessage);
        submitBtn.disabled = false;
        submitBtnText.textContent = 'Crear Cuenta';
      }
    } catch (error) {
      console.error('register error:', error);
      alert('Error de conexión. Por favor, intenta nuevamente.');
      submitBtn.disabled = false;
      submitBtnText.textContent = 'Crear Cuenta';
    }
  });
})();
</script>

</AuthLayout>
