---
// src/pages/es/admin/equipo.astro
import BaseLayout from "../../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}

const currentLang = "es";
const cspNonce = Astro.locals?.cspNonce || "";

const role = String(Astro.locals?.user?.rol || "").trim().toLowerCase().replace(/[\s_-]/g, "")
  .replace(/^superadmin$|^superuser$|^superusuario$/, "superusuario");

if (!role) return Astro.redirect(`/${currentLang}/login`);
if (role !== "admin" && role !== "superusuario") return Astro.redirect(`/${currentLang}`);
---

<BaseLayout title="Equipo admin | NEXUS" currentLang={currentLang}>
<div class="dx-root">
<main class="dx">

  <header class="dx-hero">
    <div class="dx-hero__glow" aria-hidden="true"></div>
    <div class="dx-hero__content">
      <div class="dx-hero__left">
        <p class="dx-hero__kicker">Panel Admin</p>
        <h1 class="dx-hero__title">Equipo de Administración</h1>
        <p class="dx-hero__sub">Crea nuevos admins para tu empresa sin salir del panel.</p>
      </div>
      <div class="dx-hero__right">
        <div id="statsBar" class="dx-stats"></div>
        <a class="dx-cta" href={`/${currentLang}/admin/dashboard`}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Dashboard
        </a>
      </div>
    </div>
  </header>

  <section class="dx-panel">
    <div class="dx-panel__head">
      <div>
        <p class="dx-panel__kicker">Registro</p>
        <h2 class="dx-panel__title">Crear nuevo administrador</h2>
      </div>
    </div>
    
    <form id="teamCreateForm" class="dx-form-container">
      <div class="dx-grid-3">
        <div class="dx-field"><label>Nombre *</label><input id="newNombre" type="text" class="dx-search" required /></div>
        <div class="dx-field"><label>Ap. Paterno *</label><input id="newApellidoPaterno" type="text" class="dx-search" required /></div>
        <div class="dx-field"><label>Ap. Materno</label><input id="newApellidoMaterno" type="text" class="dx-search" /></div>
        <div class="dx-field"><label>Correo *</label><input id="newCorreo" type="email" class="dx-search" required /></div>
        <div class="dx-field"><label>Teléfono</label><input id="newTelefono" type="text" class="dx-search" /></div>
        <div class="dx-field"><label>Contraseña Temporal *</label><input id="newPassword" type="password" class="dx-search" minlength="8" required /></div>
        <div class="dx-field">
          <label>Rol en empresa</label>
          <select id="newRolEmpresa" class="dx-select">
            <option value="Admin">Admin</option>
            <option value="Operador">Operador</option>
            <option value="Supervisor">Supervisor</option>
          </select>
        </div>
      </div>
      
      <div style="margin-top: 20px; display: flex; gap: 10px; align-items: center;">
        <button type="submit" id="btnCreateAdmin" class="dx-cta">Crear admin</button>
        <button type="button" id="btnReloadTeam" class="dx-export-btn dx-export-btn--cyan">Actualizar lista</button>
      </div>
      <p id="teamStatus" style="margin-top: 10px; font-size: 0.8rem;"></p>
    </form>
  </section>

  <section class="dx-panel">
    <div class="dx-panel__head">
      <div>
        <p class="dx-panel__kicker">Equipo</p>
        <h2 class="dx-panel__title" id="teamEmpresaName">Cargando empresa...</h2>
      </div>
    </div>
    
    <div class="dx-table-wrap">
      <table class="dx-table" id="teamTable">
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Correo</th>
            <th>Rol Empresa</th>
            <th>Teléfono</th>
            <th class="dx-num">Asignación</th>
          </tr>
        </thead>
        <tbody id="teamRows">
          <tr><td colspan="5" style="text-align: center; padding: 40px;">Cargando equipo...</td></tr>
        </tbody>
      </table>
    </div>
  </section>

</main>
</div>

<style is:global>
/* Usamos exactamente el CSS de tu plantilla */
:root {
  --dx-bg: #060a14;
  --dx-s1: #0c1322;
  --dx-s2: #111a2e;
  --dx-s3: #172237;
  --dx-line: rgba(148,163,184,0.16);
  --dx-line-h: rgba(148,163,184,0.28);
  --dx-t1: #eef2fa;
  --dx-t2: #94a3b8;
  --dx-t3: #64748b;
  --dx-brand: #7a2532;
  --dx-brand-soft: rgba(122,37,50,0.12);
  --dx-brand-glow: rgba(122,37,50,0.2);
  --dx-cyan: #22d3ee;
  --dx-good: #34d399;
  --dx-bad: #fb7185;
  --dx-r: 20px;
  --dx-r-sm: 12px;
}

.dx-root { background: var(--dx-bg) !important; min-height: 100vh; }
.dx-root .dx * { font-family: 'Inter', sans-serif !important; }

.dx-root .dx {
  max-width: 1400px; margin: 0 auto; padding: 120px 24px 64px; display: grid; gap: 16px; color: var(--dx-t1);
}

/* Hero */
.dx-root .dx-hero {
  position: relative; border: 1px solid var(--dx-line); border-radius: var(--dx-r); padding: 28px; overflow: hidden;
  background: linear-gradient(155deg, var(--dx-s2), var(--dx-s1)); box-shadow: 0 24px 56px rgba(0,0,0,0.35);
}
.dx-root .dx-hero__glow { position: absolute; inset: 0; background: radial-gradient(ellipse at 8% -10%, rgba(122,37,50,0.2), transparent 50%); pointer-events: none; }
.dx-root .dx-hero__content { position: relative; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
.dx-root .dx-hero__title { font-size: clamp(1.5rem, 2.8vw, 2.1rem) !important; font-weight: 800 !important; line-height: 1.1 !important; color: var(--dx-t1) !important; }
.dx-root .dx-hero__kicker { font-size: 0.68rem !important; font-weight: 700; text-transform: uppercase !important; color: rgba(255,191,146,0.9); }
.dx-root .dx-hero__sub { color: var(--dx-t2); font-size: 0.88rem; margin-top: 6px; }

/* Panel & Utils */
.dx-root .dx-panel { border: 1px solid var(--dx-line); border-radius: var(--dx-r); background: linear-gradient(155deg, var(--dx-s2), var(--dx-s1)); padding: 22px; box-shadow: 0 8px 28px rgba(0,0,0,0.18); }
.dx-root .dx-panel__head { display: flex; justify-content: space-between; margin-bottom: 16px; }
.dx-root .dx-panel__kicker { font-size: 0.65rem !important; font-weight: 700; text-transform: uppercase !important; color: var(--dx-t3); }
.dx-root .dx-panel__title { font-size: 1.05rem !important; font-weight: 750 !important; color: var(--dx-t1) !important; }

/* Form específico */
.dx-root .dx-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
.dx-root .dx-field { display: flex; flex-direction: column; gap: 6px; }
.dx-root .dx-field label { font-size: 0.72rem; font-weight: 700; color: var(--dx-t3); text-transform: uppercase; }
.dx-root .dx-search, .dx-root .dx-select {
  background: rgba(255,255,255,0.04); border: 1px solid var(--dx-line); border-radius: var(--dx-r-sm); padding: 10px; color: var(--dx-t1); font-size: 0.85rem; outline: none;
}
.dx-root .dx-select option { background: #0c1322; }

/* Table */
.dx-root .dx-table-wrap { overflow: auto; border: 1px solid var(--dx-line); border-radius: var(--dx-r-sm); background: rgba(6,10,20,0.4); }
.dx-root .dx-table { width: 100%; border-collapse: collapse; font-size: 0.86rem; }
.dx-root .dx-table thead th { padding: 10px 14px; background: rgba(9,14,25,0.95); color: var(--dx-t3); font-size: 0.7rem; text-transform: uppercase; border-bottom: 1px solid var(--dx-line); text-align: left; }
.dx-root .dx-table td { padding: 12px 14px; border-bottom: 1px solid rgba(148,163,184,0.08); color: var(--dx-t2); }
.dx-root .dx-num { text-align: right; }

/* Buttons */
.dx-root .dx-cta {
  display: inline-flex; align-items: center; gap: 6px; padding: 10px 20px; border-radius: 99px;
  background: linear-gradient(135deg, var(--dx-brand), #ff8c38); color: #1b120a; font-size: 0.8rem; font-weight: 800; text-decoration: none; box-shadow: 0 4px 16px rgba(122,37,50,0.3); transition: 0.2s;
}
.dx-root .dx-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(122,37,50,0.4); }
.dx-root .dx-export-btn { padding: 8px 14px; border-radius: var(--dx-r-sm); border: 1px solid transparent; font-size: .74rem; font-weight: 700; cursor: pointer; transition: 0.2s; }
.dx-root .dx-export-btn--cyan { background: rgba(34,211,238,0.12); color: #22d3ee; border-color: rgba(34,211,238,0.22); }

.dx-root .role-chip { border: 1px solid rgba(168,85,247,0.3); background: rgba(168,85,247,0.1); color: #c4b5fd; padding: 2px 8px; border-radius: 99px; font-size: 0.7rem; font-weight: 700; }

@media (max-width: 800px) { .dx-root .dx-grid-3 { grid-template-columns: 1fr; } }
</style>

<script nonce={cspNonce} is:inline>
(function(){
  const teamRows = document.getElementById("teamRows");
  const teamStatus = document.getElementById("teamStatus");
  const teamEmpresaName = document.getElementById("teamEmpresaName");
  const form = document.getElementById("teamCreateForm");

  function formatDate(v) {
    if (!v) return "-";
    const d = new Date(v);
    return isNaN(d.getTime()) ? "-" : d.toLocaleDateString("es-MX", { year: "numeric", month: "short", day: "2-digit" });
  }

  async function loadTeam() {
    teamRows.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:40px;">Cargando equipo...</td></tr>';
    try {
      const response = await fetch("/api/admin/empresa-admins", { credentials: "include" });
      const data = await response.json();
      if (!response.ok || !data?.success) throw new Error(data?.error || "Error");

      teamEmpresaName.textContent = data?.empresa?.nombre || "Empresa";
      const admins = data.admins || [];
      
      if (!admins.length) {
        teamRows.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:40px;">No hay administradores.</td></tr>';
        return;
      }

      teamRows.innerHTML = admins.map(a => `
        <tr>
          <td style="color:#fff; font-weight:600;">${[a.nombre, a.apellidoPaterno].join(" ")}</td>
          <td>${a.correo}</td>
          <td><span class="role-chip">${a.rolEmpresa || 'Admin'}</span></td>
          <td>${a.telefono || '-'}</td>
          <td class="dx-num">${formatDate(a.fechaAsignacion)}</td>
        </tr>
      `).join("");
    } catch (e) {
      teamRows.innerHTML = '<tr><td colspan="5" style="text-align:center; color:#fb7185; padding:40px;">Error al cargar equipo.</td></tr>';
    }
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = document.getElementById("btnCreateAdmin");
    btn.disabled = true;
    teamStatus.textContent = "Procesando...";
    teamStatus.style.color = "var(--dx-t2)";

    const payload = {
      nombre: document.getElementById("newNombre").value,
      apellidoPaterno: document.getElementById("newApellidoPaterno").value,
      apellidoMaterno: document.getElementById("newApellidoMaterno").value,
      correo: document.getElementById("newCorreo").value,
      telefono: document.getElementById("newTelefono").value,
      contrasena: document.getElementById("newPassword").value,
      rolEmpresa: document.getElementById("newRolEmpresa").value,
    };

    try {
      const res = await fetch("/api/admin/empresa-admins", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (!res.ok || !data.success) throw new Error(data.error || "Error");

      teamStatus.textContent = "✓ Admin creado con éxito";
      teamStatus.style.color = "var(--dx-good)";
      form.reset();
      loadTeam();
    } catch (err) {
      teamStatus.textContent = "✕ " + err.message;
      teamStatus.style.color = "var(--dx-bad)";
    } finally {
      btn.disabled = false;
    }
  });

  document.getElementById("btnReloadTeam").onclick = loadTeam;
  loadTeam();
})();
</script>
</BaseLayout>