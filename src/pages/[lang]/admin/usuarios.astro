  <script nonce={cspNonce} is:inline define:vars={{ isSuperusuario }}>
    /* â”€â”€â”€ refs â”€â”€â”€ */
    const formPanelEl      = document.getElementById('usersFormPanel');
    const formTitleEl      = document.getElementById('formTitle');
    const currentUserIdEl  = document.getElementById('currentUserId');
    const rowsEl           = document.getElementById('usersRows');
    const btnAddUser       = document.getElementById('btnAddUser');
    const searchUsersEl    = document.getElementById('searchUsers');
    const rowsPerPageEl    = document.getElementById('rowsPerPage');
    const resultsInfoEl    = document.getElementById('usersResultsInfo');
    const statsBarEl       = document.getElementById('usersStatsBar');
    const paginationControlsEl = document.getElementById('paginationControls');
    const btnCopy  = document.getElementById('btnCopy');
    const btnExcel = document.getElementById('btnExcel');
    const btnPdf   = document.getElementById('btnPdf');
    const btnCsv   = document.getElementById('btnCsv');
    const nombreEl          = document.getElementById('nombre');
    const apellidoPaternoEl = document.getElementById('apellidoPaterno');
    const apellidoMaternoEl = document.getElementById('apellidoMaterno');
    const telefonoEl        = document.getElementById('telefono');
    const correoEl          = document.getElementById('correo');
    const rolEl             = document.getElementById('rol');
    const contrasenaEl      = document.getElementById('contrasena');
    const numeroCasaEl      = document.getElementById('numeroCasa');
    const calleEl           = document.getElementById('calle');
    const codigoPostalEl    = document.getElementById('codigoPostal');
    const ciudadEl          = document.getElementById('ciudad');
    const provinciaEl       = document.getElementById('provincia');
    const paisEl            = document.getElementById('pais');
    const btnCreate         = document.getElementById('btnCreate');
    const btnUpdate         = document.getElementById('btnUpdate');
    const btnCancelEdit     = document.getElementById('btnCancelEdit');
    const btnFormReset      = document.getElementById('btnFormReset');

    /* â”€â”€â”€ state â”€â”€â”€ */
    let users=[], filteredUsers=[], currentPage=1;

    /* â”€â”€â”€ SVG helper â€” creates proper namespace SVG via DOM â”€â”€â”€ */
    function makeSVG(pathsArray) {
      const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('viewBox', '0 0 24 24');
      svg.setAttribute('width', '14');
      svg.setAttribute('height', '14');
      svg.setAttribute('fill', 'none');
      svg.setAttribute('stroke', 'currentColor');
      svg.setAttribute('stroke-width', '2');
      svg.setAttribute('stroke-linecap', 'round');
      svg.setAttribute('stroke-linejoin', 'round');
      pathsArray.forEach(function(d) {
        const p = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        p.setAttribute('d', d);
        svg.appendChild(p);
      });
      return svg;
    }

    const ICON_EDIT = ['M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7','M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z'];
    const ICON_DELETE = ['M3 6h18','M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2','M10 11v6','M14 11v6'];

    /* â”€â”€â”€ location helpers â”€â”€â”€ */
    function setSelectOptions(select,items,placeholder){
      select.innerHTML='';
      const ph=document.createElement('option');ph.value='';ph.textContent=placeholder;select.appendChild(ph);
      items.forEach(item=>{const opt=document.createElement('option');opt.value=item;opt.textContent=item;select.appendChild(opt);});
    }
    function disableLocationSelect(select,placeholder){select.innerHTML=`<option value="">${placeholder}</option>`;select.disabled=true;}

    async function loadCountries(){
      try{
        const res=await fetch('/api/locations?action=countries');const data=await res.json();
        if(!data.success)throw new Error(data.error);
        setSelectOptions(paisEl,data.data.map(c=>c.name),'Selecciona un paÃ­s');paisEl.disabled=false;
      }catch{disableLocationSelect(paisEl,'Error cargando paÃ­ses');}
    }
    async function loadStates(country){
      disableLocationSelect(provinciaEl,'Cargando estadosâ€¦');disableLocationSelect(ciudadEl,'Primero selecciona un estado');
      if(!country){disableLocationSelect(provinciaEl,'Primero selecciona un paÃ­s');return;}
      try{
        const res=await fetch(`/api/locations?action=states&country=${encodeURIComponent(country)}`);const data=await res.json();
        if(!data.success)throw new Error(data.error);
        setSelectOptions(provinciaEl,data.data,'Selecciona un estado');provinciaEl.disabled=false;
      }catch{disableLocationSelect(provinciaEl,'Error cargando estados');}
    }
    async function loadCities(country,state){
      disableLocationSelect(ciudadEl,'Cargando municipiosâ€¦');
      if(!state){disableLocationSelect(ciudadEl,'Primero selecciona un estado');return;}
      try{
        const res=await fetch(`/api/locations?action=cities&country=${encodeURIComponent(country)}&state=${encodeURIComponent(state)}`);const data=await res.json();
        if(!data.success)throw new Error(data.error);
        setSelectOptions(ciudadEl,data.data,'Selecciona un municipio');ciudadEl.disabled=false;
      }catch{disableLocationSelect(ciudadEl,'Error cargando municipios');}
    }
    async function setLocationValues(pais,provincia,ciudad){
      if(!pais)return;
      if(!paisEl.querySelector(`option[value="${CSS.escape(pais)}"]`)){const opt=document.createElement('option');opt.value=pais;opt.textContent=pais;paisEl.appendChild(opt);}
      paisEl.value=pais;await loadStates(pais);
      if(provincia){
        if(!provinciaEl.querySelector(`option[value="${CSS.escape(provincia)}"]`)){const opt=document.createElement('option');opt.value=provincia;opt.textContent=provincia;provinciaEl.appendChild(opt);}
        provinciaEl.value=provincia;provinciaEl.disabled=false;await loadCities(pais,provincia);
        if(ciudad){
          if(!ciudadEl.querySelector(`option[value="${CSS.escape(ciudad)}"]`)){const opt=document.createElement('option');opt.value=ciudad;opt.textContent=ciudad;ciudadEl.appendChild(opt);}
          ciudadEl.value=ciudad;ciudadEl.disabled=false;
        }
      }
    }
    async function initLocationSelectors(){
      await loadCountries();
      paisEl.addEventListener('change',()=>loadStates(paisEl.value));
      provinciaEl.addEventListener('change',()=>loadCities(paisEl.value,provinciaEl.value));
    }

    /* â”€â”€â”€ form helpers â”€â”€â”€ */
    function setMode(mode,label){
      if(!formTitleEl||!currentUserIdEl)return;
      if(mode==='edit')formTitleEl.innerHTML=`Editando: <span style="color:#c084fc;font-weight:700">${label||''}</span>`;
      else{formTitleEl.textContent='Nuevo usuario';currentUserIdEl.value='';}
    }
    function resetForm(){
      nombreEl.value='';apellidoPaternoEl.value='';apellidoMaternoEl.value='';
      telefonoEl.value='';correoEl.value='';rolEl.value='usuario';contrasenaEl.value='';
      numeroCasaEl.value='';calleEl.value='';codigoPostalEl.value='';
      if(paisEl)paisEl.value='';
      disableLocationSelect(provinciaEl,'Primero selecciona un paÃ­s');
      disableLocationSelect(ciudadEl,'Primero selecciona un estado');
      setMode('create');
    }
    function openForm(mode='create',label){
      if(!formPanelEl)return;formPanelEl.hidden=false;setMode(mode,label);
      formPanelEl.scrollIntoView({behavior:'smooth',block:'start'});
    }
    function closeForm(){if(!formPanelEl)return;formPanelEl.hidden=true;resetForm();}
    function fillForm(user){
      currentUserIdEl.value=String(user.id);
      nombreEl.value=user.nombre||'';apellidoPaternoEl.value=user.apellidoPaterno||'';
      apellidoMaternoEl.value=user.apellidoMaterno||'';telefonoEl.value=user.telefono||'';
      correoEl.value=user.correo||'';rolEl.value=String(user.rol||'usuario').toLowerCase();
      contrasenaEl.value='';numeroCasaEl.value=user.numeroCasa||'';
      calleEl.value=user.calle||'';codigoPostalEl.value=user.codigoPostal||'';
      setLocationValues(user.pais||'Mexico',user.provincia||'',user.ciudad||'');
      openForm('edit',`${user.nombre||''} ${user.apellidoPaterno||''}`.trim());
    }
    function buildPayload(){
      return{nombre:nombreEl?.value?.trim()||'',apellidoPaterno:apellidoPaternoEl?.value?.trim()||'',apellidoMaterno:apellidoMaternoEl?.value?.trim()||'',telefono:telefonoEl?.value?.trim()||'',correo:correoEl?.value?.trim()||'',rol:rolEl?.value||'usuario',contrasena:contrasenaEl?.value||'',numeroCasa:numeroCasaEl?.value||'',calle:calleEl?.value?.trim()||'',codigoPostal:codigoPostalEl?.value||'',ciudad:ciudadEl?.value?.trim()||'',provincia:provinciaEl?.value?.trim()||'',pais:paisEl?.value?.trim()||''};
    }

    /* â”€â”€â”€ paginate â”€â”€â”€ */
    function applyFilters(){
      const q=String(searchUsersEl?.value||'').trim().toLowerCase();
      filteredUsers=users.filter(u=>{
        if(!q)return true;
        const name=`${u.nombre||''} ${u.apellidoPaterno||''} ${u.apellidoMaterno||''}`.toLowerCase();
        return name.includes(q)||String(u.correo||'').toLowerCase().includes(q)||String(u.rol||'').toLowerCase().includes(q);
      });
    }
    function getPageData(){
      applyFilters();
      const perPage=Number(rowsPerPageEl?.value||10);
      const totalPages=Math.max(1,Math.ceil(filteredUsers.length/perPage));
      if(currentPage>totalPages)currentPage=totalPages;
      const start=(currentPage-1)*perPage;
      return{items:filteredUsers.slice(start,start+perPage),total:filteredUsers.length,totalPages,start};
    }
    function renderPagination({total,totalPages,start,items}){
      if(resultsInfoEl)resultsInfoEl.textContent=total===0?'Sin resultados':`Mostrando ${start+1}â€“${start+items.length} de ${total} resultados`;
      if(!paginationControlsEl)return;
      paginationControlsEl.innerHTML='';
      if(totalPages<=1)return;
      const mkBtn=(label,page,active,disabled)=>{
        const b=document.createElement('button');
        b.className='page-btn'+(active?' active':'')+(disabled?' disabled':'');
        b.textContent=label;b.disabled=disabled;
        if(!disabled&&!active)b.addEventListener('click',()=>{currentPage=page;renderUsers();});
        return b;
      };
      paginationControlsEl.appendChild(mkBtn('â€¹',currentPage-1,false,currentPage===1));
      let prev=0;const pages=new Set([1,totalPages]);
      for(let i=Math.max(2,currentPage-2);i<=Math.min(totalPages-1,currentPage+2);i++)pages.add(i);
      [...pages].sort((a,b)=>a-b).forEach(p=>{
        if(prev&&p-prev>1)paginationControlsEl.appendChild(Object.assign(document.createElement('span'),{className:'page-ellipsis',textContent:'â€¦'}));
        paginationControlsEl.appendChild(mkBtn(String(p),p,p===currentPage,false));prev=p;
      });
      paginationControlsEl.appendChild(mkBtn('â€º',currentPage+1,false,currentPage===totalPages));
    }

    /* â”€â”€â”€ stats â”€â”€â”€ */
    function renderStats(){
      if(!statsBarEl)return;
      const total=users.length;
      const admins=users.filter(u=>u.rol==='admin'||u.rol==='superusuario').length;
      const regulares=users.filter(u=>u.rol==='usuario').length;
      statsBarEl.innerHTML=`<span class="stat-chip">${total} total</span><span class="stat-chip stat-chip--blue">${admins} admins</span><span class="stat-chip stat-chip--green">${regulares} usuarios</span>`;
    }

    /* â”€â”€â”€ rol badge â”€â”€â”€ */
    function rolBadge(rol){
      const r=String(rol||'').toLowerCase();
      if(r==='superusuario')return`<span class="rol-badge rol-super">${r}</span>`;
      if(r==='admin')return`<span class="rol-badge rol-admin">${r}</span>`;
      return`<span class="rol-badge rol-user">${r}</span>`;
    }

    /* â”€â”€â”€ render â”€â”€â”€ */
    function renderUsers(){
      if(!rowsEl)return;
      rowsEl.innerHTML='';
      const pageData=getPageData();
      pageData.items.forEach(user=>{
        const tr=document.createElement('tr');
        const canDelete=isSuperusuario;

        // Build row HTML WITHOUT SVGs
        tr.innerHTML=`
          <td class="td-id">${user.id}</td>
          <td><strong class="user-nombre">${user.nombre||''} ${user.apellidoPaterno||''}</strong></td>
          <td class="td-correo">${user.correo||''}</td>
          <td>${rolBadge(user.rol)}</td>
          <td class="td-tel">${user.telefono||'<span class="no-data">â€”</span>'}</td>
          <td>
            <div class="users-row-actions">
              <button class="row-icon-btn edit" data-action="edit" data-id="${user.id}" type="button" title="Editar"></button>
              <button class="row-icon-btn delete" data-action="delete" data-id="${user.id}" type="button" title="Eliminar" ${canDelete?'':'disabled'}></button>
            </div>
          </td>`;

        // Inject SVGs via DOM API (proper SVG namespace)
        const editBtn = tr.querySelector('.row-icon-btn.edit');
        const delBtn = tr.querySelector('.row-icon-btn.delete');
        if(editBtn) editBtn.appendChild(makeSVG(ICON_EDIT));
        if(delBtn) delBtn.appendChild(makeSVG(ICON_DELETE));

        rowsEl.appendChild(tr);
      });
      renderPagination(pageData);
      renderStats();
    }

    /* â”€â”€â”€ fetch â”€â”€â”€ */
    async function fetchUsers(){
      const r=await fetch('/api/admin/usuarios',{credentials:'include'});
      const d=await r.json().catch(()=>({}));
      if(!r.ok||!d?.success)throw new Error(d?.error||'No se pudieron cargar usuarios');
      users=Array.isArray(d.usuarios)?d.usuarios:[];renderUsers();
    }

    /* â”€â”€â”€ export â”€â”€â”€ */
    function usersToRowsText(list){return list.map(u=>`${u.id}\t${u.nombre||''} ${u.apellidoPaterno||''}\t${u.correo||''}\t${String(u.rol||'').toLowerCase()}\t${u.telefono||''}`).join('\n');}
    function usersToCsv(list){const h='id,nombre,correo,rol,telefono';const b=list.map(u=>`${u.id},"${(`${u.nombre||''} ${u.apellidoPaterno||''}`.trim()).replaceAll('"','""')}","${String(u.correo||'').replaceAll('"','""')}","${String(u.rol||'').toLowerCase()}","${String(u.telefono||'')}"`).join('\n');return`${h}\n${b}`;}
    function triggerDownload(content,fileName,mimeType){const blob=new Blob([content],{type:mimeType});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download=fileName;document.body.appendChild(a);a.click();a.remove();URL.revokeObjectURL(url);}

    /* â”€â”€â”€ events â”€â”€â”€ */
    btnAddUser?.addEventListener('click',()=>{resetForm();openForm('create');});
    searchUsersEl?.addEventListener('input',()=>{currentPage=1;renderUsers();});
    rowsPerPageEl?.addEventListener('change',()=>{currentPage=1;renderUsers();});
    btnCancelEdit?.addEventListener('click',closeForm);
    btnFormReset?.addEventListener('click',resetForm);

    btnCopy?.addEventListener('click',async()=>{try{await navigator.clipboard.writeText(`ID\tNOMBRE\tCORREO\tROL\tTELEFONO\n${usersToRowsText(filteredUsers)}`);Modal.success('Copiado','Datos copiados al portapapeles',{autoClose:1800});}catch{Modal.error('Error','No se pudo copiar');}});
    btnCsv?.addEventListener('click',()=>{triggerDownload(usersToCsv(filteredUsers),'usuarios.csv','text/csv;charset=utf-8;');Modal.success('CSV','Archivo descargado',{autoClose:1800});});
    btnExcel?.addEventListener('click',()=>{
      const rows=filteredUsers.map(u=>`<tr><td>${u.id}</td><td>${u.nombre||''} ${u.apellidoPaterno||''}</td><td>${u.correo||''}</td><td>${String(u.rol||'').toLowerCase()}</td><td>${u.telefono||''}</td></tr>`).join('');
      triggerDownload(`<table><thead><tr><th>ID</th><th>Nombre</th><th>Correo</th><th>Rol</th><th>Telefono</th></tr></thead><tbody>${rows}</tbody></table>`,'usuarios.xls','application/vnd.ms-excel;charset=utf-8;');
      Modal.success('Excel','Archivo descargado',{autoClose:1800});
    });
    btnPdf?.addEventListener('click',()=>{
      const rows=filteredUsers.map(u=>`<tr><td>${u.id}</td><td>${u.nombre||''} ${u.apellidoPaterno||''}</td><td>${u.correo||''}</td><td>${String(u.rol||'').toLowerCase()}</td><td>${u.telefono||''}</td></tr>`).join('');
      const w=window.open('','_blank','width=980,height=720');
      if(!w){Modal.error('Error','No se pudo abrir la ventana');return;}
      w.document.write(`<html><head><title>Usuarios</title><style>body{font-family:Arial;padding:24px;color:#111}table{width:100%;border-collapse:collapse}th,td{border:1px solid #ccc;padding:8px;font-size:12px}th{background:#f0f0f0}</style></head><body><h1>Usuarios</h1><table><thead><tr><th>ID</th><th>Nombre</th><th>Correo</th><th>Rol</th><th>Telefono</th></tr></thead><tbody>${rows}</tbody></table></body></html>`);
      w.document.close();w.focus();w.print();Modal.success('PDF','Ventana de impresiÃ³n abierta',{autoClose:1800});
    });

    btnCreate?.addEventListener('click',async()=>{
      const p=buildPayload();
      if(!p.nombre||!p.apellidoPaterno||!p.correo||!p.numeroCasa||!p.calle||!p.codigoPostal||!p.pais||!p.provincia||!p.ciudad){
        Modal.error('Campos incompletos','Nombre, apellido, correo y direccion completa son obligatorios');return;
      }
      try{
        Modal.loading('Creando usuario','Por favor espera...');
        const r=await fetch('/api/admin/usuarios',{method:'POST',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify(p)});
        const d=await r.json().catch(()=>({}));
        Modal.hideLoading();
        if(!r.ok||!d?.success)throw new Error(d?.error||'No se pudo crear el usuario');
        Modal.success('Â¡Usuario creado!','Las credenciales se enviaron al correo del usuario',{autoClose:2500});
        closeForm();await fetchUsers();
      }catch(err){Modal.hideLoading();Modal.error('Error',err.message||'Error creando usuario');}
    });

    btnUpdate?.addEventListener('click',async()=>{
      const userId=currentUserIdEl?.value;
      if(!userId){Modal.error('Error','Primero selecciona un usuario desde la tabla para editar');return;}
      const p=buildPayload();
      if(!p.nombre||!p.apellidoPaterno||!p.correo||!p.numeroCasa||!p.calle||!p.codigoPostal||!p.pais||!p.provincia||!p.ciudad){
        Modal.error('Campos incompletos','Nombre, apellido, correo y direcciÃ³n completa son obligatorios');return;
      }
      try{
        Modal.loading('Actualizando usuario','Guardando cambios...');
        const r=await fetch(`/api/admin/usuarios/${userId}`,{method:'PUT',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify(p)});
        const d=await r.json().catch(()=>({}));
        Modal.hideLoading();
        if(!r.ok||!d?.success)throw new Error(d?.error||'No se pudo actualizar el usuario');
        Modal.success('Â¡Listo!','Usuario actualizado correctamente',{autoClose:2500});
        closeForm();await fetchUsers();
      }catch(err){Modal.hideLoading();Modal.error('Error',err.message||'Error actualizando usuario');}
    });

    rowsEl?.addEventListener('click',async event=>{
      const btn=event.target?.closest('button[data-action]');
      if(!(btn instanceof HTMLButtonElement))return;
      const action=btn.dataset.action,userId=btn.dataset.id;
      if(!userId)return;
      if(action==='edit'){const user=users.find(u=>String(u.id)===String(userId));if(user)fillForm(user);return;}
      if(action==='delete'){
        if(!isSuperusuario){Modal.error('Sin permiso','Solo superusuario puede eliminar usuarios');return;}
        const ok=await Modal.confirm('Â¿Eliminar usuario?','Esta acciÃ³n es permanente y no se puede deshacer.',{confirmText:'SÃ­, eliminar',cancelText:'Cancelar'});
        if(!ok)return;
        try{
          Modal.loading('Eliminando usuario','Por favor espera...');
          const r=await fetch(`/api/admin/usuarios/${userId}`,{method:'DELETE',credentials:'include'});
          const d=await r.json().catch(()=>({}));
          Modal.hideLoading();
          if(!r.ok||!d?.success)throw new Error(d?.error||'No se pudo eliminar el usuario');
          Modal.success('Eliminado','El usuario fue eliminado correctamente',{autoClose:2000});
          closeForm();await fetchUsers();
        }catch(err){Modal.hideLoading();Modal.error('Error',err.message||'Error eliminando usuario');}
      }
    });

    initLocationSelectors();
    fetchUsers().catch(err=>Modal.error('Error',err.message||'No se pudieron cargar usuarios'));
  </script>

  <script>
    (function(){
      try{const t=localStorage.getItem('theme');if(t==='dark')document.documentElement.classList.add('dark');else document.documentElement.classList.remove('dark');}catch(e){}
      window.addEventListener('storage',(e)=>{if(e.key==='theme')document.documentElement.classList.toggle('dark',e.newValue==='dark');});
    })();
  </script>

