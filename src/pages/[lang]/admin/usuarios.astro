---
import BaseLayout from "../../../layouts/BaseLayout.astro";
export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}

const currentLang = "es";
const cspNonce = Astro.locals?.cspNonce || "";

const role = String(Astro.locals?.user?.rol || "").trim().toLowerCase().replace(/[\s_-]/g, "")
  .replace(/^superadmin$|^superuser$|^superusuario$/, "superusuario");

if (!role) return Astro.redirect(`/${currentLang}/login`);
if (role !== "superusuario") return Astro.redirect(`/${currentLang}/admin/productos`);

const isSuperusuario = role === "superusuario";
---

<BaseLayout title="Gestión de usuarios | NEXUS" currentLang={currentLang}>

  <!-- ── Modal system (idéntico al original, sin cambios) ── -->
  <script nonce={cspNonce} is:inline>
  (function(g){
    if(document.getElementById('go-modal-styles'))return;
    const s=document.createElement('style');s.id='go-modal-styles';
    s.textContent=`
      .go-modal-backdrop{position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.6);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;padding:1rem;opacity:0;transition:opacity 220ms ease}
      .go-modal-backdrop.go-visible{opacity:1}
      .go-modal{background:#0d1117;border:1px solid rgba(139,92,246,.2);border-radius:20px;box-shadow:0 32px 80px rgba(0,0,0,.6);padding:2rem 2rem 1.6rem;width:100%;max-width:420px;text-align:center;transform:scale(.88) translateY(20px);transition:transform 260ms cubic-bezier(.34,1.56,.64,1);position:relative}
      .go-modal-backdrop.go-visible .go-modal{transform:scale(1) translateY(0)}
      .go-modal-icon{width:68px;height:68px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.1rem}
      .go-modal-icon.success{background:rgba(52,211,153,.12);color:#34d399}.go-modal-icon.error{background:rgba(251,113,133,.12);color:#fb7185}
      .go-modal-icon.warning{background:rgba(251,191,36,.12);color:#fbbf24}.go-modal-icon.info{background:rgba(96,165,250,.12);color:#60a5fa}
      .go-modal-icon.confirm{background:rgba(139,92,246,.12);color:#8b5cf6}
      .go-modal-title{font-size:1.25rem;font-weight:700;color:#f1f5f9;margin:0 0 .5rem;font-family:inherit!important;letter-spacing:normal!important;text-transform:none!important}
      .go-modal-text{font-size:.9rem;color:#64748b;margin:0 0 1.4rem;line-height:1.6;font-family:inherit!important}
      .go-modal-actions{display:flex;gap:.7rem;justify-content:center;flex-wrap:wrap}
      .go-modal-btn{padding:.65rem 1.6rem;border-radius:10px;font-size:.9rem;font-weight:600;cursor:pointer;border:none;transition:filter 160ms,transform 100ms;min-width:100px;font-family:inherit!important;text-transform:none!important}
      .go-modal-btn:hover{filter:brightness(1.1)}.go-modal-btn:active{transform:scale(.97)}
      .go-modal-btn.primary{background:linear-gradient(135deg,#8b5cf6,#6d28d9);color:#fff}.go-modal-btn.secondary{background:rgba(255,255,255,.08);color:#94a3b8;border:1px solid rgba(255,255,255,.12)}
      .go-modal-btn.danger{background:linear-gradient(135deg,#7a2532,#be1a2b);color:#fff}
      .go-modal-progress{position:absolute;bottom:0;left:0;height:3px;border-radius:0 0 18px 18px;background:linear-gradient(90deg,#8b5cf6,#6d28d9);width:100%;transform-origin:left;animation:go-progress linear forwards}
      @keyframes go-progress{from{transform:scaleX(1)}to{transform:scaleX(0)}}
      .go-loading-backdrop{position:fixed;inset:0;z-index:10500;background:rgba(0,0,0,.65);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 200ms ease}
      .go-loading-backdrop.go-visible{opacity:1;pointer-events:auto}
      .go-loading-box{background:#0d1117;border:1px solid rgba(139,92,246,.15);border-radius:20px;padding:2.2rem 2.8rem;text-align:center;box-shadow:0 24px 64px rgba(0,0,0,.6);min-width:220px}
      .go-loading-spinner{width:48px;height:48px;border-radius:50%;border:3px solid rgba(139,92,246,0.18);border-top-color:#8b5cf6;animation:go-spin 0.75s linear infinite;margin:0 auto 1rem}
      @keyframes go-spin{to{transform:rotate(360deg)}}
      .go-loading-title{font-size:1rem;font-weight:700;color:#f1f5f9;margin:0 0 .25rem;font-family:inherit!important}
      .go-loading-sub{font-size:0.78rem;color:#475569;margin:0;font-family:inherit!important}
    `;
    document.head.appendChild(s);
    const IC={
      success:`<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`,
      error:`<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`,
      warning:`<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
      info:`<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>`,
      confirm:`<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    };
    function show(o){
      return new Promise(function(res){
        var type=o.type||'info',title=o.title||'',text=o.text||'',
            ct=o.confirmText||'Aceptar',cct=o.cancelText||'Cancelar',
            sc=o.showCancel||false,ac=o.autoClose||0;
        var bd=document.createElement('div');bd.className='go-modal-backdrop';
        bd.innerHTML='<div class="go-modal" role="dialog" aria-modal="true">'+
          '<div class="go-modal-icon '+type+'">'+(IC[type]||IC.info)+'</div>'+
          '<h2 class="go-modal-title">'+title+'</h2>'+
          (text?'<p class="go-modal-text">'+text+'</p>':'')+
          '<div class="go-modal-actions">'+
          (sc?'<button class="go-modal-btn secondary" id="gmc">'+cct+'</button>':'')+
          '<button class="go-modal-btn '+(type==='error'?'danger':'primary')+'" id="gmok">'+ct+'</button>'+
          '</div>'+
          (ac?'<div class="go-modal-progress" style="animation-duration:'+ac+'ms"></div>':'')+
          '</div>';
        document.body.appendChild(bd);
        requestAnimationFrame(function(){bd.classList.add('go-visible');});
        function close(r){bd.classList.remove('go-visible');setTimeout(function(){bd.remove();},260);res(r);}
        bd.querySelector('#gmok').addEventListener('click',function(){close(true);});
        var cc=bd.querySelector('#gmc');if(cc)cc.addEventListener('click',function(){close(false);});
        function onKey(e){if(e.key==='Escape'){close(false);document.removeEventListener('keydown',onKey);}}
        document.addEventListener('keydown',onKey);
        if(ac)setTimeout(function(){close(true);},ac);
      });
    }
    var _loadEl=null;
    function showLoading(title,sub){
      if(_loadEl)return;_loadEl=document.createElement('div');_loadEl.className='go-loading-backdrop';
      _loadEl.innerHTML='<div class="go-loading-box"><div class="go-loading-spinner"></div><p class="go-loading-title">'+(title||'Procesando...')+'</p><p class="go-loading-sub">'+(sub||'Por favor espera')+'</p></div>';
      document.body.appendChild(_loadEl);requestAnimationFrame(function(){_loadEl.classList.add('go-visible');});
    }
    function hideLoading(){if(!_loadEl)return;_loadEl.classList.remove('go-visible');setTimeout(function(){if(_loadEl){_loadEl.remove();_loadEl=null;}},220);}
    g.Modal={
      success:function(t,x,o){return show(Object.assign({type:'success',title:t,text:x},o||{}));},
      error:  function(t,x,o){return show(Object.assign({type:'error',  title:t,text:x},o||{}));},
      warning:function(t,x,o){return show(Object.assign({type:'warning',title:t,text:x},o||{}));},
      info:   function(t,x,o){return show(Object.assign({type:'info',   title:t,text:x},o||{}));},
      confirm:function(t,x,o){return show(Object.assign({type:'confirm',title:t,text:x,showCancel:true},o||{}));},
      loading:showLoading,hideLoading:hideLoading,
    };
  })(window);
  </script>

  <div class="ux-root">
  <main class="ux">

    <!-- ── Hero ── -->
    <header class="ux-hero">
      <div class="ux-hero__glow" aria-hidden="true"></div>
      <div class="ux-hero__body">
        <div class="ux-hero__left">
          <p class="ux-hero__kicker">Panel Admin · Superusuario</p>
          <h1 class="ux-hero__title">Gestión de Usuarios</h1>
          <p class="ux-hero__sub">CRUD completo con roles, dirección y credenciales</p>
        </div>
        <div class="ux-hero__right">
          <button id="btnAddUser" class="ux-cta" type="button">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
            Añadir usuario
          </button>
          <a href={`/${currentLang}`} class="ux-cta ux-cta--ghost">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            Volver al sitio
          </a>
        </div>
      </div>
      <!-- Stats chips inline en el hero -->
      <div id="ux-stats" class="ux-hero__stats" aria-live="polite"></div>
    </header>

    <!-- ── Form Panel (slide-in) ── -->
    <section id="usersFormPanel" class="ux-form-panel" aria-hidden="true">
      <article class="ux-card ux-card--form">

        <div class="ux-form-titlebar">
          <div class="ux-form-titlebar__left">
            <span class="ux-form-badge" id="formModeBadge">Nuevo</span>
            <h2 id="formTitle" class="ux-form-titlebar__title">Nuevo usuario</h2>
          </div>
          <button id="btnCancelEdit" class="ux-icon-btn" type="button" title="Cerrar formulario" aria-label="Cerrar formulario">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>

        <p class="ux-hint">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          Al crear, si dejas la contraseña vacía se genera una temporal y se envía al correo. En edición, vacío mantiene la actual.
        </p>

        <input id="currentUserId" type="hidden" />

        <div class="ux-sections">
          <!-- Sección Personal -->
          <fieldset class="ux-section">
            <legend class="ux-section__legend">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              Información personal
            </legend>
            <div class="ux-grid ux-grid--3">
              <div class="ux-field"><label for="nombre">Nombre <span class="req">*</span></label><input id="nombre" type="text" placeholder="Nombre" autocomplete="given-name" /></div>
              <div class="ux-field"><label for="apellidoPaterno">Apellido paterno <span class="req">*</span></label><input id="apellidoPaterno" type="text" placeholder="Apellido paterno" autocomplete="family-name" /></div>
              <div class="ux-field"><label for="apellidoMaterno">Apellido materno</label><input id="apellidoMaterno" type="text" placeholder="Apellido materno" /></div>
              <div class="ux-field"><label for="telefono">Teléfono</label><input id="telefono" type="tel" placeholder="+52 000 000 0000" autocomplete="tel" /></div>
              <div class="ux-field"><label for="correo">Correo <span class="req">*</span></label><input id="correo" type="email" placeholder="correo@ejemplo.com" autocomplete="email" /></div>
              <div class="ux-field">
                <label for="rol">Rol</label>
                <select id="rol">
                  <option value="usuario">Usuario</option>
                  <option value="admin">Admin</option>
                  <option value="superusuario">Superusuario</option>
                </select>
              </div>
            </div>
          </fieldset>

          <!-- Sección Dirección -->
          <fieldset class="ux-section">
            <legend class="ux-section__legend">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              Dirección
            </legend>
            <div class="ux-grid ux-grid--3">
              <div class="ux-field"><label for="numeroCasa">Núm. de casa <span class="req">*</span></label><input id="numeroCasa" type="number" min="1" placeholder="0" /></div>
              <div class="ux-field ux-field--wide"><label for="calle">Calle <span class="req">*</span></label><input id="calle" type="text" placeholder="Nombre de la calle" /></div>
              <div class="ux-field"><label for="codigoPostal">Código postal <span class="req">*</span></label><input id="codigoPostal" type="number" min="1" placeholder="00000" /></div>
              <div class="ux-field"><label for="pais">País <span class="req">*</span></label><select id="pais"><option value="">Cargando…</option></select></div>
              <div class="ux-field"><label for="provincia">Estado / Provincia <span class="req">*</span></label><select id="provincia" disabled><option value="">Selecciona un país</option></select></div>
              <div class="ux-field"><label for="ciudad">Ciudad <span class="req">*</span></label><select id="ciudad" disabled><option value="">Selecciona un estado</option></select></div>
            </div>
          </fieldset>

          <!-- Sección Seguridad -->
          <fieldset class="ux-section ux-section--narrow">
            <legend class="ux-section__legend">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
              Seguridad
            </legend>
            <div class="ux-grid ux-grid--2">
              <div class="ux-field">
                <label for="contrasena">Contraseña</label>
                <div class="ux-password-wrap">
                  <input id="contrasena" type="password" placeholder="Dejar vacío para mantener la actual" autocomplete="new-password" />
                  <button class="ux-eye-btn" type="button" id="togglePwd" aria-label="Mostrar contraseña">
                    <svg id="eyeIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  </button>
                </div>
              </div>
            </div>
          </fieldset>
        </div>

        <!-- Form actions — contextuales -->
        <div class="ux-form-actions">
          <div class="ux-form-actions__primary">
            <button id="btnCreate" class="ux-btn ux-btn--create" type="button">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
              Crear usuario
            </button>
            <button id="btnUpdate" class="ux-btn ux-btn--update" type="button">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 13l4 4L19 7"/></svg>
              Guardar cambios
            </button>
          </div>
          <button id="btnFormReset" class="ux-btn ux-btn--ghost" type="button">Limpiar campos</button>
        </div>

      </article>
    </section>

    <!-- ── Table Card ── -->
    <section class="ux-card ux-card--table">

      <div class="ux-toolbar">
        <div class="ux-toolbar__search">
          <svg class="ux-toolbar__search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <input id="searchUsers" class="ux-search" type="text" placeholder="Buscar por nombre, correo o rol…" aria-label="Buscar usuarios" />
        </div>
        <div class="ux-toolbar__controls">
          <div class="ux-export-group" role="group" aria-label="Exportar datos">
            <button id="btnCopy"  class="ux-export-btn" type="button">Copiar</button>
            <button id="btnCsv"   class="ux-export-btn" type="button">CSV</button>
            <button id="btnExcel" class="ux-export-btn" type="button">Excel</button>
            <button id="btnPdf"   class="ux-export-btn" type="button">PDF</button>
          </div>
          <label class="ux-rows-label" for="rowsPerPage">
            Mostrar
            <select id="rowsPerPage" class="ux-rows-select">
              <option value="10">10</option>
              <option value="25">25</option>
              <option value="50">50</option>
            </select>
          </label>
        </div>
      </div>

      {!isSuperusuario && (
        <p class="ux-warn-banner">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Solo superusuario puede eliminar usuarios.
        </p>
      )}

      <div class="ux-table-scroll" role="region" aria-label="Lista de usuarios">
        <table class="ux-table" id="usersTable">
          <thead>
            <tr>
              <th scope="col" class="col-id">ID</th>
              <th scope="col" class="col-name">Nombre</th>
              <th scope="col" class="col-email">Correo</th>
              <th scope="col" class="col-role">Rol</th>
              <th scope="col" class="col-tel">Teléfono</th>
              <th scope="col" class="col-actions">Acciones</th>
            </tr>
          </thead>
          <tbody id="usersRows">
            <!-- skeleton rows -->
            <tr class="ux-skeleton-row"><td><span class="ux-skel"></span></td><td><span class="ux-skel ux-skel--wide"></span></td><td><span class="ux-skel ux-skel--wider"></span></td><td><span class="ux-skel ux-skel--sm"></span></td><td><span class="ux-skel"></span></td><td></td></tr>
            <tr class="ux-skeleton-row"><td><span class="ux-skel"></span></td><td><span class="ux-skel ux-skel--wide"></span></td><td><span class="ux-skel ux-skel--wider"></span></td><td><span class="ux-skel ux-skel--sm"></span></td><td><span class="ux-skel"></span></td><td></td></tr>
            <tr class="ux-skeleton-row"><td><span class="ux-skel"></span></td><td><span class="ux-skel ux-skel--wide"></span></td><td><span class="ux-skel ux-skel--wider"></span></td><td><span class="ux-skel ux-skel--sm"></span></td><td><span class="ux-skel"></span></td><td></td></tr>
          </tbody>
        </table>
      </div>

      <div class="ux-pagination">
        <span id="usersResultsInfo" class="ux-pagination__info"></span>
        <div class="ux-pagination__controls" id="paginationControls"></div>
      </div>

    </section>

  </main>
  </div>

  <!-- ── All JavaScript (lógica idéntica al original) ── -->
  <script nonce={cspNonce} is:inline define:vars={{ isSuperusuario }}>
  (function () {
    /* refs */
    const formPanelEl      = document.getElementById('usersFormPanel');
    const formTitleEl      = document.getElementById('formTitle');
    const formModeBadgeEl  = document.getElementById('formModeBadge');
    const currentUserIdEl  = document.getElementById('currentUserId');
    const rowsEl           = document.getElementById('usersRows');
    const btnAddUser       = document.getElementById('btnAddUser');
    const searchUsersEl    = document.getElementById('searchUsers');
    const rowsPerPageEl    = document.getElementById('rowsPerPage');
    const resultsInfoEl    = document.getElementById('usersResultsInfo');
    const statsEl          = document.getElementById('ux-stats');
    const paginationControlsEl = document.getElementById('paginationControls');
    const btnCopy          = document.getElementById('btnCopy');
    const btnExcel         = document.getElementById('btnExcel');
    const btnPdf           = document.getElementById('btnPdf');
    const btnCsv           = document.getElementById('btnCsv');
    const nombreEl         = document.getElementById('nombre');
    const apellidoPaternoEl= document.getElementById('apellidoPaterno');
    const apellidoMaternoEl= document.getElementById('apellidoMaterno');
    const telefonoEl       = document.getElementById('telefono');
    const correoEl         = document.getElementById('correo');
    const rolEl            = document.getElementById('rol');
    const contrasenaEl     = document.getElementById('contrasena');
    const numeroCasaEl     = document.getElementById('numeroCasa');
    const calleEl          = document.getElementById('calle');
    const codigoPostalEl   = document.getElementById('codigoPostal');
    const ciudadEl         = document.getElementById('ciudad');
    const provinciaEl      = document.getElementById('provincia');
    const paisEl           = document.getElementById('pais');
    const btnCreate        = document.getElementById('btnCreate');
    const btnUpdate        = document.getElementById('btnUpdate');
    const btnCancelEdit    = document.getElementById('btnCancelEdit');
    const btnFormReset     = document.getElementById('btnFormReset');
    const togglePwdBtn     = document.getElementById('togglePwd');

    /* state */
    let users = [], filteredUsers = [], currentPage = 1;
    let formMode = 'create'; // 'create' | 'edit'

    /* SVG helper */
    function makeSVG(pathsArray) {
      const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('viewBox', '0 0 24 24');
      svg.setAttribute('fill', 'none');
      svg.setAttribute('stroke', 'currentColor');
      svg.setAttribute('stroke-width', '2');
      svg.setAttribute('stroke-linecap', 'round');
      svg.setAttribute('stroke-linejoin', 'round');
      pathsArray.forEach(d => {
        const p = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        p.setAttribute('d', d);
        svg.appendChild(p);
      });
      return svg;
    }
    const ICON_EDIT   = ['M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7','M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z'];
    const ICON_DELETE = ['M3 6h18','M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2','M10 11v6','M14 11v6'];

    /* Password toggle */
    togglePwdBtn?.addEventListener('click', () => {
      const show = contrasenaEl.type === 'password';
      contrasenaEl.type = show ? 'text' : 'password';
      togglePwdBtn.setAttribute('aria-label', show ? 'Ocultar contraseña' : 'Mostrar contraseña');
      togglePwdBtn.classList.toggle('is-active', show);
    });

    /* location helpers (idénticos al original) */
    function setSelectOptions(select, items, placeholder) {
      select.innerHTML = '';
      const ph = document.createElement('option'); ph.value = ''; ph.textContent = placeholder; select.appendChild(ph);
      items.forEach(item => { const opt = document.createElement('option'); opt.value = item; opt.textContent = item; select.appendChild(opt); });
    }
    function disableLocationSelect(select, placeholder) { select.innerHTML = `<option value="">${placeholder}</option>`; select.disabled = true; }
    async function loadCountries() {
      try {
        const res = await fetch('/api/locations?action=countries'); const data = await res.json();
        if (!data.success) throw new Error(data.error);
        setSelectOptions(paisEl, data.data.map(c => c.name), 'Selecciona un país'); paisEl.disabled = false;
      } catch { disableLocationSelect(paisEl, 'Error cargando países'); }
    }
    async function loadStates(country) {
      disableLocationSelect(provinciaEl, 'Cargando estados…'); disableLocationSelect(ciudadEl, 'Primero selecciona un estado');
      if (!country) { disableLocationSelect(provinciaEl, 'Primero selecciona un país'); return; }
      try {
        const res = await fetch(`/api/locations?action=states&country=${encodeURIComponent(country)}`); const data = await res.json();
        if (!data.success) throw new Error(data.error);
        setSelectOptions(provinciaEl, data.data, 'Selecciona un estado'); provinciaEl.disabled = false;
      } catch { disableLocationSelect(provinciaEl, 'Error cargando estados'); }
    }
    async function loadCities(country, state) {
      disableLocationSelect(ciudadEl, 'Cargando municipios…');
      if (!state) { disableLocationSelect(ciudadEl, 'Primero selecciona un estado'); return; }
      try {
        const res = await fetch(`/api/locations?action=cities&country=${encodeURIComponent(country)}&state=${encodeURIComponent(state)}`); const data = await res.json();
        if (!data.success) throw new Error(data.error);
        setSelectOptions(ciudadEl, data.data, 'Selecciona un municipio'); ciudadEl.disabled = false;
      } catch { disableLocationSelect(ciudadEl, 'Error cargando municipios'); }
    }
    async function setLocationValues(pais, provincia, ciudad) {
      if (!pais) return;
      if (!paisEl.querySelector(`option[value="${CSS.escape(pais)}"]`)) { const opt = document.createElement('option'); opt.value = pais; opt.textContent = pais; paisEl.appendChild(opt); }
      paisEl.value = pais; await loadStates(pais);
      if (provincia) {
        if (!provinciaEl.querySelector(`option[value="${CSS.escape(provincia)}"]`)) { const opt = document.createElement('option'); opt.value = provincia; opt.textContent = provincia; provinciaEl.appendChild(opt); }
        provinciaEl.value = provincia; provinciaEl.disabled = false; await loadCities(pais, provincia);
        if (ciudad) {
          if (!ciudadEl.querySelector(`option[value="${CSS.escape(ciudad)}"]`)) { const opt = document.createElement('option'); opt.value = ciudad; opt.textContent = ciudad; ciudadEl.appendChild(opt); }
          ciudadEl.value = ciudad; ciudadEl.disabled = false;
        }
      }
    }
    async function initLocationSelectors() {
      await loadCountries();
      paisEl.addEventListener('change', () => loadStates(paisEl.value));
      provinciaEl.addEventListener('change', () => loadCities(paisEl.value, provinciaEl.value));
    }

    /* form helpers */
    function setMode(mode, label) {
      formMode = mode;
      if (mode === 'edit') {
        formTitleEl.innerHTML = `Editando: <em>${label || ''}</em>`;
        formModeBadgeEl.textContent = 'Editar';
        formModeBadgeEl.className = 'ux-form-badge ux-form-badge--edit';
        btnCreate.hidden = true;
        btnUpdate.hidden = false;
      } else {
        formTitleEl.textContent = 'Nuevo usuario';
        formModeBadgeEl.textContent = 'Nuevo';
        formModeBadgeEl.className = 'ux-form-badge';
        btnCreate.hidden = false;
        btnUpdate.hidden = true;
        currentUserIdEl.value = '';
      }
    }
    function resetForm() {
      nombreEl.value = ''; apellidoPaternoEl.value = ''; apellidoMaternoEl.value = '';
      telefonoEl.value = ''; correoEl.value = ''; rolEl.value = 'usuario'; contrasenaEl.value = '';
      numeroCasaEl.value = ''; calleEl.value = ''; codigoPostalEl.value = '';
      if (paisEl) paisEl.value = '';
      disableLocationSelect(provinciaEl, 'Primero selecciona un país');
      disableLocationSelect(ciudadEl, 'Primero selecciona un estado');
      setMode('create');
    }
    function openForm(mode = 'create', label) {
      if (!formPanelEl) return;
      formPanelEl.classList.add('is-open');
      formPanelEl.setAttribute('aria-hidden', 'false');
      setMode(mode, label);
      setTimeout(() => formPanelEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 80);
    }
    function closeForm() {
      if (!formPanelEl) return;
      formPanelEl.classList.remove('is-open');
      formPanelEl.setAttribute('aria-hidden', 'true');
      resetForm();
    }
    function fillForm(user) {
      currentUserIdEl.value = String(user.id);
      nombreEl.value = user.nombre || ''; apellidoPaternoEl.value = user.apellidoPaterno || '';
      apellidoMaternoEl.value = user.apellidoMaterno || ''; telefonoEl.value = user.telefono || '';
      correoEl.value = user.correo || ''; rolEl.value = String(user.rol || 'usuario').toLowerCase();
      contrasenaEl.value = ''; numeroCasaEl.value = user.numeroCasa || '';
      calleEl.value = user.calle || ''; codigoPostalEl.value = user.codigoPostal || '';
      setLocationValues(user.pais || 'Mexico', user.provincia || '', user.ciudad || '');
      openForm('edit', `${user.nombre || ''} ${user.apellidoPaterno || ''}`.trim());
    }
    function buildPayload() {
      return { nombre: nombreEl?.value?.trim() || '', apellidoPaterno: apellidoPaternoEl?.value?.trim() || '', apellidoMaterno: apellidoMaternoEl?.value?.trim() || '', telefono: telefonoEl?.value?.trim() || '', correo: correoEl?.value?.trim() || '', rol: rolEl?.value || 'usuario', contrasena: contrasenaEl?.value || '', numeroCasa: numeroCasaEl?.value || '', calle: calleEl?.value?.trim() || '', codigoPostal: codigoPostalEl?.value || '', ciudad: ciudadEl?.value?.trim() || '', provincia: provinciaEl?.value?.trim() || '', pais: paisEl?.value?.trim() || '' };
    }

    /* initials avatar */
    function initials(nombre, apellido) {
      return ((nombre || '').charAt(0) + (apellido || '').charAt(0)).toUpperCase() || '?';
    }
    const AVATAR_COLORS = ['#8b5cf6','#6d28d9','#2563eb','#0891b2','#059669','#d97706','#dc2626'];
    function avatarColor(id) { return AVATAR_COLORS[Number(id || 0) % AVATAR_COLORS.length]; }

    /* rol badge */
    function rolBadge(rol) {
      const r = String(rol || '').toLowerCase();
      if (r === 'superusuario') return `<span class="ux-role ux-role--super">super</span>`;
      if (r === 'admin') return `<span class="ux-role ux-role--admin">admin</span>`;
      return `<span class="ux-role ux-role--user">usuario</span>`;
    }

    /* paginate */
    function applyFilters() {
      const q = String(searchUsersEl?.value || '').trim().toLowerCase();
      filteredUsers = users.filter(u => {
        if (!q) return true;
        const name = `${u.nombre || ''} ${u.apellidoPaterno || ''} ${u.apellidoMaterno || ''}`.toLowerCase();
        return name.includes(q) || String(u.correo || '').toLowerCase().includes(q) || String(u.rol || '').toLowerCase().includes(q);
      });
    }
    function getPageData() {
      applyFilters();
      const perPage = Number(rowsPerPageEl?.value || 10);
      const totalPages = Math.max(1, Math.ceil(filteredUsers.length / perPage));
      if (currentPage > totalPages) currentPage = totalPages;
      const start = (currentPage - 1) * perPage;
      return { items: filteredUsers.slice(start, start + perPage), total: filteredUsers.length, totalPages, start };
    }
    function renderPagination({ total, totalPages, start, items }) {
      if (resultsInfoEl) resultsInfoEl.textContent = total === 0 ? 'Sin resultados' : `Mostrando ${start + 1}–${start + items.length} de ${total} resultado${total !== 1 ? 's' : ''}`;
      if (!paginationControlsEl) return;
      paginationControlsEl.innerHTML = '';
      if (totalPages <= 1) return;
      const mkBtn = (label, page, active, disabled) => {
        const b = document.createElement('button');
        b.className = 'ux-page-btn' + (active ? ' is-active' : '') + (disabled ? ' is-disabled' : '');
        b.textContent = label; b.disabled = disabled;
        if (!disabled && !active) b.addEventListener('click', () => { currentPage = page; renderUsers(); });
        return b;
      };
      paginationControlsEl.appendChild(mkBtn('‹', currentPage - 1, false, currentPage === 1));
      let prev = 0; const pages = new Set([1, totalPages]);
      for (let i = Math.max(2, currentPage - 2); i <= Math.min(totalPages - 1, currentPage + 2); i++) pages.add(i);
      [...pages].sort((a, b) => a - b).forEach(p => {
        if (prev && p - prev > 1) paginationControlsEl.appendChild(Object.assign(document.createElement('span'), { className: 'ux-page-ellipsis', textContent: '…' }));
        paginationControlsEl.appendChild(mkBtn(String(p), p, p === currentPage, false)); prev = p;
      });
      paginationControlsEl.appendChild(mkBtn('›', currentPage + 1, false, currentPage === totalPages));
    }

    /* stats */
    function renderStats() {
      if (!statsEl) return;
      const total = users.length;
      const supers = users.filter(u => u.rol === 'superusuario').length;
      const admins = users.filter(u => u.rol === 'admin').length;
      const regulares = users.filter(u => u.rol === 'usuario').length;
      statsEl.innerHTML = `
        <span class="ux-stat">
          <strong>${total}</strong> usuarios totales
        </span>
        <span class="ux-stat-sep" aria-hidden="true">·</span>
        <span class="ux-stat ux-stat--violet"><strong>${supers + admins}</strong> con acceso admin</span>
        <span class="ux-stat-sep" aria-hidden="true">·</span>
        <span class="ux-stat ux-stat--green"><strong>${regulares}</strong> usuarios regulares</span>`;
    }

    /* render */
    function renderUsers() {
      if (!rowsEl) return;
      rowsEl.innerHTML = '';
      const pageData = getPageData();
      if (pageData.items.length === 0) {
        rowsEl.innerHTML = `<tr><td colspan="6" class="ux-empty">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <span>No se encontraron usuarios</span>
        </td></tr>`;
      } else {
        pageData.items.forEach(user => {
          const tr = document.createElement('tr');
          const canDelete = isSuperusuario;
          const ini = initials(user.nombre, user.apellidoPaterno);
          const bgColor = avatarColor(user.id);
          tr.innerHTML = `
            <td class="col-id"><span class="ux-id">#${user.id}</span></td>
            <td class="col-name">
              <div class="ux-user-cell">
                <span class="ux-avatar" style="background:${bgColor}20;color:${bgColor};border-color:${bgColor}30">${ini}</span>
                <span class="ux-user-name">${user.nombre || ''} ${user.apellidoPaterno || ''}</span>
              </div>
            </td>
            <td class="col-email"><span class="ux-email">${user.correo || ''}</span></td>
            <td class="col-role">${rolBadge(user.rol)}</td>
            <td class="col-tel">${user.telefono || '<span class="ux-muted">—</span>'}</td>
            <td class="col-actions">
              <div class="ux-row-actions">
                <button class="ux-action-btn ux-action-btn--edit" data-action="edit" data-id="${user.id}" type="button" title="Editar usuario"></button>
                <button class="ux-action-btn ux-action-btn--delete" data-action="delete" data-id="${user.id}" type="button" title="Eliminar usuario" ${canDelete ? '' : 'disabled'}></button>
              </div>
            </td>`;
          const editBtn = tr.querySelector('.ux-action-btn--edit');
          const delBtn  = tr.querySelector('.ux-action-btn--delete');
          if (editBtn) editBtn.appendChild(makeSVG(ICON_EDIT));
          if (delBtn)  delBtn.appendChild(makeSVG(ICON_DELETE));
          rowsEl.appendChild(tr);
        });
      }
      renderPagination(pageData);
      renderStats();
    }

    /* fetch */
    async function fetchUsers() {
      const r = await fetch('/api/admin/usuarios', { credentials: 'include' });
      const d = await r.json().catch(() => ({}));
      if (!r.ok || !d?.success) throw new Error(d?.error || 'No se pudieron cargar usuarios');
      users = Array.isArray(d.usuarios) ? d.usuarios : [];
      renderUsers();
    }

    /* export */
    function usersToRowsText(list) { return list.map(u => `${u.id}\t${u.nombre || ''} ${u.apellidoPaterno || ''}\t${u.correo || ''}\t${String(u.rol || '').toLowerCase()}\t${u.telefono || ''}`).join('\n'); }
    function usersToCsv(list) { const h = 'id,nombre,correo,rol,telefono'; const b = list.map(u => `${u.id},"${(`${u.nombre || ''} ${u.apellidoPaterno || ''}`.trim()).replaceAll('"', '""')}","${String(u.correo || '').replaceAll('"', '""')}","${String(u.rol || '').toLowerCase()}","${String(u.telefono || '')}"`).join('\n'); return `${h}\n${b}`; }
    function triggerDownload(content, fileName, mimeType) { const blob = new Blob([content], { type: mimeType }); const url = URL.createObjectURL(blob); const a = document.createElement('a'); a.href = url; a.download = fileName; document.body.appendChild(a); a.click(); a.remove(); URL.revokeObjectURL(url); }

    /* events */
    btnAddUser?.addEventListener('click', () => { resetForm(); openForm('create'); });
    searchUsersEl?.addEventListener('input', () => { currentPage = 1; renderUsers(); });
    rowsPerPageEl?.addEventListener('change', () => { currentPage = 1; renderUsers(); });
    btnCancelEdit?.addEventListener('click', closeForm);
    btnFormReset?.addEventListener('click', resetForm);

    btnCopy?.addEventListener('click', async () => {
      try { await navigator.clipboard.writeText(`ID\tNOMBRE\tCORREO\tROL\tTELEFONO\n${usersToRowsText(filteredUsers)}`); Modal.success('Copiado', 'Datos copiados al portapapeles', { autoClose: 1800 }); }
      catch { Modal.error('Error', 'No se pudo copiar al portapapeles'); }
    });
    btnCsv?.addEventListener('click', () => { triggerDownload(usersToCsv(filteredUsers), 'usuarios.csv', 'text/csv;charset=utf-8;'); Modal.success('CSV descargado', 'Archivo listo', { autoClose: 1800 }); });
    btnExcel?.addEventListener('click', () => {
      const rows = filteredUsers.map(u => `<tr><td>${u.id}</td><td>${u.nombre || ''} ${u.apellidoPaterno || ''}</td><td>${u.correo || ''}</td><td>${String(u.rol || '').toLowerCase()}</td><td>${u.telefono || ''}</td></tr>`).join('');
      triggerDownload(`<table><thead><tr><th>ID</th><th>Nombre</th><th>Correo</th><th>Rol</th><th>Telefono</th></tr></thead><tbody>${rows}</tbody></table>`, 'usuarios.xls', 'application/vnd.ms-excel;charset=utf-8;');
      Modal.success('Excel descargado', 'Archivo listo', { autoClose: 1800 });
    });
    btnPdf?.addEventListener('click', () => {
      const rows = filteredUsers.map(u => `<tr><td>${u.id}</td><td>${u.nombre || ''} ${u.apellidoPaterno || ''}</td><td>${u.correo || ''}</td><td>${String(u.rol || '').toLowerCase()}</td><td>${u.telefono || ''}</td></tr>`).join('');
      const w = window.open('', '_blank', 'width=980,height=720');
      if (!w) { Modal.error('Error', 'No se pudo abrir la ventana de impresión'); return; }
      w.document.write(`<html><head><title>Usuarios</title><style>body{font-family:Arial;padding:24px;color:#111}table{width:100%;border-collapse:collapse}th,td{border:1px solid #ccc;padding:8px;font-size:12px}th{background:#f0f0f0}</style></head><body><h1>Usuarios NEXUS</h1><table><thead><tr><th>ID</th><th>Nombre</th><th>Correo</th><th>Rol</th><th>Telefono</th></tr></thead><tbody>${rows}</tbody></table></body></html>`);
      w.document.close(); w.focus(); w.print();
      Modal.success('PDF', 'Ventana de impresión abierta', { autoClose: 1800 });
    });

    btnCreate?.addEventListener('click', async () => {
      const p = buildPayload();
      if (!p.nombre || !p.apellidoPaterno || !p.correo || !p.numeroCasa || !p.calle || !p.codigoPostal || !p.pais || !p.provincia || !p.ciudad) {
        Modal.error('Campos incompletos', 'Nombre, apellido, correo y dirección completa son obligatorios'); return;
      }
      try {
        Modal.loading('Creando usuario', 'Por favor espera…');
        const r = await fetch('/api/admin/usuarios', { method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(p) });
        const d = await r.json().catch(() => ({}));
        Modal.hideLoading();
        if (!r.ok || !d?.success) throw new Error(d?.error || 'No se pudo crear el usuario');
        Modal.success('¡Usuario creado!', 'Las credenciales se enviaron al correo del usuario', { autoClose: 2500 });
        closeForm(); await fetchUsers();
      } catch (err) { Modal.hideLoading(); Modal.error('Error al crear', err.message || 'Error desconocido'); }
    });

    btnUpdate?.addEventListener('click', async () => {
      const userId = currentUserIdEl?.value;
      if (!userId) { Modal.error('Sin selección', 'Primero selecciona un usuario desde la tabla para editar'); return; }
      const p = buildPayload();
      if (!p.nombre || !p.apellidoPaterno || !p.correo || !p.numeroCasa || !p.calle || !p.codigoPostal || !p.pais || !p.provincia || !p.ciudad) {
        Modal.error('Campos incompletos', 'Nombre, apellido, correo y dirección completa son obligatorios'); return;
      }
      try {
        Modal.loading('Actualizando usuario', 'Guardando cambios…');
        const r = await fetch(`/api/admin/usuarios/${userId}`, { method: 'PUT', credentials: 'include', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(p) });
        const d = await r.json().catch(() => ({}));
        Modal.hideLoading();
        if (!r.ok || !d?.success) throw new Error(d?.error || 'No se pudo actualizar');
        Modal.success('¡Guardado!', 'Usuario actualizado correctamente', { autoClose: 2500 });
        closeForm(); await fetchUsers();
      } catch (err) { Modal.hideLoading(); Modal.error('Error al guardar', err.message || 'Error desconocido'); }
    });

    rowsEl?.addEventListener('click', async event => {
      const btn = event.target?.closest('button[data-action]');
      if (!(btn instanceof HTMLButtonElement)) return;
      const action = btn.dataset.action, userId = btn.dataset.id;
      if (!userId) return;
      if (action === 'edit') { const user = users.find(u => String(u.id) === String(userId)); if (user) fillForm(user); return; }
      if (action === 'delete') {
        if (!isSuperusuario) { Modal.error('Sin permiso', 'Solo superusuario puede eliminar usuarios'); return; }
        const ok = await Modal.confirm('¿Eliminar usuario?', 'Esta acción es permanente y no se puede deshacer.', { confirmText: 'Sí, eliminar', cancelText: 'Cancelar' });
        if (!ok) return;
        try {
          Modal.loading('Eliminando usuario', 'Por favor espera…');
          const r = await fetch(`/api/admin/usuarios/${userId}`, { method: 'DELETE', credentials: 'include' });
          const d = await r.json().catch(() => ({}));
          Modal.hideLoading();
          if (!r.ok || !d?.success) throw new Error(d?.error || 'No se pudo eliminar');
          Modal.success('Eliminado', 'El usuario fue eliminado correctamente', { autoClose: 2000 });
          closeForm(); await fetchUsers();
        } catch (err) { Modal.hideLoading(); Modal.error('Error al eliminar', err.message || 'Error desconocido'); }
      }
    });

    initLocationSelectors();
    fetchUsers().catch(err => Modal.error('Error', err.message || 'No se pudieron cargar los usuarios'));
  })();
  </script>

  <script>
    (function(){
      try{const t=localStorage.getItem('theme');if(t==='dark')document.documentElement.classList.add('dark');else document.documentElement.classList.remove('dark');}catch(e){}
      window.addEventListener('storage',(e)=>{if(e.key==='theme')document.documentElement.classList.toggle('dark',e.newValue==='dark');});
    })();
  </script>

  <style is:global>
  /* ════════════════════════════════════════════════════════
     GESTIÓN DE USUARIOS — Rediseño v2
     Isolated via .ux-root · matches dashboard design system
     ════════════════════════════════════════════════════════ */

  .ux-root {
    /* Tokens — espejo del dashboard */
    --ux-bg:        #060a14;
    --ux-s1:        #0c1322;
    --ux-s2:        #111a2e;
    --ux-s3:        #172237;
    --ux-line:      rgba(148,163,184,0.14);
    --ux-line-h:    rgba(148,163,184,0.26);
    --ux-t1:        #eef2fa;
    --ux-t2:        #94a3b8;
    --ux-t3:        #475569;
    /* Accent — violet (admin diferenciador) */
    --ux-vi:        #8b5cf6;
    --ux-vi-soft:   rgba(139,92,246,0.12);
    --ux-vi-glow:   rgba(139,92,246,0.22);
    --ux-vi-dim:    rgba(139,92,246,0.08);
    /* Semantic */
    --ux-good:      #34d399;
    --ux-bad:       #fb7185;
    --ux-warn:      #fbbf24;
    /* Layout */
    --ux-r:         18px;
    --ux-r-sm:      12px;
    --ux-r-xs:      8px;
    /* Transitions */
    --ux-t-fast:    0.15s ease;
    --ux-t-med:     0.22s ease;

    background: var(--ux-bg) !important;
    min-height: 100vh;
    font-family: 'Inter', -apple-system, 'SF Pro Text', system-ui, sans-serif;
  }

  /* Nuclear reset — kill any global typography overrides */
  .ux-root .ux *,
  .ux-root .ux *::before,
  .ux-root .ux *::after {
    font-family: 'Inter', -apple-system, system-ui, sans-serif !important;
    text-transform: none !important;
    letter-spacing: normal !important;
    text-shadow: none !important;
    -webkit-text-fill-color: unset !important;
    -webkit-text-stroke: 0 !important;
    background-clip: unset !important;
    -webkit-background-clip: unset !important;
    box-sizing: border-box;
  }

  .ux-root .ux h1 { font-size: clamp(1.4rem, 2.4vw, 2rem) !important; line-height: 1.1 !important; margin: 0 !important; padding: 0 !important; background: none !important; }
  .ux-root .ux h2 { font-size: 1rem !important; line-height: 1.3 !important; margin: 0 !important; padding: 0 !important; background: none !important; }

  .ux-root .ux {
    max-width: 1340px;
    margin: 0 auto;
    padding: 108px 24px 64px;
    display: grid;
    gap: 14px;
  }

  /* ── Hero ── */
  .ux-root .ux-hero {
    position: relative;
    border: 1px solid var(--ux-line);
    border-radius: var(--ux-r);
    padding: 28px 28px 22px;
    overflow: hidden;
    background: linear-gradient(150deg, var(--ux-s2), var(--ux-s1));
    box-shadow: 0 20px 50px rgba(0,0,0,0.3);
  }

  .ux-root .ux-hero__glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 5% -15%, rgba(139,92,246,0.22), transparent 48%),
      radial-gradient(ellipse at 92% 0%, rgba(34,211,238,0.09), transparent 42%);
    pointer-events: none;
  }

  .ux-root .ux-hero__body {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .ux-root .ux-hero__kicker {
    margin: 0;
    font-size: 0.66rem !important;
    font-weight: 700;
    text-transform: uppercase !important;
    letter-spacing: 0.14em !important;
    color: #c4b5fd;
  }

  .ux-root .ux-hero__title {
    margin: 4px 0 0 !important;
    font-size: clamp(1.4rem, 2.4vw, 2rem) !important;
    font-weight: 800 !important;
    color: var(--ux-t1) !important;
  }

  .ux-root .ux-hero__sub {
    margin: 5px 0 0;
    font-size: 0.85rem;
    color: var(--ux-t2);
  }

  .ux-root .ux-hero__right {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .ux-root .ux-hero__stats {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--ux-line);
    font-size: 0.8rem;
    color: var(--ux-t2);
  }

  .ux-root .ux-stat strong { color: var(--ux-t1); font-weight: 700; margin-right: 3px; }
  .ux-root .ux-stat--violet strong { color: #c4b5fd; }
  .ux-root .ux-stat--green strong { color: var(--ux-good); }
  .ux-root .ux-stat-sep { color: var(--ux-t3); user-select: none; }

  /* CTA buttons */
  .ux-root .ux-cta {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 18px;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
    transition: transform var(--ux-t-fast), box-shadow var(--ux-t-fast);
    text-decoration: none;
    border: none;
    white-space: nowrap;
  }

  .ux-root .ux-cta:not(.ux-cta--ghost) {
    background: linear-gradient(135deg, var(--ux-vi), #6d28d9);
    color: #fff;
    box-shadow: 0 4px 18px var(--ux-vi-glow);
  }

  .ux-root .ux-cta--ghost {
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--ux-line-h);
    color: var(--ux-t2);
    box-shadow: none;
  }

  .ux-root .ux-cta:hover { transform: translateY(-2px); }
  .ux-root .ux-cta:not(.ux-cta--ghost):hover { box-shadow: 0 8px 26px var(--ux-vi-glow); }
  .ux-root .ux-cta--ghost:hover { color: var(--ux-t1); border-color: var(--ux-vi); }

  .ux-root .ux-icon-btn {
    width: 34px; height: 34px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: var(--ux-r-xs);
    border: 1px solid var(--ux-line);
    background: rgba(255,255,255,0.04);
    color: var(--ux-t3);
    cursor: pointer;
    transition: all var(--ux-t-fast);
  }
  .ux-root .ux-icon-btn svg { width: 15px; height: 15px; stroke: currentColor; }
  .ux-root .ux-icon-btn:hover { border-color: var(--ux-bad); color: var(--ux-bad); background: rgba(251,113,133,0.08); }

  /* ── Cards ── */
  .ux-root .ux-card {
    border: 1px solid var(--ux-line);
    border-radius: var(--ux-r);
    background: linear-gradient(155deg, var(--ux-s2), var(--ux-s1));
    box-shadow: 0 8px 28px rgba(0,0,0,0.2);
    transition: border-color var(--ux-t-med);
    overflow: hidden;
  }
  .ux-root .ux-card:hover { border-color: var(--ux-line-h); }
  .ux-root .ux-card--form { border-left: 2px solid var(--ux-vi); padding: 24px; }
  .ux-root .ux-card--table { padding: 0; }

  /* ── Form Panel (slide-in) ── */
  .ux-root .ux-form-panel {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition: grid-template-rows 0.32s cubic-bezier(0.4,0,0.2,1), opacity 0.22s ease;
    pointer-events: none;
  }
  .ux-root .ux-form-panel.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
    pointer-events: auto;
  }
  .ux-root .ux-form-panel > * { overflow: hidden; }
  .ux-root .ux-form-panel.is-open > * { overflow: visible; }

  .ux-root .ux-form-titlebar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }
  .ux-root .ux-form-titlebar__left { display: flex; align-items: center; gap: 10px; }
  .ux-root .ux-form-titlebar__title { font-size: 1.05rem !important; font-weight: 700; color: var(--ux-t1) !important; }
  .ux-root .ux-form-titlebar__title em { font-style: normal; color: #c4b5fd; }

  .ux-root .ux-form-badge {
    display: inline-flex;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
    background: var(--ux-vi-soft);
    color: #c4b5fd;
    border: 1px solid rgba(139,92,246,0.3);
  }
  .ux-root .ux-form-badge--edit {
    background: rgba(251,191,36,0.1);
    color: #fbbf24;
    border-color: rgba(251,191,36,0.3);
  }

  .ux-root .ux-hint {
    display: flex;
    align-items: flex-start;
    gap: 7px;
    margin: 0 0 18px;
    padding: 10px 14px;
    border-radius: var(--ux-r-xs);
    background: var(--ux-vi-dim);
    border: 1px solid rgba(139,92,246,0.2);
    font-size: 0.75rem;
    color: var(--ux-t2);
    line-height: 1.5;
  }
  .ux-root .ux-hint svg { flex-shrink: 0; margin-top: 1px; color: #c4b5fd; }

  .ux-root .ux-warn-banner {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0 16px 0;
    padding: 10px 14px;
    border-radius: var(--ux-r-xs);
    background: rgba(251,113,133,0.08);
    border: 1px solid rgba(251,113,133,0.2);
    font-size: 0.75rem;
    color: #fda4af;
  }

  /* Sections inside form */
  .ux-root .ux-sections { display: flex; flex-direction: column; gap: 14px; }

  .ux-root .ux-section {
    border: 1px solid var(--ux-line);
    border-radius: var(--ux-r-sm);
    padding: 16px 18px 18px;
    background: rgba(6,10,20,0.3);
    margin: 0;
  }
  .ux-root .ux-section--narrow { max-width: 600px; }

  .ux-root .ux-section__legend {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 0 8px;
    font-size: 0.7rem !important;
    font-weight: 700;
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
    color: var(--ux-t3);
    background: transparent;
    float: none;
  }
  .ux-root .ux-section__legend svg { width: 13px; height: 13px; stroke: var(--ux-vi); flex-shrink: 0; }

  /* Grid */
  .ux-root .ux-grid { display: grid; gap: 12px; margin-top: 12px; }
  .ux-root .ux-grid--3 { grid-template-columns: repeat(3, 1fr); }
  .ux-root .ux-grid--2 { grid-template-columns: repeat(2, 1fr); }
  .ux-root .ux-field--wide { grid-column: span 2; }

  /* Fields */
  .ux-root .ux-field { display: flex; flex-direction: column; gap: 5px; }
  .ux-root .ux-field label {
    font-size: 0.67rem !important;
    font-weight: 700;
    text-transform: uppercase !important;
    letter-spacing: 0.08em !important;
    color: var(--ux-t3);
  }
  .ux-root .req { color: #fb7185; font-size: 0.7rem; }

  /* Inputs & selects */
  .ux-root input:not([type=hidden]),
  .ux-root select {
    width: 100%;
    border: 1px solid var(--ux-line);
    border-radius: var(--ux-r-xs);
    padding: 9px 12px;
    background: rgba(6,10,20,0.5);
    color: var(--ux-t1);
    font-size: 0.82rem;
    transition: border-color var(--ux-t-fast), background var(--ux-t-fast);
    outline: none;
  }
  .ux-root input:focus:not([type=hidden]),
  .ux-root select:focus {
    border-color: var(--ux-vi);
    background: rgba(6,10,20,0.7);
    box-shadow: 0 0 0 3px var(--ux-vi-dim);
  }
  .ux-root input::placeholder { color: var(--ux-t3); }
  .ux-root select:disabled { opacity: 0.4; cursor: not-allowed; }
  .ux-root select option { background: #0c1322; }

  /* Password toggle */
  .ux-root .ux-password-wrap { position: relative; }
  .ux-root .ux-password-wrap input { padding-right: 40px; }
  .ux-root .ux-eye-btn {
    position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
    width: 24px; height: 24px;
    background: none; border: none; cursor: pointer;
    color: var(--ux-t3); display: flex; align-items: center; justify-content: center;
    transition: color var(--ux-t-fast);
  }
  .ux-root .ux-eye-btn:hover { color: var(--ux-t1); }
  .ux-root .ux-eye-btn.is-active { color: var(--ux-vi); }
  .ux-root .ux-eye-btn svg { width: 15px; height: 15px; stroke: currentColor; }

  /* Form action buttons */
  .ux-root .ux-form-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid var(--ux-line);
  }
  .ux-root .ux-form-actions__primary { display: flex; gap: 10px; flex-wrap: wrap; }

  .ux-root .ux-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 10px 20px;
    border-radius: var(--ux-r-xs);
    font-size: 0.82rem;
    font-weight: 700;
    cursor: pointer;
    border: none;
    transition: transform var(--ux-t-fast), box-shadow var(--ux-t-fast), opacity var(--ux-t-fast);
  }
  .ux-root .ux-btn svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; }
  .ux-root .ux-btn:hover { transform: translateY(-1px); }

  .ux-root .ux-btn--create {
    background: linear-gradient(135deg, #059669, #34d399);
    color: #fff;
    box-shadow: 0 4px 14px rgba(52,211,153,0.3);
  }
  .ux-root .ux-btn--create:hover { box-shadow: 0 6px 20px rgba(52,211,153,0.4); }

  .ux-root .ux-btn--update {
    background: linear-gradient(135deg, var(--ux-vi), #6d28d9);
    color: #fff;
    box-shadow: 0 4px 14px var(--ux-vi-glow);
  }
  .ux-root .ux-btn--update:hover { box-shadow: 0 6px 20px var(--ux-vi-glow); }

  .ux-root .ux-btn--ghost {
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--ux-line);
    color: var(--ux-t2);
  }
  .ux-root .ux-btn--ghost:hover { background: rgba(255,255,255,0.09); color: var(--ux-t1); }

  /* ── Toolbar ── */
  .ux-root .ux-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    padding: 16px 20px;
    border-bottom: 1px solid var(--ux-line);
  }

  .ux-root .ux-toolbar__search {
    position: relative;
    flex: 1;
    min-width: 220px;
    max-width: 360px;
  }
  .ux-root .ux-toolbar__search-icon {
    position: absolute;
    left: 12px; top: 50%;
    transform: translateY(-50%);
    width: 14px; height: 14px;
    stroke: var(--ux-t3);
    pointer-events: none;
  }
  .ux-root .ux-search {
    width: 100%;
    padding: 9px 12px 9px 36px !important;
    border: 1px solid var(--ux-line) !important;
    border-radius: var(--ux-r-xs) !important;
    background: rgba(6,10,20,0.5) !important;
    color: var(--ux-t1) !important;
    font-size: 0.82rem !important;
  }
  .ux-root .ux-search:focus {
    border-color: var(--ux-vi) !important;
    box-shadow: 0 0 0 3px var(--ux-vi-dim) !important;
  }

  .ux-root .ux-toolbar__controls {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .ux-root .ux-export-group {
    display: inline-flex;
    border: 1px solid var(--ux-line);
    border-radius: var(--ux-r-xs);
    overflow: hidden;
  }
  .ux-root .ux-export-btn {
    padding: 7px 13px;
    background: rgba(255,255,255,0.03);
    border: none;
    border-right: 1px solid var(--ux-line);
    color: var(--ux-t3);
    font-size: 0.72rem;
    font-weight: 700;
    cursor: pointer;
    transition: all var(--ux-t-fast);
  }
  .ux-root .ux-export-btn:last-child { border-right: none; }
  .ux-root .ux-export-btn:hover { background: var(--ux-vi-dim); color: #c4b5fd; }

  .ux-root .ux-rows-label {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 0.75rem;
    color: var(--ux-t3);
    white-space: nowrap;
  }
  .ux-root .ux-rows-select {
    padding: 6px 10px !important;
    border-radius: var(--ux-r-xs) !important;
    font-size: 0.75rem !important;
    min-width: 0 !important;
    width: auto !important;
  }

  /* ── Table ── */
  .ux-root .ux-table-scroll {
    overflow-x: auto;
    max-height: 58vh;
  }

  .ux-root .ux-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 760px;
    font-size: 0.82rem;
  }

  .ux-root .ux-table thead th {
    position: sticky; top: 0; z-index: 2;
    padding: 11px 14px;
    text-align: left;
    font-size: 0.67rem !important;
    font-weight: 700;
    text-transform: uppercase !important;
    letter-spacing: 0.08em !important;
    color: var(--ux-t3);
    background: rgba(9,14,25,0.96);
    border-bottom: 1px solid var(--ux-line);
    white-space: nowrap;
    user-select: none;
  }

  .ux-root .ux-table tbody tr {
    transition: background var(--ux-t-fast);
    border-bottom: 1px solid rgba(148,163,184,0.07);
  }
  .ux-root .ux-table tbody tr:last-child { border-bottom: none; }
  .ux-root .ux-table tbody tr:hover { background: var(--ux-vi-dim); }

  .ux-root .ux-table td { padding: 11px 14px; color: var(--ux-t2); vertical-align: middle; }

  /* Column widths */
  .ux-root .col-id      { width: 64px; }
  .ux-root .col-role    { width: 110px; }
  .ux-root .col-tel     { width: 150px; }
  .ux-root .col-actions { width: 100px; }

  /* Cell components */
  .ux-root .ux-id {
    font-size: 0.72rem;
    color: var(--ux-t3);
    font-variant-numeric: tabular-nums;
  }

  .ux-root .ux-user-cell {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ux-root .ux-avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: 1px solid transparent;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 800;
    flex-shrink: 0;
  }
  .ux-root .ux-user-name { color: var(--ux-t1); font-weight: 600; }
  .ux-root .ux-email { color: var(--ux-t2); }
  .ux-root .ux-muted { color: var(--ux-t3); font-size: 0.72rem; }

  /* Role badges */
  .ux-root .ux-role {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase !important;
    letter-spacing: 0.07em !important;
    white-space: nowrap;
  }
  .ux-root .ux-role--super {
    background: rgba(139,92,246,0.18);
    color: #c4b5fd;
    border: 1px solid rgba(139,92,246,0.35);
  }
  .ux-root .ux-role--admin {
    background: rgba(96,165,250,0.14);
    color: #93c5fd;
    border: 1px solid rgba(96,165,250,0.3);
  }
  .ux-root .ux-role--user {
    background: rgba(52,211,153,0.12);
    color: #6ee7b7;
    border: 1px solid rgba(52,211,153,0.25);
  }

  /* Row action buttons */
  .ux-root .ux-row-actions { display: flex; align-items: center; gap: 6px; justify-content: flex-end; }
  .ux-root .ux-action-btn {
    width: 30px; height: 30px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: var(--ux-r-xs);
    border: 1px solid var(--ux-line);
    background: rgba(255,255,255,0.03);
    cursor: pointer;
    transition: all var(--ux-t-fast);
    padding: 0;
  }
  .ux-root .ux-action-btn svg { width: 13px; height: 13px; stroke: currentColor; display: block; }
  .ux-root .ux-action-btn:disabled { opacity: 0.25; cursor: not-allowed; pointer-events: none; }
  .ux-root .ux-action-btn:hover:not(:disabled) { transform: translateY(-1px); }
  .ux-root .ux-action-btn--edit { color: #c4b5fd; border-color: rgba(139,92,246,0.3); }
  .ux-root .ux-action-btn--edit:hover:not(:disabled) { background: var(--ux-vi-soft); border-color: rgba(139,92,246,0.5); }
  .ux-root .ux-action-btn--delete { color: #fda4af; border-color: rgba(251,113,133,0.3); }
  .ux-root .ux-action-btn--delete:hover:not(:disabled) { background: rgba(251,113,133,0.1); border-color: rgba(251,113,133,0.5); }

  /* Empty state */
  .ux-root .ux-empty {
    text-align: center !important;
    padding: 48px 24px !important;
    color: var(--ux-t3) !important;
  }
  .ux-root .ux-empty svg { display: block; margin: 0 auto 12px; stroke: var(--ux-t3); opacity: 0.4; }
  .ux-root .ux-empty span { font-size: 0.85rem; }

  /* Skeleton loading */
  .ux-root .ux-skel {
    display: inline-block;
    height: 12px;
    width: 60px;
    border-radius: 6px;
    background: linear-gradient(90deg, rgba(255,255,255,0.04) 30%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.04) 70%);
    background-size: 220% 100%;
    animation: ux-shimmer 1.3s linear infinite;
  }
  .ux-root .ux-skel--sm   { width: 44px; }
  .ux-root .ux-skel--wide { width: 100px; }
  .ux-root .ux-skel--wider{ width: 140px; }
  @keyframes ux-shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

  /* ── Pagination ── */
  .ux-root .ux-pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    padding: 14px 20px;
    border-top: 1px solid var(--ux-line);
  }
  .ux-root .ux-pagination__info { font-size: 0.74rem; color: var(--ux-t3); }
  .ux-root .ux-pagination__controls { display: flex; align-items: center; gap: 4px; }
  .ux-root .ux-page-btn {
    min-width: 32px; height: 32px;
    padding: 0 6px;
    border-radius: var(--ux-r-xs);
    border: 1px solid var(--ux-line);
    background: rgba(255,255,255,0.03);
    color: var(--ux-t2);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    transition: all var(--ux-t-fast);
  }
  .ux-root .ux-page-btn:hover:not(.is-disabled):not(.is-active) { background: rgba(255,255,255,0.08); color: var(--ux-t1); border-color: var(--ux-line-h); }
  .ux-root .ux-page-btn.is-active { background: linear-gradient(135deg, var(--ux-vi), #6d28d9); border-color: transparent; color: #fff; box-shadow: 0 2px 10px var(--ux-vi-glow); }
  .ux-root .ux-page-btn.is-disabled { opacity: 0.25; cursor: not-allowed; }
  .ux-root .ux-page-ellipsis { color: var(--ux-t3); font-size: 0.78rem; padding: 0 3px; user-select: none; }

  /* ── Responsive ── */
  @media (max-width: 980px) {
    .ux-root .ux { padding: 96px 16px 48px; }
    .ux-root .ux-grid--3 { grid-template-columns: repeat(2, 1fr); }
    .ux-root .ux-field--wide { grid-column: span 1; }
    .ux-root .ux-hero__body { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 640px) {
    .ux-root .ux { padding: 88px 12px 40px; }
    .ux-root .ux-hero { padding: 20px; }
    .ux-root .ux-grid--3,
    .ux-root .ux-grid--2 { grid-template-columns: 1fr; }
    .ux-root .ux-field--wide { grid-column: span 1; }
    .ux-root .ux-toolbar { flex-direction: column; align-items: stretch; }
    .ux-root .ux-toolbar__search { max-width: 100%; }
    .ux-root .ux-toolbar__controls { justify-content: space-between; }
    .ux-root .ux-form-actions { flex-direction: column; }
    .ux-root .ux-form-actions__primary { width: 100%; }
    .ux-root .ux-btn { width: 100%; justify-content: center; }
    .ux-root .ux-pagination { flex-direction: column; align-items: flex-start; }
  }

  /* ── Light mode ── */
  html:not(.dark) .ux-root {
