---
import BaseLayout from "../../../layouts/BaseLayout.astro";
export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}

const currentLang = "es";
const cspNonce = Astro.locals?.cspNonce || "";

const role = String(Astro.locals?.user?.rol || "").trim().toLowerCase().replace(/[\s_-]/g, "")
  .replace(/^superadmin$|^superuser$|^superusuario$/, "superusuario");

if (!role) return Astro.redirect(`/${currentLang}/login`);
if (role !== "admin" && role !== "superusuario") return Astro.redirect(`/${currentLang}`);
---

<BaseLayout title="Gestión de pedidos" currentLang={currentLang}>
<div class="dx-root">
<main class="dx">

  <!-- Hero -->
  <header class="dx-hero">
    <div class="dx-hero__glow" aria-hidden="true"></div>
    <div class="dx-hero__content">
      <div class="dx-hero__left">
        <p class="dx-hero__kicker">Panel Admin</p>
        <h1 class="dx-hero__title">Pedidos</h1>
        <p class="dx-hero__sub">Historial completo de compras, clientes y productos.</p>
      </div>
      <div class="dx-hero__right">
        <div id="statsBar" class="dx-stats"></div>
        <a class="dx-cta" href={`/${currentLang}/admin`}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Dashboard
        </a>
      </div>
    </div>
  </header>

  <!-- Toolbar -->
  <div class="dx-panel dx-toolbar">
    <div class="dx-toolbar__left">
      <div class="dx-search-wrap">
        <svg class="dx-search-ico" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input id="searchInput" type="search" class="dx-search" placeholder="Buscar pedido, cliente, correo, producto…" autocomplete="off" />
      </div>
    </div>
    <div class="dx-toolbar__right">
      <select id="statusFilter" class="dx-select">
        <option value="">Todos los estados</option>
        <option value="pagado">Pagado</option>
        <option value="pendiente">Pendiente</option>
        <option value="cancelado">Cancelado</option>
      </select>
      <select id="rowsSelect" class="dx-select">
        <option value="10">10 / pág</option>
        <option value="25">25 / pág</option>
        <option value="50">50 / pág</option>
      </select>
      <button id="btnCsv"   class="dx-export-btn dx-export-btn--cyan">↓ CSV</button>
      <button id="btnExcel" class="dx-export-btn dx-export-btn--green">↓ Excel</button>
      <button id="btnPdf"   class="dx-export-btn dx-export-btn--red">↓ PDF</button>
    </div>
  </div>

  <!-- Grid -->
  <div id="ordersGrid" class="dx-grid">
    <div class="dx-loading">
      <div class="dx-spinner"></div>
      <p>Cargando pedidos…</p>
    </div>
  </div>

  <!-- Pagination -->
  <div class="dx-pagination">
    <span id="pageInfo" class="dx-page-info"></span>
    <div id="pageControls" class="dx-page-controls"></div>
  </div>

</main>

<!-- Detail drawer — dentro de dx-root para heredar las variables CSS -->
<div id="drawer" class="dx-drawer" hidden>
  <div id="drawerPanel" class="dx-drawer-panel">
    <button id="drawerClose" class="dx-drawer-close" type="button">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div id="drawerContent" class="dx-drawer-content"></div>
  </div>
</div>

</div><!-- /dx-root -->

<script nonce={cspNonce} is:inline>
(function(){

  /* ── state ── */
  let orders = [], filtered = [], page = 1;
  const perPage = () => Number(document.getElementById("rowsSelect")?.value || 10);

  /* ── helpers ── */
  const $ = id => document.getElementById(id);
  const money = v => `$${Number(v||0).toLocaleString("es-MX",{minimumFractionDigits:2,maximumFractionDigits:2})} MXN`;
  const compact = v => new Intl.NumberFormat("es-MX",{style:"currency",currency:"MXN",notation:"compact",maximumFractionDigits:1}).format(Number(v||0));
  const norm = v => String(v||"").toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"");

  function fDate(v){
    const d=new Date(v);
    if(isNaN(d.getTime()))return"—";
    return d.toLocaleDateString("es-MX",{year:"numeric",month:"short",day:"numeric",hour:"2-digit",minute:"2-digit"});
  }
  function fFin(t){
    if(t==="debito")return"Débito";
    if(t==="credito")return"Crédito";
    return"—";
  }

  /* ── badge ── */
  function badge(v, map){
    const s = norm(v);
    const cfg = map[s] || {cls:"gray", label: v||"—"};
    return `<span class="dx-badge dx-badge--${cfg.cls}">${cfg.label||v||"—"}</span>`;
  }
  const estadoPagoMap = {
    pagado:{cls:"green",label:"Pagado"}, aprobado:{cls:"green",label:"Aprobado"},
    completado:{cls:"green",label:"Completado"}, pendiente:{cls:"yellow",label:"Pendiente"},
    fallido:{cls:"red",label:"Fallido"}, rechazado:{cls:"red",label:"Rechazado"},
  };
  const estadoPedidoMap = {
    pagado:{cls:"green",label:"Pagado"}, entregado:{cls:"teal",label:"Entregado"},
    enviado:{cls:"blue",label:"Enviado"}, procesando:{cls:"yellow",label:"Procesando"},
    "en proceso":{cls:"yellow",label:"En proceso"}, cancelado:{cls:"red",label:"Cancelado"},
    "error_batch":{cls:"red",label:"Error"},
  };

  /* ── card HTML ── */
  function cardHtml(o){
    const items = Array.isArray(o.items) ? o.items : [];
    const firstItems = items.slice(0,2);
    const extra = items.length - 2;
    const itemsHtml = firstItems.map(it=>`
      <div class="dx-card-item">
        <span class="dx-card-item-name">${it.nombre||"Producto"}</span>
        ${it.variante ? `<span class="dx-card-item-var">${it.variante}</span>` : ""}
        <span class="dx-card-item-qty">×${it.cantidad||1}</span>
      </div>
    `).join("");

    return `
      <article class="dx-card" data-id="${o.id||o.numeroPedido}">
        <div class="dx-card-head">
          <div class="dx-card-head-left">
            <span class="dx-card-num">#${o.numeroPedido||"—"}</span>
            <span class="dx-card-date">${fDate(o.fechaPedido)}</span>
          </div>
          <div class="dx-card-head-right">
            ${badge(o.estadoPedido, estadoPedidoMap)}
            ${badge(o.pago?.estado, estadoPagoMap)}
          </div>
        </div>

        <div class="dx-card-body">
          <div class="dx-card-section">
            <div class="dx-card-avatar">${(o.usuario?.nombreCompleto||"?")[0].toUpperCase()}</div>
            <div class="dx-card-user">
              <p class="dx-card-user-name">${o.usuario?.nombreCompleto||"—"}</p>
              <p class="dx-card-user-email">${o.usuario?.correo||"—"}</p>
            </div>
            <div class="dx-card-total">${money(o.pago?.monto??o.totalPedido)}</div>
          </div>

          <div class="dx-card-items">
            ${itemsHtml}
            ${extra > 0 ? `<p class="dx-card-more">+${extra} producto${extra>1?"s":""} más</p>` : ""}
          </div>

          <div class="dx-card-addr">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            ${o.direccion?.completa ? o.direccion.completa.slice(0,60)+(o.direccion.completa.length>60?"…":"") : "Sin dirección"}
          </div>
        </div>

        <div class="dx-card-foot">
          <div class="dx-card-pay">
            ${o.pago?.marcaTarjeta ? `<span class="dx-card-brand">${o.pago.marcaTarjeta.toUpperCase()}</span>` : ""}
            ${o.pago?.ultimos4 ? `<span class="dx-card-last4">····${o.pago.ultimos4}</span>` : ""}
            ${o.pago?.tipoFinanciamiento && o.pago.tipoFinanciamiento !== "no_definido" ? `<span class="dx-card-fin">${fFin(o.pago.tipoFinanciamiento)}</span>` : ""}
          </div>
          <button class="dx-card-detail-btn" data-id="${o.id||o.numeroPedido}">
            Ver detalle
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      </article>
    `;
  }

  /* ── drawer ── */
  async function openDrawer(orderId){
    const o = orders.find(x => String(x.id||x.numeroPedido) === String(orderId));
    if(!o) return;
    const items = Array.isArray(o.items) ? o.items : [];
    const content = $("drawerContent");
    if(!content) return;

    content.innerHTML = `
      <div class="dx-d-header">
        <div>
          <span class="dx-d-num">Pedido #${o.numeroPedido||"—"}</span>
          <p class="dx-d-date">${fDate(o.fechaPedido)}</p>
        </div>
        <div class="dx-d-badges">
          ${badge(o.estadoPedido, estadoPedidoMap)}
          ${badge(o.pago?.estado, estadoPagoMap)}
        </div>
      </div>

      <div class="dx-d-block">
        <p class="dx-d-block-title">Cliente</p>
        <div class="dx-d-row"><span>Nombre</span><strong>${o.usuario?.nombreCompleto||"—"}</strong></div>
        <div class="dx-d-row"><span>Correo</span><strong>${o.usuario?.correo||"—"}</strong></div>
        ${o.usuario?.telefono ? `<div class="dx-d-row"><span>Teléfono</span><strong>${o.usuario.telefono}</strong></div>` : ""}
      </div>

      <div class="dx-d-block">
        <p class="dx-d-block-title">Dirección de envío</p>
        <div class="dx-d-row"><span>Calle</span><strong>${o.direccion?.calle||"—"}</strong></div>
        <div class="dx-d-row"><span>Ciudad</span><strong>${o.direccion?.ciudad||"—"}</strong></div>
        <div class="dx-d-row"><span>Estado</span><strong>${o.direccion?.estado||"—"}</strong></div>
        <div class="dx-d-row"><span>CP</span><strong>${o.direccion?.cp||"—"}</strong></div>
        <div class="dx-d-row"><span>País</span><strong>${o.direccion?.pais||"México"}</strong></div>
      </div>

      <div class="dx-d-block">
        <p class="dx-d-block-title">Productos (${items.length})</p>
        ${items.map(it=>`
          <div class="dx-d-product">
            <div class="dx-d-product-info">
              <p class="dx-d-product-name">${it.nombre||"Producto"}</p>
              ${it.variante ? `<p class="dx-d-product-var">${it.variante}</p>` : ""}
            </div>
            <div class="dx-d-product-right">
              <span class="dx-d-product-qty">×${it.cantidad||1}</span>
              <span class="dx-d-product-price">${money(it.precioUnitario||0)}</span>
            </div>
          </div>
        `).join("")}
      </div>

      <div class="dx-d-block">
        <p class="dx-d-block-title">Pago</p>
        <div class="dx-d-row"><span>Método</span><strong>${o.pago?.metodo||"—"}</strong></div>
        ${o.pago?.marcaTarjeta ? `<div class="dx-d-row"><span>Tarjeta</span><strong>${o.pago.marcaTarjeta.toUpperCase()} ····${o.pago.ultimos4||"—"}</strong></div>` : ""}
        ${o.pago?.tipoFinanciamiento && o.pago.tipoFinanciamiento !== "no_definido" ? `<div class="dx-d-row"><span>Tipo</span><strong>${fFin(o.pago.tipoFinanciamiento)}</strong></div>` : ""}
        ${o.pago?.transaccion ? `<div class="dx-d-row"><span>Transacción</span><strong class="dx-d-mono">${o.pago.transaccion}</strong></div>` : ""}
        <div class="dx-d-divider"></div>
        <div class="dx-d-row"><span>Subtotal</span><strong>${money(o.subtotalProductos||0)}</strong></div>
        <div class="dx-d-row"><span>Envío</span><strong>${money(o.costoEnvio||0)}</strong></div>
        <div class="dx-d-row dx-d-total"><span>Total</span><strong>${money(o.pago?.monto??o.totalPedido)}</strong></div>
      </div>

      ${o.notas ? `<div class="dx-d-block"><p class="dx-d-block-title">Notas del cliente</p><p class="dx-d-notes">${o.notas}</p></div>` : ""}

      <div class="dx-d-block" id="dx-d-factura-block">
        <p class="dx-d-block-title">Factura Electrónica (CFDI)</p>
        <div id="dx-d-factura-body" style="display:flex;align-items:center;gap:.5rem;padding:.5rem 0">
          <span style="font-size:.78rem;color:var(--dx-t3)">Consultando…</span>
        </div>
      </div>
    `;

    const drawer = $("drawer");
    const panel  = $("drawerPanel");
    drawer.hidden = false;
    requestAnimationFrame(()=>{ drawer.classList.add("is-open"); panel.classList.add("is-open"); });

    currentDrawerOrderId = o.id || o.numeroPedido;
    loadDrawerFactura(currentDrawerOrderId);
  }

  /* ── drawer factura ── */
  async function loadDrawerFactura(orderId) {
    const body = document.getElementById("dx-d-factura-body");
    if (!body) return;
    try {
      const res  = await fetch("/api/me/pedidos/" + orderId + "/factura", { credentials: "include" });
      const data = await res.json().catch(() => ({}));
      if (!data.success) { body.innerHTML = '<span style="font-size:.78rem;color:var(--dx-t3)">No disponible</span>'; return; }
      if (data.factura && data.factura.estado === "vigente") {
        body.innerHTML =
          '<span style="display:inline-flex;align-items:center;gap:5px;font-size:.75rem;font-weight:600;color:#34d399;background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.25);padding:3px 10px;border-radius:20px">✓ Factura vigente</span>' +
          '<a href="/api/me/pedidos/' + orderId + '/factura?download=pdf" target="_blank" rel="noopener" class="dx-fac-btn dx-fac-btn--red">⬇ PDF</a>' +
          '<a href="/api/me/pedidos/' + orderId + '/factura?download=xml" target="_blank" rel="noopener" class="dx-fac-btn dx-fac-btn--yellow">⬇ XML</a>' +
          '<button type="button" class="dx-fac-btn dx-fac-btn--cancel" onclick="openDrawerCancelFactura(' + orderId + ')">✕ Cancelar</button>';
        return;
      }
      if (data.factura && data.factura.estado === "cancelada") {
        body.innerHTML = '<span style="font-size:.78rem;color:var(--dx-bad);background:rgba(251,113,133,.08);border:1px solid rgba(251,113,133,.2);padding:3px 10px;border-radius:20px">Factura cancelada</span>';
        return;
      }
      if (data.canRequest) {
        body.innerHTML = '<button type="button" class="dx-fac-btn dx-fac-btn--emit" onclick="openDrawerEmitFactura(' + orderId + ')">📄 Emitir Factura</button>';
        return;
      }
      body.innerHTML = '<span style="font-size:.75rem;color:var(--dx-t3)">' + (data.reason || "Factura no disponible aún") + '</span>';
    } catch {
      body.innerHTML = '<span style="font-size:.78rem;color:var(--dx-t3)">Error al consultar</span>';
    }
  }

  window.openDrawerEmitFactura = function(orderId) {
    const body = document.getElementById("dx-d-factura-body");
    if (!body) return;
    body.innerHTML =
      '<div class="dx-fac-form" id="dx-fac-form-wrap">' +
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem;margin-bottom:.5rem">' +
          '<div><label class="dx-fac-label">RFC *</label><input id="dx-fac-rfc" type="text" maxlength="13" placeholder="RFC12 ó RFC123" class="dx-fac-input" /></div>' +
          '<div><label class="dx-fac-label">CP Fiscal *</label><input id="dx-fac-cp" type="text" maxlength="5" placeholder="64000" class="dx-fac-input" /></div>' +
        '</div>' +
        '<div style="margin-bottom:.5rem"><label class="dx-fac-label">Razón social / Nombre *</label><input id="dx-fac-nombre" type="text" maxlength="254" placeholder="Nombre en SAT" class="dx-fac-input" style="width:100%;box-sizing:border-box" /></div>' +
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem;margin-bottom:.5rem">' +
          '<div><label class="dx-fac-label">Régimen Fiscal</label><select id="dx-fac-regimen" class="dx-fac-input"><option value="601">601 - Personas Morales</option><option value="612">612 - Personas Físicas</option><option value="616">616 - Sin Obligaciones</option><option value="626">626 - RESICO</option></select></div>' +
          '<div><label class="dx-fac-label">Uso CFDI</label><select id="dx-fac-uso" class="dx-fac-input"><option value="G03" selected>G03 - Gastos Gral</option><option value="G01">G01 - Adquisición</option><option value="S01">S01 - Sin efectos</option></select></div>' +
        '</div>' +
        '<p id="dx-fac-error" style="font-size:.75rem;color:var(--dx-bad);margin:.25rem 0;display:none"></p>' +
        '<div style="display:flex;gap:.4rem;flex-wrap:wrap">' +
          '<button type="button" class="dx-fac-btn dx-fac-btn--ghost" onclick="cancelDrawerFacForm()">Volver</button>' +
          '<button type="button" id="dx-fac-submit" class="dx-fac-btn dx-fac-btn--emit" onclick="submitDrawerFactura(' + orderId + ')">Generar Factura</button>' +
        '</div>' +
      '</div>';
  };

  window.cancelDrawerFacForm = function() { loadDrawerFactura(currentDrawerOrderId); };
  let currentDrawerOrderId = null;

  window.openDrawerCancelFactura = function(orderId) {
    currentDrawerOrderId = orderId;
    const body = document.getElementById("dx-d-factura-body");
    if (!body) return;
    body.innerHTML =
      '<div class="dx-fac-form">' +
        '<p style="font-size:.75rem;color:var(--dx-bad);margin:0 0 .5rem">⚠️ Cancelar la factura SAT. Acción irreversible.</p>' +
        '<div style="margin-bottom:.5rem"><label class="dx-fac-label">Motivo SAT</label><select id="dx-fac-cancel-motivo" class="dx-fac-input"><option value="02" selected>02 — Sin relación</option><option value="01">01 — Con relación</option><option value="03">03 — No se realizó</option><option value="04">04 — Operación global</option></select></div>' +
        '<div id="dx-fac-folio-row" style="display:none;margin-bottom:.5rem"><label class="dx-fac-label">UUID sustituto</label><input id="dx-fac-cancel-folio" type="text" maxlength="36" placeholder="xxxxxxxx-xxxx-…" class="dx-fac-input" /></div>' +
        '<p id="dx-fac-cancel-error" style="font-size:.75rem;color:var(--dx-bad);margin:.25rem 0;display:none"></p>' +
        '<div style="display:flex;gap:.4rem;flex-wrap:wrap">' +
          '<button type="button" class="dx-fac-btn dx-fac-btn--ghost" onclick="loadDrawerFactura(' + orderId + ')">Volver</button>' +
          '<button type="button" id="dx-fac-cancel-submit" class="dx-fac-btn dx-fac-btn--cancel" onclick="submitDrawerCancelFactura(' + orderId + ')">Confirmar Cancelación</button>' +
        '</div>' +
      '</div>';
    document.getElementById("dx-fac-cancel-motivo")?.addEventListener("change", function() {
      const row = document.getElementById("dx-fac-folio-row");
      if (row) row.style.display = this.value === "01" ? "" : "none";
    });
  };

  window.submitDrawerFactura = async function(orderId) {
    const rfc    = document.getElementById("dx-fac-rfc")?.value.trim().toUpperCase() || "";
    const nombre = document.getElementById("dx-fac-nombre")?.value.trim() || "";
    const cp     = document.getElementById("dx-fac-cp")?.value.trim() || "";
    const regimen = document.getElementById("dx-fac-regimen")?.value || "601";
    const uso    = document.getElementById("dx-fac-uso")?.value || "G03";
    const errEl  = document.getElementById("dx-fac-error");
    if (rfc.length < 12) { if (errEl) { errEl.textContent="RFC inválido"; errEl.style.display=""; } return; }
    if (nombre.length < 3) { if (errEl) { errEl.textContent="Nombre demasiado corto"; errEl.style.display=""; } return; }
    if (cp.length < 4) { if (errEl) { errEl.textContent="CP inválido"; errEl.style.display=""; } return; }
    if (errEl) errEl.style.display = "none";
    const btn = document.getElementById("dx-fac-submit");
    if (btn) { btn.disabled = true; btn.textContent = "Generando…"; }
    try {
      const res  = await fetch("/api/me/pedidos/" + orderId + "/factura", { method: "POST", credentials: "include", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ rfc, nombre, usoCfdi: uso, regimenFiscal: regimen, cpFiscal: cp }) });
      const data = await res.json().catch(() => ({}));
      if (!data.success) { if (errEl) { errEl.textContent = data.error || "Error al generar"; errEl.style.display = ""; } return; }
      const a = document.createElement("a"); a.href = "/api/me/pedidos/" + orderId + "/factura?download=pdf"; a.rel = "noopener"; a.style.display = "none"; document.body.appendChild(a); a.click(); a.remove();
      await loadDrawerFactura(orderId);
    } catch (err) { if (errEl) { errEl.textContent = "Error de red: " + err.message; errEl.style.display = ""; } }
    finally { if (btn) { btn.disabled = false; btn.textContent = "Generar Factura"; } }
  };

  window.submitDrawerCancelFactura = async function(orderId) {
    const motivo = document.getElementById("dx-fac-cancel-motivo")?.value || "02";
    const folio  = document.getElementById("dx-fac-cancel-folio")?.value.trim() || null;
    const errEl  = document.getElementById("dx-fac-cancel-error");
    if (motivo === "01" && !folio) { if (errEl) { errEl.textContent = "El motivo 01 requiere el UUID sustituto"; errEl.style.display = ""; } return; }
    if (errEl) errEl.style.display = "none";
    const btn = document.getElementById("dx-fac-cancel-submit");
    if (btn) { btn.disabled = true; btn.textContent = "Cancelando…"; }
    try {
      const res  = await fetch("/api/me/pedidos/" + orderId + "/factura", { method: "DELETE", credentials: "include", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ motivo, folioSustitucion: folio }) });
      const data = await res.json().catch(() => ({}));
      if (!data.success) { if (errEl) { errEl.textContent = data.error || "Error al cancelar"; errEl.style.display = ""; } return; }
      await loadDrawerFactura(orderId);
    } catch (err) { if (errEl) { errEl.textContent = "Error de red: " + err.message; errEl.style.display = ""; } }
    finally { if (btn) { btn.disabled = false; btn.textContent = "Confirmar Cancelación"; } }
  };

  function closeDrawer(){
    const drawer = $("drawer"); const panel = $("drawerPanel");
    drawer.classList.remove("is-open"); panel.classList.remove("is-open");
    setTimeout(()=>{ drawer.hidden = true; }, 280);
  }
  $("drawerClose")?.addEventListener("click", closeDrawer);
  $("drawer")?.addEventListener("click", e => { if(e.target === $("drawer")) closeDrawer(); });

  /* ── filter + render ── */
  function applyFilters(){
    const q    = norm($("searchInput")?.value || "");
    const stat = norm($("statusFilter")?.value || "");
    filtered = orders.filter(o => {
      const items = Array.isArray(o.items) ? o.items : [];
      const itemsText = items.map(it => `${it.nombre||""} ${it.variante||""}`).join(" ");
      const haystack = norm([o.numeroPedido, o.usuario?.nombreCompleto, o.usuario?.correo, o.usuario?.telefono, o.direccion?.completa, o.estadoPedido, o.pago?.estado, o.pago?.marcaTarjeta, itemsText].join(" "));
      return (!q || haystack.includes(q)) && (!stat || norm(o.estadoPedido||"").includes(stat) || norm(o.pago?.estado||"").includes(stat));
    });
  }

  function renderStats(){
    const el = $("statsBar");
    if(!el) return;
    const total   = orders.length;
    const pagados = orders.filter(o => ["pagado","aprobado","completado"].includes(norm(o.pago?.estado||""))).length;
    const monto   = orders.reduce((s,o) => s + Number(o.pago?.monto??o.totalPedido??0), 0);
    el.innerHTML = `
      <span class="dx-stat">${total} pedidos</span>
      <span class="dx-stat dx-stat--green">${pagados} pagados</span>
      <span class="dx-stat dx-stat--cyan">${new Intl.NumberFormat("es-MX",{style:"currency",currency:"MXN",notation:"compact",maximumFractionDigits:1}).format(monto)}</span>
    `;
  }

  function renderGrid(){
    const grid = $("ordersGrid");
    if(!grid) return;
    applyFilters();
    const pp    = perPage();
    const total = filtered.length;
    const pages = Math.max(1, Math.ceil(total / pp));
    if(page > pages) page = pages;
    const slice = filtered.slice((page-1)*pp, page*pp);

    if(!slice.length){
      grid.innerHTML = `<div class="dx-empty"><svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg><p>Sin resultados</p></div>`;
    } else {
      grid.innerHTML = slice.map(cardHtml).join("");
      grid.querySelectorAll(".dx-card-detail-btn").forEach(btn => {
        btn.addEventListener("click", () => openDrawer(btn.dataset.id));
      });
    }

    const info = $("pageInfo"); const ctrl = $("pageControls");
    if(info) info.textContent = total ? `Mostrando ${(page-1)*pp+1}–${Math.min(page*pp,total)} de ${total}` : "";
    if(ctrl){
      ctrl.innerHTML = "";
      const mk = (label, p, active, disabled) => {
        const b = document.createElement("button");
        b.className = "dx-pg-btn" + (active?" active":"") + (disabled?" disabled":"");
        b.innerHTML = label; b.disabled = disabled;
        if(!disabled && !active) b.addEventListener("click",()=>{ page=p; renderGrid(); });
        return b;
      };
      ctrl.appendChild(mk("‹", page-1, false, page===1));
      const pageSet = new Set([1, pages]);
      for(let i=Math.max(2,page-2); i<=Math.min(pages-1,page+2); i++) pageSet.add(i);
      let prev = 0;
      [...pageSet].sort((a,b)=>a-b).forEach(p2 => {
        if(prev && p2-prev>1){ const d=document.createElement("span"); d.className="dx-pg-ellipsis"; d.textContent="…"; ctrl.appendChild(d); }
        ctrl.appendChild(mk(p2, p2, p2===page, false)); prev=p2;
      });
      ctrl.appendChild(mk("›", page+1, false, page===pages));
    }
    renderStats();
  }

  /* ── fetch ── */
  async function fetchOrders(){
    try{
      const r = await fetch("/api/admin/pedidos", { credentials:"include" });
      const d = await r.json().catch(()=>({}));
      if(!r.ok || !d?.success) throw new Error(d?.error || "Error cargando pedidos");
      orders = Array.isArray(d.pedidos) ? d.pedidos : [];
      renderGrid();
    } catch(err){
      const g = $("ordersGrid");
      if(g) g.innerHTML = `<div class="dx-empty dx-empty--error"><p>Error: ${err.message}</p></div>`;
    }
  }

  /* ── exports ── */
  function toRow(o){
    const items = Array.isArray(o.items) ? o.items : [];
    const itemsStr = items.map(it=>`${it.nombre}${it.variante?" ("+it.variante+")":""} x${it.cantidad}`).join(" | ");
    return [`#${o.numeroPedido||"—"}`, fDate(o.fechaPedido), o.usuario?.nombreCompleto||"—", o.usuario?.correo||"—", o.usuario?.telefono||"—", money(o.pago?.monto??o.totalPedido), o.pago?.metodo||"—", fFin(o.pago?.tipoFinanciamiento||""), `${(o.pago?.marcaTarjeta||"").toUpperCase()} ····${o.pago?.ultimos4||""}`, o.direccion?.completa||"—", o.estadoPedido||"—", o.pago?.estado||"—", itemsStr];
  }
  const headers = ["Pedido","Fecha","Cliente","Correo","Teléfono","Total","Método","Tipo","Tarjeta","Dirección","Estado pedido","Estado pago","Productos"];
  function download(content, name, mime){ const blob = new Blob([content],{type:mime}); const a = document.createElement("a"); a.href=URL.createObjectURL(blob); a.download=name; document.body.appendChild(a); a.click(); a.remove(); }
  $("btnCsv")?.addEventListener("click",()=>{ const h=headers.map(v=>`"${v}"`).join(","); const b=filtered.map(o=>toRow(o).map(v=>`"${String(v).replaceAll('"','""')}"`).join(",")).join("\n"); download(`${h}\n${b}`,"pedidos.csv","text/csv;charset=utf-8;"); });
  $("btnExcel")?.addEventListener("click",()=>{ const rows=filtered.map(o=>`<tr>${toRow(o).map(v=>`<td>${v}</td>`).join("")}</tr>`).join(""); download(`<table><thead><tr>${headers.map(h=>`<th>${h}</th>`).join("")}</tr></thead><tbody>${rows}</tbody></table>`,"pedidos.xls","application/vnd.ms-excel"); });
  $("btnPdf")?.addEventListener("click",()=>{ const rows=filtered.map(o=>`<tr>${toRow(o).map(v=>`<td>${v}</td>`).join("")}</tr>`).join(""); const w=window.open("","_blank","width=1400,height=780"); if(!w)return; w.document.write(`<html><head><title>Pedidos</title><style>body{font-family:Arial;padding:16px}table{width:100%;border-collapse:collapse;font-size:10px}th,td{border:1px solid #ccc;padding:5px;text-align:left;vertical-align:top}th{background:#f0f0f0}</style></head><body><h1>Pedidos</h1><table><thead><tr>${headers.map(h=>`<th>${h}</th>`).join("")}</tr></thead><tbody>${rows}</tbody></table></body></html>`); w.document.close(); w.focus(); w.print(); });

  /* ── events ── */
  $("searchInput")?.addEventListener("input", ()=>{ page=1; renderGrid(); });
  $("statusFilter")?.addEventListener("change", ()=>{ page=1; renderGrid(); });
  $("rowsSelect")?.addEventListener("change", ()=>{ page=1; renderGrid(); });

  fetchOrders();
})();
</script>

<script>
  (function(){
    try{const t=localStorage.getItem("theme");if(t==="dark")document.documentElement.classList.add("dark");else document.documentElement.classList.remove("dark");}catch{}
    window.addEventListener("storage",e=>{if(e.key==="theme")document.documentElement.classList.toggle("dark",e.newValue==="dark");});
  })();
</script>

