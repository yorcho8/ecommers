---
import BaseLayout from "../../../layouts/BaseLayout.astro";
export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}

const currentLang = "es";
const cspNonce = Astro.locals?.cspNonce || "";

const role = String(Astro.locals?.user?.rol || "").trim().toLowerCase().replace(/[\s_-]/g, "")
  .replace(/^superadmin$|^superuser$|^superusuario$/, "superusuario");

if (!role) return Astro.redirect(`/${currentLang}/login`);
if (role !== "admin" && role !== "superusuario") return Astro.redirect(`/${currentLang}`);
---

<BaseLayout title="GestiÃ³n de pedidos" currentLang={currentLang}>
<main class="op-page">
  <div class="op-shell">

    <!-- Header -->
    <header class="op-header">
      <div class="op-header-left">
        <span class="op-kicker">Panel Admin</span>
        <h1 class="op-title">Pedidos</h1>
        <p class="op-sub">Historial completo de compras, clientes y productos.</p>
      </div>
      <div class="op-header-right">
        <div id="statsBar" class="op-stats"></div>
        <a class="op-back" href={`/${currentLang}`}>â† Volver al sitio</a>
      </div>
    </header>

    <!-- Toolbar -->
    <div class="op-toolbar">
      <div class="op-toolbar-left">
        <input id="searchInput" type="search" class="op-search" placeholder="ðŸ”  Buscar pedido, cliente, correo, producto..." autocomplete="off" />
      </div>
      <div class="op-toolbar-right">
        <select id="statusFilter" class="op-select">
          <option value="">Todos los estados</option>
          <option value="pagado">Pagado</option>
          <option value="pendiente">Pendiente</option>
          <option value="cancelado">Cancelado</option>
        </select>
        <select id="rowsSelect" class="op-select">
          <option value="10">10 / pÃ¡g</option>
          <option value="25">25 / pÃ¡g</option>
          <option value="50">50 / pÃ¡g</option>
        </select>
        <button id="btnCsv"   class="op-btn op-btn--blue">â†“ CSV</button>
        <button id="btnExcel" class="op-btn op-btn--green">â†“ Excel</button>
        <button id="btnPdf"   class="op-btn op-btn--red">â†“ PDF</button>
      </div>
    </div>

    <!-- Cards grid -->
    <div id="ordersGrid" class="op-grid">
      <div class="op-loading">
        <div class="op-spinner"></div>
        <p>Cargando pedidosâ€¦</p>
      </div>
    </div>

    <!-- Pagination -->
    <div class="op-pagination">
      <span id="pageInfo" class="op-page-info"></span>
      <div id="pageControls" class="op-page-controls"></div>
    </div>

  </div>
</main>

<!-- Detail drawer -->
<div id="drawer" class="op-drawer" hidden>
  <div id="drawerPanel" class="op-drawer-panel">
    <button id="drawerClose" class="op-drawer-close" type="button">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div id="drawerContent" class="op-drawer-content"></div>
  </div>
</div>

<script nonce={cspNonce} is:inline>
(function(){

  /* â”€â”€ state â”€â”€ */
  let orders = [], filtered = [], page = 1;
  const perPage = () => Number(document.getElementById("rowsSelect")?.value || 10);

  /* â”€â”€ helpers â”€â”€ */
  const $ = id => document.getElementById(id);
  const money = v => `$${Number(v||0).toLocaleString("es-MX",{minimumFractionDigits:2,maximumFractionDigits:2})} MXN`;
  const norm = v => String(v||"").toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"");
  function fDate(v){
    const d=new Date(v);
    if(isNaN(d.getTime()))return"â€”";
    return d.toLocaleDateString("es-MX",{year:"numeric",month:"short",day:"numeric",hour:"2-digit",minute:"2-digit"});
  }
  function fFin(t){
    if(t==="debito")return"DÃ©bito";
    if(t==="credito")return"CrÃ©dito";
    return"â€”";
  }

  /* â”€â”€ badge â”€â”€ */
  function badge(v, map){
    const s = norm(v);
    const cfg = map[s] || {cls:"gray", label: v||"â€”"};
    return `<span class="op-badge op-badge--${cfg.cls}">${cfg.label||v||"â€”"}</span>`;
  }
  const estadoPagoMap = {
    pagado:{cls:"green",label:"Pagado"}, aprobado:{cls:"green",label:"Aprobado"},
    completado:{cls:"green",label:"Completado"}, pendiente:{cls:"yellow",label:"Pendiente"},
    fallido:{cls:"red",label:"Fallido"}, rechazado:{cls:"red",label:"Rechazado"},
  };
  const estadoPedidoMap = {
    pagado:{cls:"green",label:"Pagado"}, entregado:{cls:"teal",label:"Entregado"},
    enviado:{cls:"blue",label:"Enviado"}, procesando:{cls:"yellow",label:"Procesando"},
    "en proceso":{cls:"yellow",label:"En proceso"}, cancelado:{cls:"red",label:"Cancelado"},
    "error_batch":{cls:"red",label:"Error"},
  };

  /* â”€â”€ card HTML â”€â”€ */
  function cardHtml(o){
    const items = Array.isArray(o.items) ? o.items : [];
    const firstItems = items.slice(0,2);
    const extra = items.length - 2;
    const itemsHtml = firstItems.map(it=>`
      <div class="op-card-item">
        <span class="op-card-item-name">${it.nombre||"Producto"}</span>
        ${it.variante ? `<span class="op-card-item-var">${it.variante}</span>` : ""}
        <span class="op-card-item-qty">Ã—${it.cantidad||1}</span>
      </div>
    `).join("");

    return `
      <article class="op-card" data-id="${o.id||o.numeroPedido}">
        <div class="op-card-head">
          <div class="op-card-head-left">
            <span class="op-card-num">#${o.numeroPedido||"â€”"}</span>
            <span class="op-card-date">${fDate(o.fechaPedido)}</span>
          </div>
          <div class="op-card-head-right">
            ${badge(o.estadoPedido, estadoPedidoMap)}
            ${badge(o.pago?.estado, estadoPagoMap)}
          </div>
        </div>

        <div class="op-card-body">
          <!-- Cliente -->
          <div class="op-card-section">
            <div class="op-card-avatar">${(o.usuario?.nombreCompleto||"?")[0].toUpperCase()}</div>
            <div class="op-card-user">
              <p class="op-card-user-name">${o.usuario?.nombreCompleto||"â€”"}</p>
              <p class="op-card-user-email">${o.usuario?.correo||"â€”"}</p>
            </div>
            <div class="op-card-total">${money(o.pago?.monto??o.totalPedido)}</div>
          </div>

          <!-- Productos -->
          <div class="op-card-items">
            ${itemsHtml}
            ${extra > 0 ? `<p class="op-card-more">+${extra} producto${extra>1?"s":""} mÃ¡s</p>` : ""}
          </div>

          <!-- DirecciÃ³n corta -->
          <div class="op-card-addr">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            ${o.direccion?.completa ? o.direccion.completa.slice(0,60)+(o.direccion.completa.length>60?"â€¦":"") : "Sin direcciÃ³n"}
          </div>
        </div>

        <div class="op-card-foot">
          <div class="op-card-pay">
            ${o.pago?.marcaTarjeta ? `<span class="op-card-brand">${o.pago.marcaTarjeta.toUpperCase()}</span>` : ""}
            ${o.pago?.ultimos4 ? `<span class="op-card-last4">Â·Â·Â·Â·${o.pago.ultimos4}</span>` : ""}
            ${o.pago?.tipoFinanciamiento && o.pago.tipoFinanciamiento !== "no_definido" ? `<span class="op-card-fin">${fFin(o.pago.tipoFinanciamiento)}</span>` : ""}
          </div>
          <button class="op-card-detail-btn" data-id="${o.id||o.numeroPedido}">
            Ver detalle
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      </article>
    `;
  }

  /* ── drawer ── */
  async function openDrawer(orderId){
    const o = orders.find(x => String(x.id||x.numeroPedido) === String(orderId));
    if(!o) return;
    const items = Array.isArray(o.items) ? o.items : [];
    const content = $("drawerContent");
    if(!content) return;

    content.innerHTML = `
      <div class="op-d-header">
        <div>
          <span class="op-d-num">Pedido #${o.numeroPedido||"â€”"}</span>
          <p class="op-d-date">${fDate(o.fechaPedido)}</p>
        </div>
        <div class="op-d-badges">
          ${badge(o.estadoPedido, estadoPedidoMap)}
          ${badge(o.pago?.estado, estadoPagoMap)}
        </div>
      </div>

      <!-- Cliente -->
      <div class="op-d-block">
        <p class="op-d-block-title">Cliente</p>
        <div class="op-d-row"><span>Nombre</span><strong>${o.usuario?.nombreCompleto||"â€”"}</strong></div>
        <div class="op-d-row"><span>Correo</span><strong>${o.usuario?.correo||"â€”"}</strong></div>
        ${o.usuario?.telefono ? `<div class="op-d-row"><span>TelÃ©fono</span><strong>${o.usuario.telefono}</strong></div>` : ""}
      </div>

      <!-- DirecciÃ³n -->
      <div class="op-d-block">
        <p class="op-d-block-title">DirecciÃ³n de envÃ­o</p>
        <div class="op-d-row"><span>Calle</span><strong>${o.direccion?.calle||"â€”"}</strong></div>
        <div class="op-d-row"><span>Ciudad</span><strong>${o.direccion?.ciudad||"â€”"}</strong></div>
        <div class="op-d-row"><span>Estado</span><strong>${o.direccion?.estado||"â€”"}</strong></div>
        <div class="op-d-row"><span>CP</span><strong>${o.direccion?.cp||"â€”"}</strong></div>
        <div class="op-d-row"><span>PaÃ­s</span><strong>${o.direccion?.pais||"MÃ©xico"}</strong></div>
      </div>

      <!-- Productos -->
      <div class="op-d-block">
        <p class="op-d-block-title">Productos (${items.length})</p>
        ${items.map(it=>`
          <div class="op-d-product">
            <div class="op-d-product-info">
              <p class="op-d-product-name">${it.nombre||"Producto"}</p>
              ${it.variante ? `<p class="op-d-product-var">${it.variante}</p>` : ""}
            </div>
            <div class="op-d-product-right">
              <span class="op-d-product-qty">Ã—${it.cantidad||1}</span>
              <span class="op-d-product-price">${money(it.precioUnitario||0)}</span>
            </div>
          </div>
        `).join("")}
      </div>

      <!-- Pago -->
      <div class="op-d-block">
        <p class="op-d-block-title">Pago</p>
        <div class="op-d-row"><span>MÃ©todo</span><strong>${o.pago?.metodo||"â€”"}</strong></div>
        ${o.pago?.marcaTarjeta ? `<div class="op-d-row"><span>Tarjeta</span><strong>${o.pago.marcaTarjeta.toUpperCase()} Â·Â·Â·Â·${o.pago.ultimos4||"â€”"}</strong></div>` : ""}
        ${o.pago?.tipoFinanciamiento && o.pago.tipoFinanciamiento !== "no_definido" ? `<div class="op-d-row"><span>Tipo</span><strong>${fFin(o.pago.tipoFinanciamiento)}</strong></div>` : ""}
        ${o.pago?.transaccion ? `<div class="op-d-row"><span>TransacciÃ³n</span><strong class="op-d-mono">${o.pago.transaccion}</strong></div>` : ""}
        <div class="op-d-divider"></div>
        <div class="op-d-row"><span>Subtotal</span><strong>${money(o.subtotalProductos||0)}</strong></div>
        <div class="op-d-row"><span>EnvÃ­o</span><strong>${money(o.costoEnvio||0)}</strong></div>
        <div class="op-d-row op-d-total"><span>Total</span><strong>${money(o.pago?.monto??o.totalPedido)}</strong></div>
      </div>

      ${o.notas ? `<div class="op-d-block"><p class="op-d-block-title">Notas del cliente</p><p class="op-d-notes">${o.notas}</p></div>` : ""}

      <!-- Factura electrónica -->
      <div class="op-d-block" id="op-d-factura-block">
        <p class="op-d-block-title">Factura Electrónica (CFDI)</p>
        <div id="op-d-factura-body" style="display:flex;align-items:center;gap:.5rem;padding:.5rem 0">
          <span style="font-size:.78rem;color:#888">Consultando…</span>
        </div>
      </div>
    `;

    const drawer = $("drawer");
    const panel  = $("drawerPanel");
    drawer.hidden = false;
    requestAnimationFrame(()=>{ drawer.classList.add("is-open"); panel.classList.add("is-open"); });

    // Load invoice status for this order
    currentDrawerOrderId = o.id || o.numeroPedido;
    loadDrawerFactura(currentDrawerOrderId);
  }

  /* ── drawer factura ── */
  async function loadDrawerFactura(orderId) {
    const body = document.getElementById("op-d-factura-body");
    if (!body) return;

    try {
      const res  = await fetch("/api/me/pedidos/" + orderId + "/factura", { credentials: "include" });
      const data = await res.json().catch(() => ({}));

      if (!data.success) {
        body.innerHTML = '<span style="font-size:.78rem;color:#888">No disponible</span>';
        return;
      }

      if (data.factura && data.factura.estado === "vigente") {
        // Show cancel + download
        body.innerHTML =
          '<span style="display:inline-flex;align-items:center;gap:5px;font-size:.75rem;font-weight:600;color:#16a34a;background:rgba(22,163,74,.1);border:1px solid rgba(22,163,74,.3);padding:3px 10px;border-radius:20px">' +
            '✓ Factura vigente' +
          '</span>' +
          '<a href="/api/me/pedidos/' + orderId + '/factura?download=pdf" target="_blank" rel="noopener" class="op-d-fac-btn op-d-fac-btn--pdf">⬇ PDF</a>' +
          '<a href="/api/me/pedidos/' + orderId + '/factura?download=xml" target="_blank" rel="noopener" class="op-d-fac-btn op-d-fac-btn--xml">⬇ XML</a>' +
          '<button type="button" class="op-d-fac-btn op-d-fac-btn--cancel" onclick="openDrawerCancelFactura(' + orderId + ')">✕ Cancelar Factura</button>';
        return;
      }

      if (data.factura && data.factura.estado === "cancelada") {
        body.innerHTML = '<span style="font-size:.78rem;color:#e87;background:rgba(200,50,80,.1);border:1px solid rgba(200,50,80,.3);padding:3px 10px;border-radius:20px">Factura cancelada</span>';
        return;
      }

      if (data.canRequest) {
        body.innerHTML = '<button type="button" class="op-d-fac-btn op-d-fac-btn--emit" onclick="openDrawerEmitFactura(' + orderId + ')">📄 Emitir Factura</button>';
        return;
      }

      body.innerHTML = '<span style="font-size:.75rem;color:#888">' + (data.reason || "Factura no disponible aún") + '</span>';
    } catch {
      body.innerHTML = '<span style="font-size:.78rem;color:#888">Error al consultar</span>';
    }
  }

  /* ── drawer emit factura ── */
  window.openDrawerEmitFactura = function(orderId) {
    const body = document.getElementById("op-d-factura-body");
    if (!body) return;

    body.innerHTML =
      '<div class="op-d-fac-form" id="op-d-fac-form-wrap">' +
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem;margin-bottom:.5rem">' +
          '<div>' +
            '<label style="font-size:.72rem;font-weight:700;color:#888;display:block;margin-bottom:.25rem">RFC *</label>' +
            '<input id="op-d-fac-rfc" type="text" maxlength="13" placeholder="RFC12 ó RFC123" class="op-d-fac-input" />' +
          '</div>' +
          '<div>' +
            '<label style="font-size:.72rem;font-weight:700;color:#888;display:block;margin-bottom:.25rem">CP Fiscal *</label>' +
            '<input id="op-d-fac-cp" type="text" maxlength="5" placeholder="64000" class="op-d-fac-input" />' +
          '</div>' +
        '</div>' +
        '<div style="margin-bottom:.5rem">' +
          '<label style="font-size:.72rem;font-weight:700;color:#888;display:block;margin-bottom:.25rem">Razón social / Nombre *</label>' +
          '<input id="op-d-fac-nombre" type="text" maxlength="254" placeholder="Nombre en SAT" class="op-d-fac-input" style="width:100%;box-sizing:border-box" />' +
        '</div>' +
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem;margin-bottom:.5rem">' +
          '<div>' +
            '<label style="font-size:.72rem;font-weight:700;color:#888;display:block;margin-bottom:.25rem">Régimen Fiscal</label>' +
            '<select id="op-d-fac-regimen" class="op-d-fac-input">' +
              '<option value="601">601 - Personas Morales</option>' +
              '<option value="612">612 - Personas Físicas</option>' +
              '<option value="616">616 - Sin Obligaciones</option>' +
              '<option value="626">626 - RESICO</option>' +
            '</select>' +
          '</div>' +
          '<div>' +
            '<label style="font-size:.72rem;font-weight:700;color:#888;display:block;margin-bottom:.25rem">Uso CFDI</label>' +
            '<select id="op-d-fac-uso" class="op-d-fac-input">' +
              '<option value="G03" selected>G03 - Gastos Gral</option>' +
              '<option value="G01">G01 - Adquisición</option>' +
              '<option value="S01">S01 - Sin efectos</option>' +
            '</select>' +
          '</div>' +
        '</div>' +
        '<p id="op-d-fac-error" style="font-size:.75rem;color:#e87;margin:.25rem 0;display:none"></p>' +
        '<div style="display:flex;gap:.4rem;flex-wrap:wrap">' +
          '<button type="button" class="op-d-fac-btn op-d-fac-btn--ghost" onclick="cancelDrawerFacForm()">Volver</button>' +
          '<button type="button" id="op-d-fac-submit" class="op-d-fac-btn op-d-fac-btn--emit" onclick="submitDrawerFactura(' + orderId + ')">Generar Factura</button>' +
        '</div>' +
      '</div>';
  };

  window.cancelDrawerFacForm = function() { loadDrawerFactura(currentDrawerOrderId); };
  let currentDrawerOrderId = null;

  /* ── drawer cancel factura ── */
  window.openDrawerCancelFactura = function(orderId) {
    currentDrawerOrderId = orderId;
    const body = document.getElementById("op-d-factura-body");
    if (!body) return;

    body.innerHTML =
      '<div class="op-d-fac-form">' +
        '<p style="font-size:.75rem;color:#e87;margin:0 0 .5rem">⚠️ Cancelar la factura SAT. Acción irreversible.</p>' +
        '<div style="margin-bottom:.5rem">' +
          '<label style="font-size:.72rem;font-weight:700;color:#888;display:block;margin-bottom:.25rem">Motivo SAT</label>' +
          '<select id="op-d-fac-cancel-motivo" class="op-d-fac-input">' +
            '<option value="02" selected>02 — Sin relación</option>' +
            '<option value="01">01 — Con relación</option>' +
            '<option value="03">03 — No se realizó</option>' +
            '<option value="04">04 — Operación global</option>' +
          '</select>' +
        '</div>' +
        '<div id="op-d-fac-folio-row" style="display:none;margin-bottom:.5rem">' +
          '<label style="font-size:.72rem;font-weight:700;color:#888;display:block;margin-bottom:.25rem">UUID sustituto</label>' +
          '<input id="op-d-fac-cancel-folio" type="text" maxlength="36" placeholder="xxxxxxxx-xxxx-…" class="op-d-fac-input" />' +
        '</div>' +
        '<p id="op-d-fac-cancel-error" style="font-size:.75rem;color:#e87;margin:.25rem 0;display:none"></p>' +
        '<div style="display:flex;gap:.4rem;flex-wrap:wrap">' +
          '<button type="button" class="op-d-fac-btn op-d-fac-btn--ghost" onclick="loadDrawerFactura(' + orderId + ')">Volver</button>' +
          '<button type="button" id="op-d-fac-cancel-submit" class="op-d-fac-btn op-d-fac-btn--cancel" onclick="submitDrawerCancelFactura(' + orderId + ')">Confirmar Cancelación</button>' +
        '</div>' +
      '</div>';

    document.getElementById("op-d-fac-cancel-motivo")?.addEventListener("change", function() {
      const row = document.getElementById("op-d-fac-folio-row");
      if (row) row.style.display = this.value === "01" ? "" : "none";
    });
  };

  /* ── submit emit ── */
  window.submitDrawerFactura = async function(orderId) {
    const rfc    = document.getElementById("op-d-fac-rfc")?.value.trim().toUpperCase() || "";
    const nombre = document.getElementById("op-d-fac-nombre")?.value.trim() || "";
    const cp     = document.getElementById("op-d-fac-cp")?.value.trim() || "";
    const regimen = document.getElementById("op-d-fac-regimen")?.value || "601";
    const uso    = document.getElementById("op-d-fac-uso")?.value || "G03";
    const errEl  = document.getElementById("op-d-fac-error");

    if (rfc.length < 12) { if (errEl) { errEl.textContent="RFC inválido"; errEl.style.display=""; } return; }
    if (nombre.length < 3) { if (errEl) { errEl.textContent="Nombre demasiado corto"; errEl.style.display=""; } return; }
    if (cp.length < 4) { if (errEl) { errEl.textContent="CP inválido"; errEl.style.display=""; } return; }
    if (errEl) errEl.style.display = "none";

    const btn = document.getElementById("op-d-fac-submit");
    if (btn) { btn.disabled = true; btn.textContent = "Generando…"; }

    try {
      const res  = await fetch("/api/me/pedidos/" + orderId + "/factura", {
        method: "POST", credentials: "include",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ rfc, nombre, usoCfdi: uso, regimenFiscal: regimen, cpFiscal: cp }),
      });
      const data = await res.json().catch(() => ({}));

      if (!data.success) {
        if (errEl) { errEl.textContent = data.error || "Error al generar"; errEl.style.display = ""; }
        return;
      }

      // Auto-download PDF
      const a = document.createElement("a");
      a.href = "/api/me/pedidos/" + orderId + "/factura?download=pdf";
      a.rel = "noopener"; a.style.display = "none";
      document.body.appendChild(a); a.click(); a.remove();

      await loadDrawerFactura(orderId);
    } catch (err) {
      if (errEl) { errEl.textContent = "Error de red: " + err.message; errEl.style.display = ""; }
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = "Generar Factura"; }
    }
  };

  /* ── submit cancel ── */
  window.submitDrawerCancelFactura = async function(orderId) {
    const motivo = document.getElementById("op-d-fac-cancel-motivo")?.value || "02";
    const folio  = document.getElementById("op-d-fac-cancel-folio")?.value.trim() || null;
    const errEl  = document.getElementById("op-d-fac-cancel-error");

    if (motivo === "01" && !folio) {
      if (errEl) { errEl.textContent = "El motivo 01 requiere el UUID sustituto"; errEl.style.display = ""; }
      return;
    }
    if (errEl) errEl.style.display = "none";

    const btn = document.getElementById("op-d-fac-cancel-submit");
    if (btn) { btn.disabled = true; btn.textContent = "Cancelando…"; }

    try {
      const res  = await fetch("/api/me/pedidos/" + orderId + "/factura", {
        method: "DELETE", credentials: "include",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ motivo, folioSustitucion: folio }),
      });
      const data = await res.json().catch(() => ({}));

      if (!data.success) {
        if (errEl) { errEl.textContent = data.error || "Error al cancelar"; errEl.style.display = ""; }
        return;
      }

      await loadDrawerFactura(orderId);
    } catch (err) {
      if (errEl) { errEl.textContent = "Error de red: " + err.message; errEl.style.display = ""; }
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = "Confirmar Cancelación"; }
    }
  };

  function closeDrawer(){
    const drawer = $("drawer");
    const panel  = $("drawerPanel");
    drawer.classList.remove("is-open");
    panel.classList.remove("is-open");
    setTimeout(()=>{ drawer.hidden = true; }, 280);
  }

  $("drawerClose")?.addEventListener("click", closeDrawer);
  $("drawer")?.addEventListener("click", e => { if(e.target === $("drawer")) closeDrawer(); });

  /* â”€â”€ filter + render â”€â”€ */
  function applyFilters(){
    const q    = norm($("searchInput")?.value || "");
    const stat = norm($("statusFilter")?.value || "");
    filtered = orders.filter(o => {
      const items = Array.isArray(o.items) ? o.items : [];
      const itemsText = items.map(it => `${it.nombre||""} ${it.variante||""}`).join(" ");
      const haystack = norm([
        o.numeroPedido, o.usuario?.nombreCompleto, o.usuario?.correo,
        o.usuario?.telefono, o.direccion?.completa, o.estadoPedido,
        o.pago?.estado, o.pago?.marcaTarjeta, itemsText
      ].join(" "));
      const matchQ    = !q    || haystack.includes(q);
      const matchStat = !stat || norm(o.estadoPedido||"").includes(stat) || norm(o.pago?.estado||"").includes(stat);
      return matchQ && matchStat;
    });
  }

  function renderStats(){
    const el = $("statsBar");
    if(!el) return;
    const total   = orders.length;
    const pagados = orders.filter(o => ["pagado","aprobado","completado"].includes(norm(o.pago?.estado||""))).length;
    const monto   = orders.reduce((s,o) => s + Number(o.pago?.monto??o.totalPedido??0), 0);
    el.innerHTML = `
      <span class="op-stat">${total} pedidos</span>
      <span class="op-stat op-stat--green">${pagados} pagados</span>
      <span class="op-stat op-stat--blue">${money(monto)}</span>
    `;
  }

  function renderGrid(){
    const grid = $("ordersGrid");
    if(!grid) return;
    applyFilters();

    const pp    = perPage();
    const total = filtered.length;
    const pages = Math.max(1, Math.ceil(total / pp));
    if(page > pages) page = pages;

    const slice = filtered.slice((page-1)*pp, page*pp);

    if(!slice.length){
      grid.innerHTML = `<div class="op-empty"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg><p>Sin resultados</p></div>`;
    } else {
      grid.innerHTML = slice.map(cardHtml).join("");
      grid.querySelectorAll(".op-card-detail-btn").forEach(btn => {
        btn.addEventListener("click", () => openDrawer(btn.dataset.id));
      });
    }

    // pagination
    const info = $("pageInfo");
    const ctrl = $("pageControls");
    if(info) info.textContent = total ? `Mostrando ${(page-1)*pp+1}â€“${Math.min(page*pp,total)} de ${total}` : "";
    if(ctrl){
      ctrl.innerHTML = "";
      const mk = (label, p, active, disabled) => {
        const b = document.createElement("button");
        b.className = "op-pg-btn" + (active?" active":"") + (disabled?" disabled":"");
        b.innerHTML = label; b.disabled = disabled;
        if(!disabled && !active) b.addEventListener("click",()=>{ page=p; renderGrid(); });
        return b;
      };
      ctrl.appendChild(mk("â€¹", page-1, false, page===1));
      const pageSet = new Set([1, pages]);
      for(let i=Math.max(2,page-2); i<=Math.min(pages-1,page+2); i++) pageSet.add(i);
      let prev = 0;
      [...pageSet].sort((a,b)=>a-b).forEach(p2 => {
        if(prev && p2-prev>1){ const d=document.createElement("span"); d.className="op-pg-ellipsis"; d.textContent="â€¦"; ctrl.appendChild(d); }
        ctrl.appendChild(mk(p2, p2, p2===page, false)); prev=p2;
      });
      ctrl.appendChild(mk("â€º", page+1, false, page===pages));
    }
    renderStats();
  }

  /* â”€â”€ fetch â”€â”€ */
  async function fetchOrders(){
    try{
      const r = await fetch("/api/admin/pedidos", { credentials:"include" });
      const d = await r.json().catch(()=>({}));
      if(!r.ok || !d?.success) throw new Error(d?.error || "Error cargando pedidos");
      orders = Array.isArray(d.pedidos) ? d.pedidos : [];
      renderGrid();
    } catch(err){
      const g = $("ordersGrid");
      if(g) g.innerHTML = `<div class="op-empty op-empty--error"><p>Error: ${err.message}</p></div>`;
    }
  }

  /* â”€â”€ exports â”€â”€ */
  function toRow(o){
    const items = Array.isArray(o.items) ? o.items : [];
    const itemsStr = items.map(it=>`${it.nombre}${it.variante?" ("+it.variante+")":""} x${it.cantidad}`).join(" | ");
    return [
      `#${o.numeroPedido||"â€”"}`, fDate(o.fechaPedido),
      o.usuario?.nombreCompleto||"â€”", o.usuario?.correo||"â€”", o.usuario?.telefono||"â€”",
      money(o.pago?.monto??o.totalPedido), o.pago?.metodo||"â€”",
      fFin(o.pago?.tipoFinanciamiento||""), `${(o.pago?.marcaTarjeta||"").toUpperCase()} Â·Â·Â·Â·${o.pago?.ultimos4||""}`,
      o.direccion?.completa||"â€”", o.estadoPedido||"â€”", o.pago?.estado||"â€”",
      itemsStr
    ];
  }
  const headers = ["Pedido","Fecha","Cliente","Correo","TelÃ©fono","Total","MÃ©todo","Tipo","Tarjeta","DirecciÃ³n","Estado pedido","Estado pago","Productos"];
  function download(content, name, mime){
    const blob = new Blob([content],{type:mime});
    const a = document.createElement("a"); a.href=URL.createObjectURL(blob); a.download=name;
    document.body.appendChild(a); a.click(); a.remove();
  }
  $("btnCsv")?.addEventListener("click",()=>{
    const h=headers.map(v=>`"${v}"`).join(",");
    const b=filtered.map(o=>toRow(o).map(v=>`"${String(v).replaceAll('"','""')}"`).join(",")).join("\n");
    download(`${h}\n${b}`,"pedidos.csv","text/csv;charset=utf-8;");
  });
  $("btnExcel")?.addEventListener("click",()=>{
    const rows=filtered.map(o=>`<tr>${toRow(o).map(v=>`<td>${v}</td>`).join("")}</tr>`).join("");
    download(`<table><thead><tr>${headers.map(h=>`<th>${h}</th>`).join("")}</tr></thead><tbody>${rows}</tbody></table>`,"pedidos.xls","application/vnd.ms-excel");
  });
  $("btnPdf")?.addEventListener("click",()=>{
    const rows=filtered.map(o=>`<tr>${toRow(o).map(v=>`<td>${v}</td>`).join("")}</tr>`).join("");
    const w=window.open("","_blank","width=1400,height=780");
    if(!w) return;
    w.document.write(`<html><head><title>Pedidos</title><style>body{font-family:Arial;padding:16px}table{width:100%;border-collapse:collapse;font-size:10px}th,td{border:1px solid #ccc;padding:5px;text-align:left;vertical-align:top}th{background:#f0f0f0}</style></head><body><h1>Pedidos</h1><table><thead><tr>${headers.map(h=>`<th>${h}</th>`).join("")}</tr></thead><tbody>${rows}</tbody></table></body></html>`);
    w.document.close(); w.focus(); w.print();
  });

  /* â”€â”€ events â”€â”€ */
  $("searchInput")?.addEventListener("input", ()=>{ page=1; renderGrid(); });
  $("statusFilter")?.addEventListener("change", ()=>{ page=1; renderGrid(); });
  $("rowsSelect")?.addEventListener("change", ()=>{ page=1; renderGrid(); });

  fetchOrders();
})();
</script>

<script>
  (function(){
    try{const t=localStorage.getItem("theme");if(t==="dark")document.documentElement.classList.add("dark");else document.documentElement.classList.remove("dark");}catch{}
    window.addEventListener("storage",e=>{if(e.key==="theme")document.documentElement.classList.toggle("dark",e.newValue==="dark");});
  })();
</script>

