</div>

<style>
.fac-root { min-height: 100vh; }
.fac { max-width: 1440px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

/* â”€â”€ Hero â”€â”€ */
.fac-hero { position: relative; overflow: hidden; border-radius: 1.25rem; background: linear-gradient(135deg, #0a1628 0%, #0d0d0d 60%); border: 1px solid rgba(14,165,233,.22); padding: 2.5rem 2rem; margin-bottom: 1.75rem; }
.fac-hero__glow { position: absolute; inset: 0; background: radial-gradient(ellipse 60% 55% at 10% 50%, rgba(14,165,233,.13) 0%, transparent 70%); pointer-events: none; }
.fac-hero__content { position: relative; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; }
.fac-hero__badge { display: inline-block; padding: .25rem .75rem; background: rgba(14,165,233,.15); border: 1px solid rgba(14,165,233,.35); border-radius: 2rem; font-size: .72rem; font-weight: 600; color: #7dd3fc; letter-spacing: .06em; text-transform: uppercase; margin-bottom: .5rem; }
.fac-hero__title { font-size: clamp(1.4rem,3vw,2rem); font-weight: 700; color: #fff; margin: 0 0 .3rem; }
.fac-hero__sub { font-size: .85rem; color: #888; margin: 0; }
.fac-hero__actions { display: flex; gap: .75rem; align-items: center; }
.fac-back { padding: .5rem 1.25rem; border-radius: .6rem; border: 1px solid rgba(255,255,255,.12); color: #ccc; font-size: .82rem; text-decoration: none; transition: background .15s; }
.fac-back:hover { background: rgba(255,255,255,.06); }

/* â”€â”€ Status â”€â”€ */
.fac-status { padding: .75rem 1.25rem; border-radius: .6rem; margin-bottom: 1rem; font-size: .85rem; }
.fac-status--ok  { background: rgba(40,170,80,.12); border: 1px solid rgba(40,170,80,.3); color: #5d9; }
.fac-status--err { background: rgba(200,50,80,.12); border: 1px solid rgba(200,50,80,.3); color: #e87; }

/* â”€â”€ Toolbar â”€â”€ */
.fac-toolbar { display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
.fac-toolbar__left, .fac-toolbar__right { display: flex; gap: .75rem; align-items: center; flex-wrap: wrap; }
.fac-search-bar { display: flex; align-items: center; gap: .5rem; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1); border-radius: .6rem; padding: .45rem .85rem; min-width: 260px; }
.fac-search-bar svg { flex-shrink: 0; color: #666; }
.fac-search-bar input { background: none; border: none; outline: none; color: #f0f0f0; font-size: .85rem; width: 100%; }
.fac-search-bar input::placeholder { color: #555; }
.fac-select { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1); border-radius: .6rem; color: #ccc; font-size: .82rem; padding: .45rem .75rem; cursor: pointer; }
.fac-select option { background: #1e1e1e; }
.fac-count { font-size: .8rem; color: #666; }

/* â”€â”€ Table â”€â”€ */
.fac-table-wrap { overflow-x: auto; border-radius: .75rem; border: 1px solid rgba(14,165,233,.12); }
.fac-table { width: 100%; border-collapse: collapse; font-size: .83rem; }
.fac-table thead th { padding: .75rem 1rem; text-align: left; font-weight: 600; color: #888; font-size: .75rem; letter-spacing: .04em; text-transform: uppercase; border-bottom: 1px solid rgba(14,165,233,.1); white-space: nowrap; background: rgba(14,165,233,.04); }
.fac-table tbody tr { border-bottom: 1px solid rgba(255,255,255,.04); transition: background .1s; }
.fac-table tbody tr:hover { background: rgba(14,165,233,.04); }
.fac-table tbody td { padding: .7rem 1rem; color: #ccc; vertical-align: middle; }
.fac-loading-cell { text-align: center; padding: 2rem; color: #555; }

/* â”€â”€ Badges â”€â”€ */
.fac-badge { display: inline-block; padding: .2rem .6rem; border-radius: 2rem; font-size: .72rem; font-weight: 600; letter-spacing: .04em; }
.fac-badge--activa  { background: rgba(40,170,80,.15); color: #5d9; border: 1px solid rgba(40,170,80,.3); }
.fac-badge--vencida { background: rgba(120,120,120,.15); color: #888; border: 1px solid rgba(120,120,120,.3); }
.fac-badge--vigente { background: rgba(14,165,233,.15); color: #7dd3fc; border: 1px solid rgba(14,165,233,.3); }
.fac-badge--cancelada { background: rgba(200,50,80,.12); color: #e87; border: 1px solid rgba(200,50,80,.3); }
.fac-badge--sin { background: rgba(255,255,255,.05); color: #666; border: 1px solid rgba(255,255,255,.08); }
.fac-badge--pos { background: rgba(255,170,60,.12); color: #fa6; border: 1px solid rgba(255,170,60,.3); }

/* â”€â”€ Actions â”€â”€ */
.fac-action-group { display: flex; gap: .4rem; align-items: center; flex-wrap: nowrap; }
.fac-act { display: inline-flex; align-items: center; gap: .3rem; padding: .3rem .65rem; border-radius: .45rem; font-size: .75rem; font-weight: 600; border: none; cursor: pointer; transition: opacity .15s; white-space: nowrap; }
.fac-act--emit   { background: rgba(14,165,233,.15); color: #7dd3fc; border: 1px solid rgba(14,165,233,.3); }
.fac-act--emit:hover   { background: rgba(14,165,233,.28); }
.fac-act--pdf    { background: rgba(80,140,240,.12); color: #8af; border: 1px solid rgba(80,140,240,.25); }
.fac-act--pdf:hover    { background: rgba(80,140,240,.22); }
.fac-act--xml    { background: rgba(255,200,60,.1); color: #fc6; border: 1px solid rgba(255,200,60,.25); }
.fac-act--xml:hover    { background: rgba(255,200,60,.2); }
.fac-act--cancel { background: rgba(200,50,80,.08); color: #e66; border: 1px solid rgba(200,50,80,.2); }
.fac-act--cancel:hover { background: rgba(200,50,80,.2); }
.fac-act:disabled { opacity: .4; cursor: not-allowed; }

/* â”€â”€ Pagination â”€â”€ */
.fac-pagination { display: flex; justify-content: space-between; align-items: center; margin-top: 1.25rem; flex-wrap: wrap; gap: .75rem; }
.fac-page-info { font-size: .8rem; color: #666; }
.fac-page-controls { display: flex; gap: .4rem; }
.fac-page-btn { padding: .4rem .7rem; border-radius: .45rem; border: 1px solid rgba(255,255,255,.1); background: rgba(255,255,255,.03); color: #ccc; font-size: .8rem; cursor: pointer; transition: background .15s; }
.fac-page-btn:hover { background: rgba(255,255,255,.08); }
.fac-page-btn.is-active { background: rgba(14,165,233,.2); border-color: rgba(14,165,233,.4); color: #7dd3fc; }
.fac-page-btn:disabled { opacity: .35; cursor: not-allowed; }

/* â”€â”€ Overlay â”€â”€ */
.fac-overlay { position: fixed; inset: 0; z-index: 900; display: flex; align-items: center; justify-content: center; padding: 1rem; }
.fac-overlay[hidden] { display: none; }
.fac-overlay__bg { position: absolute; inset: 0; background: rgba(0,0,0,.7); backdrop-filter: blur(4px); }
.fac-dialog { position: relative; background: #161616; border: 1px solid rgba(255,255,255,.1); border-radius: 1rem; padding: 2rem; width: 100%; max-width: 520px; max-height: 90vh; overflow-y: auto; z-index: 1; box-shadow: 0 24px 80px rgba(0,0,0,.5); }
.fac-dialog--sm { max-width: 420px; }
.fac-dialog__close { position: absolute; top: 1rem; right: 1rem; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); color: #ccc; border-radius: .4rem; padding: .35rem; cursor: pointer; line-height: 0; }
.fac-dialog__close:hover { background: rgba(255,255,255,.12); }
.fac-dialog__title { font-size: 1.05rem; font-weight: 700; color: #fff; margin: 0 0 .3rem; }
.fac-dialog__title--danger { color: #e87; }
.fac-dialog__sub { font-size: .82rem; color: #888; margin: 0 0 1.4rem; }
.fac-dialog__actions { display: flex; gap: .75rem; justify-content: flex-end; margin-top: 1.4rem; flex-wrap: wrap; }

/* â”€â”€ Form â”€â”€ */
.fac-field { margin-bottom: 1rem; }
.fac-field label { display: block; font-size: .78rem; font-weight: 600; color: #aaa; margin-bottom: .35rem; }
.fac-field input, .fac-field select {
  width: 100%; padding: .55rem .85rem; background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.12); border-radius: .55rem; color: #f0f0f0;
  font-size: .85rem; box-sizing: border-box; transition: border-color .15s;
}
.fac-field input:focus, .fac-field select:focus { outline: none; border-color: rgba(14,165,233,.5); }
.fac-field select option { background: #1e1e1e; }
.fac-field__hint { font-size: .72rem; color: #666; margin: .25rem 0 0; }
.fac-grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.fac-form-error { background: rgba(200,50,80,.12); border: 1px solid rgba(200,50,80,.3); border-radius: .55rem; padding: .65rem .9rem; font-size: .82rem; color: #e87; margin-top: .5rem; }

/* â”€â”€ Buttons â”€â”€ */
.fac-btn { display: inline-flex; align-items: center; gap: .4rem; padding: .55rem 1.2rem; border-radius: .6rem; font-size: .85rem; font-weight: 600; border: none; cursor: pointer; transition: opacity .15s, background .15s; }
.fac-btn--primary { background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%); color: #fff; }
.fac-btn--primary:hover { opacity: .88; }
.fac-btn--ghost { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12); color: #ccc; }
.fac-btn--ghost:hover { background: rgba(255,255,255,.1); }
.fac-btn--danger { background: rgba(200,50,80,.2); border: 1px solid rgba(200,50,80,.4); color: #e87; }
.fac-btn--danger:hover { background: rgba(200,50,80,.35); }
.fac-btn:disabled { opacity: .4; cursor: not-allowed; }

@media (max-width: 640px) {
  .fac-grid2 { grid-template-columns: 1fr; }
  .fac-dialog { padding: 1.25rem; }
}
</style>

<script nonce={cspNonce} is:inline>
(function () {
  const $ = id => document.getElementById(id);
  const money = v => '$' + Number(v || 0).toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' MXN';
  const dateStr = v => v ? new Date(v).toLocaleDateString('es-MX', { day: '2-digit', month: 'short', year: 'numeric' }) : 'â€”';
  const posLabel = p => ({ hero: 'Hero', top1: 'Top 1', grid: 'Grid' })[p] || (p || 'â€”');
  const esc = s => String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

  let allPagos = [], page = 1, totalPages = 1, totalCount = 0;
  const perPageSel = () => Number($('facPerPage')?.value || 20);

  /* â”€â”€ status â”€â”€ */
  function showStatus(msg, isErr) {
    const el = $('facStatus');
    el.textContent = msg;
    el.className = 'fac-status ' + (isErr ? 'fac-status--err' : 'fac-status--ok');
    el.hidden = false;
    setTimeout(() => { el.hidden = true; }, 5000);
  }

  /* â”€â”€ load â”€â”€ */
  async function loadPagos() {
    const q       = $('facSearch')?.value.trim() || '';
    const estado  = $('facEstado')?.value || '';
    const facFilt = $('facFactura')?.value || '';
    const perPage = perPageSel();
    const params  = new URLSearchParams({ page, perPage });
    if (q)      params.set('q', q);
    if (estado) params.set('estado', estado);

    const tbody = $('facTableBody');
    tbody.innerHTML = '<tr><td colspan="10" class="fac-loading-cell">Cargandoâ€¦</td></tr>';

    try {
      const res  = await fetch('/api/admin/publicidad/pagos?' + params.toString());
      const data = await res.json();
      if (!data.success) throw new Error(data.error || 'Error al cargar');

      let pagos = data.pagos || [];

      // Client-side filter by factura status
      if (facFilt === 'pendiente') {
        pagos = pagos.filter(p => !p.factura);
      } else if (facFilt === 'vigente') {
        pagos = pagos.filter(p => p.factura?.estado === 'vigente');
      } else if (facFilt === 'cancelada') {
        pagos = pagos.filter(p => p.factura?.estado === 'cancelada');
      }

      allPagos    = pagos;
      totalCount  = data.pagination?.total || 0;
      totalPages  = data.pagination?.pages || 1;

      $('facCount').textContent = totalCount + ' registros';
      renderTable();
      renderPagination();
    } catch (err) {
      tbody.innerHTML = '<tr><td colspan="10" class="fac-loading-cell" style="color:#e87">Error: ' + esc(err.message) + '</td></tr>';
    }
  }

  /* â”€â”€ render table â”€â”€ */
  function renderTable() {
    const tbody = $('facTableBody');
    if (!allPagos.length) {
      tbody.innerHTML = '<tr><td colspan="10" class="fac-loading-cell">Sin resultados</td></tr>';
      return;
    }

    tbody.innerHTML = allPagos.map(p => {
      const facBadge = p.factura
        ? `<span class="fac-badge fac-badge--${p.factura.estado}">${p.factura.estado}</span>`
        : `<span class="fac-badge fac-badge--sin">Sin factura</span>`;

      const actions = p.factura?.estado === 'vigente'
        ? `<div class="fac-action-group">
             <button class="fac-act fac-act--pdf"    onclick="dlFactura(${p.id},'pdf')">â¬‡ PDF</button>
             <button class="fac-act fac-act--xml"    onclick="dlFactura(${p.id},'xml')">â¬‡ XML</button>
             <button class="fac-act fac-act--cancel" onclick="openCancelModal(${p.id})">âœ• Cancelar</button>
           </div>`
        : p.factura?.estado === 'cancelada'
          ? `<span style="font-size:.75rem;color:#666">Factura cancelada</span>`
          : `<button class="fac-act fac-act--emit" onclick="openEmitModal(${p.id},'${esc(p.empresa.nombre)}','${esc(p.empresa.rfc||'')}','${esc(p.empresa.regimenFiscal||'601')}',${p.monto},'${esc(p.empresa.cp||'')}')">
               ðŸ“„ Emitir CFDI
             </button>`;

      return `<tr>
        <td style="color:#666;font-size:.75rem">${p.id}</td>
        <td>
          <div style="font-weight:600;color:#f0f0f0">${esc(p.empresa.nombre)}</div>
          <div style="font-size:.72rem;color:#666">${p.empresa.rfc ? esc(p.empresa.rfc) : 'Sin RFC'}</div>
        </td>
        <td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${esc(p.producto)}">${esc(p.producto)}</td>
        <td><span class="fac-badge fac-badge--pos">${posLabel(p.posicion)}</span></td>
        <td style="color:#888">${p.duracionDias}d</td>
        <td style="font-weight:600;color:#f0f0f0">${money(p.monto)}</td>
        <td><span class="fac-badge fac-badge--${p.estado}">${p.estado}</span></td>
        <td style="font-size:.78rem;color:#888">${dateStr(p.fechaCreacion)}</td>
        <td>${facBadge}</td>
        <td>${actions}</td>
      </tr>`;
    }).join('');
  }

  /* â”€â”€ pagination â”€â”€ */
  function renderPagination() {
    $('facPageInfo').textContent = `PÃ¡gina ${page} de ${totalPages} Â· ${totalCount} total`;
    const ctrl = $('facPageControls');
    const btns = [];
    if (page > 1) btns.push(`<button class="fac-page-btn" onclick="goPage(${page-1})">â€¹ Ant</button>`);
    const s = Math.max(1, page-2), e = Math.min(totalPages, page+2);
    for (let i = s; i <= e; i++) {
      btns.push(`<button class="fac-page-btn ${i===page?'is-active':''}" onclick="goPage(${i})">${i}</button>`);
    }
    if (page < totalPages) btns.push(`<button class="fac-page-btn" onclick="goPage(${page+1})">Sig â€º</button>`);
    ctrl.innerHTML = btns.join('');
  }

  window.goPage = p => { page = p; loadPagos(); };

  /* â”€â”€ download â”€â”€ */
  window.dlFactura = function(campanaId, tipo) {
    const a = document.createElement('a');
    a.href = '/api/admin/publicidad/pagos/' + campanaId + '/factura?download=' + tipo;
    a.rel = 'noopener'; a.style.display = 'none';
    document.body.appendChild(a); a.click(); a.remove();
  };

  /* â”€â”€â”€â”€â”€â”€ Emit Modal â”€â”€â”€â”€â”€â”€ */
  window.openEmitModal = function(campanaId, empresa, rfc, regimen, monto, cp) {
    $('facCampanaId').value = campanaId;
    $('facModalSubtitle').textContent = 'CampaÃ±a #' + campanaId + ' Â· ' + empresa + ' Â· ' + money(monto);
    $('facRfc').value = rfc || '';
    $('facNombre').value = empresa || '';
    const regimenSel = $('facRegimen');
    if (rfc && rfc.length === 12) regimenSel.value = regimen || '601';
    else if (rfc && rfc.length === 13) regimenSel.value = regimen || '612';
    else regimenSel.value = regimen || '601';
    $('facCp').value = cp || '';
    $('facFormError').hidden = true;
    $('facModal').hidden = false;
  };

  function closeEmitModal() { $('facModal').hidden = true; }
  $('facModalClose').onclick = closeEmitModal;
  $('facModalCancelBtn').onclick = closeEmitModal;
  $('facModalBg').onclick = closeEmitModal;

  $('facRfc').addEventListener('input', function() {
    const len = this.value.trim().replace(/\s+/g,'').length;
    if (len === 12) $('facRegimen').value = '601';
    else if (len === 13) $('facRegimen').value = '612';
  });

  $('facRegimen').addEventListener('change', function() {
    if (this.value === '616') $('facUsoCfdi').value = 'S01';
  });

  $('facFacturaForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const errEl = $('facFormError');
    errEl.hidden = true;

    const campanaId     = Number($('facCampanaId').value);
    const rfc           = $('facRfc').value.trim().toUpperCase();
    const nombre        = $('facNombre').value.trim();
    const regimenFiscal = $('facRegimen').value;
    const usoCfdi       = $('facUsoCfdi').value;
    const cpFiscal      = $('facCp').value.trim();

    if (!rfc || rfc.length < 12)      { errEl.textContent = 'RFC invÃ¡lido';           errEl.hidden = false; return; }
    if (!nombre || nombre.length < 3) { errEl.textContent = 'Nombre demasiado corto'; errEl.hidden = false; return; }
    if (!cpFiscal || cpFiscal.length < 4) { errEl.textContent = 'Ingresa el CP Fiscal'; errEl.hidden = false; return; }

    const btn = $('facFormSubmit');
    btn.disabled = true; btn.textContent = 'Generandoâ€¦';

    try {
      const res  = await fetch('/api/admin/publicidad/pagos/' + campanaId + '/factura', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ rfc, nombre, usoCfdi, regimenFiscal, cpFiscal }),
      });
      const data = await res.json();

      if (!data.success) { errEl.textContent = data.error || 'Error al generar'; errEl.hidden = false; return; }

      closeEmitModal();
      showStatus('âœ“ Factura generada: UUID ' + (data.factura?.uuid || 'â€”'), false);
      page = 1;
      await loadPagos();
      setTimeout(() => dlFactura(campanaId, 'pdf'), 400);
    } catch (err) {
      errEl.textContent = 'Error de red: ' + esc(err.message);
      errEl.hidden = false;
    } finally {
      btn.disabled = false;
      btn.textContent = 'Generar Factura';
    }
  });

  /* â”€â”€â”€â”€â”€â”€ Cancel Modal â”€â”€â”€â”€â”€â”€ */
  window.openCancelModal = function(campanaId) {
    $('facCancelCampanaId').value = campanaId;
    $('facCancelMotivo').value = '02';
    $('facFolioSustField').hidden = true;
    $('facFolioSust').value = '';
    $('facCancelError').hidden = true;
    $('facCancelModal').hidden = false;
  };

  function closeCancelModal() { $('facCancelModal').hidden = true; }
  $('facCancelModalClose').onclick = closeCancelModal;
  $('facCancelCancelBtn').onclick  = closeCancelModal;
  $('facCancelModalBg').onclick    = closeCancelModal;

  $('facCancelMotivo').addEventListener('change', function() {
    $('facFolioSustField').hidden = this.value !== '01';
  });

  $('facCancelForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const errEl = $('facCancelError');
    errEl.hidden = true;

    const campanaId       = Number($('facCancelCampanaId').value);
    const motivo          = $('facCancelMotivo').value;
    const folioSustitucion = $('facFolioSust').value.trim() || null;

    if (motivo === '01' && !folioSustitucion) {
      errEl.textContent = 'El motivo 01 requiere el UUID del CFDI sustituto';
      errEl.hidden = false; return;
    }

    const btn = $('facCancelSubmit');
    btn.disabled = true; btn.textContent = 'Cancelandoâ€¦';

    try {
      const res  = await fetch('/api/admin/publicidad/pagos/' + campanaId + '/factura', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ motivo, folioSustitucion }),
      });
      const data = await res.json();

      if (!data.success) { errEl.textContent = data.error || 'Error al cancelar'; errEl.hidden = false; return; }

      closeCancelModal();
      showStatus('âœ“ Factura cancelada exitosamente', false);
      page = 1;
      await loadPagos();
    } catch (err) {
      errEl.textContent = 'Error de red: ' + esc(err.message);
      errEl.hidden = false;
    } finally {
      btn.disabled = false;
      btn.textContent = 'Cancelar Factura';
    }
  });

  /* â”€â”€ search / filters â”€â”€ */
  let searchTimer;
  $('facSearch').addEventListener('input', () => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => { page = 1; loadPagos(); }, 400);
  });
  $('facEstado').addEventListener('change',  () => { page = 1; loadPagos(); });
  $('facPerPage').addEventListener('change', () => { page = 1; loadPagos(); });
  $('facFactura').addEventListener('change', () => { page = 1; loadPagos(); });

  /* â”€â”€ init â”€â”€ */
  loadPagos();
})();
</script>
</BaseLayout>

