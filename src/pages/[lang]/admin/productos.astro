---
import BaseLayout from "../../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}
const currentLang = "es";
const cspNonce = Astro.locals?.cspNonce || "";

const role = String(Astro.locals?.user?.rol || "")
  .trim()
  .toLowerCase()
  .replace(/[\s_-]/g, "")
  .replace(/^superadmin$|^superuser$/, "superusuario");

if (!role) return Astro.redirect(`/${currentLang}/login`);
if (role !== "admin" && role !== "superusuario")
  return Astro.redirect(`/${currentLang}`);
---

<BaseLayout title="Gestión de productos" currentLang={currentLang}>
  <!-- ── Modal system (unchanged) ── -->
  <script nonce={cspNonce} is:inline>
    (function (g) {
      if (document.getElementById("go-modal-styles")) return;
      const s = document.createElement("style");
      s.id = "go-modal-styles";
      s.textContent = `
      .go-modal-backdrop{position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.6);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;padding:1rem;opacity:0;transition:opacity 220ms ease}
      .go-modal-backdrop.go-visible{opacity:1}
      .go-modal{background:#111827;border:1px solid rgba(99,102,241,.2);border-radius:20px;box-shadow:0 32px 80px rgba(0,0,0,.6);padding:2rem 2rem 1.6rem;width:100%;max-width:420px;text-align:center;transform:scale(.88) translateY(20px);transition:transform 260ms cubic-bezier(.34,1.56,.64,1);position:relative}
      .go-modal-backdrop.go-visible .go-modal{transform:scale(1) translateY(0)}
      .go-modal-icon{width:72px;height:72px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.1rem}
      .go-modal-icon.success{background:rgba(52,211,153,.1);color:#34d399}.go-modal-icon.error{background:rgba(244,63,94,.1);color:#fb7185}
      .go-modal-icon.warning{background:rgba(245,158,11,.1);color:#fbbf24}.go-modal-icon.info{background:rgba(99,102,241,.1);color:#a5b4fc}
      .go-modal-icon.confirm{background:rgba(99,102,241,.1);color:#a5b4fc}
      .go-modal-title{font-size:1.25rem;font-weight:700;color:#f1f5f9;margin:0 0 .5rem;font-family:inherit!important}
      .go-modal-text{font-size:.92rem;color:#64748b;margin:0 0 1.4rem;line-height:1.55;font-family:inherit!important}
      .go-modal-actions{display:flex;gap:.7rem;justify-content:center;flex-wrap:wrap}
      .go-modal-btn{padding:.65rem 1.6rem;border-radius:10px;font-size:.9rem;font-weight:700;cursor:pointer;border:none;transition:filter 160ms,transform 100ms;min-width:110px;font-family:inherit!important}
      .go-modal-btn:hover{filter:brightness(1.08)}.go-modal-btn:active{transform:scale(.97)}
      .go-modal-btn.primary{background:linear-gradient(135deg,#4f46e5,#7c3aed);color:#fff}.go-modal-btn.secondary{background:rgba(255,255,255,.06);color:#94a3b8;border:1px solid rgba(255,255,255,.1)}
      .go-modal-btn.danger{background:#ef4444;color:#fff}
      .go-modal-progress{position:absolute;bottom:0;left:0;height:3px;border-radius:0 0 20px 20px;background:linear-gradient(90deg,#4f46e5,#7c3aed);width:100%;transform-origin:left;animation:go-progress linear forwards}
      @keyframes go-progress{from{transform:scaleX(1)}to{transform:scaleX(0)}}
      .go-loading-backdrop{position:fixed;inset:0;z-index:10500;background:rgba(0,0,0,.65);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 200ms ease}
      .go-loading-backdrop.go-visible{opacity:1;pointer-events:auto}
      .go-loading-box{background:#111827;border:1px solid rgba(99,102,241,.18);border-radius:20px;padding:2rem 2.5rem;text-align:center;box-shadow:0 24px 60px rgba(0,0,0,.5);min-width:220px}
      .go-loading-spinner{width:48px;height:48px;border-radius:50%;border:3px solid rgba(99,102,241,.2);border-top-color:#6366f1;animation:go-spin 0.75s linear infinite;margin:0 auto 1rem}
      @keyframes go-spin{to{transform:rotate(360deg)}}
      .go-loading-title{font-size:.95rem;font-weight:700;color:#f1f5f9;margin:0 0 .25rem;font-family:inherit!important}
      .go-loading-sub{font-size:.78rem;color:#475569;margin:0;font-family:inherit!important}
    `;
      document.head.appendChild(s);
      const IC = {
        success: `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`,
        error: `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`,
        warning: `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
        info: `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>`,
        confirm: `<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
      };
      function show(o) {
        return new Promise(function (res) {
          var type = o.type || "info",
            title = o.title || "",
            text = o.text || "",
            ct = o.confirmText || "Aceptar",
            cct = o.cancelText || "Cancelar",
            sc = o.showCancel || false,
            ac = o.autoClose || 0;
          var bd = document.createElement("div");
          bd.className = "go-modal-backdrop";
          bd.innerHTML =
            '<div class="go-modal" role="dialog" aria-modal="true">' +
            '<div class="go-modal-icon ' +
            type +
            '">' +
            (IC[type] || IC.info) +
            "</div>" +
            '<h2 class="go-modal-title">' +
            title +
            "</h2>" +
            (text ? '<p class="go-modal-text">' + text + "</p>" : "") +
            '<div class="go-modal-actions">' +
            (sc
              ? '<button class="go-modal-btn secondary" id="gmc">' +
                cct +
                "</button>"
              : "") +
            '<button class="go-modal-btn ' +
            (type === "error" ? "danger" : "primary") +
            '" id="gmok">' +
            ct +
            "</button>" +
            "</div>" +
            (ac
              ? '<div class="go-modal-progress" style="animation-duration:' +
                ac +
                'ms"></div>'
              : "") +
            "</div>";
          document.body.appendChild(bd);
          requestAnimationFrame(function () {
            bd.classList.add("go-visible");
          });
          function close(r) {
            bd.classList.remove("go-visible");
            setTimeout(function () {
              bd.remove();
            }, 260);
            res(r);
          }
          bd.querySelector("#gmok").addEventListener("click", function () {
            close(true);
          });
          var cc = bd.querySelector("#gmc");
          if (cc)
            cc.addEventListener("click", function () {
              close(false);
            });
          function onKey(e) {
            if (e.key === "Escape") {
              close(false);
              document.removeEventListener("keydown", onKey);
            }
          }
          document.addEventListener("keydown", onKey);
          if (ac)
            setTimeout(function () {
              close(true);
            }, ac);
        });
      }
      var _loadEl = null;
      function showLoading(title, sub) {
        if (_loadEl) return;
        _loadEl = document.createElement("div");
        _loadEl.className = "go-loading-backdrop";
        _loadEl.innerHTML =
          '<div class="go-loading-box"><div class="go-loading-spinner"></div><p class="go-loading-title">' +
          (title || "Procesando...") +
          '</p><p class="go-loading-sub">' +
          (sub || "Por favor espera") +
          "</p></div>";
        document.body.appendChild(_loadEl);
        requestAnimationFrame(function () {
          _loadEl.classList.add("go-visible");
        });
      }
      function hideLoading() {
        if (!_loadEl) return;
        _loadEl.classList.remove("go-visible");
        setTimeout(function () {
          if (_loadEl) {
            _loadEl.remove();
            _loadEl = null;
          }
        }, 220);
      }
      g.Modal = {
        success: function (t, x, o) {
          return show(
            Object.assign({ type: "success", title: t, text: x }, o || {}),
          );
        },
        error: function (t, x, o) {
          return show(
            Object.assign({ type: "error", title: t, text: x }, o || {}),
          );
        },
        warning: function (t, x, o) {
          return show(
            Object.assign({ type: "warning", title: t, text: x }, o || {}),
          );
        },
        info: function (t, x, o) {
          return show(
            Object.assign({ type: "info", title: t, text: x }, o || {}),
          );
        },
        confirm: function (t, x, o) {
          return show(
            Object.assign(
              { type: "confirm", title: t, text: x, showCancel: true },
              o || {},
            ),
          );
        },
        loading: showLoading,
        hideLoading: hideLoading,
      };
    })(window);
  </script>

  <!-- ── Runtime styles for JS-generated elements (bypass Astro CSS scoping) ── -->
  <script nonce={cspNonce} is:inline>
    (function () {
      if (document.getElementById("pa-runtime-styles")) return;
      var s = document.createElement("style");
      s.id = "pa-runtime-styles";
      s.textContent = `
      .pa-row-actions{display:flex!important;align-items:center!important;gap:5px!important;justify-content:center!important}

      button.pa-row-btn{width:30px!important;height:30px!important;border-radius:7px!important;border:1px solid rgba(255,255,255,.07)!important;background:rgba(255,255,255,.03)!important;display:inline-flex!important;align-items:center!important;justify-content:center!important;cursor:pointer!important;transition:all .18s!important;padding:0!important;line-height:1!important;flex-shrink:0!important;outline:none!important}
      button.pa-row-btn:hover{transform:translateY(-1px)!important;background:rgba(255,255,255,.07)!important}
      button.pa-row-btn svg{width:13px!important;height:13px!important;stroke:currentColor!important;fill:none!important;stroke-width:2!important;stroke-linecap:round!important;stroke-linejoin:round!important;display:block!important;pointer-events:none!important}

      button.pa-row-btn.pa-row-btn--toggle.is-on{color:#34d399!important;border-color:rgba(52,211,153,.3)!important;background:rgba(52,211,153,.08)!important}
      button.pa-row-btn.pa-row-btn--toggle.is-on svg{width:14px!important;height:14px!important;stroke-width:2.4!important}
      button.pa-row-btn.pa-row-btn--toggle.is-off{color:#fb7185!important;border-color:rgba(244,63,94,.28)!important;background:rgba(244,63,94,.07)!important}
      button.pa-row-btn.pa-row-btn--toggle.is-off svg{width:14px!important;height:14px!important;stroke-width:2.4!important}

      button.pa-row-btn.pa-row-btn--edit{color:#a5b4fc!important;border-color:rgba(99,102,241,.3)!important}
      button.pa-row-btn.pa-row-btn--edit:hover{background:rgba(99,102,241,.14)!important;border-color:rgba(99,102,241,.5)!important}

      button.pa-row-btn.pa-row-btn--delete{color:#fb7185!important;border-color:rgba(244,63,94,.25)!important}
      button.pa-row-btn.pa-row-btn--delete:hover{background:rgba(244,63,94,.1)!important;border-color:rgba(244,63,94,.45)!important}

      .pa-division-badge{display:inline-block!important;font-size:10px!important;font-weight:700!important;padding:3px 9px!important;border-radius:999px!important;background:rgba(99,102,241,.12)!important;color:#a5b4fc!important;border:1px solid rgba(99,102,241,.28)!important;white-space:nowrap!important}
      .pa-variantes-badge{display:inline-block!important;font-size:10px!important;font-weight:700!important;padding:3px 9px!important;border-radius:999px!important;background:rgba(14,165,233,.1)!important;color:#38bdf8!important;border:1px solid rgba(14,165,233,.25)!important}
      .pa-estado{display:inline-block!important;font-size:10px!important;font-weight:700!important;padding:3px 9px!important;border-radius:999px!important}
      .pa-estado--on{background:rgba(52,211,153,.1)!important;color:#34d399!important;border:1px solid rgba(52,211,153,.28)!important}
      .pa-estado--off{background:rgba(244,63,94,.07)!important;color:#fb7185!important;border:1px solid rgba(244,63,94,.22)!important}

      button.pa-page-btn{min-width:32px!important;height:32px!important;border-radius:7px!important;border:1px solid rgba(255,255,255,.07)!important;background:rgba(255,255,255,.02)!important;color:#64748b!important;font-size:12px!important;font-weight:600!important;cursor:pointer!important;display:inline-flex!important;align-items:center!important;justify-content:center!important;transition:all .15s!important;padding:0 8px!important;font-family:inherit!important;outline:none!important}
      button.pa-page-btn:hover:not(.disabled):not(.active){background:rgba(99,102,241,.08)!important;border-color:rgba(99,102,241,.3)!important;color:#a5b4fc!important}
      button.pa-page-btn.active{background:linear-gradient(135deg,rgba(79,70,229,.5),rgba(124,58,237,.4))!important;border-color:rgba(99,102,241,.5)!important;color:#c7d2fe!important;box-shadow:0 2px 10px rgba(99,102,241,.25)!important;font-weight:700!important}
      button.pa-page-btn.disabled{opacity:.25!important;cursor:not-allowed!important}
      button.pa-page-btn.pa-page-btn--arrow{min-width:34px!important}
      button.pa-page-btn.pa-page-btn--arrow svg{width:13px!important;height:13px!important;stroke:currentColor!important;fill:none!important;display:block!important;pointer-events:none!important}
      .pa-page-ellipsis{color:#334155;font-size:13px;padding:0 4px;user-select:none;display:inline-flex;align-items:center;height:32px}
    `;
      document.head.appendChild(s);
    })();
  </script>

  <main class="pa-page">
    <section class="pa-shell">
      <!-- ── Hero header ── -->
      <header class="pa-hero">
        <div class="pa-hero__glow" aria-hidden="true"></div>
        <div class="pa-hero__dots" aria-hidden="true"></div>
        <div class="pa-hero__content">
          <div>
            <span class="pa-hero__badge">
              <span class="pa-hero__badge-dot"></span>
              Panel Admin
            </span>
            <h1 class="pa-hero__title">Gestión de productos</h1>
            <p class="pa-hero__sub">
              CRUD completo con variantes, specs y división.
            </p>
          </div>
          <div class="pa-hero__actions">
            <button id="btnAddProduct" class="pa-add-btn" type="button">
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.8"
                stroke-linecap="round"
                ><line x1="12" y1="5" x2="12" y2="19"></line><line
                  x1="5"
                  y1="12"
                  x2="19"
                  y2="12"></line></svg
              >
              Añadir producto
            </button>
            <a class="pa-back-btn" href={`/${currentLang}`}>
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                ><path d="M19 12H5M12 5l-7 7 7 7"></path></svg
              >
              Volver al sitio
            </a>
          </div>
        </div>
      </header>

      <!-- ── Image Viewer Modal ── -->
      <section id="imageViewerModal" class="img-viewer-modal" hidden>
        <div
          id="imageViewerPanel"
          class="img-viewer-panel"
          role="dialog"
          aria-modal="true"
        >
          <div class="img-viewer-header">
            <div class="img-viewer-header-text">
              <span class="img-viewer-badge">Galería</span>
              <h2 class="img-viewer-title" id="imageViewerProductName">
                Producto
              </h2>
            </div>
            <button
              id="imageViewerClose"
              class="img-viewer-close"
              type="button"
              aria-label="Cerrar"
            >
              <svg viewBox="0 0 24 24"
                ><path d="M18 6L6 18M6 6l12 12"></path></svg
              >
            </button>
          </div>
          <div class="img-viewer-preview-card">
            <div id="imageViewerPreview" class="img-viewer-preview">
              <img
                id="imageViewerImg"
                class="img-viewer-img"
                src=""
                alt="Preview"
              />
              <div class="img-viewer-empty" id="imageViewerEmpty">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                  ></path></svg
                >
                <span>Sin imágenes</span>
              </div>
            </div>
            <p class="img-viewer-counter" id="imageViewerCounter"></p>
          </div>
          <div class="img-viewer-section">
            <p class="img-viewer-section-label">Imágenes actuales</p>
            <div id="imageViewerList" class="img-viewer-list"></div>
          </div>
          <div class="img-viewer-section">
            <p class="img-viewer-section-label">Agregar nueva imagen</p>
            <div class="img-viewer-upload-box">
              <div class="img-viewer-upload-top">
                <label class="img-viewer-upload-select" for="imageViewerFile">
                  <svg viewBox="0 0 24 24"
                    ><path d="M12 16V6m0 0l-3 3m3-3l3 3"></path><path
                      d="M4 15v2a3 3 0 003 3h10a3 3 0 003-3v-2"></path></svg
                  >
                  Seleccionar imagen
                </label>
                <input
                  id="imageViewerFile"
                  class="img-viewer-file"
                  type="file"
                  accept="image/png,image/jpeg,image/webp,image/jpg"
                />
              </div>
              <p id="imageViewerUploadHint" class="img-viewer-upload-hint">
                PNG, JPG o WEBP. Máximo 8MB.
              </p>
            </div>
          </div>
          <div class="img-viewer-footer">
            <button
              class="img-viewer-cancel"
              type="button"
              id="imageViewerCancelBtn">Cancelar</button
            >
            <button id="imageViewerSave" class="img-viewer-save" type="button">
              <svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg>
              Guardar cambios
            </button>
          </div>
        </div>
      </section>

      <!-- ── Form Panel ── -->
      <section id="productsFormPanel" class="pa-form-panel" hidden>
        <article class="pa-card pa-card--form">
          <div class="pa-form-header">
            <h2 id="formTitle">Nuevo producto</h2>
            <button id="btnCancelEdit" class="pa-btn-close" type="button"
              >✕ Cerrar</button
            >
          </div>
          <p class="pa-note">
            Completa los campos y presiona Guardar. Los campos con * son
            obligatorios.
          </p>
          <input id="currentProductId" type="hidden" />

          <div class="pa-form-section">
            <div class="pa-form-section__title">
              <span class="pa-form-section__icon">📦</span> Información básica
            </div>
            <div class="pa-form-grid">
              <div class="pa-field">
                <label for="nombre">Nombre *</label><input
                  id="nombre"
                  type="text"
                  placeholder="Nombre del producto"
                />
              </div>
              <div class="pa-field">
                <label for="codigoReferencia">Código de referencia</label><input
                  id="codigoReferencia"
                  type="text"
                  placeholder="Opcional (ej. REF-001)"
                />
              </div>
              <div class="pa-field">
                <label for="precio">Precio *</label><input
                  id="precio"
                  type="number"
                  min="0"
                  step="0.01"
                  placeholder="0.00"
                />
              </div>
              <div class="pa-field">
                <label for="stockDisponible">Stock disponible</label><input
                  id="stockDisponible"
                  type="number"
                  min="0"
                  step="1"
                  placeholder="0"
                />
              </div>
              <div class="pa-field">
                <label for="peso">Peso (kg)</label><input
                  id="peso"
                  type="number"
                  min="0"
                  step="0.01"
                  placeholder="0.00"
                />
              </div>
              <div class="pa-field">
                <label for="activo">Estado</label><select id="activo"
                  ><option value="1">Activo</option><option value="0"
                    >Inactivo</option
                  ></select>
              </div>
              <div class="pa-field">
                <label for="categoriaId">Categoría *</label><select
                  id="categoriaId"></select>
              </div>
              <div class="pa-field pa-field--full">
                <label for="descripcion">Descripción</label><input
                  id="descripcion"
                  type="text"
                  placeholder="Descripción del producto"
                />
              </div>
            </div>
          </div>

          <div class="pa-form-section">
            <div class="pa-form-section__title">
              <span class="pa-form-section__icon">🏭</span> División e industria
            </div>
            <div class="pa-form-grid pa-form-grid--2">
              <div class="pa-field">
                <label for="division">División</label><select id="division"
                  ><option value="">Sin división</option><option
                    value="Película Stretch">Película Stretch</option
                  ><option value="Sacos de Rafia">Sacos de Rafia</option><option
                    value="Bolsa de Malla">Bolsa de Malla</option
                  ><option value="Cuerda">Cuerda</option><option value="Rafia"
                    >Rafia</option
                  ><option value="Esquineros Protectores"
                    >Esquineros Protectores</option
                  ><option value="Empaque Flexible">Empaque Flexible</option
                  ></select>
              </div>
              <div class="pa-field">
                <label for="unidadVenta">Unidad de venta</label><select
                  id="unidadVenta"
                  ><option value="">Sin especificar</option><option
                    value="Rollo">Rollo</option
                  ><option value="Pieza">Pieza</option><option value="Caja"
                    >Caja</option
                  ><option value="Kg">Kg</option><option value="Paquete"
                    >Paquete</option
                  ><option value="Metro">Metro</option></select>
              </div>
            </div>
          </div>

          <div class="pa-form-section">
            <div class="pa-form-section__title">
              <span class="pa-form-section__icon">📐</span> Dimensiones
            </div>
            <div class="pa-dims-units">
              <span class="pa-dims-label">Unidad</span>
              <span
                class="pa-division-badge"
                style="background:rgba(99,102,241,.12);color:#a5b4fc;border:1px solid rgba(99,102,241,.28);"
                >cm</span
              >
            </div>
            <div class="pa-dims-rows">
              {
                [
                  ["largoExacto", "Largo exacto"],
                  ["anchoExacto", "Ancho exacto"],
                  ["grosorExacto", "Grosor exacto"],
                ].map(([id, label]) => (
                  <div class="pa-dims-row pa-dims-row--exact">
                    <span class="pa-dims-row-label">{label}</span>
                    <div class="pa-dims-input-group">
                      <input
                        id={id}
                        type="number"
                        min="0"
                        step="0.01"
                        placeholder="0.00"
                      />
                    </div>
                  </div>
                ))
              }
            </div>
            <p class="pa-hint">
              Se guarda valor exacto. No se permiten rangos.
            </p>
          </div>

          <div class="pa-form-section">
            <div class="pa-form-section__title">
              <span class="pa-form-section__icon">🎛️</span> Variantes / Calibres
              <button id="btnAddVariante" class="pa-btn-add-var" type="button"
                >+ Agregar variante</button
              >
            </div>
            <div id="variantesContainer" class="pa-variantes">
              <p class="pa-variantes-empty">
                Sin variantes. Haz clic en "+ Agregar variante" para añadir
                calibres o medidas.
              </p>
            </div>
          </div>

          <div class="pa-form-section">
            <div class="pa-form-section__title">
              <span class="pa-form-section__icon">🖼️</span> Imágenes
            </div>
            <div class="pa-field pa-field--full">
              <textarea
                id="imagenesUrls"
                rows="3"
                placeholder="URLs de imagen"
                style="display:none;"></textarea>
              <button id="btnOpenGallery" class="pa-btn-gallery" type="button">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                  ></path></svg
                >
                Gestionar imágenes
              </button>
            </div>
          </div>

          <div class="pa-form-actions">
            <button id="btnSave" class="pa-btn-save" type="button">
              <svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg>
              Guardar cambios
            </button>
            <button id="btnFormReset" class="pa-btn-ghost" type="button"
              >Limpiar</button
            >
          </div>
        </article>
      </section>

      <!-- ── Lista ── -->
      <section class="pa-list-section">
        <article class="pa-card">
          <!-- Toolbar -->
          <div class="pa-toolbar">
            <div class="pa-toolbar__left">
              <label for="rowsPerPage">Mostrar</label>
              <select id="rowsPerPage" class="pa-toolbar-select"
                ><option value="10">10</option><option value="25">25</option
                ><option value="50">50</option></select
              >
              <span>por página</span>
            </div>
            <div class="pa-toolbar__center">
              <button id="btnCopy" class="pa-mini-btn" type="button"
                >Copiar</button
              >
              <button
                id="btnExcel"
                class="pa-mini-btn pa-mini-btn--green"
                type="button">Excel</button
              >
              <button
                id="btnPdf"
                class="pa-mini-btn pa-mini-btn--red"
                type="button">PDF</button
              >
              <button
                id="btnCsv"
                class="pa-mini-btn pa-mini-btn--blue"
                type="button">CSV</button
              >
            </div>
            <div class="pa-toolbar__right">
              <div class="pa-search-wrap">
                <svg
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  ><circle cx="11" cy="11" r="8"></circle><path
                    d="M21 21l-4.35-4.35"></path></svg
                >
                <input
                  id="searchProducts"
                  class="pa-toolbar-search"
                  type="text"
                  placeholder="Nombre, categoría o división…"
                />
              </div>
            </div>
          </div>

          <!-- List header -->
          <div class="pa-list-header">
            <h2>Lista de productos</h2>
            <div id="statsBar" class="pa-stats"></div>
          </div>

          <!-- Table -->
          <div class="pa-table-wrap">
            <table class="pa-table">
              <colgroup>
                <col class="col-id" /><col class="col-nombre" /><col
                  class="col-categoria"
                />
                <col class="col-division" /><col class="col-imagen" /><col
                  class="col-precio"
                />
                <col class="col-stock" /><col class="col-variantes" /><col
                  class="col-estado"
                />
                <col class="col-fecha" /><col class="col-acciones" />
              </colgroup>
              <thead>
                <tr>
                  <th>ID</th><th>Nombre</th><th>Categoría</th><th>División</th>
                  <th>Img</th><th>Precio</th><th>Stock</th><th>Variantes</th>
                  <th>Estado</th><th>Fecha</th><th class="pa-th-actions"
                    >Acciones</th
                  >
                </tr>
              </thead>
              <tbody id="productsRows"></tbody>
            </table>
          </div>

          <!-- Pagination -->
          <div class="pa-pagination" id="paginationBar">
            <span id="productsResultsInfo" class="pa-pagination__info"></span>
            <div class="pa-pagination__controls" id="paginationControls"></div>
          </div>
        </article>
      </section>
    </section>
  </main>

  <!-- ════════════════ ALL JS LOGIC (unchanged) ════════════════ -->
  <script nonce={cspNonce} is:inline>
    const formPanelEl = document.getElementById("productsFormPanel");
    const formTitleEl = document.getElementById("formTitle");
    const currentProductIdEl = document.getElementById("currentProductId");
    const rowsEl = document.getElementById("productsRows");
    const btnAddProduct = document.getElementById("btnAddProduct");
    const searchProductsEl = document.getElementById("searchProducts");
    const rowsPerPageEl = document.getElementById("rowsPerPage");
    const productsResultsInfoEl = document.getElementById(
      "productsResultsInfo",
    );
    const statsBarEl = document.getElementById("statsBar");
    const paginationControlsEl = document.getElementById("paginationControls");
    const btnCopy = document.getElementById("btnCopy");
    const btnExcel = document.getElementById("btnExcel");
    const btnPdf = document.getElementById("btnPdf");
    const btnCsv = document.getElementById("btnCsv");
    const nombreEl = document.getElementById("nombre");
    const codigoReferenciaEl = document.getElementById("codigoReferencia");
    const descripcionEl = document.getElementById("descripcion");
    const precioEl = document.getElementById("precio");
    const stockDisponibleEl = document.getElementById("stockDisponible");
    const pesoEl = document.getElementById("peso");
    const activoEl = document.getElementById("activo");
    const categoriaIdEl = document.getElementById("categoriaId");
    const imagenesUrlsEl = document.getElementById("imagenesUrls");
    const btnSave = document.getElementById("btnSave");
    const btnCancelEdit = document.getElementById("btnCancelEdit");
    const btnFormReset = document.getElementById("btnFormReset");
    const divisionEl = document.getElementById("division");
    const unidadVentaEl = document.getElementById("unidadVenta");
    const variantesContainer = document.getElementById("variantesContainer");
    const btnAddVariante = document.getElementById("btnAddVariante");
    const largoExactoEl = document.getElementById("largoExacto");
    const anchoExactoEl = document.getElementById("anchoExacto");
    const grosorExactoEl = document.getElementById("grosorExacto");

    let products = [],
      categories = [],
      filteredProducts = [],
      formMode = "create";
    let variantesForm = [];
    let currentPage = 1;

    function makeSVG(pathsArray, w, h, sw) {
      var svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
      svg.setAttribute("viewBox", "0 0 24 24");
      svg.setAttribute("width", String(w || 14));
      svg.setAttribute("height", String(h || 14));
      svg.setAttribute("fill", "none");
      svg.setAttribute("stroke", "currentColor");
      svg.setAttribute("stroke-width", String(sw || 2));
      svg.setAttribute("stroke-linecap", "round");
      svg.setAttribute("stroke-linejoin", "round");
      svg.style.display = "block";
      svg.style.pointerEvents = "none";
      pathsArray.forEach(function (d) {
        var p = document.createElementNS("http://www.w3.org/2000/svg", "path");
        p.setAttribute("d", d);
        svg.appendChild(p);
      });
      return svg;
    }
    var SVG_TOGGLE_ON = ["M5 12l4 4L19 6"];
    var SVG_TOGGLE_OFF = ["M6 6l12 12", "M18 6l-12 12"];
    var SVG_EDIT = [
      "M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7",
      "M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z",
    ];
    var SVG_DELETE = [
      "M3 6h18",
      "M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2",
      "M10 11v6",
      "M14 11v6",
    ];

    function getDimsUnidad() {
      return "cm";
    }
    function setDimsUnidad() {
      return;
    }
    function buildEspecificaciones() {
      const u = getDimsUnidad(),
        l = parseFloat(largoExactoEl?.value || ""),
        a = parseFloat(anchoExactoEl?.value || ""),
        g = parseFloat(grosorExactoEl?.value || "");
      if (!Number.isFinite(l) && !Number.isFinite(a) && !Number.isFinite(g))
        return null;
      if (
        !Number.isFinite(l) ||
        !Number.isFinite(a) ||
        !Number.isFinite(g) ||
        l <= 0 ||
        a <= 0 ||
        g <= 0
      )
        return null;
      return JSON.stringify({
        dimensiones: { unidad: u, largo: l, ancho: a, grosor: g },
      });
    }
    function fillDims(especStr) {
      if (largoExactoEl) largoExactoEl.value = "";
      if (anchoExactoEl) anchoExactoEl.value = "";
      if (grosorExactoEl) grosorExactoEl.value = "";
      setDimsUnidad("cm");
      if (!especStr) return;
      try {
        const s =
          typeof especStr === "string" ? JSON.parse(especStr) : especStr;
        const d = s?.dimensiones;
        if (d) {
          if (largoExactoEl && Number.isFinite(Number(d.largo)))
            largoExactoEl.value = String(d.largo);
          if (anchoExactoEl && Number.isFinite(Number(d.ancho)))
            anchoExactoEl.value = String(d.ancho);
          if (grosorExactoEl && Number.isFinite(Number(d.grosor)))
            grosorExactoEl.value = String(d.grosor);
          if (d.unidad) setDimsUnidad(String(d.unidad));
          return;
        }
        if (
          s?.largo &&
          typeof s.largo === "object" &&
          ("min" in s.largo || "max" in s.largo)
        ) {
          if (largoExactoEl)
            largoExactoEl.value = String(s.largo.max || s.largo.min || "");
          if (s.largo.unidad) setDimsUnidad(String(s.largo.unidad));
        }
        if (
          s?.ancho &&
          typeof s.ancho === "object" &&
          ("min" in s.ancho || "max" in s.ancho)
        ) {
          if (anchoExactoEl)
            anchoExactoEl.value = String(s.ancho.max || s.ancho.min || "");
        }
        if (
          (s?.alto &&
            typeof s.alto === "object" &&
            ("min" in s.alto || "max" in s.alto)) ||
          (s?.grosor &&
            typeof s.grosor === "object" &&
            ("min" in s.grosor || "max" in s.grosor))
        ) {
          const src = s.grosor || s.alto;
          if (grosorExactoEl)
            grosorExactoEl.value = String(src.max || src.min || "");
        }
      } catch {}
    }

    function renderVariantesForm() {
      if (!variantesContainer) return;
      if (variantesForm.length === 0) {
        variantesContainer.innerHTML =
          '<p class="pa-variantes-empty">Sin variantes. Puedes crear variantes por color, caja, calibre u otra presentación.</p>';
        return;
      }
      variantesContainer.innerHTML = "";
      variantesForm.forEach((v, idx) => {
        const row = document.createElement("div");
        row.className = "pa-variante-row";
        row.innerHTML = `<div class="pa-var-field"><label>Descripción / Tipo</label><input type="text" class="v-desc" value="${v.descripcion || ""}" placeholder="Ej: Color azul, Caja 50 pzs" /></div><div class="pa-var-field pa-var-field--sm"><label>Precio</label><input type="number" class="v-precio" value="${v.precio != null ? v.precio : ""}" placeholder="Opcional" min="0" step="0.01" /></div><div class="pa-var-field pa-var-field--sm"><label>Stock</label><input type="number" class="v-stock" value="${v.stock != null ? v.stock : ""}" placeholder="0" min="0" step="1" /></div><div class="pa-var-field pa-var-field--sm"><label>Peso kg</label><input type="number" class="v-peso" value="${v.peso != null ? v.peso : ""}" placeholder="Opcional" min="0" step="0.01" /></div><div class="pa-var-field pa-var-field--sm"><label>Largo</label><input type="number" class="v-largo" value="${v.largo != null ? v.largo : ""}" placeholder="Opcional" min="0" step="0.01" /></div><div class="pa-var-field pa-var-field--sm"><label>Ancho</label><input type="number" class="v-ancho" value="${v.ancho != null ? v.ancho : ""}" placeholder="Opcional" min="0" step="0.01" /></div><div class="pa-var-field pa-var-field--sm"><label>Grosor</label><input type="number" class="v-grosor" value="${v.grosor != null ? v.grosor : ""}" placeholder="Opcional" min="0" step="0.01" /></div><button class="pa-var-del" type="button" data-idx="${idx}"><svg viewBox="0 0 24 24"><path d="M6 7h12m-9 0V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2m-8 0l1 13h8l1-13M10 11v6M14 11v6"></path></svg></button>`;
        row.querySelector(".v-desc").addEventListener("input", (e) => {
          variantesForm[idx].descripcion = e.target.value;
        });
        row.querySelector(".v-precio").addEventListener("input", (e) => {
          variantesForm[idx].precio =
            e.target.value !== "" ? Number(e.target.value) : null;
        });
        row.querySelector(".v-stock").addEventListener("input", (e) => {
          variantesForm[idx].stock =
            e.target.value !== "" ? Number(e.target.value) : null;
        });
        row.querySelector(".v-peso").addEventListener("input", (e) => {
          variantesForm[idx].peso =
            e.target.value !== "" ? Number(e.target.value) : null;
        });
        row.querySelector(".v-largo").addEventListener("input", (e) => {
          variantesForm[idx].largo =
            e.target.value !== "" ? Number(e.target.value) : null;
        });
        row.querySelector(".v-ancho").addEventListener("input", (e) => {
          variantesForm[idx].ancho =
            e.target.value !== "" ? Number(e.target.value) : null;
        });
        row.querySelector(".v-grosor").addEventListener("input", (e) => {
          variantesForm[idx].grosor =
            e.target.value !== "" ? Number(e.target.value) : null;
        });
        row.querySelector(".pa-var-del").addEventListener("click", () => {
          variantesForm.splice(idx, 1);
          renderVariantesForm();
        });
        variantesContainer.appendChild(row);
      });
    }
    btnAddVariante?.addEventListener("click", () => {
      variantesForm.push({
        descripcion: "",
        precio: null,
        stock: null,
        peso: null,
        largo: null,
        ancho: null,
        grosor: null,
      });
      renderVariantesForm();
    });

    function setMode(mode, label) {
      formMode = mode;
      if (!formTitleEl || !currentProductIdEl) return;
      if (mode === "edit")
        formTitleEl.innerHTML = `Editando: <span style="color:#a5b4fc;font-weight:700">${label || ""}</span>`;
      else {
        formTitleEl.textContent = "Nuevo producto";
        currentProductIdEl.value = "";
      }
    }
    function resetForm() {
      if (!nombreEl) return;
      nombreEl.value = "";
      if (codigoReferenciaEl) codigoReferenciaEl.value = "";
      descripcionEl.value = "";
      precioEl.value = "";
      stockDisponibleEl.value = "";
      activoEl.value = "1";
      categoriaIdEl.value = "";
      imagenesUrlsEl.value = "";
      if (pesoEl) pesoEl.value = "";
      if (divisionEl) divisionEl.value = "";
      if (unidadVentaEl) unidadVentaEl.value = "";
      fillDims(null);
      variantesForm = [];
      renderVariantesForm();
      setMode("create");
    }
    function openForm(mode = "create", label) {
      if (!formPanelEl) return;
      formPanelEl.hidden = false;
      setMode(mode, label);
      formPanelEl.scrollIntoView({ behavior: "smooth", block: "start" });
    }
    function closeForm() {
      if (!formPanelEl) return;
      formPanelEl.hidden = true;
      resetForm();
    }
    function renderCategories() {
      if (!categoriaIdEl) return;
      categoriaIdEl.innerHTML = [
        '<option value="">Selecciona categoría</option>',
      ]
        .concat(
          categories.map((cat) => {
            const id = Number(cat.id || cat.Id_Categoria || 0);
            const nombre = String(cat.nombre || cat.Nombre || "");
            return `<option value="${id}">${nombre}</option>`;
          }),
        )
        .join("");
    }
    function fillForm(product) {
      if (!nombreEl || !currentProductIdEl) return;
      currentProductIdEl.value = String(product.id);
      nombreEl.value = product.nombre || "";
      if (codigoReferenciaEl)
        codigoReferenciaEl.value = product.codigoReferencia || "";
      descripcionEl.value = product.descripcion || "";
      precioEl.value = product.precio != null ? String(product.precio) : "";
      stockDisponibleEl.value =
        product.stock != null ? String(product.stock) : "";
      if (pesoEl)
        pesoEl.value = product.peso != null ? String(product.peso) : "";
      activoEl.value = product.activo === false ? "0" : "1";
      categoriaIdEl.value =
        product.categoriaId != null ? String(product.categoriaId) : "";
      const list = Array.isArray(product.imagenes)
        ? product.imagenes
        : product.imagen
          ? [product.imagen]
          : [];
      imagenesUrlsEl.value = list.join("\n");
      if (divisionEl) divisionEl.value = product.division || "";
      if (unidadVentaEl) unidadVentaEl.value = product.unidadVenta || "";
      fillDims(product.especificaciones || null);
      let fallbackUnit = "";
      variantesForm = Array.isArray(product.variantes)
        ? product.variantes.map((v) => {
            let l = null,
              a = null,
              g = null,
              u = "";
            try {
              const s =
                typeof v.especificaciones === "string"
                  ? JSON.parse(v.especificaciones)
                  : v.especificaciones;
              const d = s?.dimensiones;
              if (d) {
                l = Number(d.largo);
                a = Number(d.ancho);
                g = Number(d.grosor);
                u = String(d.unidad || "");
              }
            } catch {}
            if (!fallbackUnit && u) fallbackUnit = u;
            return {
              ...v,
              largo: Number.isFinite(l) ? l : null,
              ancho: Number.isFinite(a) ? a : null,
              grosor: Number.isFinite(g) ? g : null,
            };
          })
        : [];
      if (!product.especificaciones && fallbackUnit)
        setDimsUnidad(fallbackUnit);
      renderVariantesForm();
      openForm("edit", product.nombre);
    }
    function parseImageUrls(rawValue) {
      return String(rawValue || "")
        .split(/\r?\n|,/)
        .map((u) => u.trim())
        .filter(Boolean);
    }
    function applyFilters() {
      const q = String(searchProductsEl?.value || "")
        .trim()
        .toLowerCase();
      filteredProducts = products.filter((p) => {
        if (!q) return true;
        return (
          String(p.nombre || "")
            .toLowerCase()
            .includes(q) ||
          String(p.categoria || "")
            .toLowerCase()
            .includes(q) ||
          String(p.division || "")
            .toLowerCase()
            .includes(q)
        );
      });
    }
    function getPageProducts() {
      applyFilters();
      const perPage = Number(rowsPerPageEl?.value || 10);
      const totalPages = Math.max(
        1,
        Math.ceil(filteredProducts.length / perPage),
      );
      if (currentPage > totalPages) currentPage = totalPages;
      const start = (currentPage - 1) * perPage;
      return {
        items: filteredProducts.slice(start, start + perPage),
        total: filteredProducts.length,
        totalPages,
        perPage,
        start,
      };
    }

    function renderPagination({ total, totalPages, perPage, start, items }) {
      if (productsResultsInfoEl)
        productsResultsInfoEl.textContent =
          total > 0
            ? `Mostrando ${start + 1}–${start + items.length} de ${total} resultados`
            : "Sin resultados";
      if (!paginationControlsEl) return;
      paginationControlsEl.innerHTML = "";

      function mkBtn(label, page, active, disabled, isArrow) {
        var b = document.createElement("button");
        b.className =
          "pa-page-btn" +
          (active ? " active" : "") +
          (disabled ? " disabled" : "") +
          (isArrow ? " pa-page-btn--arrow" : "");
        b.type = "button";
        if (isArrow) {
          var svg = document.createElementNS(
            "http://www.w3.org/2000/svg",
            "svg",
          );
          svg.setAttribute("viewBox", "0 0 24 24");
          svg.setAttribute("width", "13");
          svg.setAttribute("height", "13");
          svg.setAttribute("fill", "none");
          svg.setAttribute("stroke", "currentColor");
          svg.setAttribute("stroke-width", "2.5");
          svg.setAttribute("stroke-linecap", "round");
          svg.setAttribute("stroke-linejoin", "round");
          svg.style.display = "block";
          svg.style.pointerEvents = "none";
          var p = document.createElementNS(
            "http://www.w3.org/2000/svg",
            "path",
          );
          p.setAttribute(
            "d",
            label === "prev" ? "M15 18l-6-6 6-6" : "M9 18l6-6-6-6",
          );
          svg.appendChild(p);
          b.appendChild(svg);
        } else {
          b.textContent = label;
        }
        b.disabled = disabled;
        if (!disabled && !active)
          b.addEventListener("click", function () {
            currentPage = page;
            renderProducts();
          });
        return b;
      }

      paginationControlsEl.appendChild(
        mkBtn("prev", currentPage - 1, false, currentPage === 1, true),
      );
      var delta = 2;
      var pages = new Set([1, totalPages]);
      for (
        var i = Math.max(2, currentPage - delta);
        i <= Math.min(totalPages - 1, currentPage + delta);
        i++
      )
        pages.add(i);
      var prev = 0;
      var sorted = Array.from(pages).sort(function (a, b) {
        return a - b;
      });
      sorted.forEach(function (p) {
        if (prev && p - prev > 1) {
          var ellipsis = document.createElement("span");
          ellipsis.className = "pa-page-ellipsis";
          ellipsis.textContent = "…";
          paginationControlsEl.appendChild(ellipsis);
        }
        paginationControlsEl.appendChild(
          mkBtn(String(p), p, p === currentPage, false, false),
        );
        prev = p;
      });
      paginationControlsEl.appendChild(
