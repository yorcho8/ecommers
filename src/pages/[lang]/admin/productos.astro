    .pa-form-section{margin-bottom:18px;border:1px solid var(--pa-border);border-radius:12px;padding:16px;background:rgba(255,255,255,.02);}
    .pa-form-section__title{display:flex;align-items:center;gap:8px;font-size:11px;font-weight:800;color:var(--pa-text-3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:14px;}
    .pa-form-section__icon{font-size:16px;}
    .pa-form-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
    .pa-form-grid--2{grid-template-columns:repeat(2,1fr);}
    .pa-field{display:flex;flex-direction:column;gap:5px;}
    .pa-field label{font-size:10px;font-weight:800;color:var(--pa-text-3);text-transform:uppercase;letter-spacing:.07em;}
    .pa-field--full{grid-column:1/-1;}
    .pa-hint{margin:8px 0 0;font-size:11px;color:var(--pa-text-3);}

    /* â”€â”€ Dimensions â”€â”€ */
    .pa-dims-units{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:14px;}
    .pa-dims-label{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.07em;color:var(--pa-text-3);white-space:nowrap;}
    .pa-dims-radio{display:inline-flex;align-items:center;gap:4px;font-size:12px;cursor:pointer;padding:4px 12px;border:1px solid var(--pa-border);border-radius:20px;color:var(--pa-text-2);user-select:none;transition:all .15s;}
    .pa-dims-radio:has(input:checked){border-color:var(--pa-accent-border);background:var(--pa-accent-glow);color:var(--pa-accent-hover);}
    .pa-dims-radio input{width:auto;margin:0;padding:0;border:none;background:none;accent-color:var(--pa-accent);}
    .pa-dims-rows{display:flex;flex-direction:column;gap:10px;}
    .pa-dims-row{display:grid;grid-template-columns:56px 1fr auto 1fr;align-items:center;gap:8px;}
    .pa-dims-row--exact{grid-template-columns:120px minmax(0,260px);}
    .pa-dims-row-label{font-size:12px;font-weight:700;color:var(--pa-text-3);}
    .pa-dims-input-group{display:flex;flex-direction:column;gap:2px;}
    .pa-dims-minmax{font-size:9px;text-transform:uppercase;color:var(--pa-text-3);letter-spacing:.05em;}
    .pa-dims-separator{color:var(--pa-text-3);padding:0 2px;}

    /* â”€â”€ Inputs â”€â”€ */
    .pa-page input,.pa-page select,.pa-page textarea{width:100%;border:1.5px solid var(--pa-border);border-radius:var(--pa-radius-sm);padding:10px 12px;background:rgba(255,255,255,.03);color:var(--pa-text);font-size:13px;margin-bottom:0;transition:border-color .2s,box-shadow .2s;box-sizing:border-box;font-family:inherit;outline:none;}
    .pa-page input:focus,.pa-page select:focus,.pa-page textarea:focus{border-color:rgba(168,85,247,.5);box-shadow:0 0 0 3px rgba(168,85,247,.1);}
    .pa-page input::placeholder,.pa-page textarea::placeholder{color:var(--pa-text-3);}
    .pa-page textarea{resize:vertical;min-height:80px;}

    /* â”€â”€ Variantes â”€â”€ */
    .pa-variantes{display:flex;flex-direction:column;gap:8px;}
    .pa-variantes-empty{font-size:12px;color:var(--pa-text-3);margin:0;padding:14px;border:1px dashed var(--pa-border);border-radius:var(--pa-radius-sm);text-align:center;}
    .pa-variante-row{display:grid;grid-template-columns:1.2fr repeat(6,minmax(90px,1fr)) 36px;gap:8px;align-items:end;background:rgba(255,255,255,.02);border:1px solid var(--pa-border);border-radius:12px;padding:12px 14px;}
    .pa-var-field{display:flex;flex-direction:column;gap:4px;}
    .pa-var-field label{font-size:10px;font-weight:800;color:var(--pa-text-3);text-transform:uppercase;letter-spacing:.06em;}
    .pa-var-field--sm{}
    .pa-var-del{width:36px;height:36px;border-radius:var(--pa-radius-sm);border:1px solid var(--pa-red-border);background:var(--pa-red-bg);color:var(--pa-red);cursor:pointer;display:inline-flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0;}
    .pa-var-del:hover{background:rgba(239,68,68,.15);}
    .pa-var-del svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
    .pa-btn-add-var{margin-left:auto;font-size:11px;font-weight:700;color:var(--pa-accent-hover);background:var(--pa-accent-glow);border:1px solid var(--pa-accent-border);border-radius:20px;padding:4px 14px;cursor:pointer;transition:all .15s;font-family:inherit;}
    .pa-btn-add-var:hover{background:var(--pa-accent-glow-s);}

    /* â”€â”€ Gallery btn â”€â”€ */
    .pa-btn-gallery{display:inline-flex;align-items:center;gap:8px;width:100%;padding:14px 16px;border:1px dashed var(--pa-border);border-radius:14px;background:rgba(255,255,255,.02);color:var(--pa-text-3);font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;justify-content:center;font-family:inherit;}
    .pa-btn-gallery:hover{border-color:var(--pa-accent-border);background:var(--pa-accent-glow);color:var(--pa-accent-hover);}
    .pa-btn-gallery svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;}

    /* â”€â”€ Action Buttons â”€â”€ */
    .pa-form-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:8px;}
    .pa-btn-save{display:inline-flex;align-items:center;gap:7px;border:none;background:linear-gradient(135deg,var(--pa-accent),#7c3aed);color:#fff;border-radius:12px;padding:11px 22px;font-size:13px;font-weight:700;cursor:pointer;box-shadow:0 4px 16px rgba(168,85,247,.3);transition:all .2s;font-family:inherit;}
    .pa-btn-save:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(168,85,247,.4);}
    .pa-btn-save svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round;}
    .pa-btn-ghost,.pa-btn-close{border:1px solid var(--pa-border);border-radius:12px;padding:10px 16px;font-size:12px;background:rgba(255,255,255,.03);color:var(--pa-text-2);cursor:pointer;font-weight:600;transition:all .15s;font-family:inherit;}
    .pa-btn-ghost:hover,.pa-btn-close:hover{background:rgba(255,255,255,.06);color:var(--pa-text);}

    /* â”€â”€ Toolbar â”€â”€ */
    .pa-toolbar{display:grid;grid-template-columns:1fr auto 1fr;gap:10px;align-items:center;border:1px solid var(--pa-border);background:rgba(255,255,255,.02);border-radius:12px;padding:12px 14px;margin-bottom:14px;}
    .pa-toolbar__left,.pa-toolbar__right{display:inline-flex;align-items:center;gap:6px;font-size:11px;color:var(--pa-text-3);}
    .pa-toolbar__right{justify-self:end;}
    .pa-toolbar__center{display:inline-flex;gap:5px;justify-self:center;flex-wrap:wrap;}
    .pa-toolbar-select{margin:0;padding:7px 10px;font-size:12px;border-radius:8px;border:1px solid var(--pa-border);min-width:64px;}
    .pa-toolbar-search{width:220px;margin:0;padding:7px 10px;font-size:12px;border-radius:8px;}
    .pa-mini-btn{border:1px solid var(--pa-border);background:rgba(255,255,255,.03);color:var(--pa-text-2);border-radius:8px;padding:6px 12px;font-size:11px;font-weight:700;cursor:pointer;transition:all .15s;font-family:inherit;}
    .pa-mini-btn:hover{background:rgba(255,255,255,.06);border-color:var(--pa-border-hover);}
    .pa-mini-btn--green{color:var(--pa-green);border-color:var(--pa-green-border);}
    .pa-mini-btn--red{color:var(--pa-red);border-color:var(--pa-red-border);}
    .pa-mini-btn--blue{color:var(--pa-blue);border-color:var(--pa-blue-border);}

    /* â”€â”€ List Header â”€â”€ */
    .pa-list-section{margin-top:16px;}
    .pa-list-header{display:flex;justify-content:space-between;align-items:center;gap:8px;margin-bottom:12px;flex-wrap:wrap;}
    .pa-list-header h2{margin:0;font-size:16px;font-weight:700;color:var(--pa-text);}

    /* â”€â”€ Table â”€â”€ */
    .pa-table-wrap{overflow:auto;max-height:62vh;border:1px solid var(--pa-border);border-radius:12px;}
    .pa-table{width:100%;border-collapse:collapse;min-width:1200px;font-size:12px;background:var(--pa-surface-solid);table-layout:fixed;}
    .pa-table th,.pa-table td{border-bottom:1px solid rgba(255,255,255,.05);padding:10px;text-align:left;color:var(--pa-text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
    .pa-table th{position:sticky;top:0;background:var(--pa-surface-2);color:var(--pa-text-3);font-size:10px;text-transform:uppercase;letter-spacing:.07em;font-weight:800;z-index:2;}
    .pa-table tr:hover td{background:rgba(168,85,247,.03);}
    .pa-table col.col-id{width:44px}.pa-table col.col-nombre{width:22%}.pa-table col.col-categoria{width:13%}.pa-table col.col-division{width:13%}.pa-table col.col-imagen{width:62px}.pa-table col.col-precio{width:72px}.pa-table col.col-stock{width:52px}.pa-table col.col-variantes{width:90px}.pa-table col.col-estado{width:72px}.pa-table col.col-fecha{width:82px}.pa-table col.col-acciones{width:120px}
    .pa-th-actions,.pa-td-actions{text-align:center;}
    .pa-td-image{text-align:center;}
    .pa-td-id{color:var(--pa-text-3);font-size:11px;}
    .pa-td-nombre strong{color:var(--pa-text);}
    .pa-td-precio{color:var(--pa-green);font-weight:700;}
    .pa-td-fecha{color:var(--pa-text-3);font-size:11px;}

    /* â”€â”€ Thumbnails â”€â”€ */
    .pa-thumb-wrap{width:48px;height:48px;margin:0 auto;border-radius:10px;overflow:hidden;border:1px solid var(--pa-border);background:var(--pa-surface-2);display:grid;place-items:center;cursor:pointer;transition:all .2s;}
    .pa-thumb-wrap:hover{transform:scale(1.08);border-color:var(--pa-accent-border);}
    .pa-no-img{font-size:10px;color:var(--pa-text-3);}

    /* â”€â”€ Badges â”€â”€ */
    .pa-division-badge{display:inline-block;font-size:10px;font-weight:700;padding:3px 10px;border-radius:20px;background:var(--pa-accent-glow);color:var(--pa-accent-hover);border:1px solid var(--pa-accent-border);white-space:nowrap;}
    .pa-variantes-badge{display:inline-block;font-size:10px;font-weight:700;padding:3px 10px;border-radius:20px;background:var(--pa-blue-bg);color:var(--pa-blue);border:1px solid var(--pa-blue-border);}
    .pa-estado{display:inline-block;font-size:10px;font-weight:700;padding:3px 10px;border-radius:20px;}
    .pa-estado--on{background:var(--pa-green-bg);color:var(--pa-green);border:1px solid var(--pa-green-border);}
    .pa-estado--off{background:var(--pa-red-bg);color:var(--pa-red);border:1px solid var(--pa-red-border);}
    .pa-no-data{color:var(--pa-text-3);font-size:11px;}

    /* â”€â”€ Row Actions & Pagination: styles injected via runtime script for specificity â”€â”€ */
    .pa-pagination{
      display:flex;align-items:center;justify-content:space-between;
      flex-wrap:wrap;gap:12px;
      padding:16px 4px 4px;
      border-top:1px solid var(--pa-border);
      margin-top:8px;
    }
    .pa-pagination__info{font-size:12px;color:var(--pa-text-2);font-weight:500;}
    .pa-pagination__controls{display:flex;align-items:center;gap:4px;}

    /* â”€â”€ Image Viewer â”€â”€ */
    .img-viewer-modal{position:fixed;inset:0;z-index:10000;background:rgba(0,0,0,.6);backdrop-filter:blur(12px);display:grid;place-items:center;opacity:0;pointer-events:none;transition:opacity .22s ease;}
    .img-viewer-modal.is-open{opacity:1;pointer-events:auto;}
    .img-viewer-modal[hidden]{display:none!important;}
    .img-viewer-panel{width:calc(100vw - 40px);max-width:520px;max-height:calc(100vh - 60px);overflow-y:auto;border-radius:24px;background:var(--pa-surface-solid);border:1px solid var(--pa-border);box-shadow:var(--pa-shadow-lg);padding:0;position:relative;color:var(--pa-text);transform:translateY(16px) scale(.96);opacity:0;transition:transform .28s cubic-bezier(.16,1,.3,1),opacity .22s ease;}
    .img-viewer-panel.is-open{transform:translateY(0) scale(1);opacity:1;}
    .img-viewer-panel::-webkit-scrollbar{width:6px}.img-viewer-panel::-webkit-scrollbar-thumb{background:rgba(255,255,255,.12);border-radius:10px;}
    .img-viewer-header{display:flex;align-items:center;justify-content:space-between;padding:20px 24px 14px;border-bottom:1px solid var(--pa-border);}
    .img-viewer-header-text{display:flex;flex-direction:column;gap:4px;}
    .img-viewer-badge{display:inline-block;width:fit-content;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;padding:3px 12px;border-radius:20px;background:linear-gradient(135deg,var(--pa-accent),#7c3aed);color:#fff;}
    .img-viewer-title{margin:0;font-size:16px;font-weight:800;color:var(--pa-text);}
    .img-viewer-close{width:36px;height:36px;border-radius:12px;border:1px solid var(--pa-border);background:rgba(255,255,255,.03);color:var(--pa-text-2);cursor:pointer;display:grid;place-items:center;transition:all .15s;}
    .img-viewer-close:hover{background:var(--pa-accent-glow);color:var(--pa-accent-hover);border-color:var(--pa-accent-border);}
    .img-viewer-close svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
    .img-viewer-preview-card{padding:16px 24px 0;}
    .img-viewer-preview{width:100%;aspect-ratio:4/3;border-radius:16px;background:var(--pa-surface-2);border:1px solid var(--pa-border);overflow:hidden;display:grid;place-items:center;}
    .img-viewer-img{width:100%;height:100%;object-fit:contain;display:block;}
    .img-viewer-empty{display:flex;flex-direction:column;align-items:center;gap:8px;color:var(--pa-text-3);font-size:13px;}
    .img-viewer-empty svg{width:40px;height:40px;stroke:currentColor;fill:none;stroke-width:1.2;opacity:.5;}
    .img-viewer-counter{margin:8px 0 0;text-align:center;font-size:11px;color:var(--pa-text-3);font-weight:600;}
    .img-viewer-section{padding:14px 24px 0;}
    .img-viewer-section-label{margin:0 0 10px;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:var(--pa-text-3);}
    .img-viewer-list{display:flex;flex-direction:column;gap:6px;}
    .img-viewer-row{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:14px;border:1px solid var(--pa-border);background:rgba(255,255,255,.02);transition:all .18s;}
    .img-viewer-row:hover{background:rgba(255,255,255,.04);}
    .img-viewer-row.is-selected{border-color:var(--pa-accent-border);background:var(--pa-accent-glow);}
    .img-viewer-row-thumb{width:48px;height:48px;border-radius:10px;object-fit:cover;cursor:pointer;flex-shrink:0;border:2px solid var(--pa-border);transition:all .15s;}
    .img-viewer-row-thumb:hover{border-color:var(--pa-accent-border);transform:scale(1.05);}
    .img-viewer-row.is-selected .img-viewer-row-thumb{border-color:var(--pa-accent);}
    .img-viewer-row-meta{flex:1;min-width:0;display:flex;flex-direction:column;gap:2px;}
    .img-viewer-row-name{margin:0;font-size:11px;font-weight:700;color:var(--pa-text);}
    .img-viewer-row-url{margin:0;font-size:10px;color:var(--pa-text-3);font-family:'SF Mono',monospace;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .img-viewer-row-del{width:34px;height:34px;flex-shrink:0;border-radius:10px;border:1px solid var(--pa-border);background:rgba(255,255,255,.02);color:var(--pa-text-3);cursor:pointer;display:inline-flex;align-items:center;justify-content:center;transition:all .15s;}
    .img-viewer-row-del:hover{background:var(--pa-red-bg);border-color:var(--pa-red-border);color:var(--pa-red);}
    .img-viewer-row-del svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
    .img-viewer-upload-box{display:flex;flex-direction:column;gap:8px;border:1px dashed var(--pa-border);border-radius:14px;padding:14px;background:rgba(255,255,255,.02);}
    .img-viewer-upload-top{display:flex;gap:10px;align-items:center;flex-wrap:wrap;}
    .img-viewer-file{display:none;}
    .img-viewer-upload-select{display:inline-flex;align-items:center;gap:6px;cursor:pointer;border:1px solid var(--pa-border);background:rgba(255,255,255,.03);color:var(--pa-text-2);border-radius:12px;padding:10px 16px;font-size:12px;font-weight:700;transition:all .15s;}
    .img-viewer-upload-select:hover{border-color:var(--pa-accent-border);color:var(--pa-accent-hover);}
    .img-viewer-upload-select svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round;}
    .img-viewer-upload-hint{margin:0;font-size:11px;color:var(--pa-text-3);}
    .img-viewer-upload-hint.is-error{color:var(--pa-red);}
    .img-viewer-footer{display:flex;justify-content:flex-end;gap:10px;padding:18px 24px 22px;border-top:1px solid var(--pa-border);margin-top:18px;}
    .img-viewer-cancel{border-radius:12px;border:1px solid var(--pa-border);background:rgba(255,255,255,.03);color:var(--pa-text-2);font-size:13px;font-weight:600;padding:10px 20px;cursor:pointer;transition:all .15s;font-family:inherit;}
    .img-viewer-cancel:hover{background:rgba(255,255,255,.06);color:var(--pa-text);}
    .img-viewer-save{display:inline-flex;align-items:center;gap:7px;border-radius:12px;border:none;background:linear-gradient(135deg,var(--pa-accent),#7c3aed);color:#fff;font-size:13px;font-weight:700;padding:10px 24px;cursor:pointer;box-shadow:0 2px 12px rgba(168,85,247,.3);transition:all .15s;font-family:inherit;}
    .img-viewer-save:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(168,85,247,.4);}
    .img-viewer-save svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2.5;}
    .img-viewer-row-drag{width:24px;flex-shrink:0;cursor:grab;display:grid;place-items:center;color:var(--pa-text-3);transition:color .15s;}
    .img-viewer-row-drag:hover{color:var(--pa-text-2);}
    .img-viewer-row-drag svg{width:18px;height:18px;stroke:currentColor;fill:currentColor;stroke-width:3;}
    .img-viewer-row.is-dragging{opacity:.4;transform:scale(.97);}
    .img-viewer-row.drag-over{border-color:var(--pa-accent-border);background:var(--pa-accent-glow);}

    /* â”€â”€ Responsive â”€â”€ */
    @media(max-width:1100px){.pa-header{flex-direction:column;}.pa-top-actions{width:100%;}.pa-toolbar{grid-template-columns:1fr;}.pa-toolbar__center,.pa-toolbar__right{justify-self:start;}}
    @media(max-width:820px){.pa-form-grid{grid-template-columns:1fr;}.pa-variante-row{grid-template-columns:1fr 36px;}.pa-var-field--sm{display:none;}.pa-toolbar-search{width:100%;}.pa-pagination{flex-direction:column;align-items:flex-start;}}
  </style>
</BaseLayout>


