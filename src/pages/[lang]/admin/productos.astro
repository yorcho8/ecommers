    rowsEl?.addEventListener("click", async (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const thumb = target.closest(".pa-thumb-wrap");
      if (thumb) {
        const tr = thumb.closest("tr");
        const editBtn = tr?.querySelector("button[data-action='edit']");
        const productId = editBtn?.dataset?.id;
        if (productId) openImageViewer(productId);
        return;
      }
      const button = target.closest("button[data-action]");
      if (!(button instanceof HTMLButtonElement)) return;
      const action = button.dataset.action,
        productId = Number(button.dataset.id || 0);
      if (!productId) return;
      if (action === "edit") {
        const product = products.find((p) => Number(p.id) === productId);
        if (product) fillForm(product);
        return;
      }
      if (action === "toggle") {
        try {
          const current = Number(button.dataset.active || 1) === 1;
          Modal.loading(
            current ? "Desactivando..." : "Activando...",
            "Actualizando estado del producto",
          );
          const r = await fetch(`/api/admin/productos/${productId}`, {
            method: "PATCH",
            credentials: "include",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ activo: current ? 0 : 1 }),
          });
          const d = await r.json().catch(() => ({}));
          Modal.hideLoading();
          if (!r.ok || !d?.success)
            throw new Error(d?.error || "No se pudo cambiar el estado");
          Modal.success(
            "Estado actualizado",
            current ? "Producto desactivado" : "Producto activado",
            { autoClose: 2000 },
          );
          await fetchProducts();
        } catch (err) {
          Modal.hideLoading();
          Modal.error("Error", err.message || "Error");
        }
        return;
      }
      if (action === "delete") {
        const ok = await Modal.confirm(
          "Eliminar producto",
          "¿Estás seguro? Esta acción no se puede deshacer.",
          { confirmText: "Sí, eliminar", cancelText: "Cancelar" },
        );
        if (!ok) return;
        try {
          Modal.loading("Eliminando producto", "Por favor espera...");
          const r = await fetch(`/api/admin/productos/${productId}`, {
            method: "DELETE",
            credentials: "include",
          });
          const d = await r.json().catch(() => ({}));
          Modal.hideLoading();
          if (!r.ok || !d?.success)
            throw new Error(d?.error || "No se pudo eliminar");
          Modal.success(
            "Eliminado",
            "El producto fue eliminado correctamente",
            { autoClose: 2000 },
          );
          closeForm();
          await fetchProducts();
        } catch (err) {
          Modal.hideLoading();
          Modal.error("Error", err.message || "Error");
        }
      }
    });
