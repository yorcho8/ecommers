  <!-- All JS logic -->
  <script nonce={cspNonce} is:inline>
    const formPanelEl=document.getElementById("productsFormPanel");const formTitleEl=document.getElementById("formTitle");const currentProductIdEl=document.getElementById("currentProductId");const rowsEl=document.getElementById("productsRows");const btnAddProduct=document.getElementById("btnAddProduct");const searchProductsEl=document.getElementById("searchProducts");const rowsPerPageEl=document.getElementById("rowsPerPage");const productsResultsInfoEl=document.getElementById("productsResultsInfo");const statsBarEl=document.getElementById("statsBar");const paginationControlsEl=document.getElementById("paginationControls");const btnCopy=document.getElementById("btnCopy");const btnExcel=document.getElementById("btnExcel");const btnPdf=document.getElementById("btnPdf");const btnCsv=document.getElementById("btnCsv");const nombreEl=document.getElementById("nombre");const codigoReferenciaEl=document.getElementById("codigoReferencia");const descripcionEl=document.getElementById("descripcion");const precioEl=document.getElementById("precio");const stockDisponibleEl=document.getElementById("stockDisponible");const pesoEl=document.getElementById("peso");const activoEl=document.getElementById("activo");const categoriaIdEl=document.getElementById("categoriaId");const imagenesUrlsEl=document.getElementById("imagenesUrls");const btnSave=document.getElementById("btnSave");const btnCancelEdit=document.getElementById("btnCancelEdit");const btnFormReset=document.getElementById("btnFormReset");const divisionEl=document.getElementById("division");const unidadVentaEl=document.getElementById("unidadVenta");const variantesContainer=document.getElementById("variantesContainer");const btnAddVariante=document.getElementById("btnAddVariante");const largoExactoEl=document.getElementById("largoExacto");const anchoExactoEl=document.getElementById("anchoExacto");const grosorExactoEl=document.getElementById("grosorExacto");

    let products=[],categories=[],filteredProducts=[],formMode="create";let variantesForm=[];let currentPage=1;

    /* â”€â”€â”€ SVG helper â€” creates proper namespace SVG via DOM â”€â”€â”€ */
    function makeSVG(pathsArray, w, h, sw) {
      var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('viewBox', '0 0 24 24');
      svg.setAttribute('width', String(w || 14));
      svg.setAttribute('height', String(h || 14));
      svg.setAttribute('fill', 'none');
      svg.setAttribute('stroke', 'currentColor');
      svg.setAttribute('stroke-width', String(sw || 2));
      svg.setAttribute('stroke-linecap', 'round');
      svg.setAttribute('stroke-linejoin', 'round');
      svg.style.display = 'block';
      svg.style.pointerEvents = 'none';
      pathsArray.forEach(function(d) {
        var p = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        p.setAttribute('d', d);
        svg.appendChild(p);
      });
      return svg;
    }
    var SVG_TOGGLE_ON = ['M5 12l4 4L19 6'];
    var SVG_TOGGLE_OFF = ['M6 6l12 12', 'M18 6l-12 12'];
    var SVG_EDIT = ['M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7','M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z'];
    var SVG_DELETE = ['M3 6h18','M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2','M10 11v6','M14 11v6'];

    function getDimsUnidad(){return 'cm';}
    function setDimsUnidad(){return;}
    function buildEspecificaciones(){const u=getDimsUnidad(),l=parseFloat(largoExactoEl?.value||''),a=parseFloat(anchoExactoEl?.value||''),g=parseFloat(grosorExactoEl?.value||'');if(!Number.isFinite(l)&&!Number.isFinite(a)&&!Number.isFinite(g))return null;if(!Number.isFinite(l)||!Number.isFinite(a)||!Number.isFinite(g)||l<=0||a<=0||g<=0)return null;return JSON.stringify({dimensiones:{unidad:u,largo:l,ancho:a,grosor:g}});}
    function fillDims(especStr){if(largoExactoEl)largoExactoEl.value='';if(anchoExactoEl)anchoExactoEl.value='';if(grosorExactoEl)grosorExactoEl.value='';setDimsUnidad('cm');if(!especStr)return;try{const s=typeof especStr==='string'?JSON.parse(especStr):especStr;const d=s?.dimensiones;if(d){if(largoExactoEl&&Number.isFinite(Number(d.largo)))largoExactoEl.value=String(d.largo);if(anchoExactoEl&&Number.isFinite(Number(d.ancho)))anchoExactoEl.value=String(d.ancho);if(grosorExactoEl&&Number.isFinite(Number(d.grosor)))grosorExactoEl.value=String(d.grosor);if(d.unidad)setDimsUnidad(String(d.unidad));return;}if(s?.largo&&typeof s.largo==='object'&&('min' in s.largo||'max' in s.largo)){if(largoExactoEl)largoExactoEl.value=String(s.largo.max||s.largo.min||'');if(s.largo.unidad)setDimsUnidad(String(s.largo.unidad));}if(s?.ancho&&typeof s.ancho==='object'&&('min' in s.ancho||'max' in s.ancho)){if(anchoExactoEl)anchoExactoEl.value=String(s.ancho.max||s.ancho.min||'');}if((s?.alto&&typeof s.alto==='object'&&('min' in s.alto||'max' in s.alto))||(s?.grosor&&typeof s.grosor==='object'&&('min' in s.grosor||'max' in s.grosor))){const src=s.grosor||s.alto;if(grosorExactoEl)grosorExactoEl.value=String(src.max||src.min||'');}}catch{}}

    function renderVariantesForm(){if(!variantesContainer)return;if(variantesForm.length===0){variantesContainer.innerHTML='<p class="pa-variantes-empty">Sin variantes. Puedes crear variantes por color, caja, calibre u otra presentaciÃ³n.</p>';return;}variantesContainer.innerHTML="";variantesForm.forEach((v,idx)=>{const row=document.createElement("div");row.className="pa-variante-row";row.innerHTML=`<div class="pa-var-field"><label>DescripciÃ³n / Tipo</label><input type="text" class="v-desc" value="${v.descripcion||""}" placeholder="Ej: Color azul, Caja 50 pzs" /></div><div class="pa-var-field pa-var-field--sm"><label>Precio</label><input type="number" class="v-precio" value="${v.precio!=null?v.precio:""}" placeholder="Opcional" min="0" step="0.01" /></div><div class="pa-var-field pa-var-field--sm"><label>Stock</label><input type="number" class="v-stock" value="${v.stock!=null?v.stock:""}" placeholder="0" min="0" step="1" /></div><div class="pa-var-field pa-var-field--sm"><label>Peso kg</label><input type="number" class="v-peso" value="${v.peso!=null?v.peso:""}" placeholder="Opcional" min="0" step="0.01" /></div><div class="pa-var-field pa-var-field--sm"><label>Largo</label><input type="number" class="v-largo" value="${v.largo!=null?v.largo:""}" placeholder="Opcional" min="0" step="0.01" /></div><div class="pa-var-field pa-var-field--sm"><label>Ancho</label><input type="number" class="v-ancho" value="${v.ancho!=null?v.ancho:""}" placeholder="Opcional" min="0" step="0.01" /></div><div class="pa-var-field pa-var-field--sm"><label>Grosor</label><input type="number" class="v-grosor" value="${v.grosor!=null?v.grosor:""}" placeholder="Opcional" min="0" step="0.01" /></div><button class="pa-var-del" type="button" data-idx="${idx}"><svg viewBox="0 0 24 24"><path d="M6 7h12m-9 0V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2m-8 0l1 13h8l1-13M10 11v6M14 11v6"></path></svg></button>`;row.querySelector(".v-desc").addEventListener("input",e=>{variantesForm[idx].descripcion=e.target.value;});row.querySelector(".v-precio").addEventListener("input",e=>{variantesForm[idx].precio=e.target.value!==""?Number(e.target.value):null;});row.querySelector(".v-stock").addEventListener("input",e=>{variantesForm[idx].stock=e.target.value!==""?Number(e.target.value):null;});row.querySelector(".v-peso").addEventListener("input",e=>{variantesForm[idx].peso=e.target.value!==""?Number(e.target.value):null;});row.querySelector(".v-largo").addEventListener("input",e=>{variantesForm[idx].largo=e.target.value!==""?Number(e.target.value):null;});row.querySelector(".v-ancho").addEventListener("input",e=>{variantesForm[idx].ancho=e.target.value!==""?Number(e.target.value):null;});row.querySelector(".v-grosor").addEventListener("input",e=>{variantesForm[idx].grosor=e.target.value!==""?Number(e.target.value):null;});row.querySelector(".pa-var-del").addEventListener("click",()=>{variantesForm.splice(idx,1);renderVariantesForm();});variantesContainer.appendChild(row);});}
    btnAddVariante?.addEventListener("click",()=>{variantesForm.push({descripcion:"",precio:null,stock:null,peso:null,largo:null,ancho:null,grosor:null});renderVariantesForm();});

    function setMode(mode,label){formMode=mode;if(!formTitleEl||!currentProductIdEl)return;if(mode==="edit")formTitleEl.innerHTML=`Editando: <span style="color:#c084fc;font-weight:700">${label||""}</span>`;else{formTitleEl.textContent="Nuevo producto";currentProductIdEl.value="";}}
    function resetForm(){if(!nombreEl)return;nombreEl.value="";if(codigoReferenciaEl)codigoReferenciaEl.value="";descripcionEl.value="";precioEl.value="";stockDisponibleEl.value="";activoEl.value="1";categoriaIdEl.value="";imagenesUrlsEl.value="";if(pesoEl)pesoEl.value="";if(divisionEl)divisionEl.value="";if(unidadVentaEl)unidadVentaEl.value="";fillDims(null);variantesForm=[];renderVariantesForm();setMode("create");}
    function openForm(mode="create",label){if(!formPanelEl)return;formPanelEl.hidden=false;setMode(mode,label);formPanelEl.scrollIntoView({behavior:"smooth",block:"start"});}
    function closeForm(){if(!formPanelEl)return;formPanelEl.hidden=true;resetForm();}
    function renderCategories(){if(!categoriaIdEl)return;categoriaIdEl.innerHTML=['<option value="">Selecciona categorÃ­a</option>'].concat(categories.map(cat=>{const id=Number(cat.id||cat.Id_Categoria||0);const nombre=String(cat.nombre||cat.Nombre||"");return`<option value="${id}">${nombre}</option>`;})).join("");}
    function fillForm(product){if(!nombreEl||!currentProductIdEl)return;currentProductIdEl.value=String(product.id);nombreEl.value=product.nombre||"";if(codigoReferenciaEl)codigoReferenciaEl.value=product.codigoReferencia||"";descripcionEl.value=product.descripcion||"";precioEl.value=product.precio!=null?String(product.precio):"";stockDisponibleEl.value=product.stock!=null?String(product.stock):"";if(pesoEl)pesoEl.value=product.peso!=null?String(product.peso):"";activoEl.value=product.activo===false?"0":"1";categoriaIdEl.value=product.categoriaId!=null?String(product.categoriaId):"";const list=Array.isArray(product.imagenes)?product.imagenes:product.imagen?[product.imagen]:[];imagenesUrlsEl.value=list.join("\n");if(divisionEl)divisionEl.value=product.division||"";if(unidadVentaEl)unidadVentaEl.value=product.unidadVenta||"";fillDims(product.especificaciones||null);let fallbackUnit='';variantesForm=Array.isArray(product.variantes)?product.variantes.map(v=>{let l=null,a=null,g=null,u='';try{const s=typeof v.especificaciones==='string'?JSON.parse(v.especificaciones):v.especificaciones;const d=s?.dimensiones;if(d){l=Number(d.largo);a=Number(d.ancho);g=Number(d.grosor);u=String(d.unidad||'');}}catch{}if(!fallbackUnit&&u)fallbackUnit=u;return({...v,largo:Number.isFinite(l)?l:null,ancho:Number.isFinite(a)?a:null,grosor:Number.isFinite(g)?g:null});}):[];if(!product.especificaciones&&fallbackUnit)setDimsUnidad(fallbackUnit);renderVariantesForm();openForm("edit",product.nombre);}
    function parseImageUrls(rawValue){return String(rawValue||"").split(/\r?\n|,/).map(u=>u.trim()).filter(Boolean);}
    function applyFilters(){const q=String(searchProductsEl?.value||"").trim().toLowerCase();filteredProducts=products.filter(p=>{if(!q)return true;return String(p.nombre||"").toLowerCase().includes(q)||String(p.categoria||"").toLowerCase().includes(q)||String(p.division||"").toLowerCase().includes(q);});}
    function getPageProducts(){applyFilters();const perPage=Number(rowsPerPageEl?.value||10);const totalPages=Math.max(1,Math.ceil(filteredProducts.length/perPage));if(currentPage>totalPages)currentPage=totalPages;const start=(currentPage-1)*perPage;return{items:filteredProducts.slice(start,start+perPage),total:filteredProducts.length,totalPages,perPage,start};}

    /* â”€â”€â”€ PAGINATION RENDER (improved) â”€â”€â”€ */
    function renderPagination({total,totalPages,perPage,start,items}){
      if(productsResultsInfoEl) productsResultsInfoEl.textContent = total > 0
        ? `Mostrando ${start+1}â€“${start+items.length} de ${total} resultados`
        : 'Sin resultados';
      if(!paginationControlsEl) return;
      paginationControlsEl.innerHTML="";

      function mkBtn(label, page, active, disabled, isArrow) {
        var b = document.createElement("button");
        b.className = "pa-page-btn" + (active ? " active" : "") + (disabled ? " disabled" : "") + (isArrow ? " pa-page-btn--arrow" : "");
        b.type = "button";
        if (isArrow) {
          var svg = document.createElementNS('http://www.w3.org/2000/svg','svg');
          svg.setAttribute('viewBox','0 0 24 24');svg.setAttribute('width','14');svg.setAttribute('height','14');
          svg.setAttribute('fill','none');svg.setAttribute('stroke','currentColor');svg.setAttribute('stroke-width','2.5');
          svg.setAttribute('stroke-linecap','round');svg.setAttribute('stroke-linejoin','round');
          svg.style.display='block';svg.style.pointerEvents='none';
          var p = document.createElementNS('http://www.w3.org/2000/svg','path');
          p.setAttribute('d', label === 'prev' ? 'M15 18l-6-6 6-6' : 'M9 18l6-6-6-6');
          svg.appendChild(p);
          b.appendChild(svg);
        } else {
          b.textContent = label;
        }
        b.disabled = disabled;
        if (!disabled && !active) b.addEventListener("click", function(){ currentPage = page; renderProducts(); });
        return b;
      }

      // Previous button
      paginationControlsEl.appendChild(mkBtn("prev", currentPage - 1, false, currentPage === 1, true));

      // Page numbers with ellipsis
      var delta = 2;
      var pages = new Set([1, totalPages]);
      for (var i = Math.max(2, currentPage - delta); i <= Math.min(totalPages - 1, currentPage + delta); i++) pages.add(i);
      var prev = 0;
      var sorted = Array.from(pages).sort(function(a,b){return a-b;});
      sorted.forEach(function(p) {
        if (prev && p - prev > 1) {
          var ellipsis = document.createElement("span");
          ellipsis.className = "pa-page-ellipsis";
          ellipsis.textContent = "â€¦";
          paginationControlsEl.appendChild(ellipsis);
        }
        paginationControlsEl.appendChild(mkBtn(String(p), p, p === currentPage, false, false));
        prev = p;
      });

      // Next button
      paginationControlsEl.appendChild(mkBtn("next", currentPage + 1, false, currentPage === totalPages, true));
    }

    function renderStatsBar(){if(!statsBarEl)return;const total=products.length,activos=products.filter(p=>p.activo!==false).length,conVariantes=products.filter(p=>Array.isArray(p.variantes)&&p.variantes.length>0).length;statsBarEl.innerHTML=`<span class="pa-stat-chip">${total} total</span><span class="pa-stat-chip pa-stat-chip--green">${activos} activos</span><span class="pa-stat-chip pa-stat-chip--purple">${conVariantes} con variantes</span>`;}

    function renderProducts(){
      if(!rowsEl)return;
      rowsEl.innerHTML="";
      var pageData=getPageProducts();
      pageData.items.forEach(function(product){
        var tr=document.createElement("tr");
        var thumb=product.imagen?'<img src="'+product.imagen+'" alt="'+(product.nombre||"")+'" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;cursor:pointer;" />':'<span class="pa-no-img">Sin img</span>';
        var divisionBadge=product.division?'<span class="pa-division-badge">'+product.division+'</span>':'<span class="pa-no-data">â€”</span>';
        var vc=Array.isArray(product.variantes)?product.variantes.length:0;
        var variantesBadge=vc>0?'<span class="pa-variantes-badge">'+vc+' var'+(vc>1?"s":"")+'</span>':'<span class="pa-no-data">â€”</span>';
        var estadoBadge=product.activo===false?'<span class="pa-estado pa-estado--off">Inactivo</span>':'<span class="pa-estado pa-estado--on">Activo</span>';
        var isOff=product.activo===false;

        // Build cells
        tr.innerHTML =
          '<td class="pa-td-id">'+product.id+'</td>'+
          '<td class="pa-td-nombre"><strong>'+(product.nombre||"")+'</strong></td>'+
          '<td>'+(product.categoria||"Sin categorÃ­a")+'</td>'+
          '<td>'+divisionBadge+'</td>'+
          '<td class="pa-td-image"><div class="pa-thumb-wrap">'+thumb+'</div></td>'+
          '<td class="pa-td-precio">'+Number(product.precio||0).toFixed(2)+'</td>'+
          '<td>'+Number(product.stock||0)+'</td>'+
          '<td>'+variantesBadge+'</td>'+
          '<td>'+estadoBadge+'</td>'+
          '<td class="pa-td-fecha">'+String(product.fechaCreacion||"").slice(0,10)+'</td>'+
          '<td class="pa-td-actions"><div class="pa-row-actions"></div></td>';

        // Build action buttons with proper DOM SVGs
        var actionsDiv = tr.querySelector('.pa-row-actions');

        // Toggle button
        var toggleBtn = document.createElement('button');
        toggleBtn.className = 'pa-row-btn pa-row-btn--toggle ' + (isOff ? 'is-off' : 'is-on');
        toggleBtn.type = 'button';
        toggleBtn.dataset.action = 'toggle';
        toggleBtn.dataset.id = String(product.id);
        toggleBtn.dataset.active = isOff ? '0' : '1';
        toggleBtn.title = isOff ? 'Activar' : 'Desactivar';
        toggleBtn.appendChild(makeSVG(isOff ? SVG_TOGGLE_OFF : SVG_TOGGLE_ON, 15, 15, 2.4));
        actionsDiv.appendChild(toggleBtn);

        // Edit button
        var editBtn = document.createElement('button');
        editBtn.className = 'pa-row-btn pa-row-btn--edit';
        editBtn.type = 'button';
        editBtn.dataset.action = 'edit';
        editBtn.dataset.id = String(product.id);
        editBtn.title = 'Editar';
        editBtn.appendChild(makeSVG(SVG_EDIT, 14, 14, 2));
        actionsDiv.appendChild(editBtn);

        // Delete button
        var delBtn = document.createElement('button');
        delBtn.className = 'pa-row-btn pa-row-btn--delete';
        delBtn.type = 'button';
        delBtn.dataset.action = 'delete';
        delBtn.dataset.id = String(product.id);
        delBtn.title = 'Eliminar';
        delBtn.appendChild(makeSVG(SVG_DELETE, 14, 14, 2));
        actionsDiv.appendChild(delBtn);

        rowsEl.appendChild(tr);
      });
      renderPagination(pageData);
      renderStatsBar();
    }

    async function fetchCategories(){const r=await fetch("/api/productos/categorias",{credentials:"include"});const d=await r.json().catch(()=>({}));if(!r.ok||!d?.success)throw new Error(d?.error||"No se pudieron cargar categorÃ­as");categories=Array.isArray(d.todas)?d.todas:[];renderCategories();}
