    /* Image Viewer */
    const imgModal = document.getElementById("imageViewerModal");
    const imgPanel = document.getElementById("imageViewerPanel");
    const imgCloseBtn = document.getElementById("imageViewerClose");
    const imgPreviewEl = document.getElementById("imageViewerImg");
    const imgEmptyEl = document.getElementById("imageViewerEmpty");
    const imgListEl = document.getElementById("imageViewerList");
    const imgFileEl = document.getElementById("imageViewerFile");
    const imgUploadHintEl = document.getElementById("imageViewerUploadHint");
    const imgSaveBtn = document.getElementById("imageViewerSave");
    const imgProductNameEl = document.getElementById("imageViewerProductName");
    let imgViewerProductId = null,
      imgViewerUrls = [],
      imgViewerSelectedIdx = 0,
      imgViewerMode = "product",
      dragSrcIdx = null;
    const IMG_UPLOAD_API = "/api/admin/productos/imagenes/upload";
    function openImageViewer(productId) {
      const product = products.find((p) => Number(p.id) === Number(productId));
      if (!product) return;
      imgViewerMode = "product";
      imgViewerProductId = product.id;
      imgViewerUrls =
        Array.isArray(product.imagenes) && product.imagenes.length
          ? [...product.imagenes]
          : product.imagen
            ? [product.imagen]
            : [];
      imgViewerSelectedIdx = 0;
      if (imgFileEl) imgFileEl.value = "";
      if (imgUploadHintEl)
        imgUploadHintEl.textContent = "PNG, JPG o WEBP. Máximo 8MB.";
      if (imgProductNameEl)
        imgProductNameEl.textContent = product.nombre || "Producto";
      if (imgSaveBtn) imgSaveBtn.style.display = "";
      renderImageViewer();
      showImgModal();
    }
    function openImageViewerForForm() {
      imgViewerMode = "form";
      imgViewerProductId = null;
      imgViewerUrls = parseImageUrls(imagenesUrlsEl?.value);
      imgViewerSelectedIdx = 0;
      if (imgFileEl) imgFileEl.value = "";
      if (imgUploadHintEl)
        imgUploadHintEl.textContent = "PNG, JPG o WEBP. Máximo 8MB.";
      if (imgProductNameEl)
        imgProductNameEl.textContent =
          nombreEl?.value?.trim() || "Nuevo producto";
      if (imgSaveBtn) imgSaveBtn.style.display = "";
      renderImageViewer();
      showImgModal();
    }
    function showImgModal() {
      if (imgModal) {
        imgModal.hidden = false;
        requestAnimationFrame(() => {
          imgModal.classList.add("is-open");
          imgPanel?.classList.add("is-open");
        });
      }
    }
    function closeImageViewer() {
      imgPanel?.classList.remove("is-open");
      setTimeout(() => {
        if (imgModal) {
          imgModal.classList.remove("is-open");
          imgModal.hidden = true;
        }
      }, 180);
    }
    function renderImageViewer() {
      const has = imgViewerUrls.length > 0;
      if (imgPreviewEl) {
        imgPreviewEl.style.display = has ? "block" : "none";
        imgPreviewEl.src = has ? imgViewerUrls[imgViewerSelectedIdx] || "" : "";
      }
      if (imgEmptyEl) imgEmptyEl.style.display = has ? "none" : "flex";
      const counterEl = document.getElementById("imageViewerCounter");
      if (counterEl)
        counterEl.textContent = has
          ? `Imagen ${imgViewerSelectedIdx + 1} de ${imgViewerUrls.length}`
          : "";
      if (!imgListEl) return;
      imgListEl.innerHTML = "";
      imgViewerUrls.forEach((url, idx) => {
        const row = document.createElement("div");
        row.className =
          "img-viewer-row" +
          (idx === imgViewerSelectedIdx ? " is-selected" : "");
        row.draggable = true;
        row.dataset.idx = String(idx);
        row.innerHTML = `<div class="img-viewer-row-drag" title="Arrastrar"><svg viewBox="0 0 24 24"><path d="M8 6h.01M8 12h.01M8 18h.01M16 6h.01M16 12h.01M16 18h.01"></path></svg></div><img class="img-viewer-row-thumb" src="${url}" alt="img ${idx + 1}" /><div class="img-viewer-row-meta"><p class="img-viewer-row-name">Imagen ${idx + 1}</p><p class="img-viewer-row-url">${url}</p></div><button class="img-viewer-row-del" type="button" data-idx="${idx}"><svg viewBox="0 0 24 24"><path d="M6 7h12m-9 0V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2m-8 0l1 13h8l1-13M10 11v6M14 11v6"></path></svg></button>`;
        row.addEventListener("dragstart", (e) => {
          dragSrcIdx = idx;
          row.classList.add("is-dragging");
          e.dataTransfer.effectAllowed = "move";
        });
        row.addEventListener("dragend", () => {
          row.classList.remove("is-dragging");
          dragSrcIdx = null;
          imgListEl
            .querySelectorAll(".img-viewer-row")
            .forEach((r) => r.classList.remove("drag-over"));
        });
        row.addEventListener("dragover", (e) => {
          e.preventDefault();
          e.dataTransfer.dropEffect = "move";
          row.classList.add("drag-over");
        });
        row.addEventListener("dragleave", () => {
          row.classList.remove("drag-over");
        });
        row.addEventListener("drop", (e) => {
          e.preventDefault();
          row.classList.remove("drag-over");
          const toIdx = idx;
          if (dragSrcIdx !== null && dragSrcIdx !== toIdx) {
            const moved = imgViewerUrls.splice(dragSrcIdx, 1)[0];
            imgViewerUrls.splice(toIdx, 0, moved);
            if (imgViewerSelectedIdx === dragSrcIdx)
              imgViewerSelectedIdx = toIdx;
            else if (
              dragSrcIdx < imgViewerSelectedIdx &&
              toIdx >= imgViewerSelectedIdx
            )
              imgViewerSelectedIdx--;
            else if (
              dragSrcIdx > imgViewerSelectedIdx &&
              toIdx <= imgViewerSelectedIdx
            )
              imgViewerSelectedIdx++;
            renderImageViewer();
          }
          dragSrcIdx = null;
        });
        row
          .querySelector(".img-viewer-row-thumb")
          ?.addEventListener("click", () => {
            imgViewerSelectedIdx = idx;
            renderImageViewer();
          });
        row
          .querySelector(".img-viewer-row-del")
          ?.addEventListener("click", () => {
            imgViewerUrls.splice(idx, 1);
            if (imgViewerSelectedIdx >= imgViewerUrls.length)
              imgViewerSelectedIdx = Math.max(0, imgViewerUrls.length - 1);
            renderImageViewer();
          });
        imgListEl.appendChild(row);
      });
    }
    function setUploadHint(text, isError = false) {
      if (!imgUploadHintEl) return;
      imgUploadHintEl.textContent = text;
      imgUploadHintEl.classList.toggle("is-error", !!isError);
    }
    async function uploadImageFile(file) {
      const fd = new FormData();
      fd.append("file", file);
      const res = await fetch(IMG_UPLOAD_API, {
        method: "POST",
        credentials: "include",
        body: fd,
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data?.success || !data?.url)
        throw new Error(data?.error || "No se pudo subir la imagen");
      return data.url;
    }
    imgFileEl?.addEventListener("change", async () => {
      const file = imgFileEl?.files?.[0];
      if (!file) {
        setUploadHint("PNG, JPG o WEBP. Máximo 8MB.", false);
        return;
      }
      try {
        setUploadHint(`Subiendo ${file.name}...`, false);
        const url = await uploadImageFile(file);
        imgViewerUrls.push(url);
        imgViewerSelectedIdx = imgViewerUrls.length - 1;
        if (imgFileEl) imgFileEl.value = "";
        setUploadHint("Imagen subida y agregada correctamente.", false);
        renderImageViewer();
      } catch (err) {
        setUploadHint(err?.message || "Error subiendo la imagen.", true);
      }
    });
    imgSaveBtn?.addEventListener("click", async () => {
      const cleanUrls = imgViewerUrls.filter((u) => u.trim());
      if (imgViewerMode === "form") {
        if (imagenesUrlsEl) imagenesUrlsEl.value = cleanUrls.join("\n");
        closeImageViewer();
        return;
      }
      if (!imgViewerProductId) return;
      const product = products.find(
        (p) => Number(p.id) === Number(imgViewerProductId),
      );
      if (!product) return;
      try {
        Modal.loading("Guardando imágenes", "Actualizando galería...");
        const res = await fetch(`/api/admin/productos/${imgViewerProductId}`, {
          method: "PUT",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            nombre: product.nombre || "",
            codigoReferencia: product.codigoReferencia || null,
            descripcion: product.descripcion || "",
            precio: Number(product.precio || 0),
            stockDisponible: Number(product.stock || 0),
            activo: product.activo === false ? 0 : 1,
            categoriaId: Number(product.categoriaId || 0),
            imagenesUrls: cleanUrls,
            division: product.division || null,
            unidadVenta: product.unidadVenta || null,
            especificaciones: product.especificaciones || null,
            variantes: product.variantes || [],
          }),
        });
        const data = await res.json().catch(() => ({}));
        Modal.hideLoading();
        if (!res.ok || !data?.success)
          throw new Error(data?.error || "Error guardando imágenes");
        closeImageViewer();
        Modal.success(
          "Imágenes actualizadas",
          "La galería fue guardada correctamente",
          { autoClose: 2200 },
        );
        await fetchProducts();
      } catch (err) {
        Modal.hideLoading();
        Modal.error("Error", err.message || "Error");
      }
    });
    imgCloseBtn?.addEventListener("click", closeImageViewer);
    document
      .getElementById("imageViewerCancelBtn")
      ?.addEventListener("click", closeImageViewer);
    imgModal?.addEventListener("click", (e) => {
      if (e.target === imgModal) closeImageViewer();
    });
    document
      .getElementById("btnOpenGallery")
      ?.addEventListener("click", () => openImageViewerForForm());
    Promise.all([fetchCategories(), fetchProducts()]).catch((err) =>
      Modal.error("Error", err.message || "Error cargando datos"),
    );
  </script>

