    btnSave?.addEventListener("click", async () => {
      try {
        const payload = buildJsonPayload();
        const error = validatePayload(payload, formMode === "create");
        if (error) {
          Modal.error("Error", error);
          return;
        }
        if (formMode === "edit") {
          const productId = Number(currentProductIdEl?.value || 0);
          if (!productId) {
            Modal.error("Error", "Selecciona un producto para editar");
            return;
          }
          Modal.loading("Actualizando producto", "Guardando cambios...");
          const r = await fetch(`/api/admin/productos/${productId}`, {
            method: "PUT",
            credentials: "include",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });
          const d = await r.json().catch(() => ({}));
          Modal.hideLoading();
          if (!r.ok || !d?.success)
            throw new Error(d?.error || "No se pudo actualizar");
          Modal.success("¡Listo!", "Producto actualizado correctamente", {
            autoClose: 2500,
          });
        } else {
          Modal.loading("Creando producto", "Por favor espera...");
          const r = await fetch("/api/productos/crear", {
            method: "POST",
            credentials: "include",
            body: buildCreateFormData(payload),
          });
          const d = await r.json().catch(() => ({}));
          Modal.hideLoading();
          if (!r.ok || !d?.success)
            throw new Error(d?.error || "No se pudo crear");
          Modal.success(
            d?.pendingApproval ? "Enviado a revisión" : "¡Producto creado!",
            d?.pendingApproval
              ? "El producto quedó pendiente de aprobación por superusuario."
              : "El producto fue agregado exitosamente",
            { autoClose: 2500 },
          );
        }
        closeForm();
        await fetchProducts();
      } catch (err) {
        Modal.hideLoading();
        Modal.error("Error", err.message || "Error guardando producto");
      }
    });
