---
import BaseLayout from "../../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}
const currentLang = "es";
const cspNonce = Astro.locals?.cspNonce || "";

const role = String(Astro.locals?.user?.rol || "").trim().toLowerCase().replace(/[\s_-]/g, "")
  .replace(/^superadmin$|^superuser$|^superusuario$/, "superusuario");

if (!role) return Astro.redirect(`/${currentLang}/login`);
if (role !== "admin" && role !== "superusuario") return Astro.redirect(`/${currentLang}`);
---

<BaseLayout title="GestiÃ³n de productos" currentLang={currentLang}>

  <script nonce={cspNonce} is:inline>
  (function(g){
    if(document.getElementById('go-modal-styles'))return;
    const s=document.createElement('style');
    s.id='go-modal-styles';
    s.textContent=`
      .go-modal-backdrop{position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.55);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;padding:1rem;opacity:0;transition:opacity 220ms ease}
      .go-modal-backdrop.go-visible{opacity:1}
      .go-modal{background:#1a1d28;border:1px solid rgba(168,85,247,.15);border-radius:20px;box-shadow:0 24px 60px rgba(0,0,0,.5);padding:2rem 2rem 1.6rem;width:100%;max-width:420px;text-align:center;transform:scale(.88) translateY(20px);transition:transform 260ms cubic-bezier(.34,1.56,.64,1);position:relative}
      .go-modal-backdrop.go-visible .go-modal{transform:scale(1) translateY(0)}
      .go-modal-icon{width:72px;height:72px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.1rem}
      .go-modal-icon.success{background:rgba(34,197,94,.1);color:#22c55e}.go-modal-icon.error{background:rgba(239,68,68,.1);color:#ef4444}
      .go-modal-icon.warning{background:rgba(245,158,11,.1);color:#f59e0b}.go-modal-icon.info{background:rgba(96,165,250,.1);color:#60a5fa}
      .go-modal-icon.confirm{background:rgba(168,85,247,.1);color:#a855f7}
      .go-modal-title{font-size:1.35rem;font-weight:700;color:#f0f2f5;margin:0 0 .5rem;font-family:inherit!important}
      .go-modal-text{font-size:.97rem;color:#8b95a5;margin:0 0 1.4rem;line-height:1.5;font-family:inherit!important}
      .go-modal-actions{display:flex;gap:.7rem;justify-content:center;flex-wrap:wrap}
      .go-modal-btn{padding:.65rem 1.6rem;border-radius:12px;font-size:.95rem;font-weight:600;cursor:pointer;border:none;transition:filter 160ms,transform 100ms;min-width:110px;font-family:inherit!important}
      .go-modal-btn:hover{filter:brightness(1.08)}.go-modal-btn:active{transform:scale(.97)}
      .go-modal-btn.primary{background:linear-gradient(135deg,#a855f7,#7c3aed);color:#fff}.go-modal-btn.secondary{background:rgba(255,255,255,.06);color:#8b95a5;border:1px solid rgba(255,255,255,.1)}
      .go-modal-btn.danger{background:#ef4444;color:#fff}
      .go-modal-progress{position:absolute;bottom:0;left:0;height:4px;border-radius:0 0 20px 20px;background:linear-gradient(90deg,#a855f7,#7c3aed);width:100%;transform-origin:left;animation:go-progress linear forwards}
      @keyframes go-progress{from{transform:scaleX(1)}to{transform:scaleX(0)}}
      .go-loading-backdrop{position:fixed;inset:0;z-index:10500;background:rgba(0,0,0,.6);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 200ms ease}
      .go-loading-backdrop.go-visible{opacity:1;pointer-events:auto}
      .go-loading-box{background:#1a1d28;border:1px solid rgba(168,85,247,.12);border-radius:20px;padding:2rem 2.5rem;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,.5);min-width:220px}
      .go-loading-spinner{width:52px;height:52px;border-radius:50%;border:4px solid rgba(168,85,247,.2);border-top-color:#a855f7;animation:go-spin 0.8s linear infinite;margin:0 auto 1rem}
      @keyframes go-spin{to{transform:rotate(360deg)}}
      .go-loading-title{font-size:1rem;font-weight:700;color:#f0f2f5;margin:0 0 .25rem;font-family:inherit!important}
      .go-loading-sub{font-size:0.8rem;color:#5a6478;margin:0;font-family:inherit!important}
    `;
    document.head.appendChild(s);
    const IC={
      success:`<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`,
      error:`<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`,
      warning:`<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
      info:`<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>`,
      confirm:`<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    };
    function show(o){
      return new Promise(function(res){
        var type=o.type||'info',title=o.title||'',text=o.text||'',
            ct=o.confirmText||'Aceptar',cct=o.cancelText||'Cancelar',
            sc=o.showCancel||false,ac=o.autoClose||0;
        var bd=document.createElement('div');
        bd.className='go-modal-backdrop';
        bd.innerHTML='<div class="go-modal" role="dialog" aria-modal="true">'+
          '<div class="go-modal-icon '+type+'">'+(IC[type]||IC.info)+'</div>'+
          '<h2 class="go-modal-title">'+title+'</h2>'+
          (text?'<p class="go-modal-text">'+text+'</p>':'')+
          '<div class="go-modal-actions">'+
          (sc?'<button class="go-modal-btn secondary" id="gmc">'+cct+'</button>':'')+
          '<button class="go-modal-btn '+(type==='error'?'danger':'primary')+'" id="gmok">'+ct+'</button>'+
          '</div>'+
          (ac?'<div class="go-modal-progress" style="animation-duration:'+ac+'ms"></div>':'')+
          '</div>';
        document.body.appendChild(bd);
        requestAnimationFrame(function(){bd.classList.add('go-visible');});
        function close(r){bd.classList.remove('go-visible');setTimeout(function(){bd.remove();},260);res(r);}
        bd.querySelector('#gmok').addEventListener('click',function(){close(true);});
        var cc=bd.querySelector('#gmc');
        if(cc)cc.addEventListener('click',function(){close(false);});
        function onKey(e){if(e.key==='Escape'){close(false);document.removeEventListener('keydown',onKey);}}
        document.addEventListener('keydown',onKey);
        if(ac)setTimeout(function(){close(true);},ac);
      });
    }
    var _loadEl=null;
    function showLoading(title,sub){
      if(_loadEl) return;
      _loadEl=document.createElement('div');
      _loadEl.className='go-loading-backdrop';
      _loadEl.innerHTML='<div class="go-loading-box"><div class="go-loading-spinner"></div><p class="go-loading-title">'+(title||'Procesando...')+'</p><p class="go-loading-sub">'+(sub||'Por favor espera')+'</p></div>';
      document.body.appendChild(_loadEl);
      requestAnimationFrame(function(){_loadEl.classList.add('go-visible');});
    }
    function hideLoading(){
      if(!_loadEl) return;
      _loadEl.classList.remove('go-visible');
      setTimeout(function(){if(_loadEl){_loadEl.remove();_loadEl=null;}},220);
    }
    g.Modal={
      success:function(t,x,o){return show(Object.assign({type:'success',title:t,text:x},o||{}));},
      error:  function(t,x,o){return show(Object.assign({type:'error',  title:t,text:x},o||{}));},
      warning:function(t,x,o){return show(Object.assign({type:'warning',title:t,text:x},o||{}));},
      info:   function(t,x,o){return show(Object.assign({type:'info',   title:t,text:x},o||{}));},
      confirm:function(t,x,o){return show(Object.assign({type:'confirm',title:t,text:x,showCancel:true},o||{}));},
      loading:showLoading,
      hideLoading:hideLoading,
    };
  })(window);
  </script>

  <!-- Runtime-injected styles for action buttons & pagination (bypasses Astro CSS scoping) -->
  <script nonce={cspNonce} is:inline>
  (function(){
