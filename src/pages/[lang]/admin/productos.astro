    function buildJsonPayload(){const pesoVal=pesoEl?.value?.trim();const dimsUnit=getDimsUnidad();const mappedVariants=variantesForm.filter(v=>v.descripcion?.trim()).map(v=>{const l=Number(v?.largo),a=Number(v?.ancho),g=Number(v?.grosor);const specs=(Number.isFinite(l)&&l>0&&Number.isFinite(a)&&a>0&&Number.isFinite(g)&&g>0)?{dimensiones:{unidad:dimsUnit,largo:l,ancho:a,grosor:g}}:null;return{descripcion:String(v.descripcion||'').trim(),precio:v.precio!=null&&v.precio!==''?Number(v.precio):null,stock:v.stock!=null&&v.stock!==''?Number(v.stock):null,peso:v.peso!=null&&v.peso!==''?Number(v.peso):null,especificaciones:specs};});return{nombre:nombreEl?.value?.trim()||"",codigoReferencia:codigoReferenciaEl?.value?.trim()||null,descripcion:descripcionEl?.value?.trim()||"",precio:Number(precioEl?.value||0),stockDisponible:Number(stockDisponibleEl?.value||0),peso:pesoVal!==""&&pesoVal!=null?Number(pesoVal):null,activo:Number(activoEl?.value||1),categoriaId:Number(categoriaIdEl?.value||0),imagenesUrls:parseImageUrls(imagenesUrlsEl?.value),division:divisionEl?.value||null,unidadVenta:unidadVentaEl?.value||null,especificaciones:buildEspecificaciones(),variantes:mappedVariants};}
