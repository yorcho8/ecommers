      button.pa-row-btn.pa-row-btn--toggle{color:#fbbf24!important;border-color:rgba(251,191,36,.4)!important}
      button.pa-row-btn.pa-row-btn--toggle.is-on{color:#22c55e!important;border-color:rgba(34,197,94,.25)!important;background:rgba(34,197,94,.1)!important}
      button.pa-row-btn.pa-row-btn--toggle.is-off{color:#ef4444!important;border-color:rgba(239,68,68,.2)!important;background:rgba(239,68,68,.08)!important}
      button.pa-row-btn.pa-row-btn--toggle svg{width:15px!important;height:15px!important;stroke-width:2.4!important}
      button.pa-row-btn.pa-row-btn--edit{color:#c084fc!important;border-color:rgba(168,85,247,.3)!important}
      button.pa-row-btn.pa-row-btn--edit:hover{background:rgba(168,85,247,.15)!important}
      button.pa-row-btn.pa-row-btn--delete{color:#ef4444!important;border-color:rgba(239,68,68,.2)!important}
      button.pa-row-btn.pa-row-btn--delete:hover{background:rgba(239,68,68,.08)!important}
      .pa-division-badge{display:inline-block!important;font-size:10px!important;font-weight:700!important;padding:3px 10px!important;border-radius:20px!important;background:rgba(168,85,247,.15)!important;color:#c084fc!important;border:1px solid rgba(168,85,247,.3)!important;white-space:nowrap!important}
      .pa-variantes-badge{display:inline-block!important;font-size:10px!important;font-weight:700!important;padding:3px 10px!important;border-radius:20px!important;background:rgba(96,165,250,.1)!important;color:#60a5fa!important;border:1px solid rgba(96,165,250,.25)!important}
      .pa-estado{display:inline-block!important;font-size:10px!important;font-weight:700!important;padding:3px 10px!important;border-radius:20px!important}
      .pa-estado--on{background:rgba(34,197,94,.1)!important;color:#22c55e!important;border:1px solid rgba(34,197,94,.25)!important}
      .pa-estado--off{background:rgba(239,68,68,.08)!important;color:#ef4444!important;border:1px solid rgba(239,68,68,.2)!important}
      button.pa-page-btn{min-width:34px!important;height:34px!important;border-radius:8px!important;border:1px solid rgba(255,255,255,.07)!important;background:rgba(255,255,255,.03)!important;color:#8b95a5!important;font-size:12px!important;font-weight:600!important;cursor:pointer!important;display:inline-flex!important;align-items:center!important;justify-content:center!important;transition:all .18s ease!important;padding:0 8px!important;font-family:inherit!important;outline:none!important}
      button.pa-page-btn:hover:not(.disabled):not(.active){background:rgba(255,255,255,.07)!important;border-color:rgba(255,255,255,.14)!important;color:#f0f2f5!important}
      button.pa-page-btn.active{background:linear-gradient(135deg,#a855f7,#7c3aed)!important;border-color:transparent!important;color:#fff!important;box-shadow:0 2px 12px rgba(168,85,247,.4)!important;font-weight:700!important}
      button.pa-page-btn.disabled{opacity:.3!important;cursor:not-allowed!important}
      button.pa-page-btn.pa-page-btn--arrow{min-width:36px!important}
      button.pa-page-btn.pa-page-btn--arrow svg{width:14px!important;height:14px!important;stroke:currentColor!important;fill:none!important;display:block!important;pointer-events:none!important}
      .pa-page-ellipsis{color:#5a6478;font-size:13px;padding:0 4px;user-select:none;display:inline-flex;align-items:center;height:34px}
    `;
    document.head.appendChild(s);
  })();
  </script>

