    function buildJsonPayload() {
      const pesoVal = pesoEl?.value?.trim();
      const dimsUnit = getDimsUnidad();
      const mappedVariants = variantesForm
        .filter((v) => v.descripcion?.trim())
        .map((v) => {
          const l = Number(v?.largo),
            a = Number(v?.ancho),
            g = Number(v?.grosor);
          const specs =
            Number.isFinite(l) &&
            l > 0 &&
            Number.isFinite(a) &&
            a > 0 &&
            Number.isFinite(g) &&
            g > 0
              ? {
                  dimensiones: {
                    unidad: dimsUnit,
                    largo: l,
                    ancho: a,
                    grosor: g,
                  },
                }
              : null;
          return {
            descripcion: String(v.descripcion || "").trim(),
            precio:
              v.precio != null && v.precio !== "" ? Number(v.precio) : null,
            stock: v.stock != null && v.stock !== "" ? Number(v.stock) : null,
            peso: v.peso != null && v.peso !== "" ? Number(v.peso) : null,
            especificaciones: specs,
          };
        });
      return {
        nombre: nombreEl?.value?.trim() || "",
        codigoReferencia: codigoReferenciaEl?.value?.trim() || null,
        descripcion: descripcionEl?.value?.trim() || "",
        precio: Number(precioEl?.value || 0),
        stockDisponible: Number(stockDisponibleEl?.value || 0),
        peso: pesoVal !== "" && pesoVal != null ? Number(pesoVal) : null,
        activo: Number(activoEl?.value || 1),
        categoriaId: Number(categoriaIdEl?.value || 0),
        imagenesUrls: parseImageUrls(imagenesUrlsEl?.value),
        division: divisionEl?.value || null,
        unidadVenta: unidadVentaEl?.value || null,
        especificaciones: buildEspecificaciones(),
        variantes: mappedVariants,
      };
    }
    function buildCreateFormData(payload) {
      const fd = new FormData();
      fd.append("nombre", payload.nombre);
      if (payload.codigoReferencia)
        fd.append("codigoReferencia", payload.codigoReferencia);
      fd.append("descripcion", payload.descripcion);
      fd.append("precio", String(payload.precio));
      fd.append("stockDisponible", String(payload.stockDisponible));
      fd.append("categoriaId", String(payload.categoriaId));
      if (payload.peso != null) fd.append("peso", String(payload.peso));
      payload.imagenesUrls.forEach((url) => fd.append("imagenes", url));
      if (payload.division) fd.append("division", payload.division);
      if (payload.unidadVenta) fd.append("unidadVenta", payload.unidadVenta);
      if (payload.especificaciones)
        fd.append("especificaciones", payload.especificaciones);
      if (payload.variantes.length > 0)
        fd.append("variantes", JSON.stringify(payload.variantes));
      return fd;
    }
    function validatePayload(payload, requireImage = true) {
      if (
        !payload.nombre ||
        !Number.isFinite(payload.precio) ||
        payload.precio <= 0 ||
        !Number.isFinite(payload.categoriaId) ||
        payload.categoriaId <= 0
      )
        return "Nombre, precio y categoría son obligatorios";
      if (
        requireImage &&
        (!Array.isArray(payload.imagenesUrls) ||
          payload.imagenesUrls.length === 0)
      )
        return "La URL de imagen es obligatoria";
      if (Array.isArray(payload.variantes) && payload.variantes.length > 0) {
        const valid = payload.variantes.filter((v) =>
          String(v?.descripcion || "").trim(),
        );
        for (const v of valid) {
          if (
            v?.precio != null &&
            (!Number.isFinite(Number(v.precio)) || Number(v.precio) <= 0)
          )
            return "Si capturas precio en variante, debe ser mayor a 0";
          if (
            v?.peso != null &&
            (!Number.isFinite(Number(v.peso)) || Number(v.peso) <= 0)
          )
            return "Si capturas peso en variante, debe ser mayor a 0";
        }
      }
      return "";
    }
    function productsToRowsText(list) {
      return list
        .map(
          (p) =>
            `${p.id}\t${p.nombre || ""}\t${p.categoria || ""}\t${p.division || ""}\t${Number(p.precio || 0).toFixed(2)}\t${Number(p.stock || 0)}`,
        )
        .join("\n");
    }
    function productsToCsv(list) {
      const h = "id,nombre,categoria,division,precio,stock";
      const b = list
        .map(
          (p) =>
            `${p.id},"${String(p.nombre || "").replaceAll('"', '""')}","${String(p.categoria || "").replaceAll('"', '""')}","${String(p.division || "").replaceAll('"', '""')}",${Number(p.precio || 0)},${Number(p.stock || 0)}`,
        )
        .join("\n");
      return `${h}\n${b}`;
    }
    function triggerDownload(content, fileName, mimeType) {
      const blob = new Blob([content], { type: mimeType });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = fileName;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
    }

