---
// src/pages/es/admin/perfil-empresa.astro
import BaseLayout from "../../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}
const currentLang = "es";
const cspNonce = Astro.locals?.cspNonce || "";

const role = String(Astro.locals?.user?.rol || "").trim().toLowerCase().replace(/[\s_-]/g, "")
  .replace(/^superadmin$|^superuser$|^superusuario$/, "superusuario");

if (!role) return Astro.redirect(`/${currentLang}/login`);
if (role !== "admin" && role !== "superusuario") return Astro.redirect(`/${currentLang}`);
---

<BaseLayout title="Perfil de Empresa Destacada | NEXUS" currentLang={currentLang}>
<div class="dx-root">
<main class="dx">

  <header class="dx-hero">
    <div class="dx-hero__glow" aria-hidden="true"></div>
    <div class="dx-hero__content">
      <div class="dx-hero__left">
        <p class="dx-hero__kicker">Marketing e Identidad</p>
        <h1 class="dx-hero__title">Perfil de Empresa Destacada</h1>
        <p class="dx-hero__sub">Configura tu escaparate profesional y activa tu visibilidad premium.</p>
      </div>
      <div class="dx-hero__right">
        <a class="dx-cta" href={`/${currentLang}/admin/dashboard`}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Dashboard
        </a>
      </div>
    </div>
  </header>

  <div class="dx-grid-split">
    
    <div class="dx-stack">
      <section class="dx-panel">
        <div class="dx-panel__head">
          <div>
            <p class="dx-panel__kicker">Personalización</p>
            <h2 class="dx-panel__title">Datos de Identidad</h2>
          </div>
        </div>

        <div class="dx-form-container">
          <div class="dx-upload-grid">
            <div class="dx-field">
              <label>Logotipo Comercial</label>
              <div class="dx-dropzone" id="dz-logo">
                <input type="file" id="epLogoFile" accept="image/*" class="dx-file-hidden" />
                <img id="previewLogo" class="dx-img-preview" hidden />
                <div class="dx-dz-content" id="logoMsg">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                  <span>Subir Logo</span>
                </div>
              </div>
              <input id="epLogoUrl" type="hidden" />
            </div>

            <div class="dx-field">
              <label>Banner Principal</label>
              <div class="dx-dropzone banner" id="dz-banner">
                <input type="file" id="epBannerFile" accept="image/*" class="dx-file-hidden" />
                <img id="previewBanner" class="dx-img-preview" hidden />
                <div class="dx-dz-content" id="bannerMsg">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                  <span>Subir Banner</span>
                </div>
              </div>
              <input id="epBannerUrl" type="hidden" />
            </div>
          </div>

          <div class="dx-grid-2">
            <div class="dx-field"><label>Nombre Comercial</label><input id="epNombre" type="text" class="dx-search" placeholder="Nombre de la empresa" /></div>
            <div class="dx-field"><label>Giro / Industria</label><input id="epGiro" type="text" class="dx-search" placeholder="Ej: Distribución" /></div>
          </div>
          <div class="dx-field"><label>Slogan</label><input id="epSlogan" type="text" class="dx-search" placeholder="Frase de marca" /></div>
          <div class="dx-field"><label>Descripción</label><textarea id="epDescripcion" rows="4" class="dx-search" style="resize:none;" placeholder="Describe tu empresa..."></textarea></div>
          <div class="dx-field"><label>Sitio Web</label><input id="epWeb" type="url" class="dx-search" placeholder="https://tuempresa.com" /></div>
        </div>
      </section>
    </div>

    <div class="dx-stack">
      <section class="dx-panel">
        <div class="dx-panel__head">
          <div>
            <p class="dx-panel__kicker">Activación</p>
            <h2 class="dx-panel__title">Pago y Plan</h2>
          </div>
        </div>

        <div class="dx-form-container">
          <div class="dx-field">
            <label>Tarjeta</label>
            <select id="epCard" class="dx-select"></select>
          </div>
          <div class="dx-field">
            <label>Plan de Visibilidad</label>
            <select id="epPlan" class="dx-select">
              <option value="30|399">30 días — $399 MXN</option>
              <option value="60|699">60 días — $699 MXN</option>
              <option value="90|999">90 días — $999 MXN</option>
            </select>
          </div>

          <div style="margin: 20px 0; padding-top: 15px; border-top: 1px solid var(--dx-line); display: flex; justify-content: space-between; align-items: center;">
            <span style="color: var(--dx-t2); font-size: 0.85rem;">Total:</span>
            <strong id="displayTotal" style="font-size: 1.6rem; color: #fff;">$399.00</strong>
          </div>

          <button id="epPay" class="dx-cta" style="width: 100%; justify-content: center;">
            Pagar y Publicar Perfil
          </button>
          
          <p id="epStatus" style="margin-top: 15px; font-size: 0.85rem; display: none;"></p>
        </div>
      </section>

      <div class="dx-info-card">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        Al pagar, tu perfil aparecerá destacado en la sección de empresas del Marketplace.
      </div>
    </div>

  </div>
</main>
</div>

<div id="epLoadingOverlay" style="display:none;" class="ux-overlay-fixed">
  <div class="ux-loader-card">
    <div class="ux-spinner"></div>
    <p style="color:#fff; font-weight:700;">Procesando pago...</p>
  </div>
</div>

<style is:global>
/* Usamos el CSS exacto de Equipo */
:root {
  --dx-bg: #060a14;
  --dx-s1: #0c1322;
  --dx-s2: #111a2e;
  --dx-line: rgba(148,163,184,0.16);
  --dx-line-h: rgba(148,163,184,0.28);
  --dx-t1: #eef2fa;
  --dx-t2: #94a3b8;
  --dx-t3: #64748b;
  --dx-brand: #7a2532;
  --dx-cyan: #22d3ee;
  --dx-good: #34d399;
  --dx-bad: #fb7185;
  --dx-r: 20px;
  --dx-r-sm: 12px;
}

.dx-root { background: var(--dx-bg) !important; min-height: 100vh; }
.dx-root .dx * { font-family: 'Inter', sans-serif !important; box-sizing: border-box; }

.dx-root .dx {
  max-width: 1400px; margin: 0 auto; padding: 120px 24px 64px; display: grid; gap: 24px; color: var(--dx-t1);
}

/* Layout split */
.dx-grid-split { display: grid; grid-template-columns: 1fr 380px; gap: 24px; align-items: start; }
@media (max-width: 950px) { .dx-grid-split { grid-template-columns: 1fr; } }

.dx-stack { display: flex; flex-direction: column; gap: 24px; }

/* Hero */
.dx-root .dx-hero {
  position: relative; border: 1px solid var(--dx-line); border-radius: var(--dx-r); padding: 28px; overflow: hidden;
  background: linear-gradient(155deg, var(--dx-s2), var(--dx-s1)); box-shadow: 0 24px 56px rgba(0,0,0,0.35);
}
.dx-root .dx-hero__glow { position: absolute; inset: 0; background: radial-gradient(ellipse at 8% -10%, rgba(122,37,50,0.2), transparent 50%); pointer-events: none; }
.dx-root .dx-hero__title { font-size: clamp(1.5rem, 2.8vw, 2.1rem) !important; font-weight: 800; color: var(--dx-t1); margin: 4px 0 !important; }
.dx-root .dx-hero__kicker { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; color: rgba(255,191,146,0.9); }

/* Panels */
.dx-root .dx-panel { border: 1px solid var(--dx-line); border-radius: var(--dx-r); background: linear-gradient(155deg, var(--dx-s2), var(--dx-s1)); padding: 22px; box-shadow: 0 8px 28px rgba(0,0,0,0.18); }
.dx-root .dx-panel__head { display: flex; justify-content: space-between; margin-bottom: 16px; }
.dx-root .dx-panel__kicker { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; color: var(--dx-t3); }
.dx-root .dx-panel__title { font-size: 1.05rem; font-weight: 750; color: var(--dx-t1); }

/* Form items */
.dx-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.dx-field { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
.dx-field label { font-size: 0.72rem; font-weight: 700; color: var(--dx-t3); text-transform: uppercase; }
.dx-search, .dx-select {
  background: rgba(255,255,255,0.04); border: 1px solid var(--dx-line); border-radius: var(--dx-r-sm); padding: 12px; color: var(--dx-t1); font-size: 0.85rem; outline: none; transition: 0.2s;
}
.dx-search:focus { border-color: var(--dx-cyan); background: rgba(255,255,255,0.08); }
.dx-select option { background: #0c1322; }

/* Image Dropzones */
.dx-upload-grid { display: grid; grid-template-columns: 140px 1fr; gap: 16px; margin-bottom: 8px; }
.dx-dropzone {
  height: 100px; border: 2.5px dashed var(--dx-line); border-radius: var(--dx-r-sm);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  position: relative; cursor: pointer; transition: 0.2s; background: rgba(0,0,0,0.2);
}
.dx-dropzone:hover { border-color: var(--dx-cyan); background: rgba(34,211,238,0.04); }
.dx-file-hidden { position: absolute; inset: 0; opacity: 0; cursor: pointer; z-index: 10; }
.dx-img-preview { position: absolute; width: 100%; height: 100%; object-fit: contain; z-index: 5; border-radius: 8px; background: #000; }
.dx-dz-content { display: flex; flex-direction: column; align-items: center; gap: 6px; color: var(--dx-t3); font-size: 0.7rem; font-weight: 600; }

/* Buttons */
.dx-root .dx-cta {
  display: inline-flex; align-items: center; gap: 6px; padding: 12px 24px; border-radius: 99px;
  background: linear-gradient(135deg, var(--dx-brand), #ff8c38); color: #1b120a; font-size: 0.82rem; font-weight: 800; text-decoration: none; box-shadow: 0 4px 16px rgba(122,37,50,0.3); transition: 0.2s; border: none; cursor: pointer;
}
.dx-root .dx-cta:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(122,37,50,0.4); }
.dx-root .dx-cta:disabled { opacity: 0.5; cursor: not-allowed; }

.dx-info-card { background: rgba(34,211,238,0.06); border: 1px solid rgba(34,211,238,0.15); border-radius: 12px; padding: 16px; font-size: 0.78rem; color: var(--dx-t2); display: flex; gap: 10px; }

/* Overlays */
.ux-overlay-fixed { position: fixed; inset: 0; z-index: 105000; background: rgba(0,0,0,0.8); backdrop-filter: blur(6px); display: flex; align-items: center; justify-content: center; }
.ux-loader-card { background: #111a2e; padding: 40px; border-radius: 24px; text-align: center; border: 1px solid var(--dx-line); }
.ux-spinner { width: 32px; height: 32px; border: 3px solid rgba(255,255,255,0.1); border-top-color: var(--dx-cyan); border-radius: 50%; animation: dx-spin 0.8s linear infinite; margin-bottom: 15px; }
@keyframes dx-spin { to { transform: rotate(360deg); } }
</style>

<script nonce={cspNonce} is:inline>
(function(){
  const $ = (id) => document.getElementById(id);
  const UPLOAD_API = '/api/admin/productos/imagenes/upload';

  // Preview de Imágenes
  function setupPreview(fileId, previewId, msgId) {
    $(fileId)?.addEventListener('change', function(e) {
      const file = e.target.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = (ev) => {
          $(previewId).src = ev.target.result;
          $(previewId).hidden = false;
          $(msgId).hidden = true;
        };
        reader.readAsDataURL(file);
      }
    });
  }
  setupPreview('epLogoFile', 'previewLogo', 'logoMsg');
  setupPreview('epBannerFile', 'previewBanner', 'bannerMsg');

  // Actualizar monto visual
  $('epPlan')?.addEventListener('change', (e) => {
    const amount = e.target.value.split('|')[1];
    $('displayTotal').textContent = `$${amount}.00`;
  });

  async function uploadImage(file, targetInputId) {
    if (!file) return;
    const fd = new FormData();
    fd.append('file', file);
    const res = await fetch(UPLOAD_API, { method: 'POST', credentials: 'include', body: fd });
    const data = await res.json().catch(() => ({}));
    if (!res.ok || !data?.success || !data?.url) throw new Error(data?.error || 'Fallo al subir imagen');
    $(targetInputId).value = String(data.url);
  }

  $('epPay')?.addEventListener('click', async () => {
    const payBtn = $('epPay');
    const overlay = $('epLoadingOverlay');
    const status = $('epStatus');
    const [days, amount] = $('epPlan').value.split('|');

    const payload = {
      cardId: Number($('epCard').value),
      duracionDias: Number(days),
      amount: Number(amount),
      nombreComercial: $('epNombre').value,
      slogan: $('epSlogan').value,
      descripcion: $('epDescripcion').value,
      giro: $('epGiro').value,
      sitioWeb: $('epWeb').value,
      logoUrl: $('epLogoUrl').value,
      bannerUrl: $('epBannerUrl').value,
    };

    payBtn.disabled = true;
    overlay.style.display = 'flex';
    status.style.display = 'none';

    try {
      // Subir primero si hay archivos pendientes
      if($('epLogoFile').files[0] && !$('epLogoUrl').value) await uploadImage($('epLogoFile').files[0], 'epLogoUrl');
      if($('epBannerFile').files[0] && !$('epBannerUrl').value) await uploadImage($('epBannerFile').files[0], 'epBannerUrl');
      
      payload.logoUrl = $('epLogoUrl').value;
      payload.bannerUrl = $('epBannerUrl').value;

      const res = await fetch('/api/admin/empresas-perfil', {
        method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok || !data.success) throw new Error(data.error || 'Error en pago');
      
      status.textContent = "✅ Perfil publicado correctamente.";
      status.style.color = "var(--dx-good)";
      status.style.display = "block";
    } catch (err) {
      status.textContent = "✕ " + err.message;
      status.style.color = "var(--dx-bad)";
      status.style.display = "block";
      payBtn.disabled = false;
    } finally {
      overlay.style.display = 'none';
    }
  });

  async function loadData() {
    try {
      const res = await fetch('/api/admin/empresas-perfil', { credentials: 'include' });
      const data = await res.json();
      if(data.success) {
        const e = data.empresa || {};
        $('epNombre').value = e.Nombre_Comercial || '';
        $('epSlogan').value = e.Perfil_Slogan || '';
        $('epDescripcion').value = e.Descripcion || '';
        $('epGiro').value = e.Giro || '';
        $('epWeb').value = e.Sitio_Web || '';
        $('epLogoUrl').value = e.Logo_URL || '';
        $('epBannerUrl').value = e.Banner_URL || '';

        if(e.Logo_URL) { $('previewLogo').src = e.Logo_URL; $('previewLogo').hidden = false; $('logoMsg').hidden = true; }
        if(e.Banner_URL) { $('previewBanner').src = e.Banner_URL; $('previewBanner').hidden = false; $('bannerMsg').hidden = true; }

        $('epCard').innerHTML = (data.cards || []).map(c => `<option value="${c.id}">${c.label}</option>`).join('') || '<option>No hay tarjetas guardadas</option>';
      }
    } catch(e) {}
  }
  loadData();
})();
</script>

</BaseLayout>