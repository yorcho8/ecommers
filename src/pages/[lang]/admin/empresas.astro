.emp-root .emp-upload-progress__bar{height:4px;background:var(--e-line);border-radius:99px;overflow:hidden;}
.emp-root .emp-upload-progress__fill{height:100%;background:linear-gradient(90deg,var(--e-purple),#38bdf8);border-radius:99px;transition:width 0.3s ease;}
.emp-root .emp-upload-progress__label{font-size:0.72rem;color:var(--e-t2);}
.emp-root .emp-btn{padding:9px 18px;border-radius:var(--e-r-sm);font-size:0.8rem;font-weight:700;cursor:pointer;border:1px solid transparent;transition:all 0.15s;font-family:inherit;display:inline-flex;align-items:center;gap:6px;}
.emp-root .emp-btn--accent{background:linear-gradient(135deg,var(--e-purple),#9333ea);color:#fff;box-shadow:0 4px 14px rgba(168,85,247,0.25);}
.emp-root .emp-btn--accent:hover{box-shadow:0 6px 20px rgba(168,85,247,0.4);transform:translateY(-1px);}
