---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const currentLang = "es";
const cspNonce = Astro.locals?.cspNonce || "";

const role = String(Astro.locals?.user?.rol || "").trim().toLowerCase().replace(/[\s_-]/g, "")
  .replace(/^superadmin$|^superuser$|^superusuario$/, "superusuario");

if (!role) return Astro.redirect(`/${currentLang}/login`);
if (role !== "superusuario") return Astro.redirect(`/${currentLang}`);
---

<BaseLayout title="Gestión de empresas" currentLang={currentLang}>
<div class="emp-root" data-app-view>
<main class="emp">

  <header class="emp-hero">
    <div class="emp-hero__glow" aria-hidden="true"></div>
    <div class="emp-hero__content">
      <div>
        <span class="emp-hero__badge">SuperAdmin</span>
        <h1 class="emp-hero__title">Gestión de empresas</h1>
        <p class="emp-hero__sub">Revisa solicitudes, valida documentos y aprueba o rechaza empresas.</p>
      </div>
      <div class="emp-hero__actions">
        <button id="btnAddEmpresa" class="emp-cta" type="button">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Nueva solicitud
        </button>
        <a class="emp-back" href={`/${currentLang}`}>← Volver</a>
      </div>
    </div>
  </header>

  <section id="empStatus" class="emp-status" hidden></section>

  <div class="emp-panel">
    <div class="emp-toolbar">
      <div class="emp-tabs" id="empStateTabs">
        <button type="button" class="emp-tab active" data-state="all">Todas</button>
        <button type="button" class="emp-tab" data-state="pendiente">Pendientes</button>
        <button type="button" class="emp-tab" data-state="revision">Revisar docs</button>
        <button type="button" class="emp-tab" data-state="aprobada">Aprobadas</button>
        <button type="button" class="emp-tab" data-state="rechazada">Rechazadas</button>
      </div>
      <div class="emp-toolbar__right">
        <div class="emp-search-bar">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <input id="empSearch" type="search" placeholder="Buscar empresa, RFC o correo…" />
        </div>
        <span id="empCount" class="emp-count"></span>
      </div>
    </div>
    <div class="emp-table-wrap">
      <table class="emp-table">
        <thead>
          <tr>
            <th>Empresa</th>
            <th>RFC / Régimen</th>
            <th>Estado</th>
            <th>KYC</th>
            <th>Administrador</th>
            <th>Documentos</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody id="empTableBody">
          <tr><td colspan="7" class="emp-empty-cell">Cargando…</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       MODAL REVISIÓN COMPLETA
  ═══════════════════════════════════════════ -->
  <div id="reviewModal" class="emp-overlay" hidden>
    <div class="emp-overlay__bg" id="reviewModalOverlay"></div>
    <article class="emp-dialog emp-dialog--review" role="dialog" aria-modal="true">
      <button id="reviewModalClose" class="emp-dialog__close" type="button" aria-label="Cerrar">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>

      <!-- Cabecera -->
      <div class="review-header">
        <div class="review-header__icon" id="reviewIcon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        </div>
        <div>
          <h3 id="reviewTitle" class="review-title">Revisión de solicitud</h3>
          <p id="reviewSubtitle" class="review-header__sub">Verifica toda la información antes de continuar.</p>
        </div>
      </div>

      <!-- Checklist rápido -->
      <div class="review-checklist">
        <div class="review-check" id="chkEmpresa"><span class="review-check__dot"></span>Empresa</div>
        <div class="review-check" id="chkFiscal"><span class="review-check__dot"></span>Datos fiscales</div>
        <div class="review-check" id="chkAdmin"><span class="review-check__dot"></span>Administrador</div>
        <div class="review-check" id="chkKyc"><span class="review-check__dot"></span>KYC biometrico</div>
        <div class="review-check" id="chkIdentidad"><span class="review-check__dot"></span>Comparación identidad</div>
        <div class="review-check" id="chkDocs"><span class="review-check__dot"></span>Documentos</div>
        <div class="review-check" id="chkDir"><span class="review-check__dot"></span>Dirección</div>
      </div>

      <!-- Cuerpo scrollable -->
      <div class="review-body">

        <!-- Empresa -->
        <section class="review-section">
          <div class="review-section__head">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            Empresa
          </div>
          <div class="review-grid">
            <div class="review-field"><span class="review-field__label">Nombre comercial</span><span class="review-field__val" id="rv-nombre">—</span></div>
            <div class="review-field"><span class="review-field__label">RFC</span><span class="review-field__val rv-mono" id="rv-rfc">—</span></div>
            <div class="review-field rf-full"><span class="review-field__label">Descripción</span><span class="review-field__val" id="rv-desc">—</span></div>
            <div class="review-field"><span class="review-field__label">Sitio web</span><span class="review-field__val" id="rv-sitio">—</span></div>
          </div>
        </section>

        <!-- Datos fiscales — destacado -->
        <section class="review-section review-section--fiscal">
          <div class="review-section__head">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 13h6M9 17h4"/></svg>
            Datos fiscales — SAT
            <span class="rv-fiscal-badge">CFDI 4.0</span>
          </div>
          <div class="rv-fiscal-alert">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Verifica que coincidan exactamente con la Constancia de Situación Fiscal
          </div>
          <div class="review-grid rv-fiscal-grid">
            <div class="review-field rf-full rv-fiscal-field"><span class="review-field__label">Razón social (exacta SAT)</span><span class="review-field__val rv-mono rv-big" id="rv-razon">—</span></div>
            <div class="review-field rv-fiscal-field"><span class="review-field__label">Régimen fiscal</span><span class="review-field__val" id="rv-regimen">—</span></div>
            <div class="review-field rv-fiscal-field"><span class="review-field__label">CP fiscal</span><span class="review-field__val rv-mono" id="rv-cp">—</span></div>
          </div>
        </section>

        <!-- Admin -->
        <section class="review-section">
          <div class="review-section__head">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Administrador
          </div>
          <div class="review-grid">
            <div class="review-field"><span class="review-field__label">Nombre completo</span><span class="review-field__val" id="rv-admin-nombre">—</span></div>
            <div class="review-field"><span class="review-field__label">Correo electrónico</span><span class="review-field__val rv-mono" id="rv-admin-correo">—</span></div>
            <div class="review-field rf-full"><span class="review-field__label">Teléfono</span><span class="review-field__val" id="rv-admin-tel">—</span></div>
          </div>
        </section>

        <section class="review-section">
          <div class="review-section__head">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 12l2 2 4-4"/><path d="M21 12c0 7-9 10-9 10S3 19 3 12a9 9 0 1118 0z"/></svg>
            KYC biometrico
          </div>
          <div class="review-grid">
            <div class="review-field"><span class="review-field__label">Estado KYC</span><span class="review-field__val" id="rv-kyc-estado">—</span></div>
            <div class="review-field"><span class="review-field__label">Proveedor</span><span class="review-field__val rv-mono" id="rv-kyc-proveedor">—</span></div>
            <div class="review-field"><span class="review-field__label">Biometria valida</span><span class="review-field__val" id="rv-kyc-biometria">—</span></div>
            <div class="review-field"><span class="review-field__label">Documento valido</span><span class="review-field__val" id="rv-kyc-documento">—</span></div>
            <div class="review-field"><span class="review-field__label">Liveness score</span><span class="review-field__val rv-mono" id="rv-kyc-liveness">—</span></div>
            <div class="review-field"><span class="review-field__label">Score comparacion</span><span class="review-field__val rv-mono" id="rv-kyc-score">—</span></div>
            <div class="review-field"><span class="review-field__label">Fraude sospecha</span><span class="review-field__val" id="rv-kyc-fraude">—</span></div>
            <div class="review-field"><span class="review-field__label">Fecha verificacion</span><span class="review-field__val" id="rv-kyc-fecha">—</span></div>
            <div class="review-field"><span class="review-field__label">Evidencia biometrica</span><span class="review-field__val" id="rv-bio-disponible">—</span></div>
            <div class="review-field"><span class="review-field__label">Consentimiento</span><span class="review-field__val" id="rv-bio-consent">—</span></div>
            <div class="review-field"><span class="review-field__label">Retencion hasta</span><span class="review-field__val" id="rv-bio-retencion">—</span></div>
            <div class="review-field"><span class="review-field__label">Hash evidencia</span><span class="review-field__val rv-mono" id="rv-bio-hash">—</span></div>
            <div class="review-field rf-full"><span class="review-field__label">Ver evidencia privada</span><span class="review-field__val" id="rv-bio-link">—</span></div>
            <div class="review-field rf-full"><span class="review-field__label">URL verificacion</span><span class="review-field__val rv-mono" id="rv-kyc-url">—</span></div>
          </div>
        </section>

        <section class="review-section">
          <div class="review-section__head">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Comparacion representante (INE vs selfie)
          </div>
          <div class="rv-compare" id="rv-compare-grid">
            <article class="rv-compare-card">
              <header>INE representante</header>
              <div class="rv-compare-media" id="rv-compare-ine">—</div>
              <footer><a class="rv-doc-link" id="rv-compare-ine-link" target="_blank" rel="noopener" hidden>Abrir INE completo</a></footer>
            </article>
            <article class="rv-compare-card">
              <header>Selfie biometrica privada</header>
              <div class="rv-compare-media" id="rv-compare-selfie">—</div>
              <footer><a class="rv-doc-link" id="rv-compare-selfie-link" target="_blank" rel="noopener" hidden>Abrir selfie privada</a></footer>
            </article>
          </div>
          <p class="rv-compare-note" id="rv-compare-note">Valida rasgos faciales, proporciones y coincidencia general antes de aprobar KYC.</p>
          <div style="padding:0 12px 12px;display:flex;justify-content:flex-end">
            <button type="button" id="rv-open-compare" class="emp-btn emp-btn--ghost" disabled>Abrir comparador con zoom sincronizado</button>
          </div>
        </section>

        <!-- Documentos -->
        <section class="review-section">
          <div class="review-section__head">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Documentos fiscales
          </div>
          <div class="review-docs" id="rv-docs"></div>
        </section>

        <!-- Dirección -->
        <section class="review-section">
          <div class="review-section__head">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Dirección de recolección
          </div>
          <div class="review-grid">
            <div class="review-field rf-full"><span class="review-field__label">Domicilio</span><span class="review-field__val" id="rv-dir-calle">—</span></div>
            <div class="review-field"><span class="review-field__label">Ciudad / Estado</span><span class="review-field__val" id="rv-dir-ciudad">—</span></div>
            <div class="review-field"><span class="review-field__label">CP / País</span><span class="review-field__val rv-mono" id="rv-dir-cp">—</span></div>
            <div class="review-field rf-full"><span class="review-field__label">Sucursal</span><span class="review-field__val" id="rv-sucursal">—</span></div>
          </div>
        </section>

        <!-- Motivo rechazo (solo si se rechaza) -->
        <section class="review-section review-section--reject" id="reviewRejectSection" hidden>
          <div class="review-section__head">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            Motivo de rechazo
          </div>
          <div style="padding:14px 16px">
            <textarea id="reviewMotivo" rows="3" placeholder="Describe el motivo para que el solicitante pueda corregirlo…" style="width:100%;box-sizing:border-box;background:var(--e-s3);border:1px solid var(--e-line-h);border-radius:8px;padding:9px 12px;color:var(--e-t1);font-size:0.82rem;outline:none;resize:vertical;font-family:inherit"></textarea>
          </div>
        </section>

      </div>

      <!-- Footer -->
      <div class="review-footer">
        <button type="button" id="reviewCancel" class="emp-btn emp-btn--ghost">Cerrar</button>
        <div style="display:flex;gap:8px;align-items:center">
          <button type="button" id="reviewKycRejectBtn" class="emp-btn emp-btn--danger" hidden>Rechazar KYC</button>
          <button type="button" id="reviewKycApproveBtn" class="emp-btn emp-btn--success" hidden>Validar KYC</button>
          <button type="button" id="reviewRejectBtn" class="emp-btn emp-btn--danger" hidden>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            Rechazar solicitud
          </button>
          <button type="button" id="reviewApproveBtn" class="emp-btn emp-btn--approve" hidden>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M20 6L9 17l-5-5"/></svg>
            Confirmar aprobación
          </button>
        </div>
      </div>
    </article>
  </div>

  <div id="compareModal" class="emp-overlay" hidden>
    <div class="emp-overlay__bg" id="compareModalOverlay"></div>
    <article class="emp-dialog emp-dialog--compare" role="dialog" aria-modal="true">
      <button id="compareModalClose" class="emp-dialog__close" type="button" aria-label="Cerrar comparador">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <div class="cmp-head">
        <h3>Comparador visual sincronizado</h3>
        <p>Arrastra para mover ambas imágenes y usa zoom para revisar rasgos del rostro.</p>
      </div>
      <div class="cmp-controls">
        <button type="button" id="compareZoomOut" class="emp-btn emp-btn--ghost">-</button>
        <input id="compareZoomRange" type="range" min="100" max="400" step="5" value="100" />
        <button type="button" id="compareZoomIn" class="emp-btn emp-btn--ghost">+</button>
        <button type="button" id="compareZoomReset" class="emp-btn emp-btn--ghost">Reset</button>
        <button type="button" id="compareFaceAuto" class="emp-btn emp-btn--ghost">Centrar rostro</button>
        <span id="compareZoomLabel" class="emp-count">100%</span>
      </div>
      <p id="compareHint" class="cmp-hint">Consejo: usa zoom y arrastre para alinear ojos, nariz y contorno facial.</p>
      <div class="cmp-grid">
        <section class="cmp-card">
          <header>INE representante</header>
          <div class="cmp-stage" id="compareIneStage">
            <div class="cmp-focus-box" aria-hidden="true"></div>
            <img id="compareIneImg" alt="INE representante" draggable="false" />
          </div>
        </section>
        <section class="cmp-card">
          <header>Selfie biometrica privada</header>
          <div class="cmp-stage" id="compareSelfieStage">
            <div class="cmp-focus-box" aria-hidden="true"></div>
            <img id="compareSelfieImg" alt="Selfie biometrica" draggable="false" />
          </div>
        </section>
      </div>
    </article>
  </div>

  <!-- Modal crear solicitud -->
  <div id="empModal" class="emp-overlay" hidden>
    <div class="emp-overlay__bg" id="empModalOverlay"></div>
    <article class="emp-dialog emp-dialog--lg" role="dialog" aria-modal="true">
      <button id="empModalClose" class="emp-dialog__close" type="button" aria-label="Cerrar">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <h3 id="empModalTitle" class="emp-dialog__title">Nueva solicitud</h3>
      <form id="empForm" autocomplete="off" novalidate>
        <input type="hidden" id="empId" value="" />
        <fieldset class="emp-fieldset">
          <legend>Datos de la empresa</legend>
          <div class="emp-grid">
            <div class="emp-field"><label for="empNombre">Nombre comercial *</label><input id="empNombre" type="text" placeholder="Distribuidora XYZ S.A. de C.V." required /></div>
            <div class="emp-field"><label for="empRfc">RFC</label><input id="empRfc" type="text" placeholder="XYZ240101ABC" maxlength="13" /></div>
            <div class="emp-field"><label for="empSitio">Sitio web</label><input id="empSitio" type="url" placeholder="https://empresa.com" /></div>
          </div>
          <div class="emp-field emp-field--full" style="margin-top:10px"><label for="empDesc">Descripción</label><textarea id="empDesc" rows="2" placeholder="Breve descripción"></textarea></div>
        </fieldset>
        <fieldset class="emp-fieldset emp-fieldset--fiscal">
          <legend>Datos fiscales (SAT)</legend>
          <p class="emp-hint emp-hint--info">Deben coincidir exactamente con la Constancia de Situación Fiscal.</p>
          <div class="emp-grid">
            <div class="emp-field emp-field--full"><label for="empRazonSocial">Razón social *</label><input id="empRazonSocial" type="text" placeholder="DISTRIBUIDORA XYZ SA DE CV" required /><span class="emp-field__hint">Mayúsculas, sin acentos, tal cual aparece en el SAT</span></div>
            <div class="emp-field">
              <label for="empRegimenFiscal">Régimen fiscal *</label>
              <select id="empRegimenFiscal" required>
                <option value="">Seleccionar…</option>
                <option value="601">601 – General de Ley Personas Morales</option>
                <option value="603">603 – Personas Morales con Fines no Lucrativos</option>
                <option value="606">606 – Arrendamiento</option>
                <option value="612">612 – Personas Físicas con Actividades Empresariales</option>
                <option value="616">616 – Sin obligaciones fiscales</option>
                <option value="621">621 – Incorporación Fiscal</option>
                <option value="622">622 – Actividades Agrícolas, Ganaderas, Silvícolas y Pesqueras</option>
                <option value="625">625 – Actividades Empresariales por Plataformas</option>
                <option value="626">626 – Régimen Simplificado de Confianza (RESICO)</option>
              </select>
            </div>
            <div class="emp-field"><label for="empCPFiscal">CP fiscal *</label><input id="empCPFiscal" type="text" placeholder="58000" maxlength="5" pattern="[0-9]{5}" required /></div>
          </div>
        </fieldset>
        <fieldset class="emp-fieldset">
          <legend>Administrador</legend>
          <p class="emp-hint">La contraseña se enviará al aprobar.</p>
          <div class="emp-grid">
            <div class="emp-field"><label for="empAdminNombre">Nombre *</label><input id="empAdminNombre" type="text" required /></div>
            <div class="emp-field"><label for="empAdminApellido">Apellido paterno *</label><input id="empAdminApellido" type="text" required /></div>
            <div class="emp-field"><label for="empAdminApellidoM">Apellido materno</label><input id="empAdminApellidoM" type="text" /></div>
            <div class="emp-field"><label for="empAdminCorreo">Correo *</label><input id="empAdminCorreo" type="email" required /></div>
            <div class="emp-field"><label for="empAdminTel">Teléfono</label><input id="empAdminTel" type="tel" /></div>
          </div>
        </fieldset>
        <fieldset class="emp-fieldset">
          <legend>Documentos fiscales obligatorios</legend>
          <p class="emp-hint">PDF, JPG o PNG · máx. 8 MB por archivo.</p>
          <div class="emp-grid emp-grid--3">
            <div class="emp-field"><label for="empDocActa">Acta constitutiva *</label>
              <div class="emp-file-drop" id="dropActa"><input id="empDocActa" type="file" accept=".pdf,.jpg,.jpeg,.png,.webp" required class="emp-file-input" />
                <div class="emp-file-ui"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg><span class="emp-file-label">Seleccionar</span><span class="emp-file-name" id="nameActa">—</span></div>
              </div>
            </div>
            <div class="emp-field"><label for="empDocIne">INE representante *</label>
