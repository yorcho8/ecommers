<style is:global>
.emp-root{--e-bg:#060a14;--e-s1:#0c1322;--e-s2:#111a2e;--e-s3:#172237;--e-line:rgba(148,163,184,0.14);--e-line-h:rgba(148,163,184,0.24);--e-t1:#eef2fa;--e-t2:#94a3b8;--e-t3:#64748b;--e-purple:#a855f7;--e-purple-soft:rgba(168,85,247,0.1);--e-purple-glow:rgba(168,85,247,0.2);--e-good:#34d399;--e-bad:#fb7185;--e-warn:#fbbf24;--e-info:#38bdf8;--e-r:18px;--e-r-sm:10px;background:var(--e-bg)!important;min-height:100vh;}
