function setEstadoFilter(next){estadoFilter=['all','pendiente','revision','aprobada','rechazada'].includes(next)?next:'all';document.querySelectorAll('.emp-tab').forEach(function(t){t.classList.toggle('active',t.dataset.state===estadoFilter);});renderTable(empresasData);}
