.emp-root .emp-panel{border:1px solid var(--e-line);border-radius:var(--e-r);background:linear-gradient(155deg,var(--e-s2),var(--e-s1));box-shadow:0 8px 28px rgba(0,0,0,0.18);overflow:hidden;}
