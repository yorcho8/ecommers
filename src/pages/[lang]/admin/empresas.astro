/* ═══════ CREAR SOLICITUD ═══════ */
['Acta','Ine','Constancia'].forEach(function(k){
  var iid={Acta:'empDocActa',Ine:'empDocIne',Constancia:'empDocConstancia'}[k];
  var nid={Acta:'nameActa',Ine:'nameIne',Constancia:'nameConstancia'}[k];
  var did={Acta:'dropActa',Ine:'dropIne',Constancia:'dropConstancia'}[k];
  var inp=$(iid);if(!inp)return;
  inp.addEventListener('change',function(){var f=inp.files?.[0];if(f){$(nid).textContent=f.name;$(did).classList.add('has-file');}else{$(nid).textContent='—';$(did).classList.remove('has-file');}});
});
function openCreate(){$('empForm').reset();$('empId').value='';['nameActa','nameIne','nameConstancia'].forEach(function(id){$(id).textContent='—';});['dropActa','dropIne','dropConstancia'].forEach(function(id){$(id).classList.remove('has-file');});setProgress(null);$('empModal').hidden=false;}
function closeModal(){$('empModal').hidden=true;$('empForm').reset();setProgress(null);var e=$('empFormError');if(e){e.hidden=true;e.textContent='';}}

async function uploadDocOrThrow(file,tipo){
  var form=new FormData();form.append('file',file);form.append('tipoDocumento',tipo);
  var res=await fetch(DOC_API,{method:'POST',credentials:'include',body:form});
  var data=await res.json().catch(function(){return{};});
  if(!res.ok||!data.success||!data?.documento?.url)throw new Error(data.error||'No se pudo subir '+tipo);
  return{tipo,url:String(data.documento.url||''),public_id:String(data.documento.publicId||''),resource_type:String(data.documento.resourceType||''),format:String(data.documento.format||''),mime_type:String(file.type||''),nombre_archivo:String(file.name||''),size_bytes:Number(file.size||0)};
}
function showFormError(msg){var el=$('empFormError');el.textContent='⚠ '+msg;el.hidden=false;el.scrollIntoView({behavior:'smooth',block:'nearest'});}

$('empForm').addEventListener('submit',async function(ev){
  ev.preventDefault();
  var er=$('empFormError');if(er)er.hidden=true;
  var btn=$('empFormSubmit');btn.disabled=true;btn.textContent='Guardando…';
  var body={nombre_empresa:$('empNombre').value.trim(),rfc:$('empRfc').value.trim(),descripcion:$('empDesc').value.trim(),sitio_web:$('empSitio').value.trim(),razon_social:$('empRazonSocial').value.trim().toUpperCase(),regimen_fiscal:$('empRegimenFiscal').value.trim(),codigo_postal_fiscal:$('empCPFiscal').value.trim(),numero_casa:Number($('empNumeroCasa').value||0),calle:$('empCalle').value.trim(),codigo_postal:Number($('empCodigoPostal').value||0),ciudad:$('empCiudad').value.trim(),provincia:$('empProvincia').value.trim(),pais:$('empPais').value.trim()||'México',nombre_direccion:$('empNombreDireccion').value.trim(),nombre_sucursal:$('empNombreSucursal').value.trim(),telefono_sucursal:$('empTelSucursal').value.trim(),admin_nombre:$('empAdminNombre').value.trim(),admin_apellido:$('empAdminApellido').value.trim(),admin_apellido_materno:$('empAdminApellidoM').value.trim(),admin_correo:$('empAdminCorreo').value.trim(),admin_telefono:$('empAdminTel').value.trim()};
  if(!body.nombre_empresa){showFormError('Nombre requerido.');btn.disabled=false;btn.textContent='Enviar solicitud';return;}
  if(!body.razon_social){showFormError('Razón social requerida.');btn.disabled=false;btn.textContent='Enviar solicitud';return;}
  if(!body.regimen_fiscal){showFormError('Régimen fiscal requerido.');btn.disabled=false;btn.textContent='Enviar solicitud';return;}
  if(!/^\d{5}$/.test(body.codigo_postal_fiscal)){showFormError('CP fiscal inválido (5 dígitos).');btn.disabled=false;btn.textContent='Enviar solicitud';return;}
  if(!body.numero_casa||!body.calle||!body.codigo_postal||!body.ciudad||!body.provincia){showFormError('Dirección incompleta.');btn.disabled=false;btn.textContent='Enviar solicitud';return;}
  var fA=$('empDocActa')?.files?.[0],fI=$('empDocIne')?.files?.[0],fC=$('empDocConstancia')?.files?.[0];
  if(!fA||!fI||!fC){showFormError('Sube los 3 documentos.');btn.disabled=false;btn.textContent='Enviar solicitud';return;}
  try{setProgress(10,'Subiendo acta…');var dA=await uploadDocOrThrow(fA,'ACTA_CONSTITUTIVA');setProgress(40,'Subiendo INE…');var dI=await uploadDocOrThrow(fI,'INE_REPRESENTANTE');setProgress(70,'Subiendo constancia…');var dC=await uploadDocOrThrow(fC,'CONSTANCIA_FISCAL');setProgress(90,'Registrando…');body.documentos=[dA,dI,dC];}
  catch(e){showFormError(e?.message||'Error subiendo docs');btn.disabled=false;btn.textContent='Enviar solicitud';setProgress(null);return;}
  try{var res=await fetch(API,{method:'POST',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});var data=await res.json();if(!data.success){showFormError(data.error||'Error');setProgress(null);return;}setProgress(100,'¡Registrada!');setTimeout(function(){closeModal();loadEmpresas();showStatus('Solicitud registrada.');},600);}
  catch(e){showFormError('Error de red');setProgress(null);}
  finally{btn.disabled=false;btn.textContent='Enviar solicitud';}
});

/* eliminar */
function openDelete(id,name){deleteId=id;$('empDelMsg').textContent='¿Eliminar "'+name+'"?';$('empDelModal').hidden=false;}
$('empDelConfirm').addEventListener('click',async function(){
  if(!deleteId)return;$('empDelConfirm').disabled=true;
  try{var res=await fetch(API,{method:'DELETE',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:deleteId})});var data=await res.json();if(!data.success){showStatus(data.error||'Error','error');return;}$('empDelModal').hidden=true;deleteId=null;showStatus('Eliminada.');await loadEmpresas();}
  catch(e){showStatus('Error de red','error');}finally{$('empDelConfirm').disabled=false;}
});

