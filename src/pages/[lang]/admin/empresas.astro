.emp-root .emp-btn--success:hover{background:rgba(52,211,153,0.18);}
.emp-root .emp-btn--approve{background:rgba(52,211,153,0.1);border:1px solid rgba(52,211,153,0.35);color:var(--e-good);box-shadow:0 2px 10px rgba(52,211,153,0.1);}
.emp-root .emp-btn--approve:hover{background:rgba(52,211,153,0.2);box-shadow:0 4px 18px rgba(52,211,153,0.22);transform:translateY(-1px);}
