.emp-root .emp-creds{display:flex;flex-direction:column;gap:8px;margin-bottom:8px;}
.emp-root .emp-creds__row{display:flex;flex-direction:column;gap:2px;padding:10px 14px;background:rgba(255,255,255,0.02);border:1px solid var(--e-line);border-radius:8px;}
.emp-root .emp-creds__label{font-size:0.6rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--e-t3);font-weight:700;}
.emp-root .emp-creds__val{font-size:0.85rem;color:var(--e-t1);}
.emp-root .emp-mono{font-family:'Courier New',monospace;color:var(--e-purple)!important;font-weight:700;letter-spacing:0.04em;}
html:not(.dark) .emp-root{--e-bg:#f1f5f9;--e-s1:#fff;--e-s2:#f8fafc;--e-s3:#f1f5f9;--e-line:rgba(15,23,42,0.1);--e-line-h:rgba(15,23,42,0.18);--e-t1:#0f172a;--e-t2:#475569;--e-t3:#94a3b8;}
@media(max-width:768px){
  .emp-root .emp{padding:100px 14px 40px;}
  .emp-root .emp-hero__content{flex-direction:column;}
  .emp-root .emp-grid,.emp-root .emp-grid--3{grid-template-columns:1fr;}
  .emp-root .emp-field--full{grid-column:span 1;}
  .emp-root .review-docs{grid-template-columns:1fr;}
  .emp-root .rv-compare{grid-template-columns:1fr;}
  .emp-root .cmp-grid{grid-template-columns:1fr;}
  .emp-root .cmp-stage{height:44vh;min-height:250px;}
  .emp-root .review-grid{grid-template-columns:1fr;}
  .emp-root .rf-full{grid-column:span 1;}
}
</style>

<script>
// @ts-nocheck
var API='/api/admin/empresas';
var KYC_API='/api/admin/empresas/kyc';
var DOC_API='/api/admin/empresas/documentos/upload';
var DOCS_REQUIRED=['ACTA_CONSTITUTIVA','INE_REPRESENTANTE','CONSTANCIA_FISCAL'];
var empresasData=[], deleteId=null, estadoFilter='all', reviewPayload=null;
var compareState={ineUrl:'',selfieUrl:'',enabled:false,zoom:1,panX:0,panY:0,dragging:false,lastX:0,lastY:0};
var $=function(id){return document.getElementById(id);};
var REGIMENES={'601':'601 – General de Ley Personas Morales','603':'603 – Personas Morales con Fines no Lucrativos','606':'606 – Arrendamiento','612':'612 – Personas Físicas con Actividades Empresariales','616':'616 – Sin obligaciones fiscales','621':'621 – Incorporación Fiscal','622':'622 – Actividades Agrícolas, Ganaderas, Silvícolas y Pesqueras','625':'625 – Actividades Empresariales por Plataformas','626':'626 – RESICO'};

function showStatus(msg,type){var el=$('empStatus');el.textContent=msg;el.className='emp-status '+(type||'ok');el.hidden=false;setTimeout(function(){el.hidden=true;},5000);}
function setProgress(pct,label){var w=$('uploadProgress'),f=$('uploadProgressFill'),l=$('uploadProgressLabel');if(pct===null){w.hidden=true;return;}w.hidden=false;f.style.width=pct+'%';l.textContent=label||'Subiendo…';}
function badgeHtml(s){var e=String(s||'pendiente').toLowerCase(),v=['pendiente','aprobada','rechazada','activo','inactivo','suspendido'],k=v.includes(e)?e:'pendiente';return'<span class="emp-badge '+k+'">'+k.charAt(0).toUpperCase()+k.slice(1)+'</span>';}
function boolKyc(v){if(v===true)return 'Si';if(v===false)return 'No';return '—';}
function kycSummaryHtml(kyc){
  var k=kyc&&typeof kyc==='object'?kyc:{};
  var estado=String(k.Estado||'pendiente').toLowerCase();
  var estadoLabel=estado.charAt(0).toUpperCase()+estado.slice(1);
  var badge='emp-badge pendiente';
  if(estado==='aprobado') badge='emp-badge aprobada';
  if(estado==='rechazado'||estado==='expirado') badge='emp-badge rechazada';
  var b=boolKyc(k.Biometria_Valida);
  var d=boolKyc(k.Documento_Valido);
  var l=k.Liveness_Score==null?'—':Number(k.Liveness_Score).toFixed(2);
  return '<div><span class="'+badge+'">'+estadoLabel+'</span><div class="emp-fiscal-info">Bio: '+b+' · Doc: '+d+'</div><div class="emp-fiscal-info">Live: '+l+'</div></div>';
}
function isImageMime(mime){return /^image\//i.test(String(mime||''));}
function buildDocViewUrl(doc){
  if(!doc||!doc.url) return '';
  var q=new URLSearchParams({url:String(doc.url)});
  if(doc.public_id)q.set('public_id',doc.public_id);
  if(doc.resource_type)q.set('resource_type',doc.resource_type);
  if(doc.format)q.set('format',doc.format);
  return '/api/admin/empresas/documentos/view?'+q.toString();
}
function setCompareMedia(containerId,url,imageLike,emptyMsg){
  var el=$(containerId);if(!el)return;
  if(!url){el.textContent=emptyMsg||'Sin evidencia';return;}
  if(imageLike){el.innerHTML='<img src="'+url+'" alt="Evidencia de identidad" loading="lazy" />';return;}
  el.innerHTML='<iframe src="'+url+'" title="Documento de identidad" loading="lazy" referrerpolicy="no-referrer"></iframe>';
}
function clamp(n,min,max){return Math.min(max,Math.max(min,n));}
function setCompareZoom(z){
  compareState.zoom=clamp(Number(z)||1,1,4);
  var r=$('compareZoomRange');if(r)r.value=String(Math.round(compareState.zoom*100));
  var l=$('compareZoomLabel');if(l)l.textContent=Math.round(compareState.zoom*100)+'%';
  applyCompareTransform();
}
function applyCompareTransform(){
  var t='translate(calc(-50% + '+compareState.panX+'px), calc(-50% + '+compareState.panY+'px)) scale('+compareState.zoom+')';
  var a=$('compareIneImg');var b=$('compareSelfieImg');
  if(a)a.style.transform=t;
  if(b)b.style.transform=t;
}
function setCompareHint(msg){
  var h=$('compareHint');
  if(h) h.textContent=String(msg||'');
}
async function detectPrimaryFace(imgEl){
  if(!(imgEl instanceof HTMLImageElement)) return null;
  if(!('FaceDetector' in window)) return null;
  try{
    var detector=new window.FaceDetector({fastMode:true,maxDetectedFaces:1});
    var faces=await detector.detect(imgEl);
    if(!faces||!faces.length||!faces[0].boundingBox) return null;
    var b=faces[0].boundingBox;
    var w=Math.max(1,Number(b.width||0));
    var h=Math.max(1,Number(b.height||0));
    var x=Math.max(0,Number(b.x||0));
    var y=Math.max(0,Number(b.y||0));
    return {x:x,y:y,width:w,height:h,cx:x+w/2,cy:y+h/2};
  }catch{return null;}
}
async function autoCenterFaces(){
  var ineImg=$('compareIneImg');
  var selfieImg=$('compareSelfieImg');
  if(!ineImg||!selfieImg||!ineImg.complete||!selfieImg.complete){
    setCompareHint('Espera a que carguen ambas imágenes para centrar rostro.');
    return;
  }
  if(!('FaceDetector' in window)){
    setCompareHint('Tu navegador no soporta detección facial automática. Ajusta con zoom y arrastre manual.');
    return;
  }

  var [faceIne,faceSelfie]=await Promise.all([detectPrimaryFace(ineImg),detectPrimaryFace(selfieImg)]);
  if(!faceIne||!faceSelfie){
    setCompareHint('No se detectó rostro claramente en INE/selfie. Ajusta manualmente y valida a simple vista.');
    return;
  }

  var stage=$('compareIneStage');
  var stageW=Math.max(1,Number(stage?.clientWidth||1));
  var targetFacePx=Math.max(110,Math.min(230,stageW*0.34));
  var ineFaceRatio=Math.max(0.0001,faceIne.width/Math.max(1,ineImg.naturalWidth));
  var selfieFaceRatio=Math.max(0.0001,faceSelfie.width/Math.max(1,selfieImg.naturalWidth));
  var avgFace=Math.max(1,((ineFaceRatio+selfieFaceRatio)/2)*Math.max(1,ineImg.naturalWidth));
  var desiredZoom=clamp(targetFacePx/avgFace,1.15,4);

  var targetNormX=((faceIne.cx/Math.max(1,ineImg.naturalWidth))+(faceSelfie.cx/Math.max(1,selfieImg.naturalWidth)))/2;
  var targetNormY=((faceIne.cy/Math.max(1,ineImg.naturalHeight))+(faceSelfie.cy/Math.max(1,selfieImg.naturalHeight)))/2;
  compareState.panX=-((targetNormX-0.5)*Math.max(1,ineImg.naturalWidth));
  compareState.panY=-((targetNormY-0.5)*Math.max(1,ineImg.naturalHeight));
  compareState.panX=clamp(compareState.panX,-520,520);
  compareState.panY=clamp(compareState.panY,-520,520);
  setCompareZoom(desiredZoom);
  setCompareHint('Rostro centrado automáticamente. Revisa cejas, ojos, nariz y mandíbula antes de aprobar KYC.');
}
function openCompareModal(){
  if(!compareState.enabled||!compareState.ineUrl||!compareState.selfieUrl)return;
  var ai=$('compareIneImg');var bi=$('compareSelfieImg');
  if(ai)ai.src=compareState.ineUrl;
  if(bi)bi.src=compareState.selfieUrl;
  compareState.zoom=1;compareState.panX=0;compareState.panY=0;compareState.dragging=false;
  setCompareZoom(1);
  setCompareHint('Consejo: usa zoom y arrastre para alinear ojos, nariz y contorno facial.');
  $('compareModal').hidden=false;
}
function closeCompareModal(){
  $('compareModal').hidden=true;
  compareState.dragging=false;
  ['compareIneStage','compareSelfieStage'].forEach(function(id){var el=$(id);if(el)el.classList.remove('dragging');});
}
function startCompareDrag(ev){
  if($('compareModal')?.hidden)return;
  compareState.dragging=true;
  compareState.lastX=ev.clientX;compareState.lastY=ev.clientY;
  ['compareIneStage','compareSelfieStage'].forEach(function(id){var el=$(id);if(el)el.classList.add('dragging');});
}
function moveCompareDrag(ev){
  if(!compareState.dragging)return;
  var dx=ev.clientX-compareState.lastX;
  var dy=ev.clientY-compareState.lastY;
  compareState.lastX=ev.clientX;compareState.lastY=ev.clientY;
  compareState.panX=clamp(compareState.panX+dx,-520,520);
  compareState.panY=clamp(compareState.panY+dy,-520,520);
  applyCompareTransform();
}
function endCompareDrag(){
  compareState.dragging=false;
  ['compareIneStage','compareSelfieStage'].forEach(function(id){var el=$(id);if(el)el.classList.remove('dragging');});
}
function onCompareWheel(ev){
  if($('compareModal')?.hidden)return;
  ev.preventDefault();
  var delta=ev.deltaY<0?0.08:-0.08;
  setCompareZoom(compareState.zoom+delta);
}
function docListHtml(docs){if(!Array.isArray(docs)||!docs.length)return'<span style="font-size:0.72rem;color:var(--e-t3)">Sin docs</span>';var nm={ACTA_CONSTITUTIVA:'Acta',INE_REPRESENTANTE:'INE',CONSTANCIA_FISCAL:'Constancia'};return'<div class="emp-docs">'+docs.map(function(d){var t=String(d?.tipo||'').toUpperCase(),lbl=nm[t]||t,url=String(d?.url||'').trim();if(!url)return'<span style="font-size:0.72rem;color:var(--e-t3)">'+lbl+'</span>';var q=new URLSearchParams({url:url});if(d?.public_id)q.set('public_id',d.public_id);if(d?.resource_type)q.set('resource_type',d.resource_type);if(d?.format)q.set('format',d.format);return'<a class="emp-doc-link" href="/api/admin/empresas/documentos/view?'+q.toString()+'" target="_blank">'+lbl+'</a>';}).join('')+'</div>';}
function hasAllDocs(docs){if(!Array.isArray(docs)||!docs.length)return false;var f=new Set();docs.forEach(function(d){var t=String(d?.tipo||'').toUpperCase();if(t&&d?.url)f.add(t);});return DOCS_REQUIRED.every(function(t){return f.has(t);});}

function renderTable(data){
  var q=($('empSearch')?.value||'').toLowerCase().trim();
  var filtered=data.filter(function(e){var es=String(e.Estado||'pendiente').toLowerCase();var pe=estadoFilter==='all'?true:estadoFilter==='revision'?(es==='pendiente'&&hasAllDocs(e.Documentos)):es===estadoFilter;var pq=!q||e.Nombre_Empresa.toLowerCase().includes(q)||(e.RFC||'').toLowerCase().includes(q)||(e.Usuario_Correo||'').toLowerCase().includes(q);return pe&&pq;});
  $('empCount').textContent=filtered.length+' solicitud'+(filtered.length!==1?'es':'');
  var tbody=$('empTableBody');
  if(!filtered.length){tbody.innerHTML='<tr><td colspan="7" class="emp-empty-cell">Sin resultados</td></tr>';return;}
  tbody.innerHTML=filtered.map(function(e){
    var ip=String(e.Estado||'').toLowerCase()==='pendiente';
    var ri=e.Razon_Social?'<div class="emp-fiscal-info" style="color:#93c5fd">'+e.Razon_Social+'</div>':'';
    var fi=e.RFC?'<div class="emp-fiscal-info">'+e.RFC+(e.Regimen_Fiscal?' · R'+e.Regimen_Fiscal:'')+'</div>':'';
    return'<tr><td><strong>'+e.Nombre_Empresa+'</strong>'+ri+'</td><td>'+fi+(e.Codigo_Postal_Fiscal?'<div class="emp-fiscal-info">CP: '+e.Codigo_Postal_Fiscal+'</div>':'')+'</td><td>'+badgeHtml(e.Estado)+'</td><td>'+kycSummaryHtml(e.KYC)+'</td><td><span style="font-weight:600">'+(e.Usuario_Nombre||'')+' '+(e.Usuario_Apellido||'')+'</span><div class="emp-admin-info">'+(e.Usuario_Correo||'')+'</div></td><td>'+docListHtml(e.Documentos)+'</td><td><div class="emp-row-actions">'+(ip?'<button class="emp-row-btn review-btn" data-id="'+e.Id_Solicitud+'">Revisar y aprobar</button>':'')+'<button class="emp-row-btn del" data-del="'+e.Id_Solicitud+'" data-name="'+e.Nombre_Empresa+'">Eliminar</button></div></td></tr>';
  }).join('');
  tbody.querySelectorAll('[data-id]').forEach(function(btn){btn.addEventListener('click',function(){var s=empresasData.find(function(e){return e.Id_Solicitud===Number(btn.dataset.id);});if(s)openReview(s);});});
  tbody.querySelectorAll('[data-del]').forEach(function(btn){btn.addEventListener('click',function(){openDelete(Number(btn.dataset.del),btn.dataset.name);});});
}

async function loadEmpresas(){
  $('empTableBody').innerHTML='<tr><td colspan="7" class="emp-empty-cell">Cargando…</td></tr>';
  try{var res=await fetch(API,{credentials:'include'});var data=await res.json();if(!data.success){showStatus(data.error||'Error','error');return;}empresasData=data.empresas||[];renderTable(empresasData);}
  catch(e){showStatus('Error de red','error');}
}

/* ═══════ MODAL REVISIÓN ═══════ */
function openReview(sol){
  reviewPayload=sol;
  var kyc=sol.KYC&&typeof sol.KYC==='object'?sol.KYC:{};
  var bio=sol.Biometria&&typeof sol.Biometria==='object'?sol.Biometria:{};
  var isPendiente=String(sol.Estado||'').toLowerCase()==='pendiente';
  // header
  $('reviewIcon').className='review-header__icon';
  $('reviewTitle').textContent='Revisión de solicitud';
  $('reviewSubtitle').textContent='Verifica que toda la información sea correcta antes de aprobar o rechazar.';
  // campos empresa
  setRv('rv-nombre',sol.Nombre_Empresa);
  setRv('rv-rfc',sol.RFC);
  setRv('rv-desc',sol.Descripcion);
  setRv('rv-sitio',sol.Sitio_Web);
  // campos fiscales
  setRv('rv-razon',sol.Razon_Social);
  setRv('rv-regimen',sol.Regimen_Fiscal?REGIMENES[sol.Regimen_Fiscal]||sol.Regimen_Fiscal:null);
  setRv('rv-cp',sol.Codigo_Postal_Fiscal);
  // admin
  setRv('rv-admin-nombre',[sol.Usuario_Nombre,sol.Usuario_Apellido].filter(Boolean).join(' '));
  setRv('rv-admin-correo',sol.Usuario_Correo);
  setRv('rv-admin-tel',sol.Usuario_Telefono||null);
  // kyc
  setRv('rv-kyc-estado',kyc.Estado||'pendiente');
  setRv('rv-kyc-proveedor',kyc.Proveedor||'mock');
  setRv('rv-kyc-biometria',boolKyc(kyc.Biometria_Valida));
  setRv('rv-kyc-documento',boolKyc(kyc.Documento_Valido));
  setRv('rv-kyc-liveness',kyc.Liveness_Score==null?null:Number(kyc.Liveness_Score).toFixed(2));
  setRv('rv-kyc-score',kyc.Score_Comparacion==null?null:Number(kyc.Score_Comparacion).toFixed(2));
  setRv('rv-kyc-fraude',boolKyc(kyc.Fraude_Sospecha));
  setRv('rv-kyc-fecha',kyc.Fecha_Verificacion?new Date(kyc.Fecha_Verificacion).toLocaleString('es-MX'):null);
  setRv('rv-bio-disponible',bio.Disponible?'Si':'No');
  setRv('rv-bio-consent',bio.Consentimiento_Aceptado?'Si':'No');
  setRv('rv-bio-retencion',bio.Retencion_Hasta?new Date(bio.Retencion_Hasta).toLocaleDateString('es-MX'):null);
  setRv('rv-bio-hash',bio.Hash_SHA256_Prefix||null);
  var docs=Array.isArray(sol.Documentos)?sol.Documentos:[];
  var ineDoc=docs.find(function(d){return String(d?.tipo||'').toUpperCase()==='INE_REPRESENTANTE' && !!d?.url;})||null;
  var ineUrl=ineDoc?buildDocViewUrl(ineDoc):'';
  var selfieUrl=bio.Disponible?('/api/admin/empresas/biometria/'+sol.Id_Solicitud):'';
  var canOpenAdvancedCompare=!!(ineUrl&&selfieUrl&&isImageMime(ineDoc?.mime_type));

  setCompareMedia('rv-compare-ine',ineUrl,!!(ineDoc&&isImageMime(ineDoc?.mime_type)),'INE no disponible');
  setCompareMedia('rv-compare-selfie',selfieUrl,true,'Selfie biometrica privada no disponible');

  var ineLink=$('rv-compare-ine-link');
  if(ineLink){
    if(ineUrl){ineLink.hidden=false;ineLink.href=ineUrl;}
    else{ineLink.hidden=true;ineLink.removeAttribute('href');}
  }
  var selfieLink=$('rv-compare-selfie-link');
  if(selfieLink){
    if(selfieUrl){selfieLink.hidden=false;selfieLink.href=selfieUrl;}
    else{selfieLink.hidden=true;selfieLink.removeAttribute('href');}
  }
  var compareNote=$('rv-compare-note');
  if(compareNote){
    compareNote.textContent=(ineUrl&&selfieUrl)
      ?'Valida rasgos faciales, proporciones y similitud visual general. Si no corresponde, rechaza KYC.'
      :'No se puede validar identidad completa: falta INE o selfie biometrica privada.';
  }
  var advCompareBtn=$('rv-open-compare');
  if(advCompareBtn){
    advCompareBtn.disabled=!canOpenAdvancedCompare;
    advCompareBtn.title=canOpenAdvancedCompare?'':'Para zoom sincronizado, sube INE en formato imagen (JPG/PNG/WEBP).';
  }
  compareState.ineUrl=ineUrl;
  compareState.selfieUrl=selfieUrl;
  compareState.enabled=canOpenAdvancedCompare;

  var linkEl=$('rv-bio-link');
  if(linkEl){
    if(bio.Disponible){
      linkEl.classList.remove('rv-empty');
      linkEl.innerHTML='<a class="rv-doc-link" href="/api/admin/empresas/biometria/'+sol.Id_Solicitud+'" target="_blank" rel="noopener">Abrir selfie biometrica cifrada</a>';
    }else{
      linkEl.textContent='—';
      linkEl.classList.add('rv-empty');
    }
  }
  setRv('rv-kyc-url','Oculta por seguridad');
  // docs
  var docDefs=[{tipo:'ACTA_CONSTITUTIVA',label:'Acta constitutiva'},{tipo:'INE_REPRESENTANTE',label:'INE representante'},{tipo:'CONSTANCIA_FISCAL',label:'Constancia fiscal'}];
  $('rv-docs').innerHTML=docDefs.map(function(def){
    var doc=docs.find(function(d){return String(d?.tipo||'').toUpperCase()===def.tipo;});
    var has=doc&&doc.url;
    var link='';
    if(has){var q=new URLSearchParams({url:doc.url});if(doc.public_id)q.set('public_id',doc.public_id);if(doc.resource_type)q.set('resource_type',doc.resource_type);if(doc.format)q.set('format',doc.format);link='<a class="rv-doc-link" href="/api/admin/empresas/documentos/view?'+q.toString()+'" target="_blank" rel="noopener"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>Ver documento</a>';}
    return'<div class="rv-doc '+(has?'ok':'missing')+'"><span class="rv-doc__name">'+def.label+'</span><span class="rv-doc__status">'+(has?'✓ Subido':'✗ Faltante')+'</span>'+(has?link:'')+'</div>';
  }).join('');
  // dirección
  setRv('rv-dir-calle',[sol.Domicilio_Calle,sol.Domicilio_Numero_Casa].filter(Boolean).join(' No. '));
  setRv('rv-dir-ciudad',[sol.Domicilio_Ciudad,sol.Domicilio_Provincia].filter(Boolean).join(', '));
  setRv('rv-dir-cp',[sol.Domicilio_Codigo_Postal,sol.Domicilio_Pais].filter(Boolean).join(' · '));
  setRv('rv-sucursal',sol.Sucursal_Nombre);
  // checklist
  setChk('chkEmpresa',!!sol.Nombre_Empresa);
  setChk('chkFiscal',!!(sol.Razon_Social&&sol.Regimen_Fiscal&&sol.Codigo_Postal_Fiscal));
  setChk('chkAdmin',!!(sol.Usuario_Nombre&&sol.Usuario_Correo));
  setChk('chkKyc',String(kyc.Estado||'').toLowerCase()==='aprobado'&&kyc.Biometria_Valida===true&&kyc.Documento_Valido===true&&kyc.Fraude_Sospecha!==true);
  setChk('chkIdentidad',!!(ineUrl&&selfieUrl));
  setChk('chkDocs',hasAllDocs(sol.Documentos));
  setChk('chkDir',!!(sol.Domicilio_Calle&&sol.Domicilio_Ciudad));
  // sección rechazo oculta por default
  $('reviewRejectSection').hidden=true;
  $('reviewMotivo').value='';
  // botones visibles solo si pendiente
  $('reviewApproveBtn').hidden=!isPendiente;
  $('reviewRejectBtn').hidden=!isPendiente;
  $('reviewKycApproveBtn').hidden=!isPendiente;
  $('reviewKycRejectBtn').hidden=!isPendiente;
  var kycApproveBtn=$('reviewKycApproveBtn');
  if(kycApproveBtn){
    var canApproveKyc=!!(ineUrl&&selfieUrl);
    kycApproveBtn.disabled=!canApproveKyc;
    kycApproveBtn.title=canApproveKyc?'':'Falta INE o selfie biometrica privada para validar identidad';
  }
  $('reviewModal').hidden=false;
}

async function updateKycManual(isApproved){
  if(!reviewPayload)return;
  var reqBody={
    id: reviewPayload.Id_Solicitud,
    estado: isApproved ? 'aprobado' : 'rechazado',
    proveedor: 'manual_superusuario',
    biometriaValida: !!isApproved,
    documentoValido: !!isApproved,
    fraudeSospecha: isApproved ? false : true,
    scoreComparacion: isApproved ? 0.96 : 0.35,
    livenessScore: isApproved ? 0.97 : 0.3,
    motivoRechazo: isApproved ? null : 'KYC rechazado por revisión manual de superusuario',
    payloadProveedor: {
      mode: 'manual_superuser_review',
      reviewedAt: new Date().toISOString(),
      comparedAgainstIne: true,
    },
  };

  var res=await fetch(KYC_API,{method:'PUT',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify(reqBody)});
  var data=await res.json().catch(function(){return{};});
  if(!res.ok||!data.success) throw new Error(data.error||'No se pudo actualizar KYC');

  var k=data.kyc||{};
  reviewPayload.KYC={
    Estado:k.estado||reqBody.estado,
    Proveedor:k.proveedor||reqBody.proveedor,
    Biometria_Valida:k.biometriaValida,
    Documento_Valido:k.documentoValido,
    Fraude_Sospecha:k.fraudeSospecha,
    Score_Comparacion:k.scoreComparacion,
    Liveness_Score:k.livenessScore,
    Fecha_Verificacion:k.fechaVerificacion,
  };
  openReview(reviewPayload);
}

function setRv(id,val){var el=$(id);if(!el)return;if(!val||String(val).trim()===''){el.textContent='—';el.classList.add('rv-empty');}else{el.textContent=String(val).trim();el.classList.remove('rv-empty');}}
function setChk(id,ok){var el=$(id);if(!el)return;el.className='review-check '+(ok?'ok':'warn');}
function closeReview(){$('reviewModal').hidden=true;reviewPayload=null;}

// Aprobar
$('reviewApproveBtn').addEventListener('click',async function(){
  if(!reviewPayload)return;
  var btn=$('reviewApproveBtn');btn.disabled=true;btn.textContent='Aprobando…';
  try{
    var res=await fetch(API,{method:'PUT',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:reviewPayload.Id_Solicitud,action:'approve'})});
    var data=await res.json();
    if(!data.success){if(res.status===409)await loadEmpresas();showStatus(data.error||'Error','error');return;}
    closeReview();
    showStatus(data?.email?.sent===false?'Aprobada, pero correo no enviado.':'Solicitud aprobada.');
    await loadEmpresas();
  }catch(e){showStatus('Error de red','error');}
  finally{btn.disabled=false;btn.innerHTML='<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M20 6L9 17l-5-5"/></svg>Confirmar aprobación';}
});

// Rechazar — muestra sección motivo y cambia botón
$('reviewRejectBtn').addEventListener('click',async function(){
  var section=$('reviewRejectSection');
  // primera vez: muestra el textarea
  if(section.hidden){section.hidden=false;$('reviewMotivo').focus();$('reviewRejectBtn').textContent='Confirmar rechazo';return;}
  // segunda vez: ejecuta el rechazo
  var btn=$('reviewRejectBtn');btn.disabled=true;btn.textContent='Rechazando…';
  var motivo=String($('reviewMotivo').value||'').trim();
  try{
    var res=await fetch(API,{method:'PUT',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:reviewPayload.Id_Solicitud,action:'reject',motivo:motivo})});
    var data=await res.json();
    if(!data.success){showStatus(data.error||'Error','error');return;}
    closeReview();showStatus('Solicitud rechazada.');await loadEmpresas();
  }catch(e){showStatus('Error de red','error');}
  finally{btn.disabled=false;btn.innerHTML='<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>Rechazar solicitud';}
});

$('reviewKycApproveBtn').addEventListener('click',async function(){
  var btn=$('reviewKycApproveBtn');
  btn.disabled=true;
  btn.textContent='Validando KYC…';
  try{await updateKycManual(true);showStatus('KYC biometrico aprobado por superusuario.');}
  catch(e){showStatus(e?.message||'No se pudo aprobar KYC','error');}
  finally{btn.disabled=false;btn.innerHTML='Validar KYC';}
});

$('reviewKycRejectBtn').addEventListener('click',async function(){
  var btn=$('reviewKycRejectBtn');
  btn.disabled=true;
  btn.textContent='Rechazando KYC…';
  try{await updateKycManual(false);showStatus('KYC biometrico rechazado por superusuario.','error');}
  catch(e){showStatus(e?.message||'No se pudo rechazar KYC','error');}
  finally{btn.disabled=false;btn.innerHTML='Rechazar KYC';}
});

