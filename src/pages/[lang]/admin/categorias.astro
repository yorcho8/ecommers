---
import BaseLayout from "../../../layouts/BaseLayout.astro";
export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}

const currentLang = "es";
const cspNonce = Astro.locals?.cspNonce || "";

const role = String(Astro.locals?.user?.rol || "").trim().toLowerCase().replace(/[\s_-]/g, "")
  .replace(/^superadmin$|^superuser$|^superusuario$/, "superusuario");

if (!role) return Astro.redirect(`/${currentLang}/login`);
if (role !== "admin" && role !== "superusuario") return Astro.redirect(`/${currentLang}`);
---

<BaseLayout title="Gestion de categorias" currentLang={currentLang}>

  <script nonce={cspNonce} is:inline>
  (function(g){
    if(document.getElementById('go-modal-styles'))return;
    const s=document.createElement('style');
    s.id='go-modal-styles';
    s.textContent=`
      .go-modal-backdrop{position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.55);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;padding:1rem;opacity:0;transition:opacity 220ms ease}
      .go-modal-backdrop.go-visible{opacity:1}
      .go-modal{background:#1a1d28;border:1px solid rgba(168,85,247,.15);border-radius:20px;box-shadow:0 24px 60px rgba(0,0,0,.5);padding:2rem 2rem 1.6rem;width:100%;max-width:420px;text-align:center;transform:scale(.88) translateY(20px);transition:transform 260ms cubic-bezier(.34,1.56,.64,1);position:relative}
      .go-modal-backdrop.go-visible .go-modal{transform:scale(1) translateY(0)}
      .go-modal-icon{width:72px;height:72px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.1rem}
      .go-modal-icon.success{background:rgba(34,197,94,.1);color:#22c55e}.go-modal-icon.error{background:rgba(239,68,68,.1);color:#ef4444}
      .go-modal-icon.warning{background:rgba(245,158,11,.1);color:#f59e0b}.go-modal-icon.info{background:rgba(96,165,250,.1);color:#60a5fa}
      .go-modal-icon.confirm{background:rgba(168,85,247,.1);color:#a855f7}
      .go-modal-title{font-size:1.35rem;font-weight:700;color:#f0f2f5;margin:0 0 .5rem;font-family:inherit!important;letter-spacing:normal!important;text-transform:none!important}
      .go-modal-text{font-size:.97rem;color:#8b95a5;margin:0 0 1.4rem;line-height:1.5;font-family:inherit!important;letter-spacing:normal!important}
      .go-modal-actions{display:flex;gap:.7rem;justify-content:center;flex-wrap:wrap}
      .go-modal-btn{padding:.65rem 1.6rem;border-radius:12px;font-size:.95rem;font-weight:600;cursor:pointer;border:none;transition:filter 160ms,transform 100ms;min-width:110px;font-family:inherit!important;letter-spacing:normal!important;text-transform:none!important}
      .go-modal-btn:hover{filter:brightness(1.08)}.go-modal-btn:active{transform:scale(.97)}
      .go-modal-btn.primary{background:linear-gradient(135deg,#a855f7,#7c3aed);color:#fff}.go-modal-btn.secondary{background:rgba(255,255,255,.06);color:#8b95a5;border:1px solid rgba(255,255,255,.1)}
      .go-modal-btn.danger{background:#ef4444;color:#fff}
      .go-modal-progress{position:absolute;bottom:0;left:0;height:4px;border-radius:0 0 20px 20px;background:linear-gradient(90deg,#a855f7,#7c3aed);width:100%;transform-origin:left;animation:go-progress linear forwards}
      @keyframes go-progress{from{transform:scaleX(1)}to{transform:scaleX(0)}}
      .go-loading-backdrop{position:fixed;inset:0;z-index:10500;background:rgba(0,0,0,.6);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 200ms ease}
      .go-loading-backdrop.go-visible{opacity:1;pointer-events:auto}
      .go-loading-box{background:#1a1d28;border:1px solid rgba(168,85,247,.12);border-radius:20px;padding:2rem 2.5rem;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,.5);min-width:220px}
      .go-loading-spinner{width:52px;height:52px;border-radius:50%;border:4px solid rgba(168,85,247,.2);border-top-color:#a855f7;animation:go-spin 0.8s linear infinite;margin:0 auto 1rem}
      @keyframes go-spin{to{transform:rotate(360deg)}}
      .go-loading-title{font-size:1rem;font-weight:700;color:#f0f2f5;margin:0 0 .25rem;font-family:inherit!important}
      .go-loading-sub{font-size:0.8rem;color:#5a6478;margin:0;font-family:inherit!important}
    `;
    document.head.appendChild(s);
    const IC={
      success:`<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>`,
      error:`<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`,
      warning:`<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
      info:`<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>`,
      confirm:`<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    };
    function show(o){return new Promise(function(res){var type=o.type||'info',title=o.title||'',text=o.text||'',ct=o.confirmText||'Aceptar',cct=o.cancelText||'Cancelar',sc=o.showCancel||false,ac=o.autoClose||0;var bd=document.createElement('div');bd.className='go-modal-backdrop';bd.innerHTML='<div class="go-modal" role="dialog" aria-modal="true"><div class="go-modal-icon '+type+'">'+(IC[type]||IC.info)+'</div><h2 class="go-modal-title">'+title+'</h2>'+(text?'<p class="go-modal-text">'+text+'</p>':'')+'<div class="go-modal-actions">'+(sc?'<button class="go-modal-btn secondary" id="gmc">'+cct+'</button>':'')+'<button class="go-modal-btn '+(type==='error'?'danger':'primary')+'" id="gmok">'+ct+'</button></div>'+(ac?'<div class="go-modal-progress" style="animation-duration:'+ac+'ms"></div>':'')+'</div>';document.body.appendChild(bd);requestAnimationFrame(function(){bd.classList.add('go-visible');});function close(r){bd.classList.remove('go-visible');setTimeout(function(){bd.remove();},260);res(r);}bd.querySelector('#gmok').addEventListener('click',function(){close(true);});var cc=bd.querySelector('#gmc');if(cc)cc.addEventListener('click',function(){close(false);});function onKey(e){if(e.key==='Escape'){close(false);document.removeEventListener('keydown',onKey);}}document.addEventListener('keydown',onKey);if(ac)setTimeout(function(){close(true);},ac);});}
    var _loadEl=null;
    function showLoading(title,sub){if(_loadEl)return;_loadEl=document.createElement('div');_loadEl.className='go-loading-backdrop';_loadEl.innerHTML='<div class="go-loading-box"><div class="go-loading-spinner"></div><p class="go-loading-title">'+(title||'Procesando...')+'</p><p class="go-loading-sub">'+(sub||'Por favor espera')+'</p></div>';document.body.appendChild(_loadEl);requestAnimationFrame(function(){_loadEl.classList.add('go-visible');});}
    function hideLoading(){if(!_loadEl)return;_loadEl.classList.remove('go-visible');setTimeout(function(){if(_loadEl){_loadEl.remove();_loadEl=null;}},220);}
    g.Modal={success:function(t,x,o){return show(Object.assign({type:'success',title:t,text:x},o||{}));},error:function(t,x,o){return show(Object.assign({type:'error',title:t,text:x},o||{}));},warning:function(t,x,o){return show(Object.assign({type:'warning',title:t,text:x},o||{}));},info:function(t,x,o){return show(Object.assign({type:'info',title:t,text:x},o||{}));},confirm:function(t,x,o){return show(Object.assign({type:'confirm',title:t,text:x,showCancel:true},o||{}));},loading:showLoading,hideLoading:hideLoading,};
  })(window);
  </script>

  <!-- Runtime-injected styles for action buttons, badges & pagination (bypasses Astro CSS scoping) -->
  <script nonce={cspNonce} is:inline>
  (function(){
    if(document.getElementById('ca-runtime-styles'))return;
    var s=document.createElement('style');
    s.id='ca-runtime-styles';
    s.textContent=`
      .ca-row-actions{display:flex!important;align-items:center!important;gap:6px!important;justify-content:center!important}
      button.ca-row-btn{width:32px!important;height:32px!important;border-radius:8px!important;border:1px solid rgba(255,255,255,.07)!important;background:rgba(255,255,255,.04)!important;display:inline-flex!important;align-items:center!important;justify-content:center!important;cursor:pointer!important;transition:all .2s ease!important;padding:0!important;line-height:1!important;flex-shrink:0!important;outline:none!important;box-shadow:none!important;font-size:0!important;overflow:hidden!important}
      button.ca-row-btn:hover{transform:translateY(-1px)!important;filter:brightness(1.3)!important}
      button.ca-row-btn svg{width:14px!important;height:14px!important;stroke:currentColor!important;fill:none!important;stroke-width:2!important;stroke-linecap:round!important;stroke-linejoin:round!important;display:block!important;pointer-events:none!important}
      button.ca-row-btn.ca-row-btn--edit{color:#c084fc!important;border-color:rgba(168,85,247,.3)!important}
      button.ca-row-btn.ca-row-btn--edit:hover{background:rgba(168,85,247,.15)!important}
      button.ca-row-btn.ca-row-btn--delete{color:#ef4444!important;border-color:rgba(239,68,68,.2)!important}
      button.ca-row-btn.ca-row-btn--delete:hover{background:rgba(239,68,68,.08)!important}
      .ca-prod-badge{display:inline-block!important;font-size:10px!important;font-weight:700!important;padding:3px 10px!important;border-radius:20px!important;background:rgba(96,165,250,.1)!important;color:#60a5fa!important;border:1px solid rgba(96,165,250,.25)!important}
      .ca-no-data{color:#5a6478!important;font-size:11px!important}
      button.ca-page-btn{min-width:34px!important;height:34px!important;border-radius:8px!important;border:1px solid rgba(255,255,255,.07)!important;background:rgba(255,255,255,.03)!important;color:#8b95a5!important;font-size:12px!important;font-weight:600!important;cursor:pointer!important;display:inline-flex!important;align-items:center!important;justify-content:center!important;transition:all .18s ease!important;padding:0 8px!important;font-family:inherit!important;outline:none!important}
      button.ca-page-btn:hover:not(.disabled):not(.active){background:rgba(255,255,255,.07)!important;border-color:rgba(255,255,255,.14)!important;color:#f0f2f5!important}
      button.ca-page-btn.active{background:linear-gradient(135deg,#a855f7,#7c3aed)!important;border-color:transparent!important;color:#fff!important;box-shadow:0 2px 12px rgba(168,85,247,.4)!important;font-weight:700!important}
      button.ca-page-btn.disabled{opacity:.3!important;cursor:not-allowed!important}
      button.ca-page-btn.ca-page-btn--arrow{min-width:36px!important}
      button.ca-page-btn.ca-page-btn--arrow svg{width:14px!important;height:14px!important;stroke:currentColor!important;fill:none!important;display:block!important;pointer-events:none!important}
      .ca-page-ellipsis{color:#5a6478;font-size:13px;padding:0 4px;user-select:none;display:inline-flex;align-items:center;height:34px}
    `;
    document.head.appendChild(s);
  })();
  </script>

  <main class="ca-page">
    <section class="ca-shell">

      <header class="ca-header">
        <div>
          <span class="ca-kicker">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Panel Admin
          </span>
          <h1 class="ca-title">Gestión de categorías</h1>
          <p class="ca-subtitle">Crea, edita y elimina las categorías del catálogo.</p>
        </div>
        <div class="ca-top-actions">
          <button id="btnAddCategory" class="ca-add-btn" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Añadir categoría
          </button>
          <a class="ca-back" href={`/${currentLang}`}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
            Volver al sitio
          </a>
        </div>
      </header>

      <!-- Image Viewer Modal -->
      <section id="catImageViewerModal" class="ca-img-modal" hidden>
        <div id="catImageViewerPanel" class="ca-img-panel" role="dialog" aria-modal="true">
          <div class="ca-img-head">
            <div class="ca-img-head-text">
              <span class="ca-img-badge">Galería</span>
              <h2 class="ca-img-title" id="catImageViewerName">Categoría</h2>
            </div>
            <button id="catImageViewerClose" class="ca-img-close" type="button" aria-label="Cerrar">
              <svg viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"></path></svg>
            </button>
          </div>
          <div class="ca-img-preview-card">
            <div id="catImageViewerPreview" class="ca-img-preview">
              <img id="catImageViewerImg" class="ca-img-preview-img" src="" alt="Preview" />
              <div class="ca-img-empty" id="catImageViewerEmpty">
                <svg viewBox="0 0 24 24"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <span>Sin imágenes</span>
              </div>
            </div>
            <p class="ca-img-counter" id="catImageViewerCounter"></p>
          </div>
          <div class="ca-img-section">
            <p class="ca-img-section-label">Imágenes actuales</p>
            <div id="catImageViewerList" class="ca-img-list"></div>
          </div>
          <div class="ca-img-section">
            <p class="ca-img-section-label">Agregar nueva imagen</p>
            <div class="ca-img-add-row">
              <div class="ca-img-input-wrap">
                <svg class="ca-img-input-icon" viewBox="0 0 24 24"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101"></path><path d="M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                <input id="catImageViewerNewUrl" class="ca-img-input" type="text" placeholder="URL de Cloudinary (se llena automáticamente al subir)" />
              </div>
              <button id="catImageViewerAddBtn" class="ca-img-add-btn" type="button">
                <svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"></path></svg>
                Agregar
              </button>
            </div>
            <div class="ca-img-upload-row">
              <input id="catImageUploadFile" class="ca-img-upload-file" type="file" accept="image/png,image/jpeg,image/webp" />
              <button id="catImageUploadBtn" class="ca-img-upload-btn" type="button">Subir imagen a Cloudinary</button>
            </div>
          </div>
          <div class="ca-img-footer">
            <button class="ca-img-cancel" type="button" id="catImageViewerCancelBtn">Cancelar</button>
            <button id="catImageViewerSave" class="ca-img-save" type="button">
              <svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg>
              Guardar cambios
            </button>
          </div>
        </div>
      </section>

      <!-- Form Panel -->
      <section id="catFormPanel" class="ca-form-panel" hidden>
        <article class="ca-card ca-card--form">
          <div class="ca-form-header">
            <h2 id="catFormTitle">Nueva categoría</h2>
            <button id="btnCancelEdit" class="ca-btn-close" type="button">x Cerrar</button>
          </div>
          <p class="ca-note">Completa los campos y presiona Guardar. El nombre es obligatorio.</p>
          <input id="currentCategoryId" type="hidden" />
          <div class="ca-form-grid">
            <div class="ca-field"><label for="catNombre">Nombre *</label><input id="catNombre" type="text" placeholder="Nombre de la categoría" /></div>
            <div class="ca-field"><label for="catDescripcion">Descripción</label><input id="catDescripcion" type="text" placeholder="Descripción (opcional)" /></div>
            <div class="ca-field">
              <label>&nbsp;</label>
              <input id="catImagenUrl" type="hidden" />
              <button id="btnCatOpenGallery" class="ca-btn-gallery" type="button">
                <svg viewBox="0 0 24 24"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                Gestionar imágenes
              </button>
            </div>
          </div>
          <div class="ca-form-actions">
            <button id="btnSave" class="ca-btn-save" type="button">
              <svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"></path></svg>
              Guardar cambios
            </button>
            <button id="btnFormReset" class="ca-btn-ghost" type="button">Limpiar</button>
          </div>
        </article>
      </section>

      <!-- Lista -->
      <section class="ca-list-section">
        <article class="ca-card">
          <div class="ca-toolbar">
            <div class="ca-toolbar__left"><label for="rowsPerPage">Mostrar</label><select id="rowsPerPage" class="ca-toolbar-select"><option value="5">5</option><option value="10">10</option><option value="25">25</option><option value="50">50</option></select><span>por página</span></div>
            <div class="ca-toolbar__center"><button id="btnCopy" class="ca-mini-btn" type="button">Copiar</button><button id="btnCsv" class="ca-mini-btn ca-mini-btn--blue" type="button">CSV</button></div>
            <div class="ca-toolbar__right"><label for="searchCategories">Buscar:</label><input id="searchCategories" class="ca-toolbar-search" type="text" placeholder="Nombre o descripción..." /></div>
          </div>
          <div class="ca-list-header"><h2>Lista de categorías</h2><div id="catStatsBar" class="ca-stats"></div></div>
          <div class="ca-table-wrap">
            <table class="ca-table">
              <thead><tr><th>ID</th><th>Nombre</th><th>Descripción</th><th>Imagen</th><th>Productos</th><th class="ca-th-actions">Acciones</th></tr></thead>
              <tbody id="catRows"></tbody>
            </table>
          </div>
          <div class="ca-pagination" id="paginationBar"><span id="catResultsInfo" class="ca-pagination__info"></span><div class="ca-pagination__controls" id="paginationControls"></div></div>
        </article>
      </section>

    </section>
  </main>

  <!-- All JS logic -->
  <script nonce={cspNonce} is:inline>
    const formPanelEl=document.getElementById("catFormPanel");const formTitleEl=document.getElementById("catFormTitle");const currentCategoryIdEl=document.getElementById("currentCategoryId");const rowsEl=document.getElementById("catRows");const btnAddCategory=document.getElementById("btnAddCategory");const searchEl=document.getElementById("searchCategories");const rowsPerPageEl=document.getElementById("rowsPerPage");const resultsInfoEl=document.getElementById("catResultsInfo");const statsBarEl=document.getElementById("catStatsBar");const paginationControlsEl=document.getElementById("paginationControls");const btnCopy=document.getElementById("btnCopy");const btnCsv=document.getElementById("btnCsv");const nombreEl=document.getElementById("catNombre");const descripcionEl=document.getElementById("catDescripcion");const imagenUrlEl=document.getElementById("catImagenUrl");const btnSave=document.getElementById("btnSave");const btnCancelEdit=document.getElementById("btnCancelEdit");const btnFormReset=document.getElementById("btnFormReset");
    let categories=[],filteredCategories=[],formMode="create",currentPage=1;

    /* â”€â”€â”€ SVG helper â€” creates proper namespace SVG via DOM â”€â”€â”€ */
    function makeSVG(pathsArray, w, h, sw) {
      var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('viewBox', '0 0 24 24');
      svg.setAttribute('width', String(w || 14));
      svg.setAttribute('height', String(h || 14));
      svg.setAttribute('fill', 'none');
      svg.setAttribute('stroke', 'currentColor');
      svg.setAttribute('stroke-width', String(sw || 2));
      svg.setAttribute('stroke-linecap', 'round');
      svg.setAttribute('stroke-linejoin', 'round');
      svg.style.display = 'block';
      svg.style.pointerEvents = 'none';
      pathsArray.forEach(function(d) {
        var p = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        p.setAttribute('d', d);
        svg.appendChild(p);
      });
      return svg;
    }
    var SVG_EDIT = ['M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7','M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z'];
    var SVG_DELETE = ['M3 6h18','M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2','M10 11v6','M14 11v6'];

    function setMode(mode,label){formMode=mode;if(!formTitleEl||!currentCategoryIdEl)return;if(mode==="edit")formTitleEl.innerHTML=`Editando: <span style="color:#c084fc;font-weight:700">${label||""}</span>`;else{formTitleEl.textContent="Nueva categoría";currentCategoryIdEl.value="";}}
    function resetForm(){if(!nombreEl||!descripcionEl||!imagenUrlEl)return;nombreEl.value="";descripcionEl.value="";imagenUrlEl.value="";setMode("create");}
    function openForm(mode="create",label){if(!formPanelEl)return;formPanelEl.hidden=false;setMode(mode,label);formPanelEl.scrollIntoView({behavior:"smooth",block:"start"});}
    function closeForm(){if(!formPanelEl)return;formPanelEl.hidden=true;resetForm();}
    function fillForm(cat){if(!nombreEl||!descripcionEl||!imagenUrlEl||!currentCategoryIdEl)return;currentCategoryIdEl.value=String(cat.id);nombreEl.value=cat.nombre||"";descripcionEl.value=cat.descripcion||"";imagenUrlEl.value=cat.imagenUrl||"";openForm("edit",cat.nombre||"");}
    function truncate(text,max){const s=String(text||"");return s.length>max?s.slice(0,max)+"...":s;}
    function applyFilters(){const q=String(searchEl?.value||"").trim().toLowerCase();filteredCategories=categories.filter(c=>{if(!q)return true;return String(c.nombre||"").toLowerCase().includes(q)||String(c.descripcion||"").toLowerCase().includes(q);});}
    function getPageData(){applyFilters();const perPage=Number(rowsPerPageEl?.value||10);const totalPages=Math.max(1,Math.ceil(filteredCategories.length/perPage));if(currentPage>totalPages)currentPage=totalPages;const start=(currentPage-1)*perPage;return{items:filteredCategories.slice(start,start+perPage),total:filteredCategories.length,totalPages,perPage,start};}

    /* â”€â”€â”€ PAGINATION RENDER (improved with SVG arrows, always visible) â”€â”€â”€ */
    function renderPagination({total,totalPages,start,items}){
      if(resultsInfoEl) resultsInfoEl.textContent = total === 0 ? "Sin resultados" : `Mostrando ${start+1}-${start+items.length} de ${total}`;
      if(!paginationControlsEl) return;
      paginationControlsEl.innerHTML="";

      function mkBtn(label, page, active, disabled, isArrow) {
        var b = document.createElement("button");
        b.className = "ca-page-btn" + (active ? " active" : "") + (disabled ? " disabled" : "") + (isArrow ? " ca-page-btn--arrow" : "");
        b.type = "button";
        if (isArrow) {
          var svg = document.createElementNS('http://www.w3.org/2000/svg','svg');
          svg.setAttribute('viewBox','0 0 24 24');svg.setAttribute('width','14');svg.setAttribute('height','14');
          svg.setAttribute('fill','none');svg.setAttribute('stroke','currentColor');svg.setAttribute('stroke-width','2.5');
          svg.setAttribute('stroke-linecap','round');svg.setAttribute('stroke-linejoin','round');
          svg.style.display='block';svg.style.pointerEvents='none';
          var p = document.createElementNS('http://www.w3.org/2000/svg','path');
          p.setAttribute('d', label === 'prev' ? 'M15 18l-6-6 6-6' : 'M9 18l6-6-6-6');
          svg.appendChild(p);
          b.appendChild(svg);
        } else {
          b.textContent = label;
        }
        b.disabled = disabled;
        if (!disabled && !active) b.addEventListener("click", function(){ currentPage = page; renderCategories(); });
        return b;
      }

      // Previous
      paginationControlsEl.appendChild(mkBtn("prev", currentPage - 1, false, currentPage === 1, true));

      // Page numbers
      var delta = 2;
      var pages = new Set([1, totalPages]);
      for (var i = Math.max(2, currentPage - delta); i <= Math.min(totalPages - 1, currentPage + delta); i++) pages.add(i);
      var prev = 0;
      Array.from(pages).sort(function(a,b){return a-b;}).forEach(function(p) {
        if (prev && p - prev > 1) {
          var ellipsis = document.createElement("span");
          ellipsis.className = "ca-page-ellipsis";
          ellipsis.textContent = "...";
          paginationControlsEl.appendChild(ellipsis);
        }
        paginationControlsEl.appendChild(mkBtn(String(p), p, p === currentPage, false, false));
        prev = p;
      });

      // Next
      paginationControlsEl.appendChild(mkBtn("next", currentPage + 1, false, currentPage === totalPages, true));
    }

    function renderStats(){if(!statsBarEl)return;const total=categories.length;const conImg=categories.filter(c=>c.imagenUrl).length;const conProds=categories.filter(c=>c.productCount>0).length;statsBarEl.innerHTML=`<span class="ca-stat-chip">${total} total</span><span class="ca-stat-chip ca-stat-chip--green">${conImg} con imagen</span><span class="ca-stat-chip ca-stat-chip--purple">${conProds} con productos</span>`;}

    function renderCategories(){
