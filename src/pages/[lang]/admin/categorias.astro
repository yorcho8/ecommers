  <script nonce={cspNonce} is:inline>
    (function(){
      const uploadFile = document.getElementById("catImageUploadFile");
      const uploadBtn = document.getElementById("catImageUploadBtn");
      const newUrlInput = document.getElementById("catImageViewerNewUrl");
      const addBtn = document.getElementById("catImageViewerAddBtn");

      if (!(uploadBtn instanceof HTMLButtonElement)) return;

      uploadBtn.addEventListener("click", async () => {
        if (!(uploadFile instanceof HTMLInputElement) || !uploadFile.files || !uploadFile.files[0]) {
          if (window.Modal?.warning) window.Modal.warning("Sin archivo", "Selecciona una imagen primero");
          return;
        }

        const fd = new FormData();
        fd.append("file", uploadFile.files[0]);

        try {
          if (window.Modal?.loading) window.Modal.loading("Subiendo imagen", "Enviando a Cloudinary...");
          const res = await fetch("/api/admin/categorias/imagenes/upload", {
            method: "POST",
            credentials: "include",
            body: fd,
          });
          const data = await res.json().catch(() => ({}));
          if (window.Modal?.hideLoading) window.Modal.hideLoading();

          if (!res.ok || !data?.success || !data?.url) {
            throw new Error(data?.error || "No se pudo subir la imagen");
          }

          if (newUrlInput instanceof HTMLInputElement) {
            newUrlInput.value = String(data.url);
          }
          if (addBtn instanceof HTMLButtonElement) {
            addBtn.click();
          }
          uploadFile.value = "";

          if (window.Modal?.success) window.Modal.success("Imagen lista", "Se subió correctamente", { autoClose: 1800 });
        } catch (error) {
          if (window.Modal?.hideLoading) window.Modal.hideLoading();
          if (window.Modal?.error) window.Modal.error("Error", String(error?.message || "Error subiendo imagen"));
        }
      });
    })();
  </script>

