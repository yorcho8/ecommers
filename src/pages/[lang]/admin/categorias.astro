    background-clip: unset !important;
    -webkit-background-clip: unset !important;
    box-sizing: border-box;
  }

  /* Reemplazamos h1, h2, p y svgs sueltos por clases fuertes para evitar a BaseLayout */
  .ux-root .ux .ux-hero__title { font-size: clamp(1.4rem, 2.4vw, 2rem) !important; line-height: 1.1 !important; margin: 0 !important; padding: 0 !important; background: none !important; color: var(--ux-t1) !important; font-weight: 800 !important; }
  .ux-root .ux .ux-form-titlebar__title { font-size: 1rem !important; line-height: 1.3 !important; margin: 0 !important; padding: 0 !important; background: none !important; color: var(--ux-t1) !important; font-weight: 700 !important;}
  .ux-root .ux p, .ux-root .ux span, .ux-root .ux label, .ux-root .ux div { font-size: 0.85rem; line-height: 1.5; margin: 0; }
  .ux-root .ux svg { width: 16px !important; height: 16px !important; display: inline-block; flex-shrink: 0; }

  .ux-root .ux {
    max-width: 1340px;
    margin: 0 auto;
    padding: 30px 24px 64px;
    display: grid;
    gap: 14px;
  }

  /* ── Hero ── */
  .ux-root .ux-hero {
    position: relative;
    border: 1px solid var(--ux-line);
    border-radius: var(--ux-r);
    padding: 28px 28px 22px;
    overflow: hidden;
    background: linear-gradient(150deg, var(--ux-s2), var(--ux-s1));
    box-shadow: 0 20px 50px rgba(0,0,0,0.3);
  }

  .ux-root .ux-hero__glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 5% -15%, rgba(139,92,246,0.22), transparent 48%),
      radial-gradient(ellipse at 92% 0%, rgba(34,211,238,0.09), transparent 42%);
    pointer-events: none;
  }

  .ux-root .ux-hero__body {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .ux-root .ux-hero__kicker { margin: 0 !important; font-size: 0.66rem !important; font-weight: 700 !important; text-transform: uppercase !important; letter-spacing: 0.14em !important; color: #c4b5fd !important; }
  .ux-root .ux-hero__sub { margin: 5px 0 0 !important; font-size: 0.85rem !important; color: var(--ux-t2) !important; }
  .ux-root .ux-hero__right { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }

  .ux-root .ux-hero__stats {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--ux-line);
    font-size: 0.8rem;
    color: var(--ux-t2);
  }

  .ux-root .ux-stat strong { color: var(--ux-t1); font-weight: 700; margin-right: 3px; }
  .ux-root .ux-stat--violet strong { color: #c4b5fd; }
  .ux-root .ux-stat--green strong { color: var(--ux-good); }
  .ux-root .ux-stat-sep { color: var(--ux-t3); user-select: none; }

  /* CTA buttons */
  .ux-root .ux-cta {
    display: inline-flex; align-items: center; justify-content: center; gap: 7px;
    padding: 9px 18px !important; border-radius: 99px !important; font-size: 0.8rem !important; font-weight: 700 !important;
    cursor: pointer; transition: transform var(--ux-t-fast), box-shadow var(--ux-t-fast);
    text-decoration: none !important; border: none !important; white-space: nowrap; outline: none;
  }
  .ux-root .ux-cta:not(.ux-cta--ghost) { background: linear-gradient(135deg, var(--ux-vi), #6d28d9) !important; color: #fff !important; box-shadow: 0 4px 18px var(--ux-vi-glow) !important; }
  .ux-root .ux-cta--ghost { background: rgba(255,255,255,0.05) !important; border: 1px solid var(--ux-line-h) !important; color: var(--ux-t2) !important; box-shadow: none !important; }
  .ux-root .ux-cta:hover { transform: translateY(-2px); }
  .ux-root .ux-cta:not(.ux-cta--ghost):hover { box-shadow: 0 8px 26px var(--ux-vi-glow) !important; }
  .ux-root .ux-cta--ghost:hover { color: var(--ux-t1) !important; border-color: var(--ux-vi) !important; }

  .ux-root .ux-icon-btn {
    width: 34px !important; height: 34px !important; display: inline-flex !important; align-items: center !important; justify-content: center !important;
    border-radius: var(--ux-r-xs) !important; border: 1px solid var(--ux-line) !important; background: rgba(255,255,255,0.04) !important;
    color: var(--ux-t3) !important; cursor: pointer; transition: all var(--ux-t-fast); padding: 0 !important;
  }
  .ux-root .ux-icon-btn svg { width: 15px !important; height: 15px !important; stroke: currentColor; }
  .ux-root .ux-icon-btn:hover { border-color: var(--ux-bad) !important; color: var(--ux-bad) !important; background: rgba(251,113,133,0.08) !important; }

  /* ── Cards ── */
  .ux-root .ux-card { border: 1px solid var(--ux-line); border-radius: var(--ux-r); background: linear-gradient(155deg, var(--ux-s2), var(--ux-s1)); box-shadow: 0 8px 28px rgba(0,0,0,0.2); transition: border-color var(--ux-t-med); overflow: hidden; }
  .ux-root .ux-card:hover { border-color: var(--ux-line-h); }
  .ux-root .ux-card--form { border-left: 2px solid var(--ux-vi); padding: 24px; }
  .ux-root .ux-card--table { padding: 0; }

  /* ── Form Panel (slide-in) ── */
  .ux-root .ux-form-panel { display: grid; grid-template-rows: 0fr; opacity: 0; transition: grid-template-rows 0.32s cubic-bezier(0.4,0,0.2,1), opacity 0.22s ease; pointer-events: none; }
  .ux-root .ux-form-panel.is-open { grid-template-rows: 1fr; opacity: 1; pointer-events: auto; }
  .ux-root .ux-form-panel > * { overflow: hidden; }
  .ux-root .ux-form-panel.is-open > * { overflow: visible; }

  .ux-root .ux-form-titlebar { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 12px; }
  .ux-root .ux-form-titlebar__left { display: flex; align-items: center; gap: 10px; }
  .ux-root .ux-form-titlebar__title em { font-style: normal; color: #c4b5fd; }

  .ux-root .ux-form-badge { display: inline-flex; padding: 3px 10px; border-radius: 999px; font-size: 0.65rem; font-weight: 800; text-transform: uppercase !important; letter-spacing: 0.1em !important; background: var(--ux-vi-soft); color: #c4b5fd; border: 1px solid rgba(139,92,246,0.3); }
  .ux-root .ux-form-badge--edit { background: rgba(251,191,36,0.1); color: #fbbf24; border-color: rgba(251,191,36,0.3); }

  .ux-root .ux-hint { display: flex; align-items: flex-start; gap: 7px; margin: 0 0 18px !important; padding: 10px 14px !important; border-radius: var(--ux-r-xs); background: var(--ux-vi-dim) !important; border: 1px solid rgba(139,92,246,0.2) !important; font-size: 0.75rem !important; color: var(--ux-t2) !important; line-height: 1.5 !important; }
  .ux-root .ux-hint svg { flex-shrink: 0; margin-top: 1px; color: #c4b5fd; }

  /* Sections inside form */
  .ux-root .ux-sections { display: flex; flex-direction: column; gap: 14px; }
  .ux-root .ux-section { border: 1px solid var(--ux-line); border-radius: var(--ux-r-sm); padding: 16px 18px 18px; background: rgba(6,10,20,0.3); margin: 0; }
  .ux-root .ux-section__legend { display: inline-flex; align-items: center; gap: 7px; padding: 0 8px; font-size: 0.7rem !important; font-weight: 700 !important; text-transform: uppercase !important; letter-spacing: 0.1em !important; color: var(--ux-t3) !important; background: transparent; float: none; margin-bottom:0 !important; }
  .ux-root .ux-section__legend svg { width: 13px !important; height: 13px !important; stroke: var(--ux-vi); flex-shrink: 0; }

  /* Grid */
  .ux-root .ux-grid { display: grid; gap: 12px; margin-top: 12px; }
  .ux-root .ux-grid--3 { grid-template-columns: repeat(3, 1fr); }
  .ux-root .ux-field--full { grid-column: 1 / -1; }

  /* Fields */
  .ux-root .ux-field { display: flex; flex-direction: column; gap: 5px; }
  .ux-root .ux-field label { font-size: 0.67rem !important; font-weight: 700 !important; text-transform: uppercase !important; letter-spacing: 0.08em !important; color: var(--ux-t3) !important; margin:0 !important;}
  .ux-root .req { color: #fb7185; font-size: 0.7rem; }

  /* Inputs & selects */
  .ux-root input:not([type=hidden]), .ux-root select { width: 100% !important; border: 1px solid var(--ux-line) !important; border-radius: var(--ux-r-xs) !important; padding: 9px 12px !important; background: rgba(6,10,20,0.5) !important; color: var(--ux-t1) !important; font-size: 0.82rem !important; transition: border-color var(--ux-t-fast), background var(--ux-t-fast) !important; outline: none !important; }
  .ux-root input:focus:not([type=hidden]), .ux-root select:focus { border-color: var(--ux-vi) !important; background: rgba(6,10,20,0.7) !important; box-shadow: 0 0 0 3px var(--ux-vi-dim) !important; }
  .ux-root input::placeholder { color: var(--ux-t3); }

  /* Form action buttons */
  .ux-root .ux-form-actions { display: flex; align-items: center; justify-content: space-between; gap: 10px; flex-wrap: wrap; margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--ux-line); }
  .ux-root .ux-form-actions__primary { display: flex; gap: 10px; flex-wrap: wrap; }

  /* ── Toolbar ── */
  .ux-root .ux-toolbar { display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; padding: 16px 20px; border-bottom: 1px solid var(--ux-line); }
  .ux-root .ux-toolbar__search { position: relative; flex: 1; min-width: 220px; max-width: 360px; }
  .ux-root .ux-toolbar__search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 14px !important; height: 14px !important; stroke: var(--ux-t3); pointer-events: none; }
  .ux-root .ux-search { width: 100% !important; padding: 9px 12px 9px 36px !important; border: 1px solid var(--ux-line) !important; border-radius: var(--ux-r-xs) !important; background: rgba(6,10,20,0.5) !important; color: var(--ux-t1) !important; font-size: 0.82rem !important; }
  .ux-root .ux-search:focus { border-color: var(--ux-vi) !important; box-shadow: 0 0 0 3px var(--ux-vi-dim) !important; }

  .ux-root .ux-toolbar__controls { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .ux-root .ux-export-group { display: inline-flex; border: 1px solid var(--ux-line); border-radius: var(--ux-r-xs); overflow: hidden; }
  .ux-root .ux-export-btn { padding: 7px 13px !important; background: rgba(255,255,255,0.03) !important; border: none !important; border-right: 1px solid var(--ux-line) !important; color: var(--ux-t3) !important; font-size: 0.72rem !important; font-weight: 700 !important; cursor: pointer !important; transition: all var(--ux-t-fast) !important; margin:0 !important;}
  .ux-root .ux-export-btn:last-child { border-right: none !important; }
  .ux-root .ux-export-btn:hover { background: var(--ux-vi-dim) !important; color: #c4b5fd !important; }
  
  .ux-root .ux-rows-label { display: inline-flex; align-items: center; gap: 7px; font-size: 0.75rem !important; color: var(--ux-t3) !important; white-space: nowrap; margin:0 !important; }
  .ux-root .ux-rows-select { padding: 6px 10px !important; border-radius: var(--ux-r-xs) !important; font-size: 0.75rem !important; min-width: 0 !important; width: auto !important; }

  /* ── Table ── */
  .ux-root .ux-table-scroll { overflow-x: auto; max-height: 58vh; }
  .ux-root .ux-table { width: 100%; border-collapse: collapse; min-width: 760px; font-size: 0.82rem; }
  .ux-root .ux-table thead th { position: sticky; top: 0; z-index: 2; padding: 11px 14px !important; text-align: left; font-size: 0.67rem !important; font-weight: 700 !important; text-transform: uppercase !important; letter-spacing: 0.08em !important; color: var(--ux-t3) !important; background: rgba(9,14,25,0.96) !important; border-bottom: 1px solid var(--ux-line) !important; white-space: nowrap; user-select: none; margin:0 !important;}
  .ux-root .ux-table tbody tr { transition: background var(--ux-t-fast); border-bottom: 1px solid rgba(148,163,184,0.07); }
  .ux-root .ux-table tbody tr:last-child { border-bottom: none; }
  .ux-root .ux-table tbody tr:hover { background: var(--ux-vi-dim); }
  .ux-root .ux-table td { padding: 11px 14px !important; color: var(--ux-t2) !important; vertical-align: middle; margin:0 !important;}

  .ux-root .col-id      { width: 64px; }
  .ux-root .col-img     { width: 80px; text-align: center; }
  .ux-root .col-cat     { width: 25%; }
  .ux-root .col-desc    { width: 35%; }
  .ux-root .col-prods   { text-align: center; }
  .ux-root .col-actions { width: 100px; text-align: center; }

  .ux-root .ux-id { font-size: 0.72rem !important; color: var(--ux-t3) !important; font-variant-numeric: tabular-nums; }
  .ux-root .ux-user-name { color: var(--ux-t1) !important; font-weight: 600 !important; display: block !important; }
  .ux-root .ux-email { color: var(--ux-t2) !important; display: block !important; white-space: nowrap !important; overflow: hidden !important; text-overflow: ellipsis !important; max-width: 300px !important;}
  .ux-root .ux-muted { color: var(--ux-t3) !important; font-size: 0.72rem !important; }

  /* Categoría Image Thumbnails */
  .ux-root .ux-cat-thumb { width: 44px !important; height: 44px !important; border-radius: 8px !important; object-fit: cover !important; display: inline-block; border: 1px solid transparent; transition: 0.2s; cursor: pointer; }
  .ux-root .ux-cat-thumb:hover { border-color: var(--ux-vi); transform: scale(1.05); }
  .ux-root .ux-cat-noimg { display: inline-flex; align-items: center; justify-content: center; width: 44px !important; height: 44px !important; border-radius: 8px !important; border: 1px dashed var(--ux-line); font-size: 0.65rem !important; color: var(--ux-t3) !important; cursor: pointer; transition: 0.2s; }
  .ux-root .ux-cat-noimg:hover { color: var(--ux-vi) !important; border-color: var(--ux-vi) !important; background: var(--ux-vi-dim) !important; }

  /* Prod Badges */
  .ux-root .ux-badge-prod { display: inline-flex; align-items: center; padding: 3px 10px; border-radius: 999px; font-size: 0.66rem !important; font-weight: 700 !important; text-transform: uppercase !important; letter-spacing: 0.07em !important; white-space: nowrap; background: rgba(96,165,250,0.14) !important; color: #93c5fd !important; border: 1px solid rgba(96,165,250,0.3) !important; }

  /* Row action buttons */
  .ux-root .ux-row-actions { display: flex; align-items: center; gap: 6px; justify-content: center; }
  .ux-root .ux-action-btn { width: 30px !important; height: 30px !important; display: inline-flex !important; align-items: center !important; justify-content: center !important; border-radius: var(--ux-r-xs) !important; border: 1px solid var(--ux-line) !important; background: rgba(255,255,255,0.03) !important; cursor: pointer !important; transition: all var(--ux-t-fast) !important; padding: 0 !important; margin:0 !important;}
  .ux-root .ux-action-btn svg { width: 13px !important; height: 13px !important; stroke: currentColor !important; display: block !important; }
  .ux-root .ux-action-btn:disabled { opacity: 0.25 !important; cursor: not-allowed !important; pointer-events: none !important; }
  .ux-root .ux-action-btn:hover:not(:disabled) { transform: translateY(-1px) !important; }
  .ux-root .ux-action-btn--edit { color: #c4b5fd !important; border-color: rgba(139,92,246,0.3) !important; }
  .ux-root .ux-action-btn--edit:hover:not(:disabled) { background: var(--ux-vi-soft) !important; border-color: rgba(139,92,246,0.5) !important; }
  .ux-root .ux-action-btn--delete { color: #fda4af !important; border-color: rgba(251,113,133,0.3) !important; }
  .ux-root .ux-action-btn--delete:hover:not(:disabled) { background: rgba(251,113,133,0.1) !important; border-color: rgba(251,113,133,0.5) !important; }

  /* Empty state */
  .ux-root .ux-empty { text-align: center !important; padding: 48px 24px !important; color: var(--ux-t3) !important; }
  .ux-root .ux-empty svg { display: block; margin: 0 auto 12px; stroke: var(--ux-t3); opacity: 0.4; width: 32px !important; height: 32px !important;}
  .ux-root .ux-empty span { font-size: 0.85rem !important; }

  /* Skeleton loading */
  .ux-root .ux-skel { display: inline-block; height: 12px; width: 60px; border-radius: 6px; background: linear-gradient(90deg, rgba(255,255,255,0.04) 30%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.04) 70%); background-size: 220% 100%; animation: ux-shimmer 1.3s linear infinite; }
  .ux-root .ux-skel-img { width: 44px; height: 44px; border-radius: 8px; margin: 0 auto; background: linear-gradient(90deg, rgba(255,255,255,0.04) 30%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.04) 70%); background-size: 220% 100%; animation: ux-shimmer 1.3s linear infinite; }
  .ux-root .ux-skel--sm  { width: 44px; }
  .ux-root .ux-skel--wide { width: 100px; }
  .ux-root .ux-skel--wider{ width: 140px; }
  @keyframes ux-shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

  /* ── Pagination ── */
  .ux-root .ux-pagination { display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; padding: 14px 20px; border-top: 1px solid var(--ux-line); }
  .ux-root .ux-pagination__info { font-size: 0.74rem !important; color: var(--ux-t3) !important; }
  .ux-root .ux-pagination__controls { display: flex; align-items: center; gap: 4px; }
  .ux-root .ux-page-btn { min-width: 32px !important; height: 32px !important; padding: 0 6px !important; border-radius: var(--ux-r-xs) !important; border: 1px solid var(--ux-line) !important; background: rgba(255,255,255,0.03) !important; color: var(--ux-t2) !important; font-size: 0.78rem !important; font-weight: 600 !important; cursor: pointer !important; display: inline-flex !important; align-items: center !important; justify-content: center !important; transition: all var(--ux-t-fast) !important; margin:0 !important;}
  .ux-root .ux-page-btn:hover:not(.is-disabled):not(.is-active) { background: rgba(255,255,255,0.08) !important; color: var(--ux-t1) !important; border-color: var(--ux-line-h) !important; }
  .ux-root .ux-page-btn.is-active { background: linear-gradient(135deg, var(--ux-vi), #6d28d9) !important; border-color: transparent !important; color: #fff !important; box-shadow: 0 2px 10px var(--ux-vi-glow) !important; }
  .ux-root .ux-page-btn.is-disabled { opacity: 0.25 !important; cursor: not-allowed !important; }
  .ux-root .ux-page-ellipsis { color: var(--ux-t3) !important; font-size: 0.78rem !important; padding: 0 3px !important; user-select: none !important; }

  /* ── Image Viewer Modal (Evita position fixed global) ── */
  .ux-img-modal-backdrop { position: fixed !important; inset: 0 !important; z-index: 105000 !important; background: rgba(0,0,0,0.7) !important; backdrop-filter: blur(8px) !important; display: flex !important; align-items: center !important; justify-content: center !important; padding: 1rem !important; opacity: 0; transition: opacity 220ms ease !important; pointer-events: none; }
  .ux-img-modal-backdrop.is-open { opacity: 1 !important; pointer-events: auto; }
  .ux-img-modal-panel { background: #0d1117 !important; border: 1px solid rgba(139,92,246,0.25) !important; border-radius: var(--ux-r) !important; box-shadow: 0 32px 80px rgba(0,0,0,0.6) !important; width: 100% !important; max-width: 480px !important; transform: scale(0.92) translateY(15px); transition: transform 260ms cubic-bezier(0.34,1.56,0.64,1) !important; display: flex !important; flex-direction: column !important; max-height: calc(100vh - 40px) !important; overflow: hidden !important;}
  .ux-img-modal-backdrop.is-open .ux-img-modal-panel { transform: scale(1) translateY(0); }
  
  .ux-img-header { display: flex !important; justify-content: space-between !important; align-items: flex-start !important; padding: 20px 24px 16px !important; border-bottom: 1px solid var(--ux-line) !important; background: rgba(0,0,0,0.2) !important;}
  .ux-img-title { font-size: 1.1rem !important; color: var(--ux-t1) !important; font-weight: 700 !important; margin: 4px 0 0 0 !important; }
  .ux-img-body { padding: 24px !important; overflow-y: auto !important; flex: 1 !important; }
  
  .ux-img-preview-card { border: 1px solid var(--ux-line) !important; border-radius: var(--ux-r-sm) !important; background: rgba(6,10,20,0.3) !important; overflow: hidden !important; padding: 16px !important; text-align: center !important; }
  .ux-img-preview-img { width: 100% !important; max-height: 200px !important; object-fit: contain !important; border-radius: 8px !important; }
  .ux-img-empty { display: flex !important; flex-direction: column !important; align-items: center !important; gap: 8px !important; color: var(--ux-t3) !important; font-size: 0.8rem !important; padding: 40px 0 !important; }
  .ux-img-empty svg { width: 32px !important; height: 32px !important; color: var(--ux-t3) !important;}

  .ux-img-section { margin-top: 20px !important; }
  .ux-img-section-label { font-size: 0.7rem !important; font-weight: 700 !important; text-transform: uppercase !important; color: var(--ux-t3) !important; margin: 0 0 8px 0 !important; }
  .ux-img-list { display: flex !important; flex-direction: column !important; gap: 6px !important; max-height: 120px !important; overflow-y: auto !important; }
  .ux-img-row { display: flex !important; align-items: center !important; gap: 10px !important; padding: 6px 10px !important; border: 1px solid var(--ux-line) !important; border-radius: 8px !important; background: rgba(255,255,255,0.03) !important; cursor: pointer;}
  .ux-img-row.is-selected { border-color: var(--ux-purple) !important; background: var(--ux-vi-soft) !important; }
  .ux-img-row img { width: 32px !important; height: 32px !important; border-radius: 6px !important; object-fit: cover !important; }
  .ux-img-input { width: 100% !important; padding: 8px 12px 8px 32px !important; border: 1px solid var(--ux-line) !important; border-radius: 8px !important; background: rgba(6,10,20,0.5) !important; color: var(--ux-t1) !important; font-size: 0.8rem !important; outline: none !important;}
  .ux-img-input:focus { border-color: var(--ux-vi) !important; }
  .ux-img-input-wrap { position: relative !important; flex: 1 !important; }
  .ux-img-input-icon { position: absolute !important; left: 10px !important; top: 50% !important; transform: translateY(-50%) !important; width: 14px !important; height: 14px !important; stroke: var(--ux-t3) !important; }
  
  .ux-img-add-row { display: flex !important; gap: 8px !important; margin-bottom: 10px !important; }
  .ux-img-upload-row { display: flex !important; gap: 8px !important; align-items: center !important; }
  .ux-img-upload-file { flex: 1 !important; font-size: 0.75rem !important; color: var(--ux-t2) !important; }
  
  .ux-img-footer { padding: 16px 24px !important; border-top: 1px solid var(--ux-line) !important; display: flex !important; justify-content: flex-end !important; gap: 10px !important; background: rgba(0,0,0,0.2) !important; }

  /* ── Responsive ── */
  @media (max-width: 980px) {
    .ux-root .ux { padding: 40px 16px 48px; }
    .ux-root .ux-grid--3 { grid-template-columns: repeat(2, 1fr); }
    .ux-root .ux-field--wide { grid-column: span 1; }
    .ux-root .ux-hero__body { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 640px) {
    .ux-root .ux { padding: 40px 12px 40px; }
    .ux-root .ux-grid--3 { grid-template-columns: 1fr; }
    .ux-root .ux-toolbar { flex-direction: column; align-items: stretch; }
    .ux-root .ux-toolbar__search { max-width: 100%; }
    .ux-root .ux-toolbar__controls { justify-content: space-between; }
    .ux-root .ux-form-actions { flex-direction: column; }
    .ux-root .ux-form-actions__primary { width: 100%; }
    .ux-root .ux-btn { width: 100%; justify-content: center; }
    .ux-root .ux-pagination { flex-direction: column; align-items: flex-start; }
  }

  /* ── Light mode overrides ── */
  html:not(.dark) .ux-root {
    --ux-bg:      transparent;
    --ux-s1:      #ffffff;
    --ux-s2:      #f8fafc;
    --ux-s3:      #e2e8f0;
    --ux-line:    rgba(15,23,42,0.1);
    --ux-line-h:  rgba(15,23,42,0.18);
    --ux-t1:      #0f172a;
    --ux-t2:      #475569;
    --ux-t3:      #94a3b8;
    --ux-vi-dim:  rgba(139,92,246,0.06);
    --ux-good:    #059669;
    --ux-bad:     #dc2626;
  }
  html:not(.dark) .ux-root .ux-hero__glow { background: radial-gradient(ellipse at 5% -15%, rgba(139,92,246,0.1), transparent 48%), radial-gradient(ellipse at 92% 0%, rgba(34,211,238,0.05), transparent 42%); }
  html:not(.dark) .ux-root input:not([type=hidden]), html:not(.dark) .ux-root select { background: #fff !important; color: #0f172a !important; border-color: rgba(15,23,42,0.15) !important;}
  html:not(.dark) .ux-root .ux-section { background: rgba(241,245,249,0.6); }
  html:not(.dark) .ux-root .ux-table thead th { background: rgba(248,250,252,0.98) !important; color: var(--ux-t2) !important;}
  html:not(.dark) .ux-root .ux-table tbody tr:hover { background: rgba(139,92,246,0.04); }
  html:not(.dark) .ux-root .ux-skel { background: linear-gradient(90deg, rgba(0,0,0,0.04) 30%, rgba(0,0,0,0.09) 50%, rgba(0,0,0,0.04) 70%); background-size: 220% 100%; }
  html:not(.dark) .ux-root .ux-skel-img { background: linear-gradient(90deg, rgba(0,0,0,0.04) 30%, rgba(0,0,0,0.09) 50%, rgba(0,0,0,0.04) 70%); background-size: 220% 100%; }
  html:not(.dark) .ux-root .ux-hint { background: rgba(139,92,246,0.06); color: #475569; }
  html:not(.dark) .ux-root .ux-hero__kicker { color: #7c3aed !important; }
  html:not(.dark) .go-modal { background: #ffffff; border-color: rgba(15,23,42,0.1); }
  html:not(.dark) .go-modal-title { color: #0f172a; }
  html:not(.dark) .ux-img-modal-panel { background: #fff !important; border-color: rgba(15,23,42,0.1) !important; }
