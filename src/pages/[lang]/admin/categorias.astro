        rowsEl.appendChild(tr);
      });
      renderPagination(pageData);
      renderStats();
    }

    async function fetchCategories(){const r=await fetch("/api/categorias",{credentials:"include"});const d=await r.json().catch(()=>({}));if(!r.ok||!d?.success)throw new Error(d?.error||"No se pudieron cargar categorías");categories=(Array.isArray(d.categorias)?d.categorias:[]).map(c=>({id:c.Id_Categoria??c.id,nombre:c.Nombre??c.nombre??"",descripcion:c.Descripcion??c.descripcion??"",imagenUrl:c.Imagen_URL??c.imagenUrl??c.imagen??"",productCount:c.productCount??0,}));try{const pr=await fetch("/api/productos",{credentials:"include"});const pd=await pr.json().catch(()=>({}));if(pr.ok&&pd?.success){const countMap={};(Array.isArray(pd.productos)?pd.productos:[]).forEach(p=>{const id=Number(p.categoriaId||0);if(id)countMap[id]=(countMap[id]||0)+1;});categories.forEach(c=>{c.productCount=countMap[c.id]||0;});}}catch{}renderCategories();}
