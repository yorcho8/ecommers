---
import BaseLayout from "../../../layouts/BaseLayout.astro";
export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}

const currentLang = "es";
const cspNonce = Astro.locals?.cspNonce || "";

const role = String(Astro.locals?.user?.rol || "").trim().toLowerCase().replace(/[\s_-]/g, "")
  .replace(/^superadmin$|^superuser$|^superusuario$/, "superusuario");

if (!role) return Astro.redirect(`/${currentLang}/login`);
if (role !== "superusuario") return Astro.redirect(`/${currentLang}/admin/productos`);

const isSuperusuario = role === "superusuario";
---

<BaseLayout title="Gestión de Categorías | NEXUS" currentLang={currentLang}>

  <script nonce={cspNonce} is:inline>
  (function(g){
    if(document.getElementById('go-modal-styles'))return;
    const s=document.createElement('style');s.id='go-modal-styles';
    s.textContent=`
      .go-modal-backdrop{position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.6);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;padding:1rem;opacity:0;transition:opacity 220ms ease; pointer-events: none;}
      .go-modal-backdrop.go-visible{opacity:1; pointer-events: auto;}
      .go-modal{background:#0d1117;border:1px solid rgba(139,92,246,.2);border-radius:20px;box-shadow:0 32px 80px rgba(0,0,0,.6);padding:2rem 2rem 1.6rem;width:100%;max-width:420px;text-align:center;transform:scale(.88) translateY(20px);transition:transform 260ms cubic-bezier(.34,1.56,.64,1);position:relative}
      .go-modal-backdrop.go-visible .go-modal{transform:scale(1) translateY(0)}
      .go-modal-icon{width:68px;height:68px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.1rem}
      .go-modal-icon.success{background:rgba(52,211,153,.12);color:#34d399}.go-modal-icon.error{background:rgba(251,113,133,.12);color:#fb7185}
      .go-modal-icon.warning{background:rgba(251,191,36,.12);color:#fbbf24}.go-modal-icon.info{background:rgba(96,165,250,.12);color:#60a5fa}
      .go-modal-icon.confirm{background:rgba(139,92,246,.12);color:#8b5cf6}
      .go-modal-title{font-size:1.25rem;font-weight:700;color:#f1f5f9;margin:0 0 .5rem;font-family:inherit!important;letter-spacing:normal!important;text-transform:none!important}
      .go-modal-text{font-size:.9rem;color:#64748b;margin:0 0 1.4rem;line-height:1.6;font-family:inherit!important}
      .go-modal-actions{display:flex;gap:.7rem;justify-content:center;flex-wrap:wrap}
      .go-modal-btn{padding:.65rem 1.6rem;border-radius:10px;font-size:.9rem;font-weight:600;cursor:pointer;border:none;transition:filter 160ms,transform 100ms;min-width:100px;font-family:inherit!important;text-transform:none!important}
      .go-modal-btn:hover{filter:brightness(1.1)}.go-modal-btn:active{transform:scale(.97)}
      .go-modal-btn.primary{background:linear-gradient(135deg,#8b5cf6,#6d28d9);color:#fff}.go-modal-btn.secondary{background:rgba(255,255,255,.08);color:#94a3b8;border:1px solid rgba(255,255,255,.12)}
      .go-modal-btn.danger{background:linear-gradient(135deg,#7a2532,#be1a2b);color:#fff}
      .go-loading-backdrop{position:fixed;inset:0;z-index:10500;background:rgba(0,0,0,.65);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 200ms ease}
      .go-loading-backdrop.go-visible{opacity:1;pointer-events:auto}
      .go-loading-box{background:#0d1117;border:1px solid rgba(139,92,246,.15);border-radius:20px;padding:2.2rem 2.8rem;text-align:center;box-shadow:0 24px 64px rgba(0,0,0,.6);min-width:220px}
      .go-loading-spinner{width:48px;height:48px;border-radius:50%;border:3px solid rgba(139,92,246,0.18);border-top-color:#8b5cf6;animation:go-spin 0.75s linear infinite;margin:0 auto 1rem}
      @keyframes go-spin{to{transform:rotate(360deg)}}
      .go-loading-title{font-size:1rem;font-weight:700;color:#f1f5f9;margin:0 0 .25rem;font-family:inherit!important}
      .go-loading-sub{font-size:0.78rem;color:#475569;margin:0;font-family:inherit!important}
    `;
    document.head.appendChild(s);
    const IC={
      success:`<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`,
      error:`<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`,
      warning:`<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
      info:`<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>`,
      confirm:`<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    };
    function show(o){
      return new Promise(function(res){
        var type=o.type||'info',title=o.title||'',text=o.text||'',ct=o.confirmText||'Aceptar',cct=o.cancelText||'Cancelar',sc=o.showCancel||false,ac=o.autoClose||0;
        var bd=document.createElement('div');bd.className='go-modal-backdrop';
        bd.innerHTML='<div class="go-modal" role="dialog" aria-modal="true"><div class="go-modal-icon '+type+'">'+(IC[type]||IC.info)+'</div><h2 class="go-modal-title">'+title+'</h2>'+(text?'<p class="go-modal-text">'+text+'</p>':'')+'<div class="go-modal-actions">'+(sc?'<button class="go-modal-btn secondary" id="gmc">'+cct+'</button>':'')+'<button class="go-modal-btn '+(type==='error'?'danger':'primary')+'" id="gmok">'+ct+'</button></div></div>';
        document.body.appendChild(bd);requestAnimationFrame(function(){bd.classList.add('go-visible');});
        function close(r){bd.classList.remove('go-visible');setTimeout(function(){bd.remove();},260);res(r);}
        bd.querySelector('#gmok').addEventListener('click',function(){close(true);});
        var cc=bd.querySelector('#gmc');if(cc)cc.addEventListener('click',function(){close(false);});
        function onKey(e){if(e.key==='Escape'){close(false);document.removeEventListener('keydown',onKey);}}
        document.addEventListener('keydown',onKey);if(ac)setTimeout(function(){close(true);},ac);
      });
    }
    var _loadEl=null;
    function showLoading(title,sub){if(_loadEl)return;_loadEl=document.createElement('div');_loadEl.className='go-loading-backdrop';_loadEl.innerHTML='<div class="go-loading-box"><div class="go-loading-spinner"></div><p class="go-loading-title">'+(title||'Procesando...')+'</p><p class="go-loading-sub">'+(sub||'Por favor espera')+'</p></div>';document.body.appendChild(_loadEl);requestAnimationFrame(function(){_loadEl.classList.add('go-visible');});}
    function hideLoading(){if(!_loadEl)return;_loadEl.classList.remove('go-visible');setTimeout(function(){if(_loadEl){_loadEl.remove();_loadEl=null;}},220);}
    g.Modal={success:function(t,x,o){return show(Object.assign({type:'success',title:t,text:x},o||{}));},error:function(t,x,o){return show(Object.assign({type:'error',title:t,text:x},o||{}));},warning:function(t,x,o){return show(Object.assign({type:'warning',title:t,text:x},o||{}));},info:function(t,x,o){return show(Object.assign({type:'info',title:t,text:x},o||{}));},confirm:function(t,x,o){return show(Object.assign({type:'confirm',title:t,text:x,showCancel:true},o||{}));},loading:showLoading,hideLoading:hideLoading,};
  })(window);
  </script>

  <div class="ux-root">
  <main class="ux">

    <header class="ux-hero">
      <div class="ux-hero__glow" aria-hidden="true"></div>
      <div class="ux-hero__body">
        <div class="ux-hero__left">
          <p class="ux-hero__kicker">PANEL ADMIN · SUPERUSUARIO</p>
          <h1 class="ux-hero__title">Gestión de Categorías</h1>
          <p class="ux-hero__sub">Crea, edita y organiza las clasificaciones del catálogo</p>
        </div>
        <div class="ux-hero__right">
          <button id="btnAddCategory" class="ux-cta" type="button">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
            Añadir categoría
          </button>
          <a href={`/${currentLang}`} class="ux-cta ux-cta--ghost">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            Volver al sitio
          </a>
        </div>
      </div>
      <div id="ux-stats" class="ux-hero__stats" aria-live="polite">
        <span class="ux-stat-loading">Calculando métricas...</span>
      </div>
    </header>

    <section id="catFormPanel" class="ux-form-panel" aria-hidden="true">
      <article class="ux-card ux-card--form">

        <div class="ux-form-titlebar">
          <div class="ux-form-titlebar__left">
            <span class="ux-form-badge" id="formModeBadge">Nuevo</span>
            <h2 id="formTitle" class="ux-form-titlebar__title">Nueva categoría</h2>
          </div>
          <button id="btnCancelEdit" class="ux-icon-btn" type="button" title="Cerrar formulario" aria-label="Cerrar formulario">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>

        <p class="ux-hint">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          Completa los campos obligatorios. Las imágenes se gestionan desde la galería.
        </p>

        <input id="currentCategoryId" type="hidden" />

        <div class="ux-sections">
          <fieldset class="ux-section">
            <legend class="ux-section__legend">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
              Información principal
            </legend>
            <div class="ux-grid ux-grid--3">
              <div class="ux-field ux-field--wide">
                <label for="catNombre">Nombre <span class="req">*</span></label>
                <input id="catNombre" type="text" placeholder="Ej: Empaques Flexibles" />
              </div>
              <div class="ux-field">
                <label for="btnCatOpenGallery">Imagen Representativa</label>
                <input id="catImagenUrl" type="hidden" />
                <button id="btnCatOpenGallery" class="ux-cta ux-cta--ghost" type="button" style="width: 100%; justify-content: center; padding: 9px 12px; margin-top: 2px;">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                  Gestionar Imagen
                </button>
              </div>
              <div class="ux-field ux-field--full">
                <label for="catDescripcion">Descripción (Opcional)</label>
                <input id="catDescripcion" type="text" placeholder="Breve detalle de la categoría..." />
              </div>
            </div>
          </fieldset>
        </div>

        <div class="ux-form-actions">
          <div class="ux-form-actions__primary">
            <button id="btnCreate" class="ux-cta" type="button">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
              Crear categoría
            </button>
            <button id="btnUpdate" class="ux-cta" type="button" style="display:none;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 13l4 4L19 7"/></svg>
              Guardar cambios
            </button>
          </div>
          <button id="btnFormReset" class="ux-cta ux-cta--ghost" type="button">Limpiar campos</button>
        </div>

      </article>
    </section>

    <section class="ux-card ux-card--table">

      <div class="ux-toolbar">
        <div class="ux-toolbar__search">
          <svg class="ux-toolbar__search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <input id="searchCategories" class="ux-search" type="text" placeholder="Buscar categoría por nombre..." aria-label="Buscar categorías" />
        </div>
        <div class="ux-toolbar__controls">
          <div class="ux-export-group" role="group" aria-label="Exportar datos">
            <button id="btnCopy"  class="ux-export-btn" type="button">Copiar</button>
            <button id="btnCsv"   class="ux-export-btn" type="button">CSV</button>
          </div>
          <label class="ux-rows-label" for="rowsPerPage">
            Mostrar
            <select id="rowsPerPage" class="ux-rows-select">
              <option value="5">5</option>
              <option value="10" selected>10</option>
              <option value="25">25</option>
              <option value="50">50</option>
            </select>
          </label>
        </div>
      </div>

      <div class="ux-table-scroll" role="region" aria-label="Lista de categorías">
        <table class="ux-table" id="categoriesTable">
          <thead>
            <tr>
              <th scope="col" class="col-id">ID</th>
              <th scope="col" class="col-img">IMAGEN</th>
              <th scope="col" class="col-cat">CATEGORÍA</th>
              <th scope="col" class="col-desc">DESCRIPCIÓN</th>
              <th scope="col" class="col-prods">PRODS.</th>
              <th scope="col" class="col-actions">ACCIONES</th>
            </tr>
          </thead>
          <tbody id="catRows">
            <tr class="ux-skeleton-row"><td><span class="ux-skel"></span></td><td><div class="ux-skel-img"></div></td><td><span class="ux-skel ux-skel--wide"></span></td><td><span class="ux-skel ux-skel--wider"></span></td><td><span class="ux-skel ux-skel--sm"></span></td><td></td></tr>
            <tr class="ux-skeleton-row"><td><span class="ux-skel"></span></td><td><div class="ux-skel-img"></div></td><td><span class="ux-skel ux-skel--wide"></span></td><td><span class="ux-skel ux-skel--wider"></span></td><td><span class="ux-skel ux-skel--sm"></span></td><td></td></tr>
            <tr class="ux-skeleton-row"><td><span class="ux-skel"></span></td><td><div class="ux-skel-img"></div></td><td><span class="ux-skel ux-skel--wide"></span></td><td><span class="ux-skel ux-skel--wider"></span></td><td><span class="ux-skel ux-skel--sm"></span></td><td></td></tr>
          </tbody>
        </table>
      </div>

      <div class="ux-pagination">
        <span id="catResultsInfo" class="ux-pagination__info"></span>
        <div class="ux-pagination__controls" id="paginationControls"></div>
      </div>

    </section>

  </main>
  </div>

  <div id="catImageViewerModal" class="ux-modal-backdrop" hidden>
    <div id="catImageViewerPanel" class="ux-modal-panel" role="dialog" aria-modal="true">
      <div class="ux-modal-header">
        <div class="ux-modal-header-text">
          <span class="ux-form-badge">Galería</span>
          <h2 class="ux-modal-title" id="catImageViewerName">Categoría</h2>
        </div>
        <button id="catImageViewerClose" class="ux-icon-btn" type="button" aria-label="Cerrar">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <div class="ux-modal-body">
        <div class="ux-img-preview-card">
          <img id="catImageViewerImg" class="ux-img-preview-img" src="" alt="Preview" style="display:none;" />
          <div class="ux-img-empty" id="catImageViewerEmpty">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            <span>Sin imagen asignada</span>
          </div>
          <p class="ux-img-counter" id="catImageViewerCounter"></p>
        </div>

        <div class="ux-img-section">
          <p class="ux-img-section-label">Opciones de imagen</p>
          <div id="catImageViewerList" class="ux-img-list"></div>
        </div>

        <div class="ux-img-section">
          <p class="ux-img-section-label">Subir o enlazar nueva imagen</p>
          <div class="ux-img-add-row">
            <div class="ux-img-input-wrap">
              <svg class="ux-img-input-icon" viewBox="0 0 24 24"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101"></path><path d="M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
              <input id="catImageViewerNewUrl" class="ux-img-input" type="text" placeholder="URL de imagen externa..." />
            </div>
            <button id="catImageViewerAddBtn" class="ux-cta ux-cta--ghost" type="button" style="padding: 9px 14px;">Enlazar</button>
          </div>
          <div class="ux-img-upload-row">
            <input id="catImageUploadFile" class="ux-img-upload-file" type="file" accept="image/png,image/jpeg,image/webp" />
            <button id="catImageUploadBtn" class="ux-cta" type="button" style="padding: 9px 14px;">Subir a Cloudinary</button>
          </div>
        </div>
      </div>

      <div class="ux-modal-footer">
        <button class="ux-cta ux-cta--ghost" type="button" id="catImageViewerCancelBtn">Cancelar</button>
        <button id="catImageViewerSave" class="ux-cta" type="button">Guardar cambios</button>
      </div>
    </div>
  </div>

  <script nonce={cspNonce} is:inline define:vars={{ isSuperusuario }}>
  (function () {
    /* refs */
    const formPanelEl      = document.getElementById('catFormPanel');
    const formTitleEl      = document.getElementById('formTitle');
    const formModeBadgeEl  = document.getElementById('formModeBadge');
    const currentCategoryIdEl = document.getElementById('currentCategoryId');
    const rowsEl           = document.getElementById('catRows');
    const btnAddCategory   = document.getElementById('btnAddCategory');
    const searchCategoriesEl = document.getElementById('searchCategories');
    const rowsPerPageEl    = document.getElementById('rowsPerPage');
    const resultsInfoEl    = document.getElementById('catResultsInfo');
    const statsEl          = document.getElementById('ux-stats');
    const paginationControlsEl = document.getElementById('paginationControls');
    const btnCopy          = document.getElementById('btnCopy');
    const btnCsv           = document.getElementById('btnCsv');
    const nombreEl         = document.getElementById('catNombre');
    const descripcionEl    = document.getElementById('catDescripcion');
    const imagenUrlEl      = document.getElementById('catImagenUrl');
    const btnCreate        = document.getElementById('btnCreate');
    const btnUpdate        = document.getElementById('btnUpdate');
    const btnCancelEdit    = document.getElementById('btnCancelEdit');
    const btnFormReset     = document.getElementById('btnFormReset');

    /* state */
    let categories = [], filteredCategories = [], currentPage = 1;
    let formMode = 'create'; // 'create' | 'edit'

    /* SVG helper */
    function makeSVG(pathsArray) {
      const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('viewBox', '0 0 24 24');
      svg.setAttribute('fill', 'none');
      svg.setAttribute('stroke', 'currentColor');
      svg.setAttribute('stroke-width', '2');
      svg.setAttribute('stroke-linecap', 'round');
      svg.setAttribute('stroke-linejoin', 'round');
      pathsArray.forEach(d => {
        const p = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        p.setAttribute('d', d);
        svg.appendChild(p);
      });
      return svg;
    }
    const ICON_EDIT   = ['M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7','M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z'];
    const ICON_DELETE = ['M3 6h18','M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2','M10 11v6','M14 11v6'];

    /* form helpers */
    function setMode(mode, label) {
      formMode = mode;
      if (mode === 'edit') {
        formTitleEl.innerHTML = `Editando: <em>${label || ''}</em>`;
        formModeBadgeEl.textContent = 'Editar';
        formModeBadgeEl.classList.add('ux-form-badge--edit');
        btnCreate.style.display = 'none';
        btnUpdate.style.display = 'inline-flex';
      } else {
        formTitleEl.textContent = 'Nueva categoría';
        formModeBadgeEl.textContent = 'Nuevo';
        formModeBadgeEl.classList.remove('ux-form-badge--edit');
        btnCreate.style.display = 'inline-flex';
        btnUpdate.style.display = 'none';
        currentCategoryIdEl.value = '';
      }
    }
    function resetForm() {
      if(nombreEl) nombreEl.value = '';
      if(descripcionEl) descripcionEl.value = '';
      if(imagenUrlEl) imagenUrlEl.value = '';
      setMode('create');
    }
    function openForm(mode = 'create', label) {
      if (!formPanelEl) return;
      formPanelEl.classList.add('is-open');
      formPanelEl.setAttribute('aria-hidden', 'false');
      setMode(mode, label);
      setTimeout(() => formPanelEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 80);
    }
    function closeForm() {
      if (!formPanelEl) return;
      formPanelEl.classList.remove('is-open');
      formPanelEl.setAttribute('aria-hidden', 'true');
      resetForm();
    }
    function fillForm(cat) {
      if(!currentCategoryIdEl) return;
      currentCategoryIdEl.value = String(cat.id);
      if(nombreEl) nombreEl.value = cat.nombre || '';
      if(descripcionEl) descripcionEl.value = cat.descripcion || '';
      if(imagenUrlEl) imagenUrlEl.value = cat.imagenUrl || '';
      openForm('edit', cat.nombre || '');
    }
    function buildPayload() {
      return { 
        nombre: nombreEl?.value?.trim() || '', 
        descripcion: descripcionEl?.value?.trim() || '', 
        imagenUrl: imagenUrlEl?.value?.trim() || '' 
      };
    }

    function truncate(text, max){ const s=String(text||""); return s.length>max?s.slice(0,max)+"...":s; }

    /* paginate */
    function applyFilters() {
      const q = String(searchCategoriesEl?.value || '').trim().toLowerCase();
      filteredCategories = categories.filter(c => {
        if (!q) return true;
        return String(c.nombre || '').toLowerCase().includes(q) || String(c.descripcion || '').toLowerCase().includes(q);
      });
    }
    function getPageData() {
      applyFilters();
      const perPage = Number(rowsPerPageEl?.value || 10);
      const totalPages = Math.max(1, Math.ceil(filteredCategories.length / perPage));
      if (currentPage > totalPages) currentPage = totalPages;
      const start = (currentPage - 1) * perPage;
      return { items: filteredCategories.slice(start, start + perPage), total: filteredCategories.length, totalPages, start };
    }
    function renderPagination({ total, totalPages, start, items }) {
      if (resultsInfoEl) resultsInfoEl.textContent = total === 0 ? 'Sin resultados' : `Mostrando ${start + 1}–${start + items.length} de ${total} resultado${total !== 1 ? 's' : ''}`;
      if (!paginationControlsEl) return;
      paginationControlsEl.innerHTML = '';
      if (totalPages <= 1) return;
      const mkBtn = (label, page, active, disabled) => {
        const b = document.createElement('button');
        b.className = 'ux-page-btn' + (active ? ' is-active' : '') + (disabled ? ' is-disabled' : '');
        b.textContent = label; b.disabled = disabled;
        if (!disabled && !active) b.addEventListener('click', () => { currentPage = page; renderCategories(); });
        return b;
      };
      paginationControlsEl.appendChild(mkBtn('‹', currentPage - 1, false, currentPage === 1));
      let prev = 0; const pages = new Set([1, totalPages]);
      for (let i = Math.max(2, currentPage - 2); i <= Math.min(totalPages - 1, currentPage + 2); i++) pages.add(i);
      [...pages].sort((a, b) => a - b).forEach(p => {
        if (prev && p - prev > 1) paginationControlsEl.appendChild(Object.assign(document.createElement('span'), { className: 'ux-page-ellipsis', textContent: '…' }));
        paginationControlsEl.appendChild(mkBtn(String(p), p, p === currentPage, false)); prev = p;
      });
      paginationControlsEl.appendChild(mkBtn('›', currentPage + 1, false, currentPage === totalPages));
    }

    /* stats */
    function renderStats() {
      if (!statsEl) return;
      const total = categories.length;
      const conImg = categories.filter(c => c.imagenUrl).length;
      const conProds = categories.filter(c => c.productCount > 0).length;
      statsEl.innerHTML = `
        <span class="ux-stat">
          <strong>${total}</strong> categorías en total
        </span>
        <span class="ux-stat-sep" aria-hidden="true">·</span>
        <span class="ux-stat ux-stat--violet"><strong>${conImg}</strong> con imagen representativa</span>
        <span class="ux-stat-sep" aria-hidden="true">·</span>
        <span class="ux-stat ux-stat--green"><strong>${conProds}</strong> en uso por productos</span>`;
    }

    /* render */
    function renderCategories() {
      if (!rowsEl) return;
      rowsEl.innerHTML = '';
      const pageData = getPageData();
      if (pageData.items.length === 0) {
        rowsEl.innerHTML = `<tr><td colspan="6" class="ux-empty">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <span>No se encontraron categorías</span>
        </td></tr>`;
      } else {
        pageData.items.forEach(cat => {
          const tr = document.createElement('tr');
          const canDelete = isSuperusuario;
          
          const imgCell = cat.imagenUrl
            ? `<div class="ux-cat-thumb" data-cat-id="${cat.id}"><img src="${cat.imagenUrl}" alt="${cat.nombre||''}" /></div>`
            : `<div class="ux-cat-noimg" data-cat-id="${cat.id}">Sin img</div>`;
            
          const prodBadge = cat.productCount > 0
            ? `<span class="ux-badge-prod">${cat.productCount} PRODS</span>`
            : `<span class="ux-muted">0 PRODS</span>`;

          tr.innerHTML = `
            <td class="col-id"><span class="ux-id">#${cat.id}</span></td>
            <td class="col-img">${imgCell}</td>
            <td class="col-cat"><span class="ux-user-name">${cat.nombre || ''}</span></td>
            <td class="col-desc"><span class="ux-email">${truncate(cat.descripcion, 40)}</span></td>
            <td class="col-prods">${prodBadge}</td>
            <td class="col-actions">
              <div class="ux-row-actions">
                <button class="ux-action-btn ux-action-btn--edit" data-action="edit" data-id="${cat.id}" type="button" title="Editar categoría"></button>
                <button class="ux-action-btn ux-action-btn--delete" data-action="delete" data-id="${cat.id}" type="button" title="Eliminar categoría" ${canDelete ? '' : 'disabled'}></button>
              </div>
            </td>`;
          
          const editBtn = tr.querySelector('.ux-action-btn--edit');
          const delBtn  = tr.querySelector('.ux-action-btn--delete');
          if (editBtn) editBtn.appendChild(makeSVG(ICON_EDIT));
          if (delBtn)  delBtn.appendChild(makeSVG(ICON_DELETE));
          
          // Image viewer open trigger
          const imgTrigger = tr.querySelector('[data-cat-id]');
          if(imgTrigger) imgTrigger.addEventListener('click', () => openCatImageViewer(cat.id));

          rowsEl.appendChild(tr);
        });
      }
      renderPagination(pageData);
      renderStats();
    }

    /* fetch */
    async function fetchCategories() {
      try {
        const r = await fetch('/api/categorias', { credentials: 'include' });
        const d = await r.json().catch(() => ({}));
        if (!r.ok || !d?.success) throw new Error(d?.error || 'No se pudieron cargar categorías');
        
        categories = (Array.isArray(d.categorias)?d.categorias:[]).map(c=>({
          id: c.Id_Categoria ?? c.id,
          nombre: c.Nombre ?? c.nombre ?? "",
          descripcion: c.Descripcion ?? c.descripcion ?? "",
          imagenUrl: c.Imagen_URL ?? c.imagenUrl ?? c.imagen ?? "",
          productCount: c.productCount ?? 0,
        }));

        try {
          const pr = await fetch("/api/productos", {credentials:"include"});
          const pd = await pr.json().catch(()=>({}));
          if(pr.ok && pd?.success) {
            const countMap = {};
            (Array.isArray(pd.productos)?pd.productos:[]).forEach(p=>{
              const id = Number(p.categoriaId||0);
              if(id) countMap[id] = (countMap[id]||0) + 1;
            });
            categories.forEach(c => { c.productCount = countMap[c.id] || 0; });
          }
        } catch{}

        renderCategories();
      } catch (err) {
        if(window.Modal) Modal.error('Error', err.message);
      }
    }

    /* events */
    btnAddCategory?.addEventListener('click', () => { resetForm(); openForm('create'); });
    searchCategoriesEl?.addEventListener('input', () => { currentPage = 1; renderCategories(); });
    rowsPerPageEl?.addEventListener('change', () => { currentPage = 1; renderCategories(); });
    btnCancelEdit?.addEventListener('click', closeForm);
    btnFormReset?.addEventListener('click', resetForm);

    btnCopy?.addEventListener('click', async () => {
      try { 
        const rows=filteredCategories.map(c=>`${c.id}\t${c.nombre}\t${c.descripcion}\t${c.productCount}`).join("\n");
        await navigator.clipboard.writeText(`ID\tNOMBRE\tDESCRIPCION\tPRODUCTOS\n${rows}`); 
        Modal.success('Copiado', 'Datos copiados al portapapeles', { autoClose: 1800 }); 
      }
      catch { Modal.error('Error', 'No se pudo copiar al portapapeles'); }
    });
    btnCsv?.addEventListener('click', () => {
      const rows=filteredCategories.map(c=>`${c.id},"${String(c.nombre||"").replaceAll('"','""')}","${String(c.descripcion||"").replaceAll('"','""')}",${c.productCount}`).join("\n");
      const blob=new Blob([`id,nombre,descripcion,productos\n${rows}`],{type:"text/csv;charset=utf-8;"});
      const url=URL.createObjectURL(blob); const a=document.createElement("a"); a.href=url; a.download="categorias.csv"; document.body.appendChild(a); a.click(); a.remove(); URL.revokeObjectURL(url);
      Modal.success('CSV descargado', 'Archivo listo', { autoClose: 1800 });
    });

    const handleSave = async (isEdit) => {
      const p = buildPayload();
      if (!p.nombre) { Modal.error('Error', 'El nombre de la categoría es obligatorio'); return; }
      try {
        Modal.loading(isEdit ? 'Actualizando...' : 'Creando categoría', 'Por favor espera…');
        const url = isEdit ? `/api/admin/categorias/${currentCategoryIdEl.value}` : '/api/admin/categorias/crear';
        const method = isEdit ? 'PUT' : 'POST';
        const r = await fetch(url, { method, credentials: 'include', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(p) });
        const d = await r.json().catch(() => ({}));
        Modal.hideLoading();
        if (!r.ok || !d?.success) throw new Error(d?.error || 'No se pudo procesar la solicitud');
        Modal.success('¡Hecho!', isEdit ? 'Categoría actualizada' : 'Categoría creada', { autoClose: 2500 });
        closeForm(); await fetchCategories();
      } catch (err) { Modal.hideLoading(); Modal.error('Error', err.message); }
    };

    btnCreate?.addEventListener('click', () => handleSave(false));
    btnUpdate?.addEventListener('click', () => handleSave(true));

    rowsEl?.addEventListener('click', async event => {
      const btn = event.target?.closest('button[data-action]');
      if (!(btn instanceof HTMLButtonElement)) return;
      const action = btn.dataset.action, catId = btn.dataset.id;
      if (!catId) return;
      
      if (action === 'edit') { const cat = categories.find(c => String(c.id) === String(catId)); if (cat) fillForm(cat); return; }
      if (action === 'delete') {
        if (!isSuperusuario) { Modal.error('Sin permiso', 'Solo superusuario puede eliminar'); return; }
        const ok = await Modal.confirm('¿Eliminar categoría?', 'Esta acción es permanente y no se puede deshacer.', { confirmText: 'Sí, eliminar', cancelText: 'Cancelar' });
        if (!ok) return;
        try {
          Modal.loading('Eliminando', 'Por favor espera…');
          const r = await fetch(`/api/admin/categorias/${catId}`, { method: 'DELETE', credentials: 'include' });
          const d = await r.json().catch(() => ({}));
          Modal.hideLoading();
          if (!r.ok || !d?.success) throw new Error(d?.error || 'No se pudo eliminar');
          Modal.success('Eliminado', 'La categoría fue eliminada correctamente', { autoClose: 2000 });
          closeForm(); await fetchCategories();
        } catch (err) { Modal.hideLoading(); Modal.error('Error al eliminar', err.message); }
      }
    });

    /* ── IMAGE VIEWER MODAL LOGIC ── */
    const catImgModal = document.getElementById("catImageViewerModal");
    const catImgPreviewEl = document.getElementById("catImageViewerImg");
    const catImgEmptyEl = document.getElementById("catImageViewerEmpty");
    const catImgListEl = document.getElementById("catImageViewerList");
    const catImgNewUrlEl = document.getElementById("catImageViewerNewUrl");
    let catImgViewerCatId=null, catImgViewerUrls=[], catImgViewerSelectedIdx=0, catImgViewerMode="category";

    function showCatImgModal(){ 
      catImgModal.hidden = false; 
      requestAnimationFrame(()=>catImgModal.classList.add("is-open")); 
    }
    function closeCatImageViewer(){ 
      catImgModal.classList.remove("is-open"); 
      setTimeout(()=>catImgModal.hidden = true, 250); 
    }
    
    function openCatImageViewer(catId){
      const cat = categories.find(c=>Number(c.id)===Number(catId));
      if(!cat) return;
      catImgViewerMode="category"; catImgViewerCatId=cat.id;
      catImgViewerUrls=cat.imagenUrl?[cat.imagenUrl]:[];
      catImgViewerSelectedIdx=0;
      document.getElementById("catImageViewerName").textContent=cat.nombre;
      renderCatImageViewer(); showCatImgModal();
    }

    function openCatImageViewerForForm(){
      catImgViewerMode="form"; catImgViewerCatId=null;
      const url=imagenUrlEl?.value?.trim();
      catImgViewerUrls=url?[url]:[]; catImgViewerSelectedIdx=0;
      document.getElementById("catImageViewerName").textContent=nombreEl?.value?.trim()||"Nueva categoría";
      renderCatImageViewer(); showCatImgModal();
    }

    function renderCatImageViewer(){
      const has = catImgViewerUrls.length > 0;
      if(catImgPreviewEl) { 
        catImgPreviewEl.style.display = has ? "block" : "none"; 
        catImgPreviewEl.src = has ? catImgViewerUrls[catImgViewerSelectedIdx] : ""; 
      }
      if(catImgEmptyEl) catImgEmptyEl.style.display = has ? "none" : "flex";
      
      const c = document.getElementById("catImageViewerCounter");
      if(c) c.textContent = has ? `Mostrando 1 de ${catImgViewerUrls.length}` : "";
      
      if(!catImgListEl) return;
      catImgListEl.innerHTML = "";
      catImgViewerUrls.forEach((url, idx) => {
        const row = document.createElement("div");
        row.className = "ux-img-row" + (idx === catImgViewerSelectedIdx ? " is-selected" : "");
        row.innerHTML = `
          <img src="${url}" class="ux-img-row-thumb" />
          <input type="text" class="ux-img-input" style="padding:4px 8px; font-size:0.75rem; flex:1;" value="${url}" readonly />
          <button type="button" class="ux-icon-btn" style="color:var(--ux-bad);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
        `;
        row.querySelector('button').onclick = () => {
          catImgViewerUrls.splice(idx,1);
          catImgViewerSelectedIdx = Math.max(0, catImgViewerUrls.length-1);
          renderCatImageViewer();
        };
        row.onclick = (e) => { 
          if(e.target.tagName !== 'BUTTON' && e.target.tagName !== 'svg') { 
            catImgViewerSelectedIdx = idx; renderCatImageViewer(); 
          } 
        };
        catImgListEl.appendChild(row);
      });
    }

    document.getElementById("catImageViewerAddBtn")?.addEventListener("click", () => {
      const u = catImgNewUrlEl?.value?.trim();
      if(!u) return;
      catImgViewerUrls.push(u); 
      catImgViewerSelectedIdx = catImgViewerUrls.length - 1;
      if(catImgNewUrlEl) catImgNewUrlEl.value = "";
      renderCatImageViewer();
    });

    document.getElementById("catImageViewerClose")?.addEventListener("click", closeCatImageViewer);
    document.getElementById("catImageViewerCancelBtn")?.addEventListener("click", closeCatImageViewer);
    document.getElementById("catImageViewerModal")?.addEventListener("click", e => { if(e.target === document.getElementById("catImageViewerModal")) closeCatImageViewer(); });

    document.getElementById("catImageViewerSave")?.addEventListener("click", async () => {
      const cleanUrls = catImgViewerUrls.filter(u=>u.trim());
      const firstUrl = cleanUrls[0] || "";
      
      if(catImgViewerMode === "form"){
        if(imagenUrlEl) imagenUrlEl.value = firstUrl;
        closeCatImageViewer(); return;
      }
      
      if(!catImgViewerCatId) return;
      const cat = categories.find(c=>Number(c.id)===Number(catImgViewerCatId));
      if(!cat) return;
      
      try {
        Modal.loading("Guardando","Actualizando imagen...");
        const res = await fetch(`/api/admin/categorias/${catImgViewerCatId}`,{
          method:"PUT", credentials:"include", headers:{"Content-Type":"application/json"},
          body:JSON.stringify({nombre:cat.nombre, descripcion:cat.descripcion, imagenUrl:firstUrl})
        });
        const data = await res.json().catch(()=>({}));
        Modal.hideLoading();
        if(!res.ok||!data?.success) throw new Error(data?.error||"Error al guardar");
        closeCatImageViewer(); 
        Modal.success("¡Listo!","Imagen actualizada",{autoClose:2200});
        await fetchCategories();
      } catch(err){ Modal.hideLoading(); Modal.error("Error",err.message); }
    });

    document.getElementById("btnCatOpenGallery")?.addEventListener("click", openCatImageViewerForForm);

    /* Cloudinary Logic */
    const uploadFile = document.getElementById("catImageUploadFile");
    const uploadBtn = document.getElementById("catImageUploadBtn");
    if(uploadBtn) {
      uploadBtn.addEventListener("click", async () => {
        if (!uploadFile.files || !uploadFile.files[0]) { Modal.warning("Sin archivo", "Selecciona una imagen primero"); return; }
        const fd = new FormData(); fd.append("file", uploadFile.files[0]);
        try {
          Modal.loading("Subiendo", "Enviando a Cloudinary...");
          const res = await fetch("/api/admin/categorias/imagenes/upload", { method: "POST", credentials: "include", body: fd });
          const data = await res.json().catch(() => ({}));
          Modal.hideLoading();
          if (!res.ok || !data?.success || !data?.url) throw new Error(data?.error || "Error al subir");
          catImgViewerUrls.push(String(data.url));
          catImgViewerSelectedIdx = catImgViewerUrls.length - 1;
          uploadFile.value = ""; renderCatImageViewer();
          Modal.success("Listo", "Imagen subida", { autoClose: 1500 });
        } catch (error) { Modal.hideLoading(); Modal.error("Error", error.message); }
      });
    }

    fetchCategories().catch(err => Modal.error('Error', err.message || 'No se pudieron cargar categorías'));
  })();
  </script>

  <script>
    (function(){
      try{const t=localStorage.getItem('theme');if(t==='dark')document.documentElement.classList.add('dark');else document.documentElement.classList.remove('dark');}catch(e){}
      window.addEventListener('storage',(e)=>{if(e.key==='theme')document.documentElement.classList.toggle('dark',e.newValue==='dark');});
    })();
  </script>

  <style is:global>
