    btnCsv?.addEventListener("click",()=>{const rows=filteredCategories.map(c=>`${c.id},"${String(c.nombre||"").replaceAll('"','""')}","${String(c.descripcion||"").replaceAll('"','""')}",${c.productCount}`).join("\n");const blob=new Blob([`id,nombre,descripcion,productos\n${rows}`],{type:"text/csv;charset=utf-8;"});const url=URL.createObjectURL(blob);const a=document.createElement("a");a.href=url;a.download="categorias.csv";document.body.appendChild(a);a.click();a.remove();URL.revokeObjectURL(url);Modal.success("CSV","Archivo descargado",{autoClose:1800});});

    /* Image Viewer */
    const catImgModal=document.getElementById("catImageViewerModal");const catImgPanel=document.getElementById("catImageViewerPanel");const catImgCloseBtn=document.getElementById("catImageViewerClose");const catImgPreviewEl=document.getElementById("catImageViewerImg");const catImgEmptyEl=document.getElementById("catImageViewerEmpty");const catImgListEl=document.getElementById("catImageViewerList");const catImgNewUrlEl=document.getElementById("catImageViewerNewUrl");const catImgAddBtn=document.getElementById("catImageViewerAddBtn");const catImgSaveBtn=document.getElementById("catImageViewerSave");const catImgNameEl=document.getElementById("catImageViewerName");const catImgCancelBtn=document.getElementById("catImageViewerCancelBtn");let catImgViewerCatId=null,catImgViewerUrls=[],catImgViewerSelectedIdx=0,catImgViewerMode="category",catDragSrcIdx=null;
    function showCatImgModal(){if(!catImgModal||!catImgPanel)return;catImgModal.hidden=false;requestAnimationFrame(()=>{catImgModal.classList.add("is-open");catImgPanel.classList.add("is-open");});}
    function closeCatImageViewer(){if(!catImgModal||!catImgPanel)return;catImgModal.classList.remove("is-open");catImgPanel.classList.remove("is-open");setTimeout(()=>{catImgModal.hidden=true;},200);}
    function openCatImageViewer(catId){const cat=categories.find(c=>Number(c.id)===Number(catId));if(!cat)return;catImgViewerMode="category";catImgViewerCatId=cat.id;catImgViewerUrls=cat.imagenUrl?[cat.imagenUrl]:[];catImgViewerSelectedIdx=0;if(catImgNameEl)catImgNameEl.textContent=cat.nombre||"Categoría";renderCatImageViewer();showCatImgModal();}
    function openCatImageViewerForForm(){catImgViewerMode="form";catImgViewerCatId=null;const url=imagenUrlEl?.value?.trim();catImgViewerUrls=url?[url]:[];catImgViewerSelectedIdx=0;if(catImgNameEl)catImgNameEl.textContent=nombreEl?.value?.trim()||"Nueva categoría";renderCatImageViewer();showCatImgModal();}
    function renderCatImageViewer(){const has=catImgViewerUrls.length>0;if(catImgPreviewEl){catImgPreviewEl.style.display=has?"block":"none";catImgPreviewEl.src=has?(catImgViewerUrls[catImgViewerSelectedIdx]||""):"";}if(catImgEmptyEl)catImgEmptyEl.style.display=has?"none":"flex";const counterEl=document.getElementById("catImageViewerCounter");if(counterEl)counterEl.textContent=has?`Imagen ${catImgViewerSelectedIdx+1} de ${catImgViewerUrls.length}`:"";if(!catImgListEl)return;catImgListEl.innerHTML="";catImgViewerUrls.forEach((url,idx)=>{const row=document.createElement("div");row.className="ca-img-row"+(idx===catImgViewerSelectedIdx?" is-selected":"");row.draggable=true;row.dataset.idx=String(idx);row.innerHTML=`<div class="ca-img-row-drag" title="Arrastrar"><svg viewBox="0 0 24 24"><path d="M8 6h.01M8 12h.01M8 18h.01M16 6h.01M16 12h.01M16 18h.01"></path></svg></div><img class="ca-img-row-thumb" src="${url}" alt="img ${idx+1}" /><input class="ca-img-row-url" type="text" value="${url}" data-idx="${idx}" /><button class="ca-img-row-del" type="button"><svg viewBox="0 0 24 24"><path d="M6 7h12m-9 0V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2m-8 0l1 13h8l1-13M10 11v6M14 11v6"></path></svg></button>`;row.addEventListener("dragstart",e=>{catDragSrcIdx=idx;row.classList.add("is-dragging");e.dataTransfer.effectAllowed="move";});row.addEventListener("dragend",()=>{row.classList.remove("is-dragging");catDragSrcIdx=null;catImgListEl.querySelectorAll(".ca-img-row").forEach(r=>r.classList.remove("drag-over"));});row.addEventListener("dragover",e=>{e.preventDefault();row.classList.add("drag-over");});row.addEventListener("dragleave",()=>row.classList.remove("drag-over"));row.addEventListener("drop",e=>{e.preventDefault();row.classList.remove("drag-over");if(catDragSrcIdx!==null&&catDragSrcIdx!==idx){const moved=catImgViewerUrls.splice(catDragSrcIdx,1)[0];catImgViewerUrls.splice(idx,0,moved);catImgViewerSelectedIdx=idx;renderCatImageViewer();}catDragSrcIdx=null;});row.querySelector(".ca-img-row-thumb")?.addEventListener("click",()=>{catImgViewerSelectedIdx=idx;renderCatImageViewer();});row.querySelector(".ca-img-row-url")?.addEventListener("input",e=>{catImgViewerUrls[idx]=e.target.value.trim();if(catImgPreviewEl&&idx===catImgViewerSelectedIdx)catImgPreviewEl.src=catImgViewerUrls[idx];});row.querySelector(".ca-img-row-del")?.addEventListener("click",()=>{catImgViewerUrls.splice(idx,1);catImgViewerSelectedIdx=Math.max(0,catImgViewerUrls.length-1);renderCatImageViewer();});catImgListEl.appendChild(row);});}
