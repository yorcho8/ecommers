---
// src/pages/[lang]/promociones.astro
import "../../styles/promociones.css";
import "../../styles/global.css";

import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";


export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}

const currentLang = "es";

const promoData = {
  meta_title: "Promociones | NEXUS",
  original_price: "Antes",
  promo_price: "Precio Especial",
  buy_button: "Solicitar Cotización",
  valid_until: "Válido hasta agotar existencias*",
  contact_cta: "Contacta a un asesor para más información",
  products: [
    {
      id: "promo-stretch",
      name: "Stretch Film",
      subtitle: "$33 POR KG EN STRETCH DE COLOR",
      image: "/images/stretch/manual.webp",
      discount: 35,
      originalPrice: "",
      promoPrice: "$33/KG",
      features: [
        "Película estirable de color",
        "Precio especial por kilogramo",
        "Stock limitado",
        "Disponible en varios colores",
      ],
      validUntil: "Válido hasta agotar existencias*",
    },
    {
      id: "promo-cuerda",
      name: "Cuerda",
      subtitle: "$33 POR KG",
      image: "/images/cuerdas/CuerdaT1.webp",
      discount: 25,
      originalPrice: "",
      promoPrice: "$33/KG",
      features: [
        "Cuerda de alta calidad",
        "Precio especial por kilogramo",
        "Oferta por tiempo limitado",
        "Disponibilidad sujeta a stock",
      ],
      validUntil: "Válido hasta agotar existencias*",
    },
  ],
};

// Solo 2 productos para el carrusel
const featuredProducts = [
  { 
    ...promoData.products[0], // Película Estirable
    video: '/videos/producto-1.mp4' // Video para producto 1
  },
  { 
    ...promoData.products[1], // Cuerda Premium
    video: '/videos/producto-1.mp4' // Video para producto 2
  }
];
---

<BaseLayout title={promoData.meta_title} currentLang={currentLang}>
  
  <main class="promo-main-carousel">
    
    <!-- SPLIT CAROUSEL SECTION CON NAVEGACIÓN CIRCULAR -->
    <section class="split-carousel">
      <div class="carousel-container">
        
        <!-- Navegación Circular Lateral Izquierda -->
        <div class="circular-nav-left">
          {featuredProducts.map((product, index) => (
            <button 
              class={`circle-nav-item ${index === 0 ? 'active' : ''}`}
              data-slide={index}
              aria-label={`Ver ${product.name}`}
            >
              <div class="circle-image">
                <img src={product.image} alt={product.name} />
              </div>
              <span class="circle-label">{product.name}</span>
            </button>
          ))}
        </div>

        <!-- Slides Container -->
        <div class="carousel-slides">
          {featuredProducts.map((product, index) => (
            <div class="carousel-slide" data-slide={index}>
              
              <!-- Left Side: Product Info -->
              <div class="slide-left">
                <div class="slide-content">
                  
                  <div class="promo-hero-brand">
                    <h1 class="promo-hero-title">
                      <span class="promo-text">PROMOCIONES</span>
                      <span class="go-text-hero">GO</span>
                    </h1>
                  </div>
                  
                  <h1 class="product-title">
                    {product.name.toUpperCase()}
                  </h1>

                  <ul class="feature-list">
                    {product.features.map((feature) => (
                      <li>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                          <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>

                  <div class="price-section">
                    {product.originalPrice && (
                      <div class="price-before">
                        <span class="price-label">{promoData.original_price}</span>
                        <span class="price-value">{product.originalPrice}</span>
                      </div>
                    )}
                    <div class="price-now">
                      <span class="price-label">{promoData.promo_price}</span>
                      <span class="price-value">{product.promoPrice}</span>
                    </div>
                  </div>

                  <a href={`https://wa.me/5214433165858?text=Hola, me interesa la promoción de ${product.name}`} 
                     class="cta-button" 
                     target="_blank"
                     rel="noopener noreferrer">
                    {promoData.buy_button}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </a>

                  <div class="validity-tag">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                      <line x1="16" y1="2" x2="16" y2="6"></line>
                      <line x1="8" y1="2" x2="8" y2="6"></line>
                      <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    <span>{promoData.valid_until} {product.validUntil}</span>
                  </div>

                </div>
              </div>

              <!-- Right Side: Product Image with Video Background -->
              <div class="slide-right">
                <!-- Video de fondo específico para cada producto -->
                <video class="background-video" autoplay muted loop playsinline>
                  <source src={product.video} type="video/mp4" />
                </video>
                
                <!-- Overlay oscuro suave -->
                <div class="video-overlay"></div>
                
                <!-- Imagen del producto -->
                <div class="product-image-container">
                  <img src={product.image} alt={product.name} class="product-image" />
                </div>
              </div>

            </div>
          ))}
        </div>

        <!-- Botón de explorar (opcional, al centro abajo) -->
<button class="explore-btn" aria-label="Descubre más productos">
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <circle cx="11" cy="11" r="8"></circle>
    <path d="m21 21-4.35-4.35"></path>
  </svg>
  <span>Descubre más</span>
</button>

      </div>
    </section>

    <!-- CTA SECTION -->
    <section class="promo-cta">
      <div class="promo-cta-content">
        <h2>¿Necesitas más información?</h2>
        <p>{promoData.contact_cta}</p>
        <a href="https://wa.me/5214433165858" class="promo-cta-btn" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Contactar por WhatsApp
        </a>
      </div>
    </section>

  </main>

  <Footer currentLang={currentLang} />

</BaseLayout>

<script>
  // Carousel functionality con navegación circular
  const slides = document.querySelectorAll('.carousel-slide');
  const circleNavItems = document.querySelectorAll('.circle-nav-item');
  
  let currentSlide = 0;
  const totalSlides = slides.length;

  function goToSlide(n: number) {
    // Remove active classes
    slides.forEach(slide => slide.classList.remove('active'));
    circleNavItems.forEach(item => item.classList.remove('active'));
    
    currentSlide = (n + totalSlides) % totalSlides;
    
    // Add active classes
    slides[currentSlide].classList.add('active');
    circleNavItems[currentSlide].classList.add('active');
  }

  function nextSlide() {
    goToSlide(currentSlide + 1);
  }

  // Event listeners para navegación circular
  circleNavItems.forEach((item, index) => {
    item.addEventListener('click', () => goToSlide(index));
  });

  // Auto-play
  let autoplay = setInterval(nextSlide, 5000);

  // Pause on hover
  const carouselContainer = document.querySelector('.carousel-container');
  carouselContainer?.addEventListener('mouseenter', () => clearInterval(autoplay));
  carouselContainer?.addEventListener('mouseleave', () => {
    autoplay = setInterval(nextSlide, 5000);
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
      goToSlide(currentSlide - 1);
    }
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
      nextSlide();
    }
  });

  // Touch swipe support
  let touchStartX = 0;
  let touchEndX = 0;
  let touchStartY = 0;
  let touchEndY = 0;

  carouselContainer?.addEventListener('touchstart', (e: Event) => {
    const touchEvent = e as TouchEvent;
    touchStartX = touchEvent.changedTouches[0].screenX;
    touchStartY = touchEvent.changedTouches[0].screenY;
  });

  carouselContainer?.addEventListener('touchend', (e: Event) => {
    const touchEvent = e as TouchEvent;
    touchEndX = touchEvent.changedTouches[0].screenX;
    touchEndY = touchEvent.changedTouches[0].screenY;
    handleSwipe();
  });

  function handleSwipe() {
    const diffX = touchStartX - touchEndX;
    const diffY = touchStartY - touchEndY;
    
    // Determinar si es swipe horizontal o vertical
    if (Math.abs(diffX) > Math.abs(diffY)) {
      // Swipe horizontal
      if (diffX > 50) nextSlide();
      if (diffX < -50) goToSlide(currentSlide - 1);
    } else {
      // Swipe vertical
      if (diffY > 50) nextSlide();
      if (diffY < -50) goToSlide(currentSlide - 1);
    }
  }

  // Initialize
  goToSlide(0);
</script>