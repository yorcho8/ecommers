}

.login-modal.success .login-modal-kicker { color: #86efac; }
.login-modal.error .login-modal-kicker { color: #fca5a5; }

.login-modal-panel h2 {
  margin: 0;
  font-family: 'Sora', sans-serif;
  font-size: 1.6rem;
  font-weight: 800;
  line-height: 1.2;
}

.login-modal-message {
  margin: 10px 0 0;
  font-size: 0.95rem;
  line-height: 1.5;
  color: var(--text-secondary);
}

.login-modal-ok {
  margin-top: 1.4rem;
  width: 100%;
  border-radius: 12px;
