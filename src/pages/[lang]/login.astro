  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #fff;
  font-family: 'Sora', sans-serif;
  font-size: 0.95rem;
  font-weight: 700;
  padding: 0.8rem 1rem;
  cursor: pointer;
  transition: transform 0.15s ease, box-shadow 0.2s ease;
}

.login-modal-ok:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 20px rgba(232, 82, 26, 0.3);
}

@media (max-width: 480px) {
  .login-container { padding: 2rem 1.5rem 1.6rem; }
  .login-title { font-size: 1.5rem; }
  .empresa-grid { grid-template-columns: 1fr; }
}
</style>

<script is:inline data-astro-rerun nonce={cspNonce}>
function initLoginPage() {
  var currentLang = document.documentElement.lang || 'es';
  var form = document.getElementById('login-form');
  if (!form) return;
  if (form.dataset.jsBound === '1') return;
  form.dataset.jsBound = '1';

  // If credentials were accidentally sent in query params, immediately scrub URL.
  try {
    var url = new URL(window.location.href);
    var hadSensitiveParams = url.searchParams.has('correo') || url.searchParams.has('contrasena');
    if (hadSensitiveParams) {
      url.searchParams.delete('correo');
      url.searchParams.delete('contrasena');
      var nextSearch = url.searchParams.toString();
      var cleanedUrl = url.pathname + (nextSearch ? ('?' + nextSearch) : '') + url.hash;
      window.history.replaceState({}, '', cleanedUrl);
    }
  } catch (_) {}

  /* ── EYE TRACKING ── */
  var eyeSvg       = document.getElementById('eye-svg');
  var iris         = document.getElementById('iris');
  var pupil        = document.getElementById('pupil');
  var reflection   = document.getElementById('reflection');
  var toggleBtn    = document.getElementById('toggle-password');
  var passwordInput= document.getElementById('contrasena');

  var isPasswordVisible = false;
  var isEyeOpen = true;
  var eyeRect = null;
  var targetX = 32, targetY = 32;
  var currentX = 32, currentY = 32;
  var EYE_MOVE_RADIUS = 5;

  function updateEyeRect() {
    if (eyeSvg) eyeRect = eyeSvg.getBoundingClientRect();
  }

  window.addEventListener('resize', updateEyeRect);
  window.addEventListener('scroll', updateEyeRect, { passive: true });
  setTimeout(updateEyeRect, 300);

  document.addEventListener('mousemove', function(e) {
    if (!eyeRect || !isEyeOpen) return;
    var eyeCenterX = eyeRect.left + eyeRect.width / 2;
    var eyeCenterY = eyeRect.top + eyeRect.height / 2;
    var dx = e.clientX - eyeCenterX;
    var dy = e.clientY - eyeCenterY;
    var dist = Math.sqrt(dx * dx + dy * dy);
    var maxDist = Math.max(window.innerWidth, window.innerHeight) * 0.5;
    var factor = Math.min(dist / maxDist, 1);
    var angle = Math.atan2(dy, dx);
    targetX = 32 + Math.cos(angle) * EYE_MOVE_RADIUS * factor;
    targetY = 32 + Math.sin(angle) * EYE_MOVE_RADIUS * factor;
  });

  function animateEye() {
    if (isEyeOpen && iris && pupil && reflection) {
      currentX += (targetX - currentX) * 0.18;
      currentY += (targetY - currentY) * 0.18;
      iris.setAttribute('cx', currentX.toFixed(2));
      iris.setAttribute('cy', currentY.toFixed(2));
      pupil.setAttribute('cx', currentX.toFixed(2));
      pupil.setAttribute('cy', currentY.toFixed(2));
      reflection.setAttribute('cx', (currentX - 3).toFixed(2));
      reflection.setAttribute('cy', (currentY - 2.5).toFixed(2));
    }
    requestAnimationFrame(animateEye);
  }
  requestAnimationFrame(animateEye);

  if (toggleBtn && passwordInput && eyeSvg && toggleBtn.dataset.eyeBound !== '1') {
    toggleBtn.dataset.eyeBound = '1';
    toggleBtn.addEventListener('click', function() {
      isPasswordVisible = !isPasswordVisible;
      if (isPasswordVisible) {
        passwordInput.type = 'text';
        eyeSvg.classList.add('is-closed');
        isEyeOpen = false;
      } else {
        passwordInput.type = 'password';
        eyeSvg.classList.remove('is-closed');
        isEyeOpen = true;
        updateEyeRect();
      }
    });
  }

  /* ── MODAL ── */
  var modalEl       = document.getElementById('login-modal');
  var modalPanelEl  = document.getElementById('login-modal-panel');
  var modalKickerEl = document.getElementById('login-modal-kicker');
  var modalTitleEl  = document.getElementById('login-modal-title');
  var modalMessageEl= document.getElementById('login-modal-message');
  var modalOkEl     = document.getElementById('login-modal-ok');
  var modalCloseEl  = document.getElementById('login-modal-close');
  var modalRedirect = '';

  function closeModal() {
    if (!modalEl || !modalPanelEl) return;
    modalPanelEl.classList.remove('is-open');
    setTimeout(function() {
      modalEl.classList.remove('is-open', 'success', 'error');
      modalEl.hidden = true;
      if (modalRedirect) {
        var url = modalRedirect;
        modalRedirect = '';
        window.location.href = url;
      }
    }, 200);
  }

  function openModal(opts) {
    if (!modalEl || !modalPanelEl) return;
    modalRedirect = opts.redirectTo || '';
    if (modalTitleEl) modalTitleEl.textContent = opts.title || 'Error';
    if (modalMessageEl) modalMessageEl.textContent = opts.message || '';
    if (modalKickerEl) modalKickerEl.textContent = opts.type === 'success' ? 'Éxito' : 'Error';
    if (modalOkEl) modalOkEl.textContent = opts.buttonText || 'Aceptar';
    modalEl.hidden = false;
    modalEl.classList.remove('success', 'error');
    modalEl.classList.add('is-open', opts.type || 'error');
    setTimeout(function() { modalPanelEl.classList.add('is-open'); }, 10);
  }

  if (modalOkEl) modalOkEl.addEventListener('click', closeModal);
  if (modalCloseEl) modalCloseEl.addEventListener('click', closeModal);
  if (modalEl) modalEl.addEventListener('click', function(e) { if (e.target === modalEl) closeModal(); });

  // ── Feedback from email verification redirect ──
  (function showVerificationFeedback() {
    try {
      var params = new URLSearchParams(window.location.search || '');
      if (params.get('verified') === '1') {
        openModal({
          type: 'success',
          title: 'Correo verificado',
          message: 'Tu correo fue verificado correctamente. Ya puedes iniciar sesión.',
          buttonText: 'Continuar',
        });
        return;
      }

      var loginError = params.get('loginError') || '';
      if (loginError === 'missing') {
        openModal({ type: 'error', title: 'Campos incompletos', message: 'Por favor completa correo y contrasena.', buttonText: 'Aceptar' });
      } else if (loginError === 'invalid') {
        openModal({ type: 'error', title: 'No se pudo iniciar sesion', message: 'Correo o contrasena incorrectos.', buttonText: 'Aceptar' });
      } else if (loginError === 'verify-email') {
        openModal({ type: 'error', title: 'Correo no verificado', message: 'Verifica tu correo electronico antes de iniciar sesion.', buttonText: 'Entendido' });
      } else if (loginError === 'blocked') {
        openModal({ type: 'error', title: 'Demasiados intentos', message: 'Tu acceso fue bloqueado temporalmente por seguridad. Intenta de nuevo en unos minutos.', buttonText: 'Aceptar' });
      } else if (loginError === '2fa') {
        openModal({ type: 'error', title: 'Verificacion adicional', message: 'Tu cuenta requiere un segundo factor. Inicia sesion desde el flujo principal para completar la verificacion.', buttonText: 'Aceptar' });
      } else if (loginError === 'server') {
        openModal({ type: 'error', title: 'Error interno', message: 'Ocurrio un error al iniciar sesion. Intenta nuevamente.', buttonText: 'Aceptar' });
      }
    } catch (_) {}
  })();

  /* ── ENCRIPTACIÓN RSA ── */
  var cachedPublicKey = null;

  async function fetchPublicKey() {
    if (cachedPublicKey) return cachedPublicKey;
    console.log('[login] Pidiendo llave pública...');
    var res = await fetch('/api/public-key');
    if (!res.ok) throw new Error('public-key respondió ' + res.status);
    var json = await res.json();
    if (!json.publicKey) throw new Error('No se recibió publicKey en JSON');
    cachedPublicKey = json.publicKey;
    console.log('[login] Llave pública recibida OK');
    return cachedPublicKey;
  }

  async function importPublicKey(pem) {
    var pemClean = pem
      .replace(/-----BEGIN PUBLIC KEY-----/, '')
      .replace(/-----END PUBLIC KEY-----/, '')
      .replace(/[\n\r\s]/g, '');
    var binaryStr = atob(pemClean);
    var bytes = new Uint8Array(binaryStr.length);
    for (var i = 0; i < binaryStr.length; i++) {
      bytes[i] = binaryStr.charCodeAt(i);
    }
    return window.crypto.subtle.importKey(
      'spki',
      bytes.buffer,
      { name: 'RSA-OAEP', hash: 'SHA-256' },
      false,
      ['encrypt']
    );
  }

  async function encryptText(plainText, publicKeyPem) {
    var key = await importPublicKey(publicKeyPem);
    var encoded = new TextEncoder().encode(plainText);
    var encrypted = await window.crypto.subtle.encrypt(
      { name: 'RSA-OAEP' },
      key,
      encoded
    );
    var bytes = new Uint8Array(encrypted);
    var binary = '';
    for (var i = 0; i < bytes.length; i++) {
      binary += String.fromCharCode(bytes[i]);
    }
    return btoa(binary);
  }

  /* ── CSRF helper ── */
  function getCsrfToken() {
    var match = document.cookie.match(/go_csrf=([^;]+)/);
    return match ? match[1] : '';
  }

  /* ── FORM SUBMIT ── */
  var correoInput     = document.getElementById('correo');
  var contrasenaInput = document.getElementById('contrasena');
  var submitBtn       = document.getElementById('submit-btn');

  form.addEventListener('submit', async function(e) {
    e.preventDefault();

    var correo = correoInput ? correoInput.value : '';
    var contrasena = contrasenaInput ? contrasenaInput.value : '';

    if (!correo || !contrasena) {
      openModal({ type: 'error', title: 'Campos incompletos', message: 'Por favor completa todos los campos.' });
      return;
    }

    if (submitBtn) submitBtn.disabled = true;

    try {
      // Intentar encriptar la contraseña
      var contrasenaFinal = contrasena;
      try {
        var publicKeyPem = await fetchPublicKey();
        contrasenaFinal = await encryptText(contrasena, publicKeyPem);
        console.log('[login] Contraseña encriptada OK (largo: ' + contrasenaFinal.length + ')');
      } catch (encErr) {
        console.warn('[login] Encriptación falló, enviando sin encriptar:', encErr.message);
        // Si la encriptación falla, enviar sin encriptar (el backend lo maneja)
      }

      var formData = new FormData();
      formData.append('correo', correo);
      formData.append('contrasena', contrasenaFinal);

      var response = await fetch('/api/login', {
        method: 'POST',
        body: formData,
        credentials: 'include',
        headers: { 'x-csrf-token': getCsrfToken() }
      });

      var responseType = String(response.headers.get('content-type') || '').toLowerCase();
      var data = null;
      var fallbackError = '';
      if (responseType.includes('application/json')) {
        data = await response.json().catch(function () { return null; });
      } else {
        var plain = await response.text().catch(function () { return ''; });
        fallbackError = plain ? plain.slice(0, 220) : '';
      }

      if (response.ok && data && data.success) {
        openModal({
          type: 'success',
          title: ('Bienvenido ' + (data.user.nombre || '')).trim(),
          message: data.mustChangePassword ? 'Por seguridad, primero debes cambiar tu contraseña.' : 'Inicio de sesión exitoso.',
          buttonText: 'Continuar',
          redirectTo: data.redirectTo || ('/' + currentLang + '/'),
        });
        return;
      }

      openModal({
        type: 'error',
        title: 'No se pudo iniciar sesión',
        message: (data && data.error) || fallbackError || 'Error al iniciar sesión',
      });
      if (submitBtn) submitBtn.disabled = false;
    } catch (error) {
      console.error('[login] Error general:', error);
      cachedPublicKey = null;
      openModal({
        type: 'error',
        title: 'Error de conexión',
        message: 'Error de conexión. Por favor, intenta nuevamente.',
      });
      if (submitBtn) submitBtn.disabled = false;
    }
  });

  /* ── SOLICITUD EMPRESA DESDE LOGIN ── */
  var reqOpenBtn = document.getElementById('open-empresa-modal');
  var reqModal = document.getElementById('empresa-request-modal');
  var reqOverlay = document.getElementById('empresa-request-overlay');
  var reqCloseBtn = document.getElementById('empresa-request-close');
  var reqCancelBtn = document.getElementById('empresa-request-cancel');
  var reqForm = document.getElementById('empresa-request-form');
  var reqSubmitBtn = document.getElementById('empresa-request-submit');
  var reqFeedback = document.getElementById('empresa-request-feedback');
  var reqKycOpenBtn = document.getElementById('er-kyc-open');
  var reqKycStatus = document.getElementById('er-kyc-status');

  var kycModal = document.getElementById('empresa-kyc-modal');
  var kycOverlay = document.getElementById('empresa-kyc-overlay');
  var kycCloseBtn = document.getElementById('empresa-kyc-close');
  var kycCancelBtn = document.getElementById('empresa-kyc-cancel');
  var kycVideo = document.getElementById('empresa-kyc-video');
  var kycCanvas = document.getElementById('empresa-kyc-canvas');
  var kycPreview = document.getElementById('empresa-kyc-preview');
  var kycFileInput = document.getElementById('empresa-kyc-file');
  var kycUploadBtn = document.getElementById('empresa-kyc-upload');
  var kycCaptureBtn = document.getElementById('empresa-kyc-capture');
  var kycAcceptBtn = document.getElementById('empresa-kyc-accept');
  var kycConfirmCheck = document.getElementById('empresa-kyc-confirm');
  var kycFeedback = document.getElementById('empresa-kyc-feedback');

  var kycStream = null;
  var kycSnapshotDataUrl = '';
  var kycCompleted = false;
  var kycVideoReady = false;

  function reqSetFeedback(msg, success) {
    if (!reqFeedback) return;
    if (!msg) {
      reqFeedback.hidden = true;
      reqFeedback.classList.remove('success');
      reqFeedback.textContent = '';
      return;
    }
    reqFeedback.hidden = false;
    reqFeedback.textContent = msg;
    reqFeedback.classList.toggle('success', !!success);
  }

  function openEmpresaRequestModal() {
    if (!reqModal) return;
    reqSetFeedback('');
    reqModal.hidden = false;
    document.body.style.overflow = 'hidden';
    kycCompleted = false;
    kycSnapshotDataUrl = '';
    if (reqKycStatus) reqKycStatus.textContent = 'Estado KYC: pendiente';
  }

  function closeEmpresaRequestModal() {
    if (!reqModal) return;
    reqModal.hidden = true;
    document.body.style.overflow = '';
    if (reqForm) reqForm.reset();
    reqSetFeedback('');
    kycCompleted = false;
    kycSnapshotDataUrl = '';
    if (reqKycStatus) reqKycStatus.textContent = 'Estado KYC: pendiente';
    closeKycModal();
  }

  function setKycFeedback(msg, success) {
    if (!kycFeedback) return;
    if (!msg) {
      kycFeedback.hidden = true;
      kycFeedback.classList.remove('success');
      kycFeedback.textContent = '';
      return;
    }
    kycFeedback.hidden = false;
    kycFeedback.textContent = msg;
    kycFeedback.classList.toggle('success', !!success);
  }

  function isSecureCameraContext() {
    return !!window.isSecureContext;
  }

  function getReadableCameraError(err) {
    var name = String(err && err.name || '');
    if (name === 'NotAllowedError' || name === 'SecurityError') {
      return 'No se dio permiso de camara. Habilitalo en tu navegador e intenta de nuevo.';
    }
    if (name === 'NotFoundError' || name === 'DevicesNotFoundError') {
      return 'No se encontro ninguna camara disponible en este equipo.';
    }
    if (name === 'NotReadableError' || name === 'TrackStartError') {
      return 'La camara esta siendo usada por otra app. Cierra esa app e intenta de nuevo.';
    }
    if (name === 'OverconstrainedError') {
      return 'La configuracion de video no es compatible con tu camara.';
    }
    if (!isSecureCameraContext()) {
      return 'La camara solo funciona en contexto seguro (HTTPS o localhost).';
    }
    return String(err && err.message || 'No se pudo abrir la camara biometrica.');
  }

  function waitForVideoReady(videoEl, timeoutMs) {
    return new Promise(function(resolve, reject) {
      if (!videoEl) {
        reject(new Error('No se encontro el video de KYC.'));
        return;
      }
      if (videoEl.videoWidth > 0 && videoEl.videoHeight > 0 && videoEl.readyState >= 2) {
        resolve();
        return;
      }

      var done = false;
      var timeoutId = setTimeout(function() {
        if (done) return;
        done = true;
        cleanup();
        reject(new Error('La camara tardó demasiado en iniciar.'));
      }, timeoutMs);

      function cleanup() {
        clearTimeout(timeoutId);
        videoEl.removeEventListener('loadedmetadata', onReady);
        videoEl.removeEventListener('canplay', onReady);
      }

      function onReady() {
        if (done) return;
        if (!(videoEl.videoWidth > 0 && videoEl.videoHeight > 0)) return;
        done = true;
        cleanup();
        resolve();
      }

      videoEl.addEventListener('loadedmetadata', onReady);
      videoEl.addEventListener('canplay', onReady);
    });
  }

  function setCaptureEnabled(enabled) {
    if (!kycCaptureBtn) return;
    kycCaptureBtn.disabled = !enabled;
    kycCaptureBtn.textContent = enabled ? 'Tomar captura' : 'Iniciando camara...';
  }

  async function startKycCamera() {
    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
      throw new Error('Tu navegador no soporta camara biometrica.');
    }
    if (!isSecureCameraContext()) {
      throw new Error('La camara solo funciona en HTTPS o localhost.');
    }
    stopKycCamera();
    kycVideoReady = false;
    setCaptureEnabled(false);
    kycStream = await navigator.mediaDevices.getUserMedia({
      video: {
        facingMode: 'user',
        width: { ideal: 1280 },
        height: { ideal: 720 },
      },
      audio: false,
    });
    if (kycVideo) {
      kycVideo.srcObject = kycStream;
      await kycVideo.play();
      await waitForVideoReady(kycVideo, 8000);
      kycVideoReady = true;
      setCaptureEnabled(true);
    }
  }

  function stopKycCamera() {
    if (kycStream) {
      kycStream.getTracks().forEach(function(track) { track.stop(); });
      kycStream = null;
    }
    if (kycVideo) kycVideo.srcObject = null;
    kycVideoReady = false;
    setCaptureEnabled(false);
  }

  async function openKycModal() {
    if (!kycModal) return;
    setKycFeedback('');
    if (kycPreview) {
      kycPreview.hidden = true;
      kycPreview.removeAttribute('src');
      kycPreview.style.display = 'none';
    }
    if (kycAcceptBtn) kycAcceptBtn.disabled = true;
    if (kycConfirmCheck) kycConfirmCheck.checked = false;
    setCaptureEnabled(false);

    kycModal.hidden = false;
    document.body.style.overflow = 'hidden';

    try {
      await startKycCamera();
      setKycFeedback('Camara activa. Coloca tu rostro centrado y toma captura.', true);
    } catch (err) {
      setKycFeedback(getReadableCameraError(err));
    }
  }

  function closeKycModal() {
    if (!kycModal) return;
    stopKycCamera();
    kycModal.hidden = true;
    if (reqModal && !reqModal.hidden) {
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = '';
    }
  }

  function captureKycSnapshot() {
    if (!kycVideo || !kycCanvas) {
      setKycFeedback('No se encontro superficie de captura.');
      return;
    }

    var width = kycVideo.videoWidth || 0;
    var height = kycVideo.videoHeight || 0;
    if (!kycVideoReady || !width || !height || kycVideo.readyState < 2) {
      setKycFeedback('Espera a que la camara cargue y vuelve a intentar.');
      return;
    }

    kycCanvas.width = width;
    kycCanvas.height = height;
    var ctx = kycCanvas.getContext('2d');
    ctx.drawImage(kycVideo, 0, 0, width, height);
    kycSnapshotDataUrl = kycCanvas.toDataURL('image/jpeg', 0.88);

    if (kycPreview) {
      kycPreview.src = kycSnapshotDataUrl;
      kycPreview.hidden = false;
      kycPreview.style.display = 'block';
    }

    if (kycAcceptBtn) kycAcceptBtn.disabled = false;
    setKycFeedback('Captura tomada. Marca el checkbox y confirma.', true);
  }

  function onKycUploadClick() {
    if (kycFileInput) kycFileInput.click();
  }

  function onKycFileSelected(ev) {
    var file = ev && ev.target && ev.target.files ? ev.target.files[0] : null;
    if (!file) return;
    if (!/^image\//i.test(String(file.type || ''))) {
      setKycFeedback('Solo se permiten imagenes para selfie.');
      return;
    }

    var reader = new FileReader();
    reader.onload = function() {
      kycSnapshotDataUrl = String(reader.result || '');
      if (!kycSnapshotDataUrl) {
        setKycFeedback('No se pudo procesar la selfie. Intenta otro archivo.');
        return;
      }
      if (kycPreview) {
        kycPreview.src = kycSnapshotDataUrl;
        kycPreview.hidden = false;
        kycPreview.style.display = 'block';
      }
      if (kycAcceptBtn) kycAcceptBtn.disabled = false;
      setKycFeedback('Selfie cargada. Marca el checkbox y confirma.', true);
    };
    reader.onerror = function() {
      setKycFeedback('No se pudo leer la imagen seleccionada.');
    };
    reader.readAsDataURL(file);
  }

  async function completeKycLocalValidation() {
    if (!kycSnapshotDataUrl) {
      setKycFeedback('Primero toma una captura.');
      return;
    }
    if (!kycConfirmCheck || !kycConfirmCheck.checked) {
      setKycFeedback('Debes confirmar autorizacion biometrica.');
      return;
    }

    kycCompleted = true;
    if (reqKycStatus) reqKycStatus.textContent = 'Estado KYC: validacion local completada';
    setKycFeedback('Verificacion local completada. Puedes enviar la solicitud.', true);
    closeKycModal();
  }

  async function uploadEmpresaDoc(file, tipo) {
    var fd = new FormData();
    fd.append('file', file);
    fd.append('tipoDocumento', tipo);

    var res = await fetch('/api/admin/empresas/documentos/upload', {
      method: 'POST',
      credentials: 'include',
      headers: {
        'x-public-company-request': '1',
        'x-csrf-token': getCsrfToken(),
      },
      body: fd,
    });
    var data = await res.json().catch(function(){ return {}; });
    if (!res.ok || !data.success || !data.documento || !data.documento.url) {
      var detail = data && data.detail ? String(data.detail) : '';
      var base = data && data.error ? String(data.error) : ('No se pudo subir ' + tipo);
      throw new Error(detail ? (base + ': ' + detail) : base);
    }
    return {
      tipo: tipo,
      url: String(data.documento.url || ''),
      public_id: String(data.documento.publicId || ''),
      resource_type: String(data.documento.resourceType || ''),
      format: String(data.documento.format || ''),
      mime_type: String(file.type || ''),
      nombre_archivo: String(file.name || ''),
      size_bytes: Number(file.size || 0),
    };
  }

  function dataUrlToFile(dataUrl, fileName) {
    var raw = String(dataUrl || '');
    var match = raw.match(/^data:([^;]+);base64,(.+)$/);
    if (!match) throw new Error('Selfie biometrica invalida. Vuelve a capturar la foto.');

    var mime = String(match[1] || 'image/jpeg').toLowerCase();
    var b64 = String(match[2] || '');
    var binary = atob(b64);
    var len = binary.length;
    var bytes = new Uint8Array(len);
    for (var i = 0; i < len; i++) bytes[i] = binary.charCodeAt(i);

    var ext = 'jpg';
    if (mime === 'image/png') ext = 'png';
    if (mime === 'image/webp') ext = 'webp';
    var safeName = (fileName || 'selfie_biometrica') + '.' + ext;
    return new File([bytes], safeName, { type: mime });
  }

  async function uploadPrivateBiometricEvidence(solicitudId, correo, selfieDataUrl) {
    var res = await fetch('/api/register-empresa/biometria', {
      method: 'POST',
      credentials: 'include',
      headers: {
        'Content-Type': 'application/json',
        'x-public-company-request': '1',
        'x-csrf-token': getCsrfToken(),
      },
      body: JSON.stringify({
        solicitudId: solicitudId,
        correo: correo,
        selfieDataUrl: selfieDataUrl,
        consentimientoAceptado: true,
        consentimientoTexto: 'Acepto tratamiento de biometria para validacion de identidad de representante legal.',
        retentionDays: 90,
      }),
    });
    var data = await res.json().catch(function(){ return {}; });
    if (!res.ok || !data.success) {
      throw new Error(data.error || 'No se pudo guardar evidencia biometrica privada.');
    }
    return data;
  }

  if (reqOpenBtn) reqOpenBtn.addEventListener('click', openEmpresaRequestModal);
  if (reqCloseBtn) reqCloseBtn.addEventListener('click', closeEmpresaRequestModal);
  if (reqCancelBtn) reqCancelBtn.addEventListener('click', closeEmpresaRequestModal);
  if (reqOverlay) reqOverlay.addEventListener('click', closeEmpresaRequestModal);
  if (reqKycOpenBtn) reqKycOpenBtn.addEventListener('click', openKycModal);
  if (kycCloseBtn) kycCloseBtn.addEventListener('click', closeKycModal);
  if (kycCancelBtn) kycCancelBtn.addEventListener('click', closeKycModal);
  if (kycOverlay) kycOverlay.addEventListener('click', closeKycModal);
  if (kycUploadBtn) kycUploadBtn.addEventListener('click', onKycUploadClick);
  if (kycFileInput) kycFileInput.addEventListener('change', onKycFileSelected);
  if (kycCaptureBtn) kycCaptureBtn.addEventListener('click', captureKycSnapshot);
  if (kycAcceptBtn) kycAcceptBtn.addEventListener('click', completeKycLocalValidation);

  document.addEventListener('keydown', function(ev) {
    if (ev.key === 'Escape' && reqModal && !reqModal.hidden) closeEmpresaRequestModal();
    if (ev.key === 'Escape' && kycModal && !kycModal.hidden) closeKycModal();
  });

  if (reqForm) {
    reqForm.addEventListener('submit', async function(ev) {
      ev.preventDefault();
      reqSetFeedback('');

      var payload = {
        nombre_empresa: (document.getElementById('er-nombre')?.value || '').trim(),
        rfc: (document.getElementById('er-rfc')?.value || '').trim(),
        descripcion: (document.getElementById('er-desc')?.value || '').trim(),
        sitio_web: (document.getElementById('er-sitio')?.value || '').trim(),
        razon_social: ((document.getElementById('er-razon')?.value || '').trim()).toUpperCase(),
        regimen_fiscal: (document.getElementById('er-regimen')?.value || '').trim(),
        codigo_postal_fiscal: (document.getElementById('er-cp-fiscal')?.value || '').trim(),
        numero_casa: Number(document.getElementById('er-numero')?.value || 0),
        codigo_postal: Number(document.getElementById('er-cp')?.value || 0),
        calle: (document.getElementById('er-calle')?.value || '').trim(),
        ciudad: (document.getElementById('er-ciudad')?.value || '').trim(),
        provincia: (document.getElementById('er-provincia')?.value || '').trim(),
        pais: (document.getElementById('er-pais')?.value || '').trim() || 'Mexico',
        admin_nombre: (document.getElementById('er-admin-nombre')?.value || '').trim(),
        admin_apellido: (document.getElementById('er-admin-apellido')?.value || '').trim(),
        admin_apellido_materno: (document.getElementById('er-admin-apellido-m')?.value || '').trim(),
        admin_correo: (document.getElementById('er-admin-correo')?.value || '').trim(),
        admin_telefono: (document.getElementById('er-admin-tel')?.value || '').trim(),
      };

      var fActa = document.getElementById('er-doc-acta')?.files?.[0];
      var fIne = document.getElementById('er-doc-ine')?.files?.[0];
      var fConst = document.getElementById('er-doc-constancia')?.files?.[0];

      if (!payload.nombre_empresa || !payload.razon_social || !payload.regimen_fiscal || !payload.admin_nombre || !payload.admin_apellido || !payload.admin_correo) {
        reqSetFeedback('Completa empresa, datos fiscales y datos del administrador obligatorios.');
        return;
      }
      if (!/^\d{5}$/.test(payload.codigo_postal_fiscal)) {
        reqSetFeedback('El CP fiscal debe tener 5 digitos.');
        return;
      }
      if (!payload.numero_casa || !payload.calle || !payload.codigo_postal || !payload.ciudad || !payload.provincia) {
        reqSetFeedback('Completa la direccion de recoleccion.');
        return;
      }
      if (!fActa || !fIne || !fConst) {
        reqSetFeedback('Debes subir acta constitutiva, INE y constancia fiscal.');
        return;
      }
      if (!kycCompleted) {
        reqSetFeedback('Completa primero la verificacion biometrica del representante.');
        return;
      }

      if (reqSubmitBtn) {
        reqSubmitBtn.disabled = true;
        reqSubmitBtn.textContent = 'Enviando...';
      }

      try {
        if (!kycSnapshotDataUrl) {
          throw new Error('No se encontro selfie biometrica. Completa nuevamente la verificacion KYC.');
        }

        reqSetFeedback('Subiendo documentos...');
        var dActa = await uploadEmpresaDoc(fActa, 'ACTA_CONSTITUTIVA');
        var dIne = await uploadEmpresaDoc(fIne, 'INE_REPRESENTANTE');
        var dConst = await uploadEmpresaDoc(fConst, 'CONSTANCIA_FISCAL');
        // Politica de privacidad: selfie biometrica no se persiste en servidor.
        payload.documentos = [dActa, dIne, dConst];

        reqSetFeedback('Registrando solicitud...');
        var res = await fetch('/api/admin/empresas', {
          method: 'POST',
          credentials: 'include',
          headers: {
            'Content-Type': 'application/json',
            'x-public-company-request': '1',
            'x-csrf-token': getCsrfToken(),
          },
          body: JSON.stringify(payload),
        });
        var data = await res.json().catch(function(){ return {}; });

        if (!res.ok || !data.success) {
          throw new Error(data.error || 'No se pudo registrar la solicitud');
        }

        var solicitudId = Number(data.solicitudId || 0);
        if (solicitudId > 0) {
          var correoKyc = payload.admin_correo;
          reqSetFeedback('Guardando evidencia biometrica segura...');
          await uploadPrivateBiometricEvidence(solicitudId, correoKyc, kycSnapshotDataUrl);

          var startRes = await fetch('/api/register-empresa/kyc', {
            method: 'POST',
            credentials: 'include',
            headers: {
              'Content-Type': 'application/json',
              'x-public-company-request': '1',
              'x-csrf-token': getCsrfToken(),
            },
            body: JSON.stringify({
              solicitudId: solicitudId,
              correo: correoKyc,
              proveedor: 'manual_superusuario',
              payloadProveedor: {
                snapshotTaken: !!kycSnapshotDataUrl,
                evidenceStored: true,
              },
            }),
          });
          var startData = await startRes.json().catch(function(){ return {}; });
          if (!startRes.ok || !startData.success) {
            throw new Error(startData.error || 'No se pudo iniciar KYC de la solicitud.');
          }

          var finishRes = await fetch('/api/register-empresa/kyc', {
            method: 'PUT',
            credentials: 'include',
            headers: {
              'Content-Type': 'application/json',
              'x-public-company-request': '1',
              'x-csrf-token': getCsrfToken(),
            },
            body: JSON.stringify({
              solicitudId: solicitudId,
              correo: correoKyc,
              proveedor: 'manual_superusuario',
              estado: 'en_proceso',
              biometriaValida: null,
              documentoValido: null,
              fraudeSospecha: null,
              scoreComparacion: null,
              livenessScore: null,
              payloadProveedor: {
                mode: 'private_biometric_evidence',
                snapshotBytes: kycSnapshotDataUrl.length,
                pendingManualReview: true,
              },
            }),
          });
          var finishData = await finishRes.json().catch(function(){ return {}; });
          if (!finishRes.ok || !finishData.success) {
            throw new Error(finishData.error || 'No se pudo completar KYC de la solicitud.');
          }
        }

        closeEmpresaRequestModal();
        openModal({
          type: 'success',
          title: 'Solicitud enviada',
          message: 'Tu solicitud empresarial fue registrada. La validacion biometrica queda en revision segura por superusuario.',
          buttonText: 'Entendido',
        });
      } catch (err) {
        reqSetFeedback(err.message || 'Error al enviar la solicitud. Intenta de nuevo.');
      } finally {
        if (reqSubmitBtn) {
          reqSubmitBtn.disabled = false;
          reqSubmitBtn.textContent = 'Enviar solicitud';
        }
      }
    });
  }

}

initLoginPage();
document.addEventListener('astro:page-load', initLoginPage);
</script>

</AuthLayout>