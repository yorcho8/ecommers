---
// src/pages/[lang]/login.astro
import AuthLayout from "../../layouts/AuthLayout.astro";
export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}

const currentLang = "es";
const cspNonce = Astro.locals.cspNonce;
---

<AuthLayout title={`Iniciar Sesión - NEXUS`} currentLang={currentLang}>

<section class="login-section">
  <div class="bg-particles" aria-hidden="true">
    <span class="particle p1"></span>
    <span class="particle p2"></span>
    <span class="particle p3"></span>
    <span class="particle p4"></span>
    <span class="particle p5"></span>
    <span class="particle p6"></span>
    <span class="particle p7"></span>
    <span class="particle p8"></span>
  </div>

  <div class="login-container">
    <div class="login-header">
      <span class="login-logo-text">NEXUS</span>
      <h1 class="login-title">Iniciar Sesión</h1>
      <p class="login-subtitle">Accede a tu cuenta para continuar</p>
    </div>

    <form class="login-form" id="login-form" method="post" action="/api/login" autocomplete="off">
      <div class="form-group">
        <label for="correo" class="form-label">Correo electrónico</label>
        <div class="input-wrapper">
          <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M22 4L12 13 2 4"/>
          </svg>
          <input type="email" id="correo" name="correo" class="form-input" placeholder="tu@correo.com" required>
        </div>
      </div>

      <div class="form-group">
        <label for="contrasena" class="form-label">Contraseña</label>
        <div class="input-wrapper">
          <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          <input type="password" id="contrasena" name="contrasena" class="form-input" placeholder="••••••••" required>
          <button type="button" id="toggle-password" class="eye-toggle" aria-label="Mostrar contraseña">
            <svg id="eye-svg" class="eye-svg" width="32" height="32" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path id="eyelid-top" class="eyelid" d="M6,32 Q32,10 58,32" stroke="var(--eye-stroke)" stroke-width="3" fill="none" stroke-linecap="round"/>
              <path id="eyelid-bottom" class="eyelid" d="M6,32 Q32,54 58,32" stroke="var(--eye-stroke)" stroke-width="3" fill="none" stroke-linecap="round"/>
              <ellipse id="sclera" cx="32" cy="32" rx="18" ry="12" fill="#f0f0f0" stroke="var(--eye-stroke)" stroke-width="1.5"/>
              <circle id="iris" cx="32" cy="32" r="8" fill="var(--iris-color)"/>
              <circle id="pupil" cx="32" cy="32" r="3.8" fill="#0a0a0a"/>
              <circle id="reflection" cx="29" cy="29.5" r="2" fill="rgba(255,255,255,0.85)"/>
              <path id="eye-closed-line" class="eye-closed" d="M6,32 Q32,32 58,32" stroke="var(--eye-stroke)" stroke-width="3" fill="none" stroke-linecap="round" opacity="0"/>
              <path id="lashes" class="lashes" d="M12,24 L10,20 M22,17 L21,12 M32,14 L32,9 M42,17 L43,12 M52,24 L54,20" stroke="var(--eye-stroke)" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="form-options">
        <a href={`/${currentLang}/forgot-password`} class="forgot-link">¿Olvidaste tu contraseña?</a>
      </div>

      <button type="submit" class="btn-submit" id="submit-btn">
        <span class="btn-text">Iniciar Sesión</span>
        <svg class="btn-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>
    </form>

    <div class="login-divider">
      <span>o</span>
    </div>

    <div class="login-footer">
      <p>¿No tienes cuenta? <a href={`/${currentLang}/register`} class="register-link">Regístrate aquí</a></p>
      <p class="empresa-cta-row">¿Representas una empresa?
        <button type="button" id="open-empresa-modal" class="empresa-cta-link">Registrar solicitud empresarial</button>
      </p>
    </div>
  </div>

  <section id="empresa-request-modal" class="empresa-request-modal" hidden>
    <div id="empresa-request-overlay" class="empresa-request-overlay"></div>
    <article class="empresa-request-panel" role="dialog" aria-modal="true" aria-labelledby="empresa-request-title">
      <button id="empresa-request-close" class="empresa-request-close" type="button" aria-label="Cerrar">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <h2 id="empresa-request-title">Solicitud de registro de empresa</h2>
      <p class="empresa-request-subtitle">Completa los datos y documentos. El equipo superusuario revisara tu solicitud.</p>

      <form id="empresa-request-form" class="empresa-request-form" novalidate>
        <fieldset>
          <legend>Empresa</legend>
          <div class="empresa-grid">
            <label>Nombre comercial *<input id="er-nombre" type="text" required /></label>
            <label>RFC<input id="er-rfc" type="text" maxlength="13" /></label>
            <label>Sitio web<input id="er-sitio" type="url" /></label>
            <label class="empresa-col-full">Descripcion<input id="er-desc" type="text" /></label>
          </div>
        </fieldset>

        <fieldset>
          <legend>Datos fiscales SAT</legend>
          <div class="empresa-grid">
            <label class="empresa-col-full">Razon social *<input id="er-razon" type="text" required /></label>
            <label>Regimen fiscal *
              <select id="er-regimen" required>
                <option value="">Seleccionar...</option>
                <option value="601">601 - General de Ley Personas Morales</option>
                <option value="603">603 - Personas Morales con Fines no Lucrativos</option>
                <option value="606">606 - Arrendamiento</option>
                <option value="612">612 - Personas Fisicas con Actividades Empresariales</option>
                <option value="616">616 - Sin obligaciones fiscales</option>
                <option value="621">621 - Incorporacion Fiscal</option>
                <option value="622">622 - Actividades Agricolas, Ganaderas, Silvicolas y Pesqueras</option>
                <option value="625">625 - Actividades Empresariales por Plataformas</option>
                <option value="626">626 - RESICO</option>
              </select>
            </label>
            <label>CP fiscal *<input id="er-cp-fiscal" type="text" maxlength="5" pattern="[0-9]{5}" required /></label>
          </div>
        </fieldset>

        <fieldset>
          <legend>Administrador</legend>
          <div class="empresa-grid">
            <label>Nombre *<input id="er-admin-nombre" type="text" required /></label>
            <label>Apellido paterno *<input id="er-admin-apellido" type="text" required /></label>
            <label>Apellido materno<input id="er-admin-apellido-m" type="text" /></label>
            <label>Correo *<input id="er-admin-correo" type="email" required /></label>
            <label>Telefono<input id="er-admin-tel" type="tel" /></label>
          </div>
        </fieldset>

        <fieldset>
          <legend>Documentos obligatorios</legend>
          <div class="empresa-grid empresa-grid-files">
            <label>Acta constitutiva *<input id="er-doc-acta" type="file" accept=".pdf,.jpg,.jpeg,.png,.webp" required /></label>
            <label>INE representante *<input id="er-doc-ine" type="file" accept=".pdf,.jpg,.jpeg,.png,.webp" required /></label>
            <label>Constancia fiscal *<input id="er-doc-constancia" type="file" accept=".pdf,.jpg,.jpeg,.png,.webp" required /></label>
          </div>
        </fieldset>

        <fieldset>
          <legend>Direccion de recoleccion</legend>
          <div class="empresa-grid">
            <label>Numero exterior *<input id="er-numero" type="number" min="1" required /></label>
            <label>Codigo postal *<input id="er-cp" type="number" min="1" required /></label>
            <label class="empresa-col-full">Calle *<input id="er-calle" type="text" required /></label>
            <label>Ciudad *<input id="er-ciudad" type="text" required /></label>
            <label>Estado/Provincia *<input id="er-provincia" type="text" required /></label>
            <label>Pais *<input id="er-pais" type="text" value="Mexico" required /></label>
          </div>
        </fieldset>

        <fieldset>
          <legend>Verificacion biometrica del representante</legend>
          <div class="empresa-grid">
            <div class="empresa-col-full" style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
              <div>
                <p id="er-kyc-status" style="font-size:12px;color:rgba(255,255,255,0.72);margin:0;">
                  Estado KYC: pendiente
                </p>
                <small style="display:block;color:rgba(255,255,255,0.45);margin-top:4px;">
                  Debes completar la validacion con camara antes de enviar la solicitud.
                </small>
              </div>
              <button id="er-kyc-open" type="button" class="empresa-btn empresa-btn-primary">Iniciar verificacion</button>
            </div>
          </div>
        </fieldset>

        <p id="empresa-request-feedback" class="empresa-request-feedback" hidden></p>
        <div class="empresa-request-actions">
          <button id="empresa-request-cancel" type="button" class="empresa-btn empresa-btn-ghost">Cancelar</button>
          <button id="empresa-request-submit" type="submit" class="empresa-btn empresa-btn-primary">Enviar solicitud</button>
        </div>
      </form>
    </article>
  </section>

  <section id="login-modal" class="login-modal" hidden>
    <div id="login-modal-panel" class="login-modal-panel" role="dialog" aria-modal="true" aria-labelledby="login-modal-title">
      <button id="login-modal-close" class="login-modal-close" type="button" aria-label="Cerrar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <div class="modal-icon-wrap" id="modal-icon-wrap">
        <svg class="modal-icon modal-icon--success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
        <svg class="modal-icon modal-icon--error" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/></svg>
      </div>
      <p id="login-modal-kicker" class="login-modal-kicker">Estado</p>
      <h2 id="login-modal-title">Mensaje</h2>
      <p id="login-modal-message" class="login-modal-message"></p>
      <button id="login-modal-ok" class="login-modal-ok" type="button">Aceptar</button>
    </div>
  </section>

  <section id="empresa-kyc-modal" class="empresa-request-modal" hidden>
    <div id="empresa-kyc-overlay" class="empresa-request-overlay"></div>
    <article class="empresa-request-panel" role="dialog" aria-modal="true" aria-labelledby="empresa-kyc-title" style="max-width:640px;">
      <button id="empresa-kyc-close" class="empresa-request-close" type="button" aria-label="Cerrar">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <h2 id="empresa-kyc-title">Prueba biometrica del representante</h2>
      <p class="empresa-request-subtitle">Permite camara, centra tu rostro y toma una captura como evidencia de vida.</p>

      <div style="display:grid;gap:12px;">
        <video id="empresa-kyc-video" autoplay playsinline muted style="width:100%;min-height:220px;background:#0f131d;border:1px solid rgba(255,255,255,.12);border-radius:10px;object-fit:cover;"></video>
        <canvas id="empresa-kyc-canvas" hidden></canvas>
        <img id="empresa-kyc-preview" alt="Captura biometrica" hidden style="width:100%;max-height:220px;object-fit:cover;border-radius:10px;border:1px solid rgba(255,255,255,.12);" />
        <input id="empresa-kyc-file" type="file" accept="image/*" hidden />

        <label style="display:flex;align-items:center;gap:8px;font-size:12px;color:rgba(255,255,255,.75);">
          <input id="empresa-kyc-confirm" type="checkbox" />
          Confirmo que soy el representante legal y autorizo validacion biometrica.
        </label>

        <p id="empresa-kyc-feedback" class="empresa-request-feedback" hidden></p>

        <div class="empresa-request-actions" style="margin-top:0;">
          <button id="empresa-kyc-cancel" type="button" class="empresa-btn empresa-btn-ghost">Cancelar</button>
          <button id="empresa-kyc-upload" type="button" class="empresa-btn empresa-btn-ghost">Subir selfie</button>
          <button id="empresa-kyc-capture" type="button" class="empresa-btn empresa-btn-primary">Tomar captura</button>
          <button id="empresa-kyc-accept" type="button" class="empresa-btn empresa-btn-primary" disabled>Usar esta verificacion</button>
        </div>
      </div>
    </article>
  </section>
</section>

<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,700&family=Sora:wght@600;700;800&display=swap');

:root {
  --primary: #e8521a;
  --primary-light: #ff7e3a;
  --primary-glow: rgba(232, 82, 26, 0.35);
  --bg-deep: #0b0e17;
  --bg-card: #12151f;
  --bg-input: #1a1e2e;
  --border-subtle: rgba(255, 255, 255, 0.08);
  --border-focus: rgba(232, 82, 26, 0.6);
  --text-primary: #f3f5f9;
  --text-secondary: rgba(255, 255, 255, 0.55);
  --text-muted: rgba(255, 255, 255, 0.35);
  --eye-stroke: #b0b8c8;
  --iris-color: #e8521a;
  --radius: 14px;
  --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

.login-section {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-deep);
  background-image:
    radial-gradient(ellipse 80% 60% at 50% 0%, rgba(232, 82, 26, 0.08) 0%, transparent 60%),
    radial-gradient(ellipse 60% 50% at 80% 100%, rgba(99, 59, 230, 0.06) 0%, transparent 50%);
  padding: 1.5rem;
  position: relative;
  overflow: hidden;
  font-family: 'DM Sans', sans-serif;
  color: var(--text-primary);
}

.bg-particles { position: absolute; inset: 0; pointer-events: none; }
.particle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
  animation: float-particle linear infinite;
}
.p1 { width: 6px; height: 6px; background: var(--primary); top: 12%; left: 8%;  animation-duration: 18s; }
.p2 { width: 4px; height: 4px; background: #7c5cf7;        top: 28%; left: 82%; animation-duration: 22s; animation-delay: -4s; }
.p3 { width: 8px; height: 8px; background: var(--primary); top: 65%; left: 15%; animation-duration: 25s; animation-delay: -8s; }
.p4 { width: 5px; height: 5px; background: #5ca8f7;        top: 80%; left: 70%; animation-duration: 20s; animation-delay: -2s; }
.p5 { width: 3px; height: 3px; background: var(--primary-light); top: 45%; left: 92%; animation-duration: 16s; animation-delay: -6s; }
.p6 { width: 7px; height: 7px; background: #7c5cf7;        top: 90%; left: 40%; animation-duration: 28s; animation-delay: -10s; }
.p7 { width: 4px; height: 4px; background: var(--primary); top: 5%;  left: 55%; animation-duration: 21s; animation-delay: -3s; }
.p8 { width: 5px; height: 5px; background: #5ca8f7;        top: 55%; left: 35%; animation-duration: 19s; animation-delay: -7s; }

@keyframes float-particle {
  0%, 100% { transform: translateY(0) translateX(0) scale(1); }
  25%      { transform: translateY(-40px) translateX(20px) scale(1.2); }
  50%      { transform: translateY(-10px) translateX(-15px) scale(0.8); }
  75%      { transform: translateY(-50px) translateX(10px) scale(1.1); }
}

.login-container {
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  border-radius: 20px;
  box-shadow:
    0 4px 24px rgba(0, 0, 0, 0.3),
    0 40px 80px rgba(0, 0, 0, 0.25),
    inset 0 1px 0 rgba(255, 255, 255, 0.04);
  padding: 2.8rem 2.5rem 2.2rem;
  max-width: 420px;
  width: 100%;
  text-align: center;
  position: relative;
  z-index: 2;
  animation: card-enter 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
}

@keyframes card-enter {
  from { opacity: 0; transform: translateY(30px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

.login-header { margin-bottom: 2rem; animation: fade-up 0.5s 0.15s both; }

@keyframes fade-up {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}

.login-logo-text {
  display: inline-block;
  margin-bottom: 0.9rem;
  font-family: 'Sora', sans-serif;
  font-size: 1.7rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  color: var(--text-primary);
  text-shadow: 0 0 20px var(--primary-glow);
}

.login-title {
  font-family: 'Sora', sans-serif;
  font-size: 1.85rem;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 0.3rem;
  letter-spacing: -0.02em;
}

.login-subtitle {
  color: var(--text-secondary);
  font-size: 0.95rem;
  font-weight: 400;
}

.login-form { margin-bottom: 1.4rem; }

.form-group {
  margin-bottom: 1.3rem;
  text-align: left;
  animation: fade-up 0.5s both;
}
.form-group:nth-child(1) { animation-delay: 0.25s; }
.form-group:nth-child(2) { animation-delay: 0.35s; }

.form-label {
  display: block;
  margin-bottom: 0.45rem;
  font-weight: 500;
  font-size: 0.88rem;
  color: var(--text-secondary);
  letter-spacing: 0.02em;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.input-icon {
  position: absolute;
  left: 14px;
  color: var(--text-muted);
  pointer-events: none;
  transition: color var(--transition);
  z-index: 2;
}

.input-wrapper:focus-within .input-icon {
  color: var(--primary);
}

.form-input {
  width: 100%;
  padding: 0.8rem 0.8rem 0.8rem 2.8rem;
  background: var(--bg-input);
  border: 1.5px solid var(--border-subtle);
  border-radius: 10px;
  font-size: 0.95rem;
  font-family: 'DM Sans', sans-serif;
  color: var(--text-primary);
  transition: border-color var(--transition), box-shadow var(--transition), background var(--transition);
  outline: none;
}

.form-input::placeholder { color: var(--text-muted); }

.form-input:focus {
  border-color: var(--border-focus);
  background: rgba(232, 82, 26, 0.04);
  box-shadow: 0 0 0 3px rgba(232, 82, 26, 0.1);
}

.eye-toggle {
  position: absolute;
  right: 6px;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
  border-radius: 8px;
  transition: background var(--transition);
}

.eye-toggle:hover { background: rgba(255, 255, 255, 0.06); }

.eye-svg { overflow: visible; transition: transform 0.15s ease; }
.eye-svg .eyelid { transition: d 0.35s cubic-bezier(0.4, 0, 0.2, 1); }
.eye-svg #sclera { transition: ry 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s; }
.eye-svg #iris,
.eye-svg #pupil,
.eye-svg #reflection { transition: cx 0.08s ease-out, cy 0.08s ease-out, r 0.2s ease, opacity 0.3s; }
.eye-svg .lashes { transition: opacity 0.3s; }

.eye-svg.is-closed #sclera    { ry: 0; opacity: 0; }
.eye-svg.is-closed #iris      { opacity: 0; }
.eye-svg.is-closed #pupil     { opacity: 0; }
.eye-svg.is-closed #reflection { opacity: 0; }
.eye-svg.is-closed .lashes    { opacity: 0; }
.eye-svg.is-closed #eye-closed-line { opacity: 1 !important; }

.form-options {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 1.5rem;
  font-size: 0.85rem;
  animation: fade-up 0.5s 0.45s both;
}

.forgot-link {
  color: var(--primary-light);
  text-decoration: none;
  font-weight: 500;
  transition: color var(--transition);
}
.forgot-link:hover { color: #ffaa7a; text-decoration: underline; }

.btn-submit {
  width: 100%;
  padding: 0.85rem 1.2rem;
  border: none;
  border-radius: 12px;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #fff;
  font-family: 'Sora', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  position: relative;
  overflow: hidden;
  transition: transform 0.18s ease, box-shadow 0.25s ease;
  animation: fade-up 0.5s 0.55s both;
}

.btn-submit::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.15), transparent);
  opacity: 0;
  transition: opacity 0.25s;
}

.btn-submit:hover::before { opacity: 1; }
.btn-submit:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(232, 82, 26, 0.35);
}

.btn-submit:active { transform: translateY(0) scale(0.98); }

.btn-submit:disabled {
  opacity: 0.7;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

.btn-arrow { transition: transform 0.2s ease; }
.btn-submit:hover .btn-arrow { transform: translateX(3px); }

.login-divider {
  display: flex;
