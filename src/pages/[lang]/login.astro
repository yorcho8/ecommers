.login-modal.error .modal-icon-wrap { background: rgba(239, 68, 68, 0.12); border: 1.5px solid rgba(239, 68, 68, 0.3); }
.login-modal.error .modal-icon--error { display: block; color: #ef4444; }

.login-modal-kicker {
  margin: 0 0 6px;
  font-size: 0.82rem;
  text-transform: uppercase;
