---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FeedbackHub from "../../components/premium/FeedbackHub.astro";
import "../../styles/premium/theme.css";
import "../../styles/premium/feedback.css";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}

const { lang = "es" } = Astro.params;
---

<BaseLayout title="Quejas y sugerencias" currentLang={lang}>
  <FeedbackHub />
</BaseLayout>
