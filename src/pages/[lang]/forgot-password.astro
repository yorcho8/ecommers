---
import AuthLayout from '../../layouts/AuthLayout.astro';
export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}

const currentLang = "es";
---

<AuthLayout title={`Recuperar contrasena - NEXUS`} currentLang={currentLang}>
  <section class="recover-section">
    <div class="recover-card">
      <h1 class="recover-title">Recuperar contraseña</h1>
      <p class="recover-subtitle">Te enviaremos un código a tu correo para que puedas cambiarla.</p>

      <div id="step-email" class="step active">
        <label class="field-label" for="correo">Correo electrónico</label>
        <input id="correo" class="field-input" type="email" autocomplete="email" placeholder="tu@correo.com" />
        <button id="btn-send" class="btn btn--solid btn--full" type="button">Enviar código</button>
      </div>

      <div id="step-code" class="step" aria-hidden="true">
        <label class="field-label" for="codigo">Código de verificación</label>
        <input id="codigo" class="field-input" type="text" inputmode="numeric" maxlength="6" placeholder="123456" />
        <button id="btn-verify" class="btn btn--solid btn--full" type="button">Verificar código</button>
      </div>

      <div id="step-password" class="step" aria-hidden="true">
        <!-- Nueva contraseña -->
        <label class="field-label" for="nuevaContrasena">Nueva contraseña</label>
        <div class="input-wrap">
          <input id="nuevaContrasena" class="field-input" type="password" minlength="8" placeholder="Mínimo 8 caracteres" />
          <button type="button" class="eye-btn" data-target="nuevaContrasena" aria-label="Mostrar contraseña">
            <svg class="eye-icon eye-off" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
              <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
              <line x1="1" y1="1" x2="23" y2="23"/>
            </svg>
            <svg class="eye-icon eye-on" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>

        <!-- Confirmar contraseña -->
        <label class="field-label" for="confirmarContrasena">Confirmar contraseña</label>
        <div class="input-wrap">
          <input id="confirmarContrasena" class="field-input" type="password" minlength="8" placeholder="Repite la contraseña" />
          <button type="button" class="eye-btn" data-target="confirmarContrasena" aria-label="Mostrar contraseña">
            <svg class="eye-icon eye-off" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
              <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
              <line x1="1" y1="1" x2="23" y2="23"/>
            </svg>
            <svg class="eye-icon eye-on" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>

        <!-- Indicador de coincidencia -->
        <p id="match-hint" class="match-hint" aria-live="polite"></p>

        <button id="btn-save" class="btn btn--solid btn--full" type="button">Guardar nueva contraseña</button>
      </div>

      <p id="status" class="status" role="status" aria-live="polite"></p>

      <div class="recover-footer">
        <a href={`/${currentLang}/login`}>Volver a iniciar sesión</a>
      </div>
    </div>
  </section>

  <style>
    .recover-section {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    }

    .recover-card {
      width: 100%;
      max-width: 460px;
      background: #fff;
      border-radius: 14px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.12);
      padding: 2rem;
    }

    .recover-title {
      font-size: 2rem;
      line-height: 1.1;
      margin: 0;
      color: #202020;
    }

    .recover-subtitle {
      margin: 0.8rem 0 1.5rem;
      color: #5b616a;
      font-size: 0.98rem;
    }

    .step { display: none; gap: 0.75rem; }
    .step.active { display: grid; }

    .field-label {
      display: block;
      color: #2d2f34;
      font-weight: 600;
      margin: 0.45rem 0 0.2rem;
    }

    /* Wrapper para input + ojito */
    .input-wrap {
      position: relative;
      display: flex;
      align-items: center;
    }

    .input-wrap .field-input {
      padding-right: 2.8rem; /* espacio para el ojito */
    }

    .field-input {
      width: 100%;
      padding: 0.75rem 0.85rem;
      border: 2px solid #e2e6eb;
      border-radius: 10px;
      font-size: 1rem;
      box-sizing: border-box;
      transition: border-color 160ms ease;
    }

    .field-input:focus {
      outline: none;
      border-color: #ff6b35;
    }

    .field-input.field-error  { border-color: #c62828; }
    .field-input.field-ok     { border-color: #0b7a31; }

    .eye-btn {
      position: absolute;
      right: 0.7rem;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0;
      color: #9ca3af;
      display: flex;
      align-items: center;
      transition: color 160ms;
    }

    .eye-btn:hover { color: #ff6b35; }

    .match-hint {
      font-size: 0.88rem;
      min-height: 1.2rem;
      margin: 0;
    }

    .match-hint.ok    { color: #0b7a31; }
    .match-hint.error { color: #c62828; }

    .btn--full { margin-top: 0.9rem; width: 100%; }

    .status {
      min-height: 1.4rem;
      margin-top: 0.9rem;
      font-size: 0.95rem;
      color: #374151;
    }
    .status.error   { color: #c62828; }
    .status.success { color: #0b7a31; }

    .recover-footer {
      margin-top: 1.2rem;
      padding-top: 1rem;
      border-top: 1px solid #eceff3;
      text-align: center;
    }

    .recover-footer a {
      color: #ff6b35;
      text-decoration: none;
      font-weight: 600;
    }

    .recover-footer a:hover { text-decoration: underline; }
  </style>

  <script is:inline>
    (function () {
      const currentLang = document.documentElement.lang || 'es';

      const emailInput   = document.getElementById('correo');
      const codeInput    = document.getElementById('codigo');
      const passInput    = document.getElementById('nuevaContrasena');
      const confirmInput = document.getElementById('confirmarContrasena');
      const matchHint    = document.getElementById('match-hint');
      const statusEl     = document.getElementById('status');
      const btnSave      = document.getElementById('btn-save');

      const stepEmail    = document.getElementById('step-email');
      const stepCode     = document.getElementById('step-code');
      const stepPassword = document.getElementById('step-password');

      const btnSend   = document.getElementById('btn-send');
      const btnVerify = document.getElementById('btn-verify');

      const state = { correo: '', codigo: '' };

      /* ── Ojito ── */
      document.querySelectorAll('.eye-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          const input  = document.getElementById(btn.getAttribute('data-target'));
          const eyeOff = btn.querySelector('.eye-off');
          const eyeOn  = btn.querySelector('.eye-on');
          const show   = input.type === 'password';

          input.type        = show ? 'text' : 'password';
          eyeOff.style.display = show ? 'none'  : '';
          eyeOn.style.display  = show ? ''      : 'none';
        });
      });

      /* ── Validación en tiempo real ── */
      function validatePasswords() {
        const a = passInput.value;
        const b = confirmInput.value;

        // Resetear clases
        passInput.classList.remove('field-error', 'field-ok');
        confirmInput.classList.remove('field-error', 'field-ok');
        matchHint.className = 'match-hint';
        matchHint.textContent = '';

        if (!a && !b) return true; // sin input aún, no mostrar nada

        if (a.length > 0 && a.length < 8) {
          passInput.classList.add('field-error');
          matchHint.className = 'match-hint error';
          matchHint.textContent = 'Mínimo 8 caracteres.';
          return false;
        }

        if (b.length > 0 && a !== b) {
          confirmInput.classList.add('field-error');
          matchHint.className = 'match-hint error';
          matchHint.textContent = 'Las contraseñas no coinciden.';
          return false;
        }

        if (a.length >= 8 && a === b) {
          passInput.classList.add('field-ok');
          confirmInput.classList.add('field-ok');
          matchHint.className = 'match-hint ok';
          matchHint.textContent = '✓ Las contraseñas coinciden.';
          return true;
        }

        return false;
      }

      passInput.addEventListener('input', validatePasswords);
      confirmInput.addEventListener('input', validatePasswords);

      /* ── Helpers ── */
      function setStatus(msg, tone) {
        statusEl.textContent = msg || '';
        statusEl.classList.remove('error', 'success');
        if (tone) statusEl.classList.add(tone);
      }

      function setStep(step) {
        stepEmail.classList.remove('active');
        stepCode.classList.remove('active');
        stepPassword.classList.remove('active');
        if (step === 1) stepEmail.classList.add('active');
        if (step === 2) stepCode.classList.add('active');
        if (step === 3) stepPassword.classList.add('active');
      }

      async function callApi(payload) {
        const response = await fetch('/api/password-reset', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await response.json().catch(function () { return {}; });
        if (!response.ok) {
          throw new Error(data.error || 'No se pudo procesar la solicitud');
        }
        return data;
      }

      /* ── Step 1: enviar correo ── */
      btnSend.addEventListener('click', async function () {
        const correo = String(emailInput.value || '').trim().toLowerCase();
        if (!correo) { setStatus('Escribe tu correo.', 'error'); return; }

        btnSend.disabled = true;
        setStatus('Enviando código...', null);
        try {
          await callApi({ action: 'request', correo });
          state.correo = correo;
          setStep(2);
          setStatus('Si el correo existe, te enviamos un código de 6 dígitos.', 'success');
        } catch (e) {
          setStatus(e.message, 'error');
        } finally {
          btnSend.disabled = false;
        }
      });

      /* ── Step 2: verificar código ── */
      btnVerify.addEventListener('click', async function () {
        const codigo = String(codeInput.value || '').trim();
        if (!codigo) { setStatus('Ingresa el código que recibiste.', 'error'); return; }

        btnVerify.disabled = true;
        setStatus('Verificando código...', null);
        try {
          await callApi({ action: 'verify', correo: state.correo, codigo });
          state.codigo = codigo;
          setStep(3);
          setStatus('Código correcto. Elige una nueva contraseña.', 'success');
        } catch (e) {
          setStatus(e.message, 'error');
        } finally {
          btnVerify.disabled = false;
        }
      });

      /* ── Step 3: guardar contraseña ── */
      btnSave.addEventListener('click', async function () {
        const nuevaContrasena    = passInput.value;
        const confirmarContrasena = confirmInput.value;

        if (!nuevaContrasena || !confirmarContrasena) {
          setStatus('Completa ambos campos.', 'error'); return;
        }
        if (!validatePasswords()) {
          setStatus('Corrige los errores antes de continuar.', 'error'); return;
        }

        btnSave.disabled = true;
        setStatus('Actualizando contraseña...', null);
        try {
          await callApi({ action: 'confirm', correo: state.correo, codigo: state.codigo, nuevaContrasena });
          setStatus('Contraseña actualizada. Redirigiendo...', 'success');
          setTimeout(function () {
            window.location.href = '/' + currentLang + '/login';
          }, 1200);
        } catch (e) {
          setStatus(e.message, 'error');
        } finally {
          btnSave.disabled = false;
        }
      });
    })();
  </script>
</AuthLayout>