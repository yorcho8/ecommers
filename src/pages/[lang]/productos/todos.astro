---
import "../../../styles/brand-colors.css";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getTodosLosProductos } from "../../../lib/productos-service.js";

interface ProductItem {
  id: number;
  nombre: string;
  descripcion: string;
  precio: number;
  precioOriginal?: number | null;
  descuento?: { tipo: string; valor: number; porcentaje: number } | null;
  stock: number;
  imagen: string | null;
  categoria: string;
  categoriaId: number | null;
  empresaId?: number | null;
  empresaNombre?: string | null;
}

export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}
const currentLang = "es";
const cspNonce = Astro.locals?.cspNonce || "";

const sessionUserId =
  Number(Astro.locals?.user?.userId || 0) > 0
    ? Number(Astro.locals?.user?.userId)
    : null;

let products: ProductItem[] = [];
try {
  products = await getTodosLosProductos({ userId: sessionUserId });
} catch (error) {
  console.error("[productos/todos] Error cargando productos:", error);
}

const categories = Array.from(
  new Set(
    products
      .map((p) => String(p.categoria || "Sin categoria").trim())
      .filter(Boolean),
  ),
).sort((a, b) => a.localeCompare(b, "es"));

const fmtPrice = (value: number) =>
  Number(value || 0).toLocaleString("es-MX", {
    style: "currency",
    currency: "MXN",
  });

const resolveImageSrc = (src: string | null) => {
  if (!src)
    return "https://res.cloudinary.com/dfuzfdrat/image/upload/v1772744553/logob_pw3jsd.png";
  if (src.startsWith("http") || src.startsWith("/")) return src;
  return `/images/${src}`;
};
---

<BaseLayout
  title="Todos los productos | NEXUS"
  currentLang={currentLang}
  useAdminOffset={false}
>
  <div class="st-root">
    <main class="st-main">
      {/* ── Hero ── */}
      <div class="st-hero">
        <div class="st-hero__left">
          <h1 class="st-hero__title">Explora nuestro catálogo</h1>
          <p class="st-hero__sub">
            Encuentra lo que necesitas entre <strong>{products.length}</strong> productos
            disponibles
          </p>
        </div>
        <a href={`/${currentLang}/productos`} class="st-hero__back"
          >← Volver al carrusel</a
        >
      </div>

      {/* ── Search ── */}
      <div class="st-search-wrap">
        <div class="st-search-bar">
          <svg
            class="st-search-icon"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            ><circle cx="11" cy="11" r="8"></circle><path d="M21 21l-4.35-4.35"
            ></path></svg
          >
          <input
            id="productSearchInput"
            type="search"
            class="st-search-input"
            placeholder="¿Qué estás buscando?"
            autocomplete="off"
          />
          <span id="productsCounter" class="st-search-count"
            >{products.length}</span
          >
        </div>
        <button
          id="stFilterToggle"
          class="st-filter-btn"
          type="button"
          aria-expanded="false"
        >
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"></path></svg
          >
          Filtros
        </button>
      </div>

      {/* ── Filters ── */}
      <div id="stFilters" class="st-filters">
        <select
          id="filterCategory"
          class="st-select"
          aria-label="Filtrar por categoria"
        >
          <option value="all">Todas las categorías</option>
          {categories.map((cat) => <option value={cat}>{cat}</option>)}
        </select>
        <select
          id="filterDiscount"
          class="st-select"
          aria-label="Filtrar por descuento"
        >
          <option value="all">Con y sin descuento</option>
          <option value="with">Solo ofertas</option>
          <option value="without">Sin descuento</option>
        </select>
        <select
          id="filterStock"
          class="st-select"
          aria-label="Filtrar por stock"
        >
          <option value="all">Todos</option>
          <option value="in">Disponibles</option>
          <option value="out">Agotados</option>
        </select>
        <select
          id="sortProducts"
          class="st-select"
          aria-label="Ordenar productos"
        >
          <option value="relevance">Relevancia</option>
          <option value="price_asc">Precio: menor</option>
          <option value="price_desc">Precio: mayor</option>
          <option value="discount_desc">Mayor descuento</option>
          <option value="name_asc">A → Z</option>
        </select>
      </div>

      {/* ── Grid ── */}
      <div id="productsGrid" class="st-grid">
        {
          products.map((product) => (
            <article
              class={`st-card${product.descuento ? " has-deal" : ""}${product.stock <= 0 ? " is-oos" : ""}`}
              data-product-card
              data-product-name={product.nombre}
              data-product-category={product.categoria || ""}
              data-product-category-raw={product.categoria || "Sin categoria"}
              data-product-description={product.descripcion || ""}
              data-product-stock={product.stock}
              data-product-has-discount={product.descuento ? "1" : "0"}
              data-product-price={product.precio}
              data-product-discount-pct={
                product.descuento ? Math.round(product.descuento.porcentaje) : 0
              }
              data-search={`${product.nombre} ${product.descripcion} ${product.categoria}`.toLowerCase()}
            >
              <a
                href={`/${currentLang}/productos/detalle/${product.id}`}
                class="st-card__media"
              >
                <img
                  src={resolveImageSrc(product.imagen)}
                  alt={product.nombre}
                  loading="lazy"
                  decoding="async"
                />
                <div class="st-card__overlay">
                  <span class="st-card__overlay-text">Ver producto</span>
                </div>
                {product.descuento && (
                  <span class="st-card__deal-tag">
                    -{Math.round(product.descuento.porcentaje)}%
                  </span>
                )}
                {product.stock <= 0 && (
                  <span class="st-card__oos-tag">Agotado</span>
                )}
              </a>

              <div class="st-card__body">
                <span class="st-card__cat">
                  {product.categoria || "Sin categoria"}
                </span>
                <h2 class="st-card__name">
                  <a href={`/${currentLang}/productos/detalle/${product.id}`}>
                    {product.nombre}
                  </a>
                </h2>
                {product.empresaId && product.empresaNombre && (
                  <a
                    class="st-card__seller"
                    href={`/${currentLang}/empresas/${product.empresaId}`}
                  >
                    Vendido por {product.empresaNombre}
                  </a>
                )}
                <div class="st-card__price-row">
                  <div class="st-card__prices">
                    {Number(product.precioOriginal || product.precio) >
                      Number(product.precio) && (
                      <span class="st-card__was">
                        {fmtPrice(Number(product.precioOriginal || 0))}
                      </span>
                    )}
                    <span class="st-card__now">{fmtPrice(product.precio)}</span>
                  </div>
                  <button
                    type="button"
                    class="st-card__cart-btn"
                    data-action="add"
                    data-product-id={product.id}
                    data-product-name={product.nombre}
                    data-product-stock={product.stock}
                    disabled={product.stock <= 0}
                  >
                    <svg
                      width="15"
                      height="15"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <>
                        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
                        <line x1="3" y1="6" x2="21" y2="6" />
                        <path d="M16 10a4 4 0 01-8 0" />
                      </>
                    </svg>
                    <span>Agregar</span>
                  </button>
                </div>
              </div>
              <p class="st-card__feedback" data-feedback hidden />
            </article>
          ))
        }
      </div>

      <div id="productsEmpty" class="st-empty" hidden>
        <svg
          width="40"
          height="40"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          opacity="0.3"
          ><circle cx="11" cy="11" r="8"></circle><path d="M21 21l-4.35-4.35"
          ></path></svg
        >
        <p>Sin resultados</p>
        <span>Intenta con otro término de búsqueda</span>
      </div>

      <nav
        id="stPagination"
        class="st-pagination"
        aria-label="Paginacion de productos"
        hidden
      >
        <button id="stPrevPage" class="st-page-btn" type="button"
          >Anterior</button
        >
        <div id="stPaginationPages" class="st-page-numbers"></div>
        <button id="stNextPage" class="st-page-btn" type="button"
          >Siguiente</button
        >
      </nav>

      {/* ── Modal variantes ── */}
      <section id="variant-modal" class="st-modal-overlay" hidden>
        <div
          id="variant-panel"
          class="st-dialog"
          role="dialog"
          aria-modal="true"
        >
          <button
            id="variant-close"
            class="st-dialog__close"
            type="button"
            aria-label="Cerrar"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"></path></svg
            >
          </button>
          <div class="st-dialog__header">
            <div class="st-dialog__icon">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"
                ></path><line x1="3" y1="6" x2="21" y2="6"></line><path
                  d="M16 10a4 4 0 01-8 0"></path></svg
              >
            </div>
            <div>
              <p class="st-dialog__kicker">Paso 1 de 2</p>
              <h3 id="variant-product-name" class="st-dialog__title"></h3>
            </div>
          </div>
          <p class="st-dialog__hint" style="margin-bottom:12px">
            Selecciona una variante para continuar
          </p>
          <div id="variant-list" class="st-dialog__vars"></div>
          <div class="st-dialog__actions" style="margin-top:16px">
            <button
              id="variant-cancel"
              type="button"
              class="st-btn st-btn--ghost">Cancelar</button
            >
            <button id="variant-base" type="button" class="st-btn st-btn--ghost"
              >Sin variante</button
            >
            <button
              id="variant-confirm"
              type="button"
              class="st-btn st-btn--accent"
              disabled>Continuar →</button
            >
          </div>
        </div>
      </section>

      {/* ── Modal cantidad ── */}
      <section id="add-cart-modal" class="st-modal-overlay" hidden>
        <div
          id="add-cart-panel"
          class="st-dialog"
          role="dialog"
          aria-modal="true"
        >
          <button
            id="add-cart-close"
            class="st-dialog__close"
            type="button"
            aria-label="Cerrar"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"></path></svg
            >
          </button>
          <div class="st-dialog__header">
            <div class="st-dialog__icon">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"
                ></path><line x1="3" y1="6" x2="21" y2="6"></line><path
                  d="M16 10a4 4 0 01-8 0"></path></svg
              >
            </div>
            <div>
              <p class="st-dialog__kicker">Paso 2 de 2 — Confirmar</p>
              <h3 id="add-cart-title" class="st-dialog__title">
                Agregar al carrito
              </h3>
            </div>
          </div>
          <p id="add-cart-product" class="st-dialog__product"></p>
          <label class="st-dialog__label" for="add-cart-qty">Cantidad</label>
          <div class="st-dialog__qty-wrap">
            <button type="button" class="st-qty-btn" id="addCartQtyMinus"
              >−</button
            >
            <input
              id="add-cart-qty"
              class="st-dialog__qty"
              type="number"
              min="1"
              step="1"
              value="1"
            />
            <button type="button" class="st-qty-btn" id="addCartQtyPlus"
              >+</button
            >
          </div>
          <p id="add-cart-stock" class="st-dialog__hint"></p>
          <div class="st-dialog__actions">
            <button
              id="add-cart-cancel"
              type="button"
              class="st-btn st-btn--ghost">Cancelar</button
            >
            <button
              id="add-cart-confirm"
              type="button"
              class="st-btn st-btn--accent"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                ><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"
                ></path><line x1="3" y1="6" x2="21" y2="6"></line><path
                  d="M16 10a4 4 0 01-8 0"></path></svg
              >
              Confirmar
            </button>
          </div>
        </div>
      </section>

      {/* ── Modal cart popup ── */}
      <section id="cart-popup" class="st-modal-overlay" hidden>
        <div
          id="cart-popup-panel"
          class="st-dialog"
          role="dialog"
          aria-modal="true"
        >
          <button
            id="cart-popup-close"
            class="st-dialog__close"
            type="button"
            aria-label="Cerrar"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"></path></svg
            >
          </button>
          <div class="st-dialog__header">
            <div class="st-dialog__icon st-dialog__icon--success">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                ><polyline points="20 6 9 17 4 12"></polyline></svg
              >
            </div>
            <div>
              <p class="st-dialog__kicker">Carrito actualizado</p>
              <h3 id="cart-popup-title" class="st-dialog__title">
                Producto agregado
              </h3>
            </div>
          </div>
          <p id="cart-popup-message" class="st-dialog__product"></p>
          <p
            id="cart-popup-count"
            class="st-dialog__hint"
            style="font-weight:700"
          >
          </p>
          <div class="st-dialog__actions">
            <button
              id="cart-popup-continue"
              type="button"
              class="st-btn st-btn--ghost">Seguir comprando</button
            >
            <button
              id="cart-popup-go"
              type="button"
              class="st-btn st-btn--accent">Ir al carrito</button
            >
          </div>
        </div>
      </section>
    </main>
  </div>

  <style is:global>
    /* ═══════════════════════════════════════════════════
       STORE v3 — Premium store, isolated
       ═══════════════════════════════════════════════════ */

    .st-root {
      --st-bg: #0a0a0a;
      --st-s: #141414;
      --st-s2: #1c1c1e;
      --st-s3: #2c2c2e;
      --st-b: #2c2c2e;
      --st-b2: #3a3a3c;
      --st-t: #f5f5f7;
      --st-t2: #a1a1a6;
      --st-t3: #6e6e73;
      --st-accent: var(--brand-accent);
      --st-accent-soft: rgba(var(--brand-accent-rgb), 0.12);
      --st-accent-glow: rgba(var(--brand-accent-rgb), 0.25);
      --st-danger: #ff453a;
      --st-success: #30d158;
      --st-r: 16px;
      --st-r-sm: 10px;

      background: var(--st-bg) !important;
      min-height: 100vh;
      position: relative;
      z-index: 1;
    }

    html:not(.dark) .st-root {
      --st-bg: #f5f5f7;
      --st-s: #ffffff;
      --st-s2: #f2f2f7;
      --st-s3: #e5e5ea;
      --st-b: #d1d1d6;
      --st-b2: #c7c7cc;
      --st-t: #1d1d1f;
      --st-t2: #6e6e73;
      --st-t3: #aeaeb2;
    }

    /* ── NUCLEAR RESET ── */
    .st-root,
    .st-root *,
    .st-root *::before,
    .st-root *::after {
      box-sizing: border-box;
    }

    .st-root .st-main h1,
    .st-root .st-main h2,
    .st-root .st-main h3,
    .st-root .st-main h4,
    .st-root .st-main p,
    .st-root .st-main span,
    .st-root .st-main a,
    .st-root .st-main button,
    .st-root .st-main select,
    .st-root .st-main input,
    .st-root .st-main label {
      font-family:
        "Inter",
        -apple-system,
        "SF Pro Display",
        system-ui,
        sans-serif !important;
      text-transform: none !important;
      letter-spacing: normal !important;
      text-shadow: none !important;
      -webkit-text-fill-color: unset;
    }

    .st-root .st-main {
      max-width: 1200px;
      margin: 0 auto;
      padding: 120px 24px 56px;
      color: var(--st-t);
      font-family:
        "Inter",
        -apple-system,
        "SF Pro Display",
        system-ui,
        sans-serif;
      background:
        radial-gradient(
          circle at 0% -8%,
          rgba(var(--brand-accent-rgb), 0.16),
          transparent 36%
        ),
        radial-gradient(
          circle at 100% 0%,
          rgba(59, 130, 246, 0.14),
          transparent 34%
        );
    }

    /* ── Hero ── */
    .st-root .st-hero {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 28px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--st-b);
      flex-wrap: wrap;
    }

    .st-root .st-hero__title {
      font-size: clamp(1.4rem, 2.8vw, 1.9rem) !important;
      font-weight: 800 !important;
      margin: 0 !important;
      padding: 0 !important;
      line-height: 1.15 !important;
      color: var(--st-t) !important;
      background: none !important;
      -webkit-text-fill-color: var(--st-t) !important;
    }

    .st-root .st-hero__sub {
      margin: 4px 0 0;
      font-size: 0.85rem;
      color: var(--st-t2);
      font-weight: 500;
    }

    .st-root .st-hero__sub strong {
      color: var(--st-accent);
      font-weight: 800;
    }

    .st-root .st-hero__back {
      font-size: 0.78rem;
      color: var(--st-t3);
      text-decoration: none;
      font-weight: 600;
      white-space: nowrap;
      padding: 8px 14px;
      border: 1px solid var(--st-b);
      border-radius: var(--st-r-sm);
      transition: all 0.15s;
    }

    .st-root .st-hero__back:hover {
      border-color: var(--st-accent);
      color: var(--st-accent);
    }

    /* ── Search ── */
    .st-root .st-search-wrap {
      display: flex;
      gap: 10px;
      margin-bottom: 18px;
      align-items: stretch;
    }

    .st-root .st-search-bar {
      flex: 1;
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0 18px;
      height: 52px;
      background: var(--st-s);
      border: 1.5px solid var(--st-b);
      border-radius: 16px;
      transition:
        border-color 0.2s,
        box-shadow 0.2s;
      box-shadow: 0 10px 26px rgba(2, 6, 23, 0.16);
    }

    .st-root .st-search-bar:focus-within {
      border-color: var(--st-accent);
      box-shadow:
        0 0 0 4px var(--st-accent-soft),
        0 12px 32px rgba(122, 37, 50, 0.08);
    }

    .st-root .st-search-icon {
      color: var(--st-t3);
      flex-shrink: 0;
    }
    .st-root .st-search-bar:focus-within .st-search-icon {
      color: var(--st-accent);
    }

    .st-root .st-search-input {
      flex: 1;
      border: none;
      background: transparent;
      color: var(--st-t);
      font-size: 0.95rem;
      font-weight: 500;
      outline: none;
    }

    .st-root .st-search-input::placeholder {
      color: var(--st-t3);
    }

    .st-root .st-search-count {
      font-size: 0.72rem;
      font-weight: 700;
      color: var(--st-accent);
      background: var(--st-accent-soft);
      padding: 4px 10px;
      border-radius: 999px;
      white-space: nowrap;
    }

    .st-root .st-filter-btn {
      display: flex;
      align-items: center;
      gap: 6px;
      height: 50px;
      padding: 0 18px;
      background: var(--st-s);
      border: 1.5px solid var(--st-b);
      border-radius: 14px;
      color: var(--st-t2);
      font-size: 0.82rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.15s;
      box-shadow: 0 8px 18px rgba(2, 6, 23, 0.12);
    }

    .st-root .st-filter-btn:hover {
      border-color: var(--st-t3);
      color: var(--st-t);
    }
    .st-root .st-filter-btn[aria-expanded="true"] {
      border-color: var(--st-accent);
      color: var(--st-accent);
      background: var(--st-accent-soft);
    }

    /* ── Filters ── */
    .st-root .st-filters {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      margin-bottom: 20px;
      padding: 14px;
      background: linear-gradient(145deg, var(--st-s), var(--st-s2));
      border: 1px solid var(--st-b);
      border-radius: 14px;
