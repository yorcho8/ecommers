    const cartPopupTitleEl = document.getElementById("cart-popup-title");
    const cartPopupMessageEl = document.getElementById("cart-popup-message");
    const cartPopupCountEl = document.getElementById("cart-popup-count");
    const cartPopupGoEl = document.getElementById("cart-popup-go");
    const cartPopupContinueEl = document.getElementById("cart-popup-continue");
    const cartPopupCloseEl = document.getElementById("cart-popup-close");
    const addCartModalEl = document.getElementById("add-cart-modal");
    const addCartPanelEl = document.getElementById("add-cart-panel");
    const addCartCloseEl = document.getElementById("add-cart-close");
    const addCartCancelEl = document.getElementById("add-cart-cancel");
    const addCartConfirmEl = document.getElementById("add-cart-confirm");
    const addCartQtyEl = document.getElementById("add-cart-qty");
    const addCartProductEl = document.getElementById("add-cart-product");
    const addCartStockEl = document.getElementById("add-cart-stock");
    const paginationEl = document.getElementById("stPagination");
    const prevPageBtnEl = document.getElementById("stPrevPage");
    const nextPageBtnEl = document.getElementById("stNextPage");
    const pageNumbersEl = document.getElementById("stPaginationPages");

    let pendingAddAction = null;
    let selectedVarianteId = null;
    let currentPage = 1;
    const pageSize = 12;

    const cards = Array.from(document.querySelectorAll("[data-product-card]"));
    const total = cards.length;

    /* ── Filter toggle ── */
    const stFilterBtn = document.getElementById("stFilterToggle");
    const stFilterPanel = document.getElementById("stFilters");
    if (stFilterBtn && stFilterPanel) {
      if (window.innerWidth <= 640) {
        stFilterPanel.hidden = true;
        stFilterBtn.setAttribute("aria-expanded", "false");
      } else {
        stFilterPanel.hidden = false;
      }
      stFilterBtn.addEventListener("click", function () {
        var open = stFilterPanel.hidden;
        stFilterPanel.hidden = !open;
        stFilterBtn.setAttribute("aria-expanded", String(open));
      });
    }

    /* ── Qty stepper ── */
    var qtyMinus = document.getElementById("addCartQtyMinus");
    var qtyPlus = document.getElementById("addCartQtyPlus");
    if (qtyMinus && addCartQtyEl)
      qtyMinus.addEventListener("click", function () {
        addCartQtyEl.value = Math.max(1, Number(addCartQtyEl.value || 1) - 1);
      });
    if (qtyPlus && addCartQtyEl)
      qtyPlus.addEventListener("click", function () {
        var max = Number(addCartQtyEl.max || 999);
        addCartQtyEl.value = Math.min(max, Number(addCartQtyEl.value || 1) + 1);
      });

    function normalizeText(value) {
      return String(value || "")
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "");
    }

    function countOccurrences(text, term) {
      if (!term) return 0;
      var count = 0,
        index = 0;
      while (true) {
        index = text.indexOf(term, index);
        if (index === -1) break;
        count += 1;
        index += Math.max(1, term.length);
      }
      return count;
    }

    var items = cards
      .filter(function (card) {
        return card instanceof HTMLElement;
      })
      .map(function (card, index) {
        return {
          card: card,
          index: index,
          name: normalizeText(card.dataset.productName || ""),
          category: normalizeText(card.dataset.productCategory || ""),
          categoryRaw: String(
            card.dataset.productCategoryRaw || "Sin categoria",
          ),
          description: normalizeText(card.dataset.productDescription || ""),
          full: normalizeText(card.dataset.search || ""),
          stock: Number(card.dataset.productStock || 0),
          hasDiscount: String(card.dataset.productHasDiscount || "0") === "1",
          price: Number(card.dataset.productPrice || 0),
          discountPct: Number(card.dataset.productDiscountPct || 0),
        };
      });

    function calculateScore(item, terms) {
      var score = 0;
      var fullQuery = terms.join(" ");
      if (fullQuery) {
        if (item.name.includes(fullQuery)) score += 60;
        if (item.full.includes(fullQuery)) score += 25;
      }
      for (var i = 0; i < terms.length; i++) {
        var term = terms[i];
        var nameHits = countOccurrences(item.name, term);
        var categoryHits = countOccurrences(item.category, term);
        var descHits = countOccurrences(item.description, term);
        if (nameHits + categoryHits + descHits === 0) return -1;
        score += nameHits * 12 + categoryHits * 7 + descHits * 4;
        if (item.name.startsWith(term)) score += 18;
        if (item.category.startsWith(term)) score += 10;
      }
      return score;
    }

    function renderPagination(totalFiltered, totalPages) {
      if (!(paginationEl instanceof HTMLElement)) return;
      if (!(prevPageBtnEl instanceof HTMLButtonElement)) return;
      if (!(nextPageBtnEl instanceof HTMLButtonElement)) return;
      if (!(pageNumbersEl instanceof HTMLElement)) return;

      if (totalFiltered <= pageSize) {
        paginationEl.hidden = true;
        pageNumbersEl.innerHTML = "";
        return;
      }

      paginationEl.hidden = false;
      prevPageBtnEl.disabled = currentPage <= 1;
      nextPageBtnEl.disabled = currentPage >= totalPages;

      const windowSize = 5;
      const start = Math.max(1, currentPage - Math.floor(windowSize / 2));
      const end = Math.min(totalPages, start + windowSize - 1);
      const normalizedStart = Math.max(1, end - windowSize + 1);

      let html = "";
      for (let p = normalizedStart; p <= end; p += 1) {
        html += `<button class="st-page-number${p === currentPage ? " is-active" : ""}" data-page="${p}" type="button">${p}</button>`;
      }
      pageNumbersEl.innerHTML = html;
    }

    function applySearchFilter() {
      var raw = String(
        searchInput instanceof HTMLInputElement ? searchInput.value : "",
      ).trim();
      var q = normalizeText(raw);
      var terms = q.split(/\s+/).filter(Boolean);
      var selectedCategory =
        categoryFilterEl instanceof HTMLSelectElement
          ? categoryFilterEl.value
          : "all";
      var selectedDiscount =
        discountFilterEl instanceof HTMLSelectElement
          ? discountFilterEl.value
          : "all";
      var selectedStock =
        stockFilterEl instanceof HTMLSelectElement
          ? stockFilterEl.value
          : "all";
      var selectedSort =
        sortProductsEl instanceof HTMLSelectElement
          ? sortProductsEl.value
          : "relevance";

      var ranked = items.map(function (item) {
        return { item: item, score: 0 };
      });
      if (terms.length) {
        ranked = items
          .map(function (item) {
            return { item: item, score: calculateScore(item, terms) };
          })
          .filter(function (e) {
            return e.score >= 0;
          })
          .sort(function (a, b) {
            return b.score !== a.score
              ? b.score - a.score
              : a.item.index - b.item.index;
          });
      }

      ranked = ranked.filter(function (e) {
        if (
          selectedCategory !== "all" &&
          e.item.categoryRaw !== selectedCategory
        )
          return false;
        if (selectedDiscount === "with" && !e.item.hasDiscount) return false;
        if (selectedDiscount === "without" && e.item.hasDiscount) return false;
        if (selectedStock === "in" && !(e.item.stock > 0)) return false;
        if (selectedStock === "out" && e.item.stock > 0) return false;
        return true;
      });

      if (selectedSort === "price_asc")
        ranked.sort(function (a, b) {
          return a.item.price - b.item.price;
        });
      else if (selectedSort === "price_desc")
        ranked.sort(function (a, b) {
          return b.item.price - a.item.price;
        });
      else if (selectedSort === "discount_desc")
        ranked.sort(function (a, b) {
          return b.item.discountPct - a.item.discountPct;
        });
      else if (selectedSort === "name_asc")
        ranked.sort(function (a, b) {
          return a.item.name.localeCompare(b.item.name, "es");
        });
      else if (!terms.length)
        ranked.sort(function (a, b) {
          return a.item.index - b.item.index;
        });

      var totalFiltered = ranked.length;
      var totalPages = Math.max(1, Math.ceil(totalFiltered / pageSize));
      if (currentPage > totalPages) currentPage = totalPages;
      if (currentPage < 1) currentPage = 1;

      var sliceStart = (currentPage - 1) * pageSize;
      var sliceEnd = sliceStart + pageSize;
      var pageEntries = ranked.slice(sliceStart, sliceEnd);

      var rankPosition = new Map(
        pageEntries.map(function (e, idx) {
          return [e.item.card, idx];
        }),
      );
      var visible = 0;

      items.forEach(function (entry) {
        var pos = rankPosition.get(entry.card);
        var match = pos != null;
        entry.card.style.display = match ? "" : "none";
        entry.card.style.order = match ? String(pos) : "9999";
        visible += match ? 1 : 0;
      });

      if (counterEl) counterEl.textContent = `${totalFiltered}/${total}`;
      if (emptyEl) emptyEl.hidden = visible > 0;
      renderPagination(totalFiltered, totalPages);
    }

    searchInput?.addEventListener("input", function () {
      currentPage = 1;
      applySearchFilter();
    });
    categoryFilterEl?.addEventListener("change", function () {
      currentPage = 1;
      applySearchFilter();
    });
    discountFilterEl?.addEventListener("change", function () {
      currentPage = 1;
      applySearchFilter();
    });
    stockFilterEl?.addEventListener("change", function () {
      currentPage = 1;
      applySearchFilter();
    });
    sortProductsEl?.addEventListener("change", function () {
      currentPage = 1;
      applySearchFilter();
    });

    prevPageBtnEl?.addEventListener("click", function () {
      if (currentPage <= 1) return;
      currentPage -= 1;
      applySearchFilter();
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    nextPageBtnEl?.addEventListener("click", function () {
      currentPage += 1;
      applySearchFilter();
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    pageNumbersEl?.addEventListener("click", function (event) {
      var target = event.target;
      if (!(target instanceof HTMLElement)) return;
      var btn = target.closest("[data-page]");
      if (!(btn instanceof HTMLButtonElement)) return;
      var page = Number(btn.dataset.page || 1);
      if (!Number.isFinite(page) || page <= 0) return;
      currentPage = page;
      applySearchFilter();
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    applySearchFilter();

    /* URL search param */
    try {
      var urlSearch = new URL(location.href).searchParams.get("busqueda");
      if (urlSearch && searchInput) {
        searchInput.value = urlSearch;
        applySearchFilter();
      }
    } catch (e) {}

    function setCardFeedback(card, message, type) {
      if (!(card instanceof HTMLElement)) return;
      var feedback = card.querySelector("[data-feedback]");
      if (!(feedback instanceof HTMLElement)) return;
      feedback.hidden = false;
      feedback.textContent = message;
      feedback.className = "st-card__feedback " + (type || "ok");
      setTimeout(function () {
        feedback.hidden = true;
      }, 2200);
    }

    async function addToCart(productId, cantidad, varianteId) {
      var response = await fetch("/api/carrito", {
        method: "POST",
        credentials: "include",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          productoId: productId,
          cantidad: cantidad || 1,
          varianteId: varianteId || null,
        }),
      });
      var data = await response.json().catch(function () {
        return {};
      });
      return { response: response, data: data };
    }

    async function getCartSummary() {
      var response = await fetch("/api/carrito", {
        method: "GET",
        credentials: "include",
      });
      var data = await response.json().catch(function () {
        return {};
      });
      return {
        ok: response.ok && !!data?.success,
        totalItems: Number(data?.summary?.totalItems || 0),
      };
    }

    /* ── Variant modal ── */
    var variantModalEl = document.getElementById("variant-modal");
    var variantPanelEl = document.getElementById("variant-panel");
    var variantTitleEl = document.getElementById("variant-product-name");
    var variantListEl = document.getElementById("variant-list");
    var variantCloseEl = document.getElementById("variant-close");
    var variantCancelEl = document.getElementById("variant-cancel");
    var variantConfirmEl = document.getElementById("variant-confirm");

    function continueWithoutVariant() {
      if (!pendingAddAction) return;
      selectedVarianteId = null;
      closeVariantModal();
      setTimeout(function () {
        openAddCartModal(pendingAddAction);
      }, 180);
    }

    function openVariantModal(opts) {
      selectedVarianteId = null;
      pendingAddAction = opts;
      if (variantTitleEl) variantTitleEl.textContent = opts.productName;
      if (variantListEl)
        variantListEl.innerHTML =
          '<p class="variant-loading">Cargando variantes…</p>';
      if (variantConfirmEl) variantConfirmEl.disabled = true;

      variantModalEl.hidden = false;
      variantModalEl.classList.add("is-open");
      setTimeout(function () {
        if (variantPanelEl) variantPanelEl.classList.add("is-open");
      }, 10);

      fetch("/api/productos/" + opts.productId + "/variantes")
        .then(function (r) {
          return r.json();
        })
        .then(function (data) {
          if (!variantListEl) return;
          if (!data.success || !data.variantes.length) {
            variantListEl.innerHTML =
              '<p class="variant-loading">Sin variantes. Continuando...</p>';
            continueWithoutVariant();
            return;
          }
          variantListEl.innerHTML = "";
          
          // Add Base Product as the first option
          var baseBtn = document.createElement("button");
          baseBtn.type = "button";
          baseBtn.className = "variant-chip active"; // pre-selected by default
          baseBtn.innerHTML = '<span class="vc-body"><span class="vc-desc">Producto Base (Original)</span></span>';
          baseBtn.addEventListener("click", function () {
            variantListEl.querySelectorAll(".variant-chip").forEach(function (b) {
              b.classList.remove("active");
            });
            this.classList.add("active");
            selectedVarianteId = null;
            if (variantConfirmEl) variantConfirmEl.disabled = false;
          });
          variantListEl.appendChild(baseBtn);
          selectedVarianteId = null; // pre-select logic
          if (variantConfirmEl) variantConfirmEl.disabled = false;

          data.variantes.forEach(function (v) {
            var btn = document.createElement("button");
            btn.type = "button";
            btn.className = "variant-chip";
            btn.dataset.varianteId = String(v.id);
            btn.innerHTML =
              '<span class="vc-body"><span class="vc-desc">' +
              v.descripcion +
              "</span></span>" +
              '<span class="vc-right">' +
              (v.precio != null
                ? '<span class="vc-price">$' +
                  Number(v.precio).toLocaleString("es-MX", {
                    minimumFractionDigits: 2,
                  }) +
                  "</span>"
                : "") +
              "</span>";
            btn.addEventListener("click", function () {
              variantListEl
                .querySelectorAll(".variant-chip")
                .forEach(function (b) {
                  b.classList.remove("active");
                });
              this.classList.add("active");
              selectedVarianteId = Number(this.dataset.varianteId);
              if (variantConfirmEl) variantConfirmEl.disabled = false;
            });
            variantListEl.appendChild(btn);
          });
        })
        .catch(function () {
          if (variantListEl)
            variantListEl.innerHTML =
              '<p class="variant-loading">Error cargando variantes.</p>';
        });
    }

    function closeVariantModal() {
      if (!variantModalEl || !variantPanelEl) return;
      variantPanelEl.classList.remove("is-open");
      setTimeout(function () {
        variantModalEl.classList.remove("is-open");
        variantModalEl.hidden = true;
      }, 160);
    }

    variantCloseEl?.addEventListener("click", closeVariantModal);
    variantCancelEl?.addEventListener("click", closeVariantModal);
    document
      .getElementById("variant-base")
      ?.addEventListener("click", continueWithoutVariant);
    variantModalEl?.addEventListener("click", function (e) {
      if (e.target === variantModalEl) closeVariantModal();
    });
    variantConfirmEl?.addEventListener("click", function () {
      if (!pendingAddAction || selectedVarianteId == null) return;
      closeVariantModal();
      setTimeout(function () {
        openAddCartModal(pendingAddAction);
      }, 180);
    });

    /* ── Add cart modal ── */
    function openAddCartModal(opts) {
      if (!(addCartModalEl instanceof HTMLElement)) return;
      pendingAddAction = opts;
      if (addCartProductEl) addCartProductEl.textContent = opts.productName;
      if (addCartStockEl)
        addCartStockEl.textContent = opts.stock + " disponibles";
      if (addCartQtyEl instanceof HTMLInputElement) {
        addCartQtyEl.value = "1";
        addCartQtyEl.max = String(Math.max(1, Number(opts.stock || 1)));
      }
      if (addCartConfirmEl instanceof HTMLButtonElement) {
        addCartConfirmEl.textContent =
          opts.action === "buy" ? "Confirmar e ir a pagar" : "Confirmar";
      }

      addCartModalEl.hidden = false;
      addCartModalEl.classList.add("is-open");
      setTimeout(function () {
        if (addCartPanelEl) addCartPanelEl.classList.add("is-open");
        if (addCartQtyEl) {
          addCartQtyEl.focus();
          addCartQtyEl.select();
        }
      }, 10);
    }

    function closeAddCartModal() {
      if (!(addCartModalEl instanceof HTMLElement)) return;
      if (addCartPanelEl) addCartPanelEl.classList.remove("is-open");
      setTimeout(function () {
        addCartModalEl.classList.remove("is-open");
        addCartModalEl.hidden = true;
      }, 160);
    }

    addCartCloseEl?.addEventListener("click", closeAddCartModal);
    addCartCancelEl?.addEventListener("click", closeAddCartModal);
    addCartModalEl?.addEventListener("click", function (e) {
      if (e.target === addCartModalEl) closeAddCartModal();
    });

    addCartConfirmEl?.addEventListener("click", async function () {
      if (!pendingAddAction) return;
      if (!(addCartQtyEl instanceof HTMLInputElement)) return;
      var cantidad = Number(addCartQtyEl.value || 1);
      var stock = Number(pendingAddAction.stock || 0);

      if (!Number.isFinite(cantidad) || cantidad <= 0) {
        if (addCartStockEl)
          addCartStockEl.textContent = "Ingresa una cantidad válida.";
        return;
      }
      if (stock > 0 && cantidad > stock) {
        if (addCartStockEl)
          addCartStockEl.textContent =
            "No puedes agregar más de " + stock + ".";
        return;
      }

      var action = pendingAddAction.action;
      var productName = pendingAddAction.productName;
      var productId = Number(pendingAddAction.productId);

      if (addCartConfirmEl instanceof HTMLButtonElement) {
        addCartConfirmEl.disabled = true;
        addCartConfirmEl.textContent = "Agregando…";
      }

      try {
        var result = await addToCart(productId, cantidad, selectedVarianteId);
        if (result.response.status === 401) {
          closeAddCartModal();
          setTimeout(function () {
            window.location.href = "/" + currentLang + "/login";
          }, 250);
          return;
        }
        if (!result.response.ok || !result.data?.success) {
          if (addCartStockEl)
            addCartStockEl.textContent =
              result.data?.error || "No se pudo agregar.";
          return;
        }

        closeAddCartModal();
        var summary = await getCartSummary();
        openCartPopup({
          productName: productName,
          totalItems: summary.totalItems,
          buyMode: action === "buy",
        });
      } catch (err) {
        if (addCartStockEl) addCartStockEl.textContent = "Error de red.";
      } finally {
        if (addCartConfirmEl instanceof HTMLButtonElement) {
          addCartConfirmEl.disabled = false;
          addCartConfirmEl.innerHTML =
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg> Confirmar';
        }
      }
    });

    /* ── Cart popup ── */
    function openCartPopup(opts) {
      if (!(cartPopupEl instanceof HTMLElement)) return;
      if (cartPopupTitleEl)
        cartPopupTitleEl.textContent = opts.buyMode
          ? "Listo para comprar"
          : "Producto agregado";
      if (cartPopupMessageEl)
        cartPopupMessageEl.textContent =
          opts.productName + " ya está en tu carrito.";
      if (cartPopupCountEl)
        cartPopupCountEl.textContent =
          "Tienes " +
          opts.totalItems +
          " producto" +
          (opts.totalItems === 1 ? "" : "s") +
          " en tu carrito.";
      if (cartPopupGoEl instanceof HTMLButtonElement)
        cartPopupGoEl.textContent = opts.buyMode
          ? "Ir a pagar"
          : "Ir al carrito";

      cartPopupEl.hidden = false;
      cartPopupEl.classList.add("is-open");
      setTimeout(function () {
        if (cartPopupPanelEl) cartPopupPanelEl.classList.add("is-open");
      }, 10);
    }

    function closeCartPopup() {
      if (!(cartPopupEl instanceof HTMLElement)) return;
      if (cartPopupPanelEl) cartPopupPanelEl.classList.remove("is-open");
      setTimeout(function () {
        cartPopupEl.classList.remove("is-open");
        cartPopupEl.hidden = true;
      }, 160);
    }

    cartPopupCloseEl?.addEventListener("click", closeCartPopup);
    cartPopupContinueEl?.addEventListener("click", closeCartPopup);
    cartPopupEl?.addEventListener("click", function (e) {
      if (e.target === cartPopupEl) closeCartPopup();
    });
    cartPopupGoEl?.addEventListener("click", function () {
      window.location.href = "/" + currentLang + "/carrito";
    });

    /* ── Delegated click ── */
    productsGrid?.addEventListener("click", async function (event) {
      var target = event.target;
      if (!(target instanceof Element)) return;
      var button = target.closest("button[data-action][data-product-id]");
      if (!(button instanceof HTMLButtonElement)) return;
      var card = button.closest("[data-product-card]");
      if (!(card instanceof HTMLElement)) return;

      var action = String(button.dataset.action || "");
      var productId = Number(button.dataset.productId);
      var productName = String(button.dataset.productName || "Producto");
      var stock = Number(button.dataset.productStock || 0);
      if (!Number.isFinite(productId) || productId <= 0) return;

      if (!Number.isFinite(stock) || stock <= 0) {
        setCardFeedback(card, "Sin stock disponible", "error");
        return;
      }

      openVariantModal({
        productId: productId,
        productName: productName,
        stock: stock,
        action: action,
      });
    });
  </script>

