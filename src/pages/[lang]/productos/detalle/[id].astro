---
import "../../../../styles/brand-colors.css";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import ResenasList from "../../../../components/ResenasList.astro";
import ResenasForm from "../../../../components/ResenasForm.astro";
import {
  getTodosLosProductos,
  getProductoDetalleById,
  getProductosPorCategoria,
} from "../../../../lib/productos-service.js";

export async function getStaticPaths() {
  const langs = ["es"];
  const todos = await getTodosLosProductos();
  return langs.flatMap((lang) =>
    todos.map((p) => ({ params: { lang, id: String(p.id) } })),
  );
}

const { id } = Astro.params;
const currentLang = "es";
const cspNonce = Astro.locals?.cspNonce || "";
const isSignedIn = Boolean(Astro.locals?.user?.userId);

const producto = (await getProductoDetalleById(Number(id))) as any;
if (!producto) return Astro.redirect(`/${currentLang}/productos/todos`);

const images = producto.imagenes?.length
  ? producto.imagenes
  : ["/images/logo/logo.png"];

let categoryProducts: any[] = [];
if (producto.categoriaId) {
  const catData = await getProductosPorCategoria(producto.categoriaId);
  categoryProducts = (catData?.productos || []).filter(
    (p: any) => p.id !== producto.id,
  );
}

function fmtPrice(val: number) {
  return val != null && val > 0
    ? `$${val.toLocaleString("es-MX", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`
    : "Cotizar";
}

const division = producto.division || "";
const unidadVenta = producto.unidad_venta || producto.unidadVenta || "";
const peso = producto.peso || null;
const variantes: any[] = producto.variantes || [];
const hasDiscount =
  Number(producto?.precioOriginal || producto?.precio || 0) >
  Number(producto?.precio || 0);

let specsJSON: Record<string, any> = {};
try {
  if (producto.especificaciones) {
    specsJSON =
      typeof producto.especificaciones === "string"
        ? JSON.parse(producto.especificaciones)
        : producto.especificaciones;
  }
} catch (_) {
  specsJSON = {};
}

const SPEC_LABELS: Record<string, string> = {
  amplitud_in: "Amplitud",
  grosor_gauges: "Grosor",
  largo_ft: "Largo",
  peso_neto_lb: "Peso neto",
  elongacion_pct: "Elongacion",
  adherencia_gfr: "Adherencia",
  resistencia_carga_lbf: "Resist. carga",
  resistencia_lbf: "Resistencia",
  material: "Material",
  construccion: "Construccion",
  usos: "Usos",
  industrias: "Industrias",
  normas: "Normas",
  calibres_in: "Calibres",
  calibres_mm: "Calibres (mm)",
  hebras: "Hebras",
  caracteristicas: "Caracteristicas",
  opcion_filtro_uv: "Filtro UV",
  alas_disponibles_in: "Alas disponibles",
  calibre_in: "Calibre",
  ancho_in: "Ancho",
  longitud_in: "Longitud",
  peso_tela_gm2: "Peso tela",
  peso_laminado_gm2: "Peso laminado",
  impermeabilidad: "Impermeabilidad",
  tipos_bolsas: "Tipos de bolsa",
  estructuras_laminado: "Estructuras laminado",
  estructuras_laminacion: "Estructuras laminacion",
  colores: "Colores",
  acabados: "Acabados",
  ventajas: "Ventajas",
  microperforaciones: "Microperforaciones",
  sin_costuras: "Sin costuras",
  impresion_colores_max: "Colores impresion max.",
  ancho_max_rollo_in: "Ancho max. rollo (in)",
  ancho_max_impresion_in: "Ancho max. impresion (in)",
};

function fmtVal(val: any): string {
  if (typeof val === "boolean") return val ? "Si" : "No";
  if (Array.isArray(val)) return val.join(", ");
  if (typeof val === "object" && val !== null) {
    if ("min" in val && "max" in val) {
      const tol = val.tolerancia
        ? ` (+/-${String(val.tolerancia).replace("+/-", "")})`
        : "";
      return `${val.min} - ${val.max}${tol}`;
    }
    return Object.entries(val)
      .map(([k, v]) => `${k}: ${v}`)
      .join(" | ");
  }
  return String(val);
}

const SKIP_KEYS = new Set([
  "medidas_pulg",
  "medidas_yd",
  "rendimiento_m_kg",
  "resistencia_traccion_lbf",
  "resistencia_traccion",
]);
const specEntries = Object.entries(specsJSON).filter(
  ([k]) => !SKIP_KEYS.has(k),
);

const infoChips = [
  {
    label: "Precio",
    value: fmtPrice(producto.precio),
    secondary: hasDiscount ? fmtPrice(producto.precioOriginal) : "",
    badge:
      hasDiscount && producto?.descuento?.porcentaje
        ? `-${Math.round(Number(producto.descuento.porcentaje))}%`
        : "",
    icon: "$",
  },
  {
    label: "Stock",
    value: producto.stock > 0 ? `${producto.stock} uds` : "Agotado",
    icon: "#",
    danger: producto.stock === 0,
  },
  ...(producto.empresaNombre
    ? [{ label: "Lo vende", value: producto.empresaNombre, icon: "Co" }]
    : []),
  ...(division ? [{ label: "Division", value: division, icon: "Dv" }] : []),
  ...(unidadVenta ? [{ label: "Unidad", value: unidadVenta, icon: "Un" }] : []),
  ...(peso ? [{ label: "Peso", value: `${peso} kg`, icon: "Kg" }] : []),
];
---

<BaseLayout
  title={`${producto.nombre} - NEXUS`}
  currentLang={currentLang}
  moveLogoMobile={true}
>
  <!-- SRI hash prevents loading a tampered version of GSAP from the CDN.
       Hash was computed from gsap@3.0.1/dist/gsap.min.js at publish time. -->
  <script
    src="https://cdn.jsdelivr.net/npm/gsap@3.0.1/dist/gsap.min.js"
    integrity="sha384-otQcV1jz7DiK+kGVOQ4POLMGmyv2CP0mH8qv1GDLlbDVel5hkeucPgvq8LSynz09"
    crossorigin="anonymous"
    defer></script>

  <div class="video-bg-wrapper">
    <div class="video-base-layer"></div>
    <div class="video-overlay"></div>
  </div>

  <main id="pdp-root" class="main-container">
    <div class="content">
      <a
        href={`/${currentLang}/productos/todos`}
        class="back-arrow-btn2"
        aria-label="Volver"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="19" y1="12" x2="5" y2="12"></line><polyline
            points="12 19 5 12 12 5"></polyline>
        </svg>
      </a>

      <div class="text-area elite-text-area">
        <div class="pd-elite-header fade-in-text">
          {division && <span class="pd-elite-brand">{division}</span>}
          <h1 id="product-title" class="pd-elite-title">{producto.nombre}</h1>
          
          <div class="pd-elite-rating">
            <div class="pd-stars">
              {"★★★★★".split("").map((star: string) => <span>{star}</span>)}
            </div>
            <a href="#pdp-reviews-title" class="pd-reviews-link">Ver reseñas</a>
          </div>
        </div>

        <div class="pd-elite-price-row fade-in-text">
          <span class="pd-elite-price" id="pd-variant-price" data-chip="price">{fmtPrice(Number(producto.precio || 0))}</span>
          {hasDiscount && <span class="pd-elite-price-original">{fmtPrice(producto.precioOriginal)}</span>}
          <span class="pd-elite-stock-badge" id="pd-variant-stock" data-chip="stock">
            {producto.stock > 0 ? `${producto.stock} uds` : "Agotado"}
          </span>
        </div>

        <p id="product-desc" class="pd-elite-desc fade-in-text">
          {producto.descripcion || "Sin descripción disponible."}
        </p>

        {variantes.length > 0 && (
          <div class="pd-elite-variants fade-in-text">
            <div class="pd-variant-header">
              <h3>Elige tu estilo</h3>
              <span id="pd-variant-label">Producto base</span>
            </div>
            <div class="pd-variants-wrap">
              <button
                class="pd-variant-chip active"
                data-base="1"
                data-precio={producto.precio ?? ""}
                data-stock={producto.stock ?? ""}
                data-image-index={0}
                data-desc=""
              >
                Base
              </button>
              {variantes.map((v: any, i: number) => (
                <button
                  class="pd-variant-chip"
                  data-variant-id={String(v.id)}
                  data-precio={v.precio ?? ""}
                  data-stock={v.stock ?? ""}
                  data-image-index={images.length ? i % images.length : 0}
                  data-desc={v.descripcion}
                >
                  {v.descripcion}
                </button>
              ))}
            </div>
          </div>
        )}

        <div class="pd-elite-actions fade-in-text">
          <button id="pd-add-to-cart-btn" type="button" class="pd-elite-buy-btn">
            Agregar al carrito
          </button>
          
          <div class="pd-elite-secondary-actions">
            <button id="pd-fav-btn" class="pd-elite-icon-btn" aria-label="Agregar a favoritos" data-producto-id={String(producto.id)}>
              <svg id="pd-fav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
              </svg>
            </button>
            <button id="pd-share-btn" class="pd-elite-icon-btn" aria-label="Compartir">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
              </svg>
            </button>
          </div>
        </div>

        <div class="pd-elite-trust-badges fade-in-text">
          <div class="trust-badge">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
            <span>Pago Seguro</span>
          </div>
          <div class="trust-badge">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5L20 7"></path></svg>
            <span>Calidad Garantizada</span>
          </div>
          <div class="trust-badge">
             <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
            <span>Envío Rápido</span>
          </div>
        </div>

        {specEntries.length > 0 && (
          <div class="pd-elite-specs-acc fade-in-text">
            <button class="pd-elite-specs-toggle" id="pd-specs-toggle" aria-expanded="false" type="button">
              <span>Especificaciones técnicas</span>
              <svg class="pd-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </button>
            <div id="pd-specs-body" class="pd-elite-specs-body" style="display:none;">
              <div class="pd-specs-table">
                {specEntries.map(([key, val]) => (
                  <div class="pd-spec-row">
                    <span class="pd-spec-key">{SPEC_LABELS[key] ?? key.replace(/_/g, " ")}</span>
                    <span class="pd-spec-val">{fmtVal(val)}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}
        
        <div id="pd-volume-section" class="pd-elite-volume fade-in-text" style="display:none;">
           <h4>Precios por volumen</h4>
           <div id="pd-volume-tiers" class="pd-volume-tiers"></div>
        </div>
      </div>
    </div>

    <div class="wheel-container">
      <div class="wheel" id="product-wheel" style="position:relative;">
        <div class="product-image-overlay" id="product-image-overlay">
          <img
            id="product-hero-img"
            class="product-hero-img"
            src={images[0]}
            alt={producto.nombre}
          />
          <div id="pd-image-fallback" class="pd-image-fallback" hidden>
            Imagen no disponible
          </div>
          <div id="pd-zoom-lens" class="pd-zoom-lens" aria-hidden="true"></div>
          <div id="pd-zoom-pane" class="pd-zoom-pane" aria-hidden="true">
            <img
              id="pd-zoom-img"
              src={images[0]}
              alt={`${producto.nombre} zoom`}
            />
          </div>
        </div>
        <div class="product-gallery" id="product-gallery">
          <div class="gallery-strip active" data-gallery-index="0">
            {
              images.map((src: string, imgIdx: number) => (
                <div
                  class={`gallery-photo ${imgIdx === 0 ? "active" : ""}`}
                  data-img-index={imgIdx + 1}
                >
                  <img
                    src={src}
                    alt={`${producto.nombre} vista ${imgIdx + 1}`}
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="gallery-photo-glow" />
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </main>

  {
    categoryProducts.length > 0 && (
      <section
        class="pdp-related fade-in-text"
        aria-labelledby="pdp-related-title"
      >
        <header class="pdp-related__head">
          <h2 id="pdp-related-title">Mas productos de esta categoria</h2>
          <p>
            Si te interesa este articulo, estos productos suelen gustar a
            clientes similares.
          </p>
        </header>
        <div class="pdp-related__grid">
          {categoryProducts.slice(0, 8).map((prod: any) => (
            <a
              class="pdp-related__card"
              href={`/${currentLang}/productos/detalle/${prod.id}`}
              aria-label={prod.nombre}
              title={prod.nombre}
            >
              <div class="pdp-related__media">
                <img
                  src={prod.imagen || "/images/logo/logo.png"}
                  alt={prod.nombre}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="pdp-related__body">
                <h3>{prod.nombre}</h3>
                {prod.precio_final != null ? (
                  <strong class="pdp-related__price">
                    $
                    {Number(prod.precio_final).toLocaleString("es-MX", {
                      minimumFractionDigits: 2,
                      maximumFractionDigits: 2,
                    })}
                  </strong>
                ) : prod.precio != null ? (
                  <strong class="pdp-related__price">
                    $
                    {Number(prod.precio).toLocaleString("es-MX", {
                      minimumFractionDigits: 2,
                      maximumFractionDigits: 2,
                    })}
                  </strong>
                ) : (
                  <span class="pdp-related__cat">
                    {prod.categoria || "Producto relacionado"}
                  </span>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <section
    class="pdp-reviews-shell fade-in-text"
    aria-labelledby="pdp-reviews-title"
  >
    <header class="pdp-reviews-shell__head">
      <h2 id="pdp-reviews-title">Resenas y experiencias de clientes</h2>
      <p>Conoce opiniones reales antes de comprar y comparte la tuya.</p>
    </header>
    <ResenasList productoId={producto.id} currentLang={currentLang} />
    <ResenasForm
      productoId={producto.id}
      cloudName={import.meta.env.CLOUDINARY_CLOUD_NAME}
    />
  </section>

  <!-- Modal cantidad -->
  <div id="pd-qty-modal" class="go-overlay" hidden>
    <div
      id="pd-qty-panel"
      class="go-card"
      role="dialog"
      aria-modal="true"
      aria-labelledby="pd-qty-title"
    >
      <div class="go-card-icon confirm">
        <svg
          width="32"
          height="32"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"
          ></circle>
          <path
            d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"
          ></path>
        </svg>
      </div>
      <h3 id="pd-qty-title" class="go-card-title">Cuantos deseas comprar?</h3>
      <p id="pd-qty-product-name" class="go-card-text"></p>
      <div class="go-stepper-wrap">
        <div class="go-stepper">
          <button
            type="button"
            id="pd-qty-minus"
            class="go-step-btn"
            aria-label="Menos">-</button
          >
          <input
            type="number"
            id="pd-qty-input"
            class="go-step-input"
            min="1"
            value="1"
          />
          <button
            type="button"
            id="pd-qty-plus"
            class="go-step-btn"
            aria-label="Mas">+</button
          >
        </div>
        <p id="pd-qty-stock-info" class="go-stock-info"></p>
      </div>
      <div class="go-card-actions">
        <button id="pd-qty-cancel" type="button" class="go-btn secondary"
          >Cancelar</button
        >
        <button id="pd-qty-confirm" type="button" class="go-btn primary">
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
          >
          Agregar al carrito
        </button>
      </div>
      <p id="pd-qty-feedback" class="go-feedback" hidden></p>
    </div>
  </div>

  <!-- Toast notification -->
  <div id="pd-toast" role="status" aria-live="polite"></div>

  <!-- Modal exito -->
  <div id="pd-success-modal" class="go-overlay" hidden>
    <div id="pd-success-panel" class="go-card" role="dialog" aria-modal="true">
      <div class="go-card-icon success">
        <svg
          width="32"
          height="32"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="10"></circle><path
            d="M7 12.5l3.5 3.5 6.5-7"></path>
        </svg>
      </div>
      <h3 class="go-card-title" style="color:#4ade80;">Producto agregado</h3>
      <p id="pd-success-name" class="go-card-text"></p>
      <p class="go-card-text">Se anadio correctamente a tu carrito.</p>
      <div class="go-card-actions">
        <button id="pd-success-continue" type="button" class="go-btn secondary"
          >Seguir comprando</button
        >
        <button id="pd-success-goto" type="button" class="go-btn primary"
          >Ver carrito</button
        >
      </div>
    </div>
  </div>

  <script
    is:inline
    define:vars={{
      images,
      currentLang,
      productId: producto.id,
      productName: producto.nombre,
      productStock: producto.stock,
      cspNonce,
    }}
    nonce={cspNonce}
  >
    function initDetalleLogic() {
      const heroImg = document.getElementById("product-hero-img");
      const imageFallback = document.getElementById("pd-image-fallback");
      const imageOverlay = document.getElementById("product-image-overlay");
      const zoomLens = document.getElementById("pd-zoom-lens");
      const zoomPane = document.getElementById("pd-zoom-pane");
      const zoomImg = document.getElementById("pd-zoom-img");

      function syncZoomImage() {
        if (heroImg && zoomPane) {
          const src = heroImg.currentSrc || heroImg.src;
          zoomPane.style.backgroundImage = `url('${src}')`;
          if (zoomImg) zoomImg.src = src;
        }
      }

      function refreshImageFallback() {
        if (!heroImg || !imageFallback) return;
        const src = heroImg.getAttribute("src") || "";
        const broken = !src || heroImg.naturalWidth === 0;
        imageFallback.hidden = !broken;
        heroImg.style.visibility = broken ? "hidden" : "visible";
      }

      function hideZoom() {
        if (!zoomLens || !zoomPane) return;
        zoomLens.classList.remove("show");
        zoomPane.classList.remove("show");
      }

      function setZoomFromPointer(clientX, clientY) {
        if (!imageOverlay || !heroImg || !zoomLens || !zoomPane || !zoomImg)
          return;
        const rect = imageOverlay.getBoundingClientRect();
        const x = clientX - rect.left;
        const y = clientY - rect.top;

        if (x < 0 || y < 0 || x > rect.width || y > rect.height) {
          hideZoom();
          return;
        }

        const rx = x / rect.width;
        const ry = y / rect.height;

        zoomLens.style.left = `${x}px`;
        zoomLens.style.top = `${y}px`;
        zoomPane.style.backgroundPosition = `${(rx * 100).toFixed(2)}% ${(ry * 100).toFixed(2)}%`;
        zoomPane.style.backgroundSize = "320%";
        zoomImg.style.transformOrigin = `${(rx * 100).toFixed(2)}% ${(ry * 100).toFixed(2)}%`;
        zoomImg.style.transform = "scale(2.25)";
        zoomLens.classList.add("show");
        zoomPane.classList.add("show");
      }

      if (imageOverlay && !imageOverlay.dataset.zoomReady) {
        imageOverlay.dataset.zoomReady = "1";
        syncZoomImage();
        if (heroImg) {
          heroImg.addEventListener("error", refreshImageFallback);
          heroImg.addEventListener("load", refreshImageFallback);
          refreshImageFallback();
        }

        imageOverlay.addEventListener("pointerenter", (e) => {
          if (!window.matchMedia("(pointer:fine)").matches) return;
          setZoomFromPointer(e.clientX, e.clientY);
        });

        imageOverlay.addEventListener("pointermove", (e) => {
          if (!window.matchMedia("(pointer:fine)").matches) return;
          setZoomFromPointer(e.clientX, e.clientY);
        });

        imageOverlay.addEventListener("pointerleave", hideZoom);
        imageOverlay.addEventListener("touchstart", hideZoom, {
          passive: true,
        });
      }

      // Galeria
      const galleryPhotos = Array.from(
        document.querySelectorAll(".gallery-photo"),
      );
      function activateImageByIndex(index) {
        const photo = galleryPhotos[index];
        const clickedImg = photo?.querySelector("img");
        if (!heroImg || !clickedImg) return;
        galleryPhotos.forEach((p) => p.classList.remove("active"));
        photo.classList.add("active");
        if (typeof gsap !== "undefined") {
          gsap.to(heroImg, {
            opacity: 0,
            scale: 0.97,
            duration: 0.15,
            onComplete: () => {
              heroImg.src = clickedImg.src;
              syncZoomImage();
              refreshImageFallback();
              gsap.to(heroImg, {
                opacity: 1,
                scale: 1,
                duration: 0.25,
                ease: "back.out(1.2)",
              });
            },
          });
        } else {
          heroImg.src = clickedImg.src;
          syncZoomImage();
          refreshImageFallback();
        }
      }

      galleryPhotos.forEach((photo) => {
        const activate = () => {
          const idx = Number(photo.dataset.imgIndex || 1) - 1;
          activateImageByIndex(Math.max(0, idx));
        };
        photo.addEventListener(
          "touchend",
          function (e) {
            e.stopPropagation();
            e.preventDefault();
            activate();
          },
          { passive: false },
        );
        photo.addEventListener("click", function (e) {
          e.stopPropagation();
          activate();
        });
      });

      // Drag movil
      const textArea = document.querySelector(".text-area");
      if (textArea && window.innerWidth <= 1024) {
        let startY = 0,
          isDragging = false;
        textArea.addEventListener(
          "touchstart",
          function (e) {
            if (
              e.target.closest(".thumb-item") ||
              e.target.closest("#thumbnails-container")
            )
              return;
            const rect = textArea.getBoundingClientRect();
            if (e.touches[0].clientY - rect.top > 60) return;
            startY = e.touches[0].clientY;
            isDragging = true;
          },
          { passive: true },
        );
        textArea.addEventListener(
          "touchend",
          function (e) {
            if (
              e.target.closest(".thumb-item") ||
              e.target.closest("#thumbnails-container")
            )
              return;
            if (!isDragging || !startY) return;
            const diff = startY - e.changedTouches[0].clientY;
            if (diff > 40) textArea.classList.add("expanded");
            else if (diff < -40) textArea.classList.remove("expanded");
            startY = 0;
            isDragging = false;
          },
          { passive: true },
        );
      }

      // Fade-in
      if (typeof gsap !== "undefined") {
        gsap.fromTo(
          document.querySelectorAll(".fade-in-text"),
          { opacity: 0, y: 20 },
          {
            opacity: 1,
            y: 0,
            duration: 0.6,
            stagger: 0.08,
            ease: "power2.out",
          },
        );
      }

      // Specs toggle
      const specsToggle = document.getElementById("pd-specs-toggle");
      const specsBody = document.getElementById("pd-specs-body");
      if (specsToggle && specsBody) {
        specsToggle.addEventListener("click", () => {
          const expanded = specsToggle.getAttribute("aria-expanded") === "true";
          specsToggle.setAttribute("aria-expanded", String(!expanded));
          specsBody.style.display = expanded ? "none" : "";
          const chevron = specsToggle.querySelector(".pd-chevron");
          if (chevron)
            chevron.style.transform = expanded
              ? "rotate(-90deg)"
              : "rotate(0deg)";
        });
      }

      // Variantes
      const variantPriceNode = document.getElementById("pd-variant-price");
      const variantStockNode = document.getElementById("pd-variant-stock");
      const variantLabelNode = document.getElementById("pd-variant-label");
      const chipPriceNode = document.querySelector('[data-chip="price"]');
      const chipStockNode = document.querySelector('[data-chip="stock"]');
      const fmtMoney = (val) => {
        const n = Number(val);
        if (!Number.isFinite(n) || n <= 0) return "Cotizar";
        return `$${n.toLocaleString("es-MX", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
      };

      function syncVariantDetails(activeBtn) {
        if (!activeBtn) return;
        const isBase = activeBtn.dataset.base === "1";
        const rawDesc = (activeBtn.dataset.desc || "").trim();
        const label = isBase
          ? "Producto base"
          : rawDesc || "Variante seleccionada";
        const price = fmtMoney(activeBtn.dataset.precio);
        const stockNum = Number(activeBtn.dataset.stock || 0);
        const imageIndex = Number(activeBtn.dataset.imageIndex || 0);
        const stockTxt = stockNum > 0 ? `${stockNum} uds` : "Sin stock";

        if (variantLabelNode) variantLabelNode.textContent = label;
        if (variantPriceNode) variantPriceNode.textContent = price;
        if (variantStockNode)
          variantStockNode.textContent = stockTxt;
        if (chipPriceNode) chipPriceNode.textContent = price;
        if (chipStockNode) chipStockNode.textContent = stockTxt;
        if (
          Number.isFinite(imageIndex) &&
          imageIndex >= 0 &&
          imageIndex < galleryPhotos.length
        ) {
          activateImageByIndex(imageIndex);
        }
      }

      const variantButtons = Array.from(
        document.querySelectorAll(".pd-variant-chip"),
      );
      variantButtons.forEach((btn) => {
        btn.addEventListener("click", function () {
          variantButtons.forEach((b) => b.classList.remove("active"));
          this.classList.add("active");
          syncVariantDetails(this);
        });
      });
      if (variantButtons.length) {
        const firstActive =
          document.querySelector(".pd-variant-chip.active") ||
          variantButtons[0];
        syncVariantDetails(firstActive);
      }

      // -- BotÃƒÂ³n principal Agregar al carrito --
      const addToCartBtn = document.getElementById("pd-add-to-cart-btn");
      if (addToCartBtn && !addToCartBtn.dataset.bound) {
        addToCartBtn.dataset.bound = "1";
        addToCartBtn.addEventListener("click", function () {
          openQtyModal();
        });
      }

      function openOverlay(modal, panel) {
        if (!modal || !panel) return;
        modal.hidden = false;
        requestAnimationFrame(() =>
          requestAnimationFrame(() => {
            modal.classList.add("is-open");
            panel.classList.add("is-open");
          }),
        );
      }
      function closeOverlay(modal, panel, cb) {
        if (!modal || !panel) return;
        panel.classList.remove("is-open");
        modal.classList.remove("is-open");
        setTimeout(() => {
          modal.hidden = true;
          if (cb) cb();
        }, 220);
      }

      const qtyModal = document.getElementById("pd-qty-modal");
      const qtyPanel = document.getElementById("pd-qty-panel");
      const qtyInput = document.getElementById("pd-qty-input");
      const qtyName = document.getElementById("pd-qty-product-name");
      const qtyStock = document.getElementById("pd-qty-stock-info");
      const qtyFeedback = document.getElementById("pd-qty-feedback");

      function openQtyModal() {
        const activeVariant = document.querySelector(".pd-variant-chip.active");
        const hasVariantStock =
          activeVariant && activeVariant.dataset.stock !== "";
        const variantStock = hasVariantStock
          ? Number(activeVariant.dataset.stock || 0)
          : null;
        const effectiveStock =
          variantStock != null ? Math.max(0, variantStock) : productStock;
        const variantLabel =
          activeVariant?.dataset.base === "1"
            ? ""
            : activeVariant?.dataset.desc?.split("|")[0]?.trim() || "";
        if (qtyName)
          qtyName.textContent =
            productName + (variantLabel ? ` - ${variantLabel}` : "");
        if (qtyInput) {
          qtyInput.value = "1";
          qtyInput.max = String(effectiveStock || 999);
        }
        if (qtyStock)
          qtyStock.textContent =
            effectiveStock > 0
              ? `Disponible: ${effectiveStock} uds`
              : "Sin stock registrado";
        openOverlay(qtyModal, qtyPanel);
        setTimeout(() => qtyInput?.focus(), 280);
      }
      function closeQtyModal() {
        closeOverlay(qtyModal, qtyPanel);
      }

      document.getElementById("pd-qty-minus")?.addEventListener("click", () => {
        if (qtyInput)
          qtyInput.value = String(Math.max(1, Number(qtyInput.value) - 1));
      });
      document.getElementById("pd-qty-plus")?.addEventListener("click", () => {
        const max = Number(qtyInput?.max) || productStock || 999;
        if (qtyInput)
          qtyInput.value = String(Math.min(max, Number(qtyInput.value) + 1));
      });
      document
        .getElementById("pd-qty-cancel")
        ?.addEventListener("click", closeQtyModal);
      qtyModal?.addEventListener("click", (e) => {
        if (e.target === qtyModal) closeQtyModal();
      });

      document
        .getElementById("pd-qty-confirm")
        ?.addEventListener("click", async function () {
          const qty = Number(qtyInput?.value || 1);
          if (!qty || qty < 1) return;
          this.disabled = true;
          this.textContent = "Agregando...";
          try {
            const activeVariant = document.querySelector(
              ".pd-variant-chip.active",
            );
            const varianteId = activeVariant?.dataset.variantId || null;
            const res = await fetch("/api/carrito", {
              method: "POST",
              credentials: "include",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                productoId: productId,
                cantidad: qty,
                varianteId,
              }),
            });
            const data = await res.json().catch(() => ({}));
            if (data?.success) {
              closeQtyModal();
              setTimeout(() => {
                const sm = document.getElementById("pd-success-modal");
                const sp = document.getElementById("pd-success-panel");
                const sn = document.getElementById("pd-success-name");
                if (sn) sn.textContent = productName;
                openOverlay(sm, sp);
              }, 250);
            } else {
              if (qtyFeedback) {
                qtyFeedback.textContent = data?.error || "Error al agregar";
                qtyFeedback.className = "go-feedback error";
                qtyFeedback.hidden = false;
                setTimeout(() => (qtyFeedback.hidden = true), 3000);
              }
            }
          } catch {
            if (qtyFeedback) {
              qtyFeedback.textContent = "Error de conexion";
              qtyFeedback.className = "go-feedback error";
              qtyFeedback.hidden = false;
              setTimeout(() => (qtyFeedback.hidden = true), 3000);
            }
          } finally {
            this.disabled = false;
            this.innerHTML =
              '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>Agregar al carrito';
          }
        });

      const successModal = document.getElementById("pd-success-modal");
      const successPanel = document.getElementById("pd-success-panel");
      document
        .getElementById("pd-success-continue")
        ?.addEventListener("click", () =>
          closeOverlay(successModal, successPanel),
        );
      document
        .getElementById("pd-success-goto")
        ?.addEventListener("click", () => {
          window.location.href = `/${currentLang}/carrito`;
        });
      successModal?.addEventListener("click", (e) => {
        if (e.target === successModal) closeOverlay(successModal, successPanel);
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          if (qtyModal && !qtyModal.hidden) closeQtyModal();
          if (successModal && !successModal.hidden)
            closeOverlay(successModal, successPanel);
        }
      });
    }

    if (document.readyState === "loading")
      document.addEventListener("DOMContentLoaded", initDetalleLogic);
    else initDetalleLogic();
    document.addEventListener("astro:page-load", initDetalleLogic);
    document.addEventListener("astro:after-swap", initDetalleLogic);
  </script>

  <!-- ====== Favoritos + Precios por Volumen ====== -->
  <script
    nonce={cspNonce}
    is:inline
    define:vars={{
      productId: producto.id,
      basePrice: producto.precio,
      isSignedIn,
    }}
  >
    (function () {
      /* ---- Toast util ---- */
      function showToast(msg, ms) {
        const el = document.getElementById("pd-toast");
        if (!el) return;
        el.textContent = msg;
        el.classList.add("show");
        setTimeout(() => el.classList.remove("show"), ms || 2800);
      }

      function isLoggedIn() {
        return Boolean(isSignedIn);
      }

      /* ---- Favoritos ---- */
      async function initFavoritos() {
        const btn = document.getElementById("pd-fav-btn");
        const icon = document.getElementById("pd-fav-icon");
        const label = document.getElementById("pd-fav-label");
        if (!btn) return;

        const id = Number(productId);

        // Check if already saved
        if (isLoggedIn()) {
          try {
            const res = await fetch("/api/me/favoritos");
            if (res.ok) {
              const data = await res.json();
              const saved = (data.favoritos || []).some(
                (f) => Number(f.productoId || f.Id_Producto) === id,
              );
              setSaved(btn, icon, label, saved);
            }
          } catch {
            /* ignore */
          }
        }

        btn.addEventListener("click", async () => {
          if (!isLoggedIn()) {
            showToast("Inicia sesiÃƒÂ³n para guardar favoritos", 3000);
            return;
          }
          const alreadySaved = btn.classList.contains("saved");
          try {
            let res;
            if (alreadySaved) {
              res = await fetch("/api/me/favoritos?productoId=" + id, {
                method: "DELETE",
              });
            } else {
              res = await fetch("/api/me/favoritos", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ productoId: id }),
              });
            }
            if (res.ok) {
              setSaved(btn, icon, label, !alreadySaved);
              showToast(
                alreadySaved
                  ? "Eliminado de favoritos"
                  : "Guardado en favoritos Ã¢ÂÂ¤Ã¯Â¸Â",
                2400,
              );
            } else {
              showToast("OcurriÃƒÂ³ un error, intenta de nuevo", 2800);
            }
          } catch {
            showToast("OcurriÃƒÂ³ un error, intenta de nuevo", 2800);
          }
        });

        // Share button
        const shareBtn = document.getElementById("pd-share-btn");
        if (shareBtn) {
          shareBtn.addEventListener("click", async () => {
            try {
              if (navigator.share) {
                await navigator.share({
                  title: document.title,
                  url: location.href,
                });
              } else {
                await navigator.clipboard.writeText(location.href);
                showToast("Enlace copiado al portapapeles", 2200);
              }
            } catch {
              /* user cancelled share */
            }
          });
        }
      }

      function setSaved(btn, icon, label, saved) {
        if (saved) {
          btn.classList.add("saved");
          btn.setAttribute("aria-pressed", "true");
          if (label) label.textContent = "Guardado";
        } else {
          btn.classList.remove("saved");
          btn.setAttribute("aria-pressed", "false");
          if (label) label.textContent = "Guardar";
        }
      }

      /* ---- Precios por volumen ---- */
      async function initVolumePricing() {
        const section = document.getElementById("pd-volume-section");
        const container = document.getElementById("pd-volume-tiers");
        if (!section || !container) return;

        try {
          const res = await fetch("/api/productos/" + productId + "/volumen");
          if (!res.ok) return;
          const data = await res.json();
          const tiers = data.tiers || [];
          if (!tiers.length) return;

          container.innerHTML = "";
          tiers.forEach((t) => {
            const price =
              basePrice != null
                ? Number(basePrice) * (1 - t.discountPct / 100)
                : null;
            const div = document.createElement("div");
            div.className = "pd-vol-tier";
            div.innerHTML =
              '<span class="pd-vol-tier__qty">' +
              (t.label || t.minQty + "+  uds.") +
              "</span>" +
              '<span class="pd-vol-tier__pct">-' +
              t.discountPct +
              "%</span>" +
              (price != null
                ? '<span class="pd-vol-tier__price">$' +
                  price.toLocaleString("es-MX", {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2,
                  }) +
                  "</span>"
                : "");
            container.appendChild(div);
          });

          section.style.display = "";

          // Highlight active tier based on qty input
          function updateActiveTier() {
            const qtyInput = document.querySelector(
              '[data-qty], #pd-qty-input, input[name="cantidad"], input[type="number"]',
            );
            const qty = qtyInput ? Number(qtyInput.value || 1) : 1;
            const sorted = [...tiers].sort((a, b) => b.minQty - a.minQty);
            const active = sorted.find((t) => qty >= t.minQty);
            container.querySelectorAll(".pd-vol-tier").forEach((el, i) => {
              el.classList.toggle(
                "pd-vol-tier--active",
                active ? tiers[i]?.minQty === active.minQty : false,
              );
            });
          }
          updateActiveTier();
          document.addEventListener("input", (e) => {
            if (
              e.target &&
              (e.target.dataset?.qty != null ||
                e.target.name === "cantidad" ||
                e.target.type === "number")
            ) {
              updateActiveTier();
            }
          });
        } catch {
          /* no volume tiers */
        }
      }

      /* ---- Init ---- */
      function init() {
        initFavoritos();
        initVolumePricing();
      }

      if (document.readyState === "loading")
        document.addEventListener("DOMContentLoaded", init);
      else init();
      document.addEventListener("astro:page-load", init);
    })();
  </script>

