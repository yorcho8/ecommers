---
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}
const currentLang = "es";
---

<BaseLayout title={`Carrito | NEXUS`} currentLang={currentLang}>
<div class="ct-root">
<main class="ct">

  <!-- Ambient glow -->
  <div class="ct-ambient"></div>

  {/* ── Header ── */}
  <header class="ct-head">
    <div class="ct-head__left">
      <a href={`/${currentLang}/productos/todos`} class="ct-back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        Seguir comprando
      </a>
      <div class="ct-head__title-group">
        <span class="ct-label">CARRITO DE COMPRAS</span>
        <h1 class="ct-title">Tu Carrito</h1>
      </div>
    </div>
    <div class="ct-head__right">
      <div class="ct-count-badge" id="ctCount">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
        <span>0 productos</span>
      </div>
    </div>
  </header>

  {/* ── Alert inline ── */}
  <div id="ctAlert" class="ct-alert" hidden></div>

  {/* ── Content: items + sidebar ── */}
  <div id="ctContent" class="ct-layout" hidden>

    {/* ── Items list ── */}
    <section id="ctItems" class="ct-items" aria-label="Productos en el carrito"></section>

    {/* ── Sidebar: resumen sticky ── */}
    <aside class="ct-sidebar">
      <div class="ct-summary">
        <div class="ct-summary__header">
          <h2 class="ct-summary__title">Resumen del Pedido</h2>
          <div class="ct-summary__icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          </div>
        </div>

        <div class="ct-summary__row">
          <span>Subtotal</span>
          <strong id="ctSubtotal">$0.00</strong>
        </div>

        <div class="ct-summary__row">
          <span>Envío</span>
          <span class="ct-summary__calc">Se calcula en checkout</span>
        </div>

        <div class="ct-summary__divider ct-summary__divider--glow"></div>

        <div class="ct-summary__row ct-summary__row--total">
          <span>Total estimado</span>
          <strong id="ctTotal">$0.00</strong>
        </div>

        <button id="ctCheckout" class="ct-btn ct-btn--primary" type="button" disabled>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          <span>Continuar al pago</span>
          <span class="ct-btn__arrow">→</span>
        </button>

        <button id="ctClear" class="ct-btn ct-btn--ghost" type="button">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
          Vaciar carrito
        </button>

        <div class="ct-badges">
          <div class="ct-badge">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Pago seguro
          </div>
          <div class="ct-badge">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            Envío rastreable
          </div>
          <div class="ct-badge">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            Garantía
          </div>
        </div>
      </div>
    </aside>
  </div>

  {/* ── Empty state ── */}
  <section id="ctEmpty" class="ct-empty" hidden>
    <div class="ct-empty__glow"></div>
    <div class="ct-empty__icon-wrap">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
    </div>
    <h2 class="ct-empty__title">Tu carrito está vacío</h2>
    <p class="ct-empty__sub">Agrega productos desde el catálogo para comenzar.</p>
    <a href={`/${currentLang}/productos/todos`} class="ct-btn ct-btn--primary ct-btn--inline">
      Ver catálogo
      <span class="ct-btn__arrow">→</span>
    </a>
  </section>

  {/* ── Confirm dialog ── */}
  <dialog id="ctDialog" class="ct-dialog">
    <div class="ct-dialog__card">
      <div class="ct-dialog__icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <h3 id="ctDialogTitle" class="ct-dialog__title"></h3>
      <p id="ctDialogMsg" class="ct-dialog__msg"></p>
      <div class="ct-dialog__actions">
        <button id="ctDialogCancel" class="ct-btn ct-btn--ghost ct-btn--sm" type="button">Cancelar</button>
        <button id="ctDialogOk" class="ct-btn ct-btn--danger ct-btn--sm" type="button">Confirmar</button>
      </div>
    </div>
  </dialog>

</main>
</div>

<style is:global>
  /* ═══════════════════════════════════════════════
     CART — PREMIUM DARK THEME (User = Brand)
     Matches the go-platform glassmorphism system
     ═══════════════════════════════════════════════ */

  .ct-root {
    --ct-bg: #0b0e14;
    --ct-surface: rgba(18,22,31,.8);
    --ct-surface-solid: #12161f;
    --ct-surface-2: #181d28;
    --ct-surface-3: #1e2433;
    --ct-border: rgba(255,255,255,.07);
    --ct-border-hover: rgba(255,255,255,.14);
    --ct-text: #f0f2f5;
    --ct-text-2: #8b95a5;
    --ct-text-3: #5a6478;
    --ct-accent: #7a2532;
    --ct-accent-h: #3a56a0;
    --ct-accent-glow: rgba(122,37,50,.15);
    --ct-accent-glow-s: rgba(224,163,91,.3);
    --ct-danger: #ef4444;
    --ct-success: #22c55e;
    --ct-green-bg: rgba(34,197,94,.1);
    --ct-green-border: rgba(34,197,94,.25);
    --ct-radius: 16px;
    --ct-radius-sm: 10px;
    --ct-shadow: 0 2px 8px rgba(0,0,0,.2), 0 0 0 1px rgba(255,255,255,.04);
    --ct-shadow-lg: 0 8px 32px rgba(0,0,0,.35), 0 0 0 1px rgba(255,255,255,.05);
    --ct-shadow-glow: 0 4px 24px rgba(122,37,50,.12), 0 0 0 1px rgba(224,163,91,.15);

    background: var(--ct-bg);
    min-height: 100vh;
    position: relative;
    z-index: 1;
    overflow-x: hidden;
  }

  /* ── Ambient glow ── */
  .ct-ambient {
    position: fixed;
    top: -180px;
    right: -180px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(122,37,50,.07) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .ct-root .ct {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 24px 80px;
    color: var(--ct-text);
    font-family: var(--fuente-cuerpo, 'NeueMontreal', 'Inter', -apple-system, sans-serif);
    position: relative;
    z-index: 1;
  }

  /* Reset inherited */
  .ct-root .ct h1, .ct-root .ct h2, .ct-root .ct h3,
  .ct-root .ct p, .ct-root .ct span, .ct-root .ct strong,
  .ct-root .ct a, .ct-root .ct button {
    font-family: inherit;
    text-transform: none;
    letter-spacing: normal;
  }

  /* ═══════════ HEADER ═══════════ */
  .ct-root .ct-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .ct-root .ct-head__left { display: flex; flex-direction: column; gap: 12px; }

  .ct-root .ct-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--ct-text-2);
    text-decoration: none;
    font-weight: 500;
    font-size: 12px;
    padding: 5px 12px;
    border-radius: 20px;
    background: var(--ct-surface-2);
    border: 1px solid var(--ct-border);
    transition: all .25s ease;
    width: fit-content;
  }
  .ct-root .ct-back:hover {
    color: var(--ct-accent);
    border-color: rgba(122,37,50,.3);
    background: var(--ct-accent-glow);
    transform: translateX(-2px);
  }
  .ct-root .ct-back svg { transition: transform .25s ease; }
  .ct-root .ct-back:hover svg { transform: translateX(-3px); }

  .ct-root .ct-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .15em;
    color: var(--ct-accent);
    text-transform: uppercase;
  }

  .ct-root .ct-title {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -.02em;
    line-height: 1;
    background: linear-gradient(135deg, #fff 0%, #bbb 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ct-root .ct-count-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: var(--ct-surface);
    backdrop-filter: blur(16px);
    border: 1px solid var(--ct-border);
    border-radius: 24px;
    font-size: 12px;
    font-weight: 600;
    color: var(--ct-text-2);
  }
  .ct-root .ct-count-badge svg { color: var(--ct-accent); }

  /* ═══════════ ALERT ═══════════ */
  .ct-root .ct-alert {
    padding: 12px 16px;
    border-radius: var(--ct-radius-sm);
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 16px;
    animation: ct-slideIn 0.25s ease;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .ct-root .ct-alert[hidden] { display: none; }
  .ct-root .ct-alert.is-ok {
    background: rgba(34,197,94,.08);
    border: 1px solid rgba(34,197,94,.2);
    color: var(--ct-success);
  }
  .ct-root .ct-alert.is-error {
    background: rgba(239,68,68,.06);
    border: 1px solid rgba(239,68,68,.2);
    color: var(--ct-danger);
  }
  @keyframes ct-slideIn {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══════════ LAYOUT ═══════════ */
  .ct-root .ct-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 24px;
    align-items: start;
  }

  /* ═══════════ ITEM CARDS ═══════════ */
  .ct-root .ct-items {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ct-root .ct-item {
    display: grid;
    grid-template-columns: 88px 1fr auto;
    gap: 16px;
    align-items: center;
    padding: 16px 18px;
    background: var(--ct-surface);
    backdrop-filter: blur(16px);
    border: 1px solid var(--ct-border);
    border-radius: var(--ct-radius);
    transition: all .25s ease;
    position: relative;
    overflow: hidden;
  }
  .ct-root .ct-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(122,37,50,.02) 0%, transparent 50%);
    pointer-events: none;
    opacity: 0;
    transition: opacity .25s ease;
  }
  .ct-root .ct-item:hover {
    border-color: var(--ct-border-hover);
    transform: translateY(-2px);
    box-shadow: var(--ct-shadow-lg);
  }
  .ct-root .ct-item:hover::before { opacity: 1; }

  /* ── Image ── */
  .ct-root .ct-item__img-wrap {
    width: 88px;
    height: 88px;
    border-radius: 12px;
    overflow: hidden;
    background: var(--ct-surface-2);
    border: 1px solid var(--ct-border);
    position: relative;
    flex-shrink: 0;
  }
  .ct-root .ct-item__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .4s cubic-bezier(.25,.46,.45,.94);
  }
  .ct-root .ct-item:hover .ct-item__img {
    transform: scale(1.08);
  }
  .ct-root .ct-item__noimg {
    width: 88px;
    height: 88px;
    border-radius: 12px;
    background: var(--ct-surface-2);
    border: 1px solid var(--ct-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ct-text-3);
  }

  /* ── Info ── */
  .ct-root .ct-item__info { min-width: 0; }

  .ct-root .ct-item__name {
    font-size: 14px;
    font-weight: 700;
    color: var(--ct-text);
    margin: 0 0 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.3;
  }

  .ct-root .ct-item__price {
    font-size: 13px;
    color: var(--ct-text-2);
    margin: 0 0 2px;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .ct-root .ct-item__price-tag {
    font-weight: 700;
    color: var(--ct-accent);
    font-size: 13px;
  }

  .ct-root .ct-item__sku {
    font-size: 11px;
    color: var(--ct-text-3);
    margin: 0;
  }

  /* ── Actions ── */
  .ct-root .ct-item__actions {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-shrink: 0;
  }

  /* Qty control */
  .ct-root .ct-qty {
    display: flex;
    align-items: center;
    border: 1.5px solid var(--ct-border);
    border-radius: 10px;
    overflow: hidden;
    height: 36px;
    background: rgba(255,255,255,.02);
    transition: border-color .2s ease;
  }
  .ct-root .ct-qty:hover { border-color: var(--ct-border-hover); }
  .ct-root .ct-qty:focus-within { border-color: rgba(122,37,50,.4); box-shadow: 0 0 0 3px rgba(122,37,50,.08); }

  .ct-root .ct-qty__btn {
    width: 34px;
    height: 100%;
    border: none;
    background: transparent;
    color: var(--ct-text-2);
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all .15s ease;
    display: grid;
    place-items: center;
  }
  .ct-root .ct-qty__btn:hover {
    background: var(--ct-accent-glow);
    color: var(--ct-accent);
  }
  .ct-root .ct-qty__btn:active { transform: scale(.92); }

  .ct-root .ct-qty__input {
    width: 38px;
    height: 100%;
    border: none;
    border-left: 1px solid var(--ct-border);
    border-right: 1px solid var(--ct-border);
    text-align: center;
    font-size: 13px;
    font-weight: 700;
    font-family: inherit;
    color: var(--ct-text);
    background: transparent;
    outline: none;
    -moz-appearance: textfield;
  }
  .ct-root .ct-qty__input::-webkit-inner-spin-button,
  .ct-root .ct-qty__input::-webkit-outer-spin-button { display: none; }

  /* Subtotal per item */
  .ct-root .ct-item__subtotal {
    font-size: 15px;
    font-weight: 800;
    color: var(--ct-text);
    min-width: 80px;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  /* Remove button */
  .ct-root .ct-item__remove {
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    background: none;
    border: 1px solid transparent;
    color: var(--ct-text-3);
    cursor: pointer;
    border-radius: 8px;
    transition: all .2s ease;
    padding: 0;
  }
  .ct-root .ct-item__remove:hover {
    color: var(--ct-danger);
    background: rgba(239,68,68,.08);
    border-color: rgba(239,68,68,.2);
  }
  .ct-root .ct-item__remove:active { transform: scale(.9); }

  /* ═══════════ SIDEBAR / SUMMARY ═══════════ */
  .ct-root .ct-sidebar { position: sticky; top: 90px; }

  .ct-root .ct-summary {
    background: var(--ct-surface);
    backdrop-filter: blur(20px);
    border: 1px solid var(--ct-border);
    border-radius: var(--ct-radius);
    padding: 22px;
    box-shadow: var(--ct-shadow-lg);
  }

  .ct-root .ct-summary__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }
  .ct-root .ct-summary__title {
    font-size: 14px;
    font-weight: 700;
    margin: 0;
    color: var(--ct-text);
    text-transform: uppercase;
    letter-spacing: .05em;
  }
  .ct-root .ct-summary__icon {
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ct-accent-glow);
    border-radius: 10px;
    color: var(--ct-accent);
  }

  .ct-root .ct-summary__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    font-size: 13px;
    color: var(--ct-text-2);
  }
  .ct-root .ct-summary__row strong { color: var(--ct-text); font-weight: 700; }

  .ct-root .ct-summary__calc {
    font-size: 11px;
    color: var(--ct-text-3);
    font-style: italic;
  }

  .ct-root .ct-summary__divider {
    height: 1px;
    background: var(--ct-border);
    margin: 10px 0;
  }
  .ct-root .ct-summary__divider--glow {
    background: linear-gradient(90deg, transparent, rgba(122,37,50,.3), transparent);
  }

  .ct-root .ct-summary__row--total {
    font-size: 18px;
    font-weight: 800;
    padding: 10px 0 4px;
  }
  .ct-root .ct-summary__row--total span { color: var(--ct-text); }
  .ct-root .ct-summary__row--total strong {
    background: linear-gradient(135deg, #fff 0%, var(--ct-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Trust badges ── */
  .ct-root .ct-badges {
    display: flex;
    justify-content: center;
    gap: 14px;
    margin-top: 16px;
    flex-wrap: wrap;
  }
  .ct-root .ct-badge {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    color: var(--ct-text-3);
    font-weight: 500;
  }
  .ct-root .ct-badge svg { opacity: .6; }

  /* ═══════════ BUTTONS ═══════════ */
  .ct-root .ct-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 13px 20px;
    border: none;
    border-radius: 12px;
    font-size: 13px;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    transition: all .25s ease;
    text-decoration: none;
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .ct-root .ct-btn--primary {
    background: linear-gradient(135deg, var(--ct-accent), #263a72);
    margin-top: 16px;
    box-shadow: 0 4px 16px rgba(122,37,50,.25);
    text-transform: uppercase;
    letter-spacing: .05em;
  }
  .ct-root .ct-btn--primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,.12) 0%, transparent 50%);
    pointer-events: none;
  }
  .ct-root .ct-btn--primary:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(122,37,50,.4);
  }
  .ct-root .ct-btn--primary:active:not(:disabled) { transform: translateY(0) scale(.98); }
  .ct-root .ct-btn--primary:disabled { opacity: .35; cursor: not-allowed; transform: none; box-shadow: none; }

  .ct-root .ct-btn__arrow {
    font-size: 16px;
    transition: transform .2s ease;
    margin-left: 4px;
  }
  .ct-root .ct-btn--primary:hover:not(:disabled) .ct-btn__arrow { transform: translateX(4px); }

  .ct-root .ct-btn--ghost {
    background: transparent;
    color: var(--ct-text-3);
    margin-top: 8px;
    border: 1px solid var(--ct-border);
    font-size: 12px;
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0;
    padding: 10px 16px;
  }
  .ct-root .ct-btn--ghost:hover {
    color: var(--ct-text-2);
    background: rgba(255,255,255,.03);
    border-color: var(--ct-border-hover);
  }

  .ct-root .ct-btn--danger {
    background: var(--ct-danger);
    box-shadow: 0 2px 8px rgba(239,68,68,.2);
  }
  .ct-root .ct-btn--danger:hover { background: #dc2626; box-shadow: 0 4px 16px rgba(239,68,68,.3); }

  .ct-root .ct-btn--sm {
    width: auto;
    padding: 9px 20px;
    font-size: 12px;
    margin-top: 0;
    border-radius: 10px;
  }

  .ct-root .ct-btn--inline { width: auto; display: inline-flex; }

  /* ═══════════ EMPTY STATE ═══════════ */
  .ct-root .ct-empty {
    text-align: center;
    padding: 70px 24px;
    background: var(--ct-surface);
    backdrop-filter: blur(16px);
    border: 1px solid var(--ct-border);
    border-radius: var(--ct-radius);
    max-width: 480px;
    margin: 40px auto;
    position: relative;
    overflow: hidden;
  }
  .ct-root .ct-empty__glow {
    position: absolute;
    top: -60px;
    left: 50%;
    transform: translateX(-50%);
    width: 300px;
    height: 200px;
    background: radial-gradient(circle, rgba(122,37,50,.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .ct-root .ct-empty__icon-wrap {
    width: 80px;
    height: 80px;
    margin: 0 auto 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ct-accent-glow);
    border: 1px solid rgba(122,37,50,.2);
    border-radius: 50%;
    color: var(--ct-accent);
    position: relative;
    z-index: 1;
  }
  .ct-root .ct-empty__title {
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 6px;
    color: var(--ct-text);
    position: relative;
  }
  .ct-root .ct-empty__sub {
    font-size: 13px;
    color: var(--ct-text-2);
    margin: 0 0 22px;
    position: relative;
  }

  /* ═══════════ DIALOG ═══════════ */
  .ct-root .ct-dialog {
    border: none;
    border-radius: var(--ct-radius);
    background: transparent;
    padding: 0;
    max-width: 400px;
    width: calc(100% - 32px);
  }
  .ct-root .ct-dialog::backdrop {
    background: rgba(0,0,0,.6);
    backdrop-filter: blur(6px);
  }
  .ct-root .ct-dialog__card {
    background: var(--ct-surface-solid);
    border: 1px solid var(--ct-border);
    border-radius: var(--ct-radius);
    padding: 28px;
    color: var(--ct-text);
    text-align: center;
  }
  .ct-root .ct-dialog__icon {
    width: 52px;
    height: 52px;
    margin: 0 auto 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(239,68,68,.08);
    border: 1px solid rgba(239,68,68,.2);
    border-radius: 50%;
    color: var(--ct-danger);
  }
  .ct-root .ct-dialog__title {
    font-size: 16px;
    font-weight: 700;
    margin: 0 0 6px;
  }
  .ct-root .ct-dialog__msg {
    font-size: 13px;
    color: var(--ct-text-2);
    margin: 0;
    line-height: 1.5;
  }
  .ct-root .ct-dialog__actions {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }

  /* ═══════════ RESPONSIVE ═══════════ */
  @media (max-width: 860px) {
    .ct-root .ct { padding: 28px 16px 60px; }
    .ct-root .ct-layout { grid-template-columns: 1fr; }
    .ct-root .ct-sidebar { position: static; }

    .ct-root .ct-item {
      grid-template-columns: 72px 1fr;
      grid-template-rows: auto auto;
      gap: 8px 14px;
      padding: 14px;
    }
    .ct-root .ct-item__img-wrap,
    .ct-root .ct-item__noimg {
      width: 72px;
      height: 72px;
      grid-row: span 2;
    }
    .ct-root .ct-item__actions {
      grid-column: 2;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
    }
    .ct-root .ct-item__subtotal { min-width: auto; }
    .ct-root .ct-head { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 480px) {
    .ct-root .ct-item__actions { gap: 6px; }
    .ct-root .ct-item__subtotal { font-size: 13px; min-width: 60px; }
    .ct-root .ct-qty { height: 32px; }
    .ct-root .ct-qty__btn { width: 30px; }
    .ct-root .ct-qty__input { width: 32px; font-size: 12px; }
  }
</style>

<script is:inline define:vars={{ currentLang }}>
(function () {
  const $ = (s) => document.getElementById(s);
  const ctItems = $("ctItems");
  const ctContent = $("ctContent");
  const ctEmpty = $("ctEmpty");
  const ctAlert = $("ctAlert");
  const ctCount = $("ctCount");
  const ctSubtotal = $("ctSubtotal");
  const ctTotal = $("ctTotal");
  const ctCheckout = $("ctCheckout");
  const ctClear = $("ctClear");
  const ctDialog = $("ctDialog");
  const ctDialogTitle = $("ctDialogTitle");
  const ctDialogMsg = $("ctDialogMsg");
  const ctDialogCancel = $("ctDialogCancel");
  const ctDialogOk = $("ctDialogOk");

  let items = [];
  let total = 0;
  let dialogCallback = null;

  const money = (v) => `$${Number(v || 0).toLocaleString("es-MX", { minimumFractionDigits: 2, maximumFractionDigits: 2 })} MXN`;

  const esc = (s) => s ? s.replace(/[&<>"]/g, (m) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[m])) : "";

  const imgSrc = (s) => {
    if (!s) return null;
    if (s.startsWith("http") || s.startsWith("/")) return s;
    return `/images/${s}`;
  };

  function alert(msg, type = "ok") {
    if (!ctAlert) return;
    ctAlert.hidden = false;
    ctAlert.textContent = msg;
    ctAlert.className = `ct-alert is-${type}`;
    setTimeout(() => { ctAlert.hidden = true; }, 2500);
  }

  function confirm(title, msg) {
    return new Promise((resolve) => {
      if (!ctDialog || !ctDialogTitle || !ctDialogMsg) { resolve(false); return; }
      ctDialogTitle.textContent = title;
      ctDialogMsg.textContent = msg;
      dialogCallback = resolve;
      ctDialog.showModal();
    });
  }

  ctDialogCancel?.addEventListener("click", () => {
    ctDialog?.close();
    if (dialogCallback) { dialogCallback(false); dialogCallback = null; }
  });
  ctDialogOk?.addEventListener("click", () => {
    ctDialog?.close();
    if (dialogCallback) { dialogCallback(true); dialogCallback = null; }
  });
  ctDialog?.addEventListener("close", () => {
    if (dialogCallback) { dialogCallback(false); dialogCallback = null; }
  });

  /* ── Render ── */
  function render() {
    if (!items.length) {
      if (ctContent) ctContent.hidden = true;
      if (ctEmpty) ctEmpty.hidden = false;
      if (ctCount) ctCount.querySelector("span").textContent = "0 productos";
      return;
    }

    if (ctContent) ctContent.hidden = false;
    if (ctEmpty) ctEmpty.hidden = true;
    if (ctCount) ctCount.querySelector("span").textContent = `${items.length} producto${items.length !== 1 ? "s" : ""}`;
    if (ctSubtotal) ctSubtotal.textContent = money(total);
    if (ctTotal) ctTotal.textContent = money(total);
    if (ctCheckout) ctCheckout.disabled = false;

    if (!ctItems) return;
    ctItems.innerHTML = items.map((it, idx) => {
      const img = imgSrc(it.imagen);
      return `
        <div class="ct-item" data-id="${it.itemId}" style="animation: ct-itemIn .3s ease ${idx * .05}s both;">
          ${img
            ? `<div class="ct-item__img-wrap"><img class="ct-item__img" src="${img}" alt="${esc(it.nombre)}" loading="lazy"/></div>`
            : `<div class="ct-item__noimg"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>`
          }
          <div class="ct-item__info">
            <p class="ct-item__name">${esc(it.nombre)}</p>
            <p class="ct-item__price"><span class="ct-item__price-tag">${money(it.precioUnitario)}</span> <span style="color:var(--ct-text-3);font-size:11px;">c/u</span></p>
          </div>
          <div class="ct-item__actions">
            <div class="ct-qty">
              <button class="ct-qty__btn" data-do="minus" data-id="${it.itemId}" type="button" aria-label="Menos">−</button>
              <input class="ct-qty__input" type="number" min="1" value="${it.cantidad}" data-do="qty" data-id="${it.itemId}" aria-label="Cantidad"/>
              <button class="ct-qty__btn" data-do="plus" data-id="${it.itemId}" type="button" aria-label="Más">+</button>
            </div>
            <span class="ct-item__subtotal">${money(it.subtotal)}</span>
            <button class="ct-item__remove" data-do="remove" data-id="${it.itemId}" type="button" aria-label="Eliminar">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
            </button>
          </div>
        </div>`;
    }).join("");

    // inject animation keyframes if not present
    if (!document.getElementById('ct-item-anim')) {
      const s = document.createElement('style');
      s.id = 'ct-item-anim';
      s.textContent = `@keyframes ct-itemIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }`;
      document.head.appendChild(s);
    }
  }

  /* ── API ── */
  async function load() {
    try {
      const res = await fetch("/api/carrito", { credentials: "include" });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.success) { alert(data.error || "Error al cargar", "error"); return; }
      items = data.items || [];
      total = Number(data.summary?.total || 0);
      render();
    } catch { alert("Error de conexión", "error"); }
  }

  async function updateQty(id, qty) {
    const res = await fetch("/api/carrito", {
      method: "PUT", credentials: "include",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ itemId: id, cantidad: qty }),
    });
    const d = await res.json().catch(() => ({}));
    if (!res.ok || !d.success) alert(d.error || "Error", "error");
    await load();
  }

  async function removeItem(id) {
    const res = await fetch("/api/carrito", {
      method: "DELETE", credentials: "include",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ itemId: id }),
    });
    const d = await res.json().catch(() => ({}));
    if (!res.ok || !d.success) alert(d.error || "Error", "error");
    await load();
  }

  async function clearAll() {
    const res = await fetch("/api/carrito", {
      method: "DELETE", credentials: "include",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ clearAll: true }),
    });
    const d = await res.json().catch(() => ({}));
    if (!res.ok || !d.success) alert(d.error || "Error", "error");
    else alert("Carrito vaciado");
    await load();
  }

  async function checkAuth() {
    try {
      const r = await fetch("/api/me", { credentials: "include" });
      if (!r.ok) return null;
      const d = await r.json().catch(() => ({}));
      return d.success && d.user ? d.user : null;
    } catch { return null; }
  }

  /* ── Events ── */
  document.addEventListener("click", async (e) => {
    const btn = e.target instanceof Element ? e.target.closest("[data-do]") : null;
    if (!btn) return;
    const action = btn.dataset.do;
    const id = Number(btn.dataset.id);

    if (action === "remove") await removeItem(id);
    if (action === "plus") {
      const inp = document.querySelector(`input[data-id="${id}"]`);
      if (inp) await updateQty(id, Number(inp.value || 1) + 1);
    }
    if (action === "minus") {
      const inp = document.querySelector(`input[data-id="${id}"]`);
      if (inp) await updateQty(id, Math.max(1, Number(inp.value || 1) - 1));
    }
  });

  document.addEventListener("change", async (e) => {
    const inp = e.target;
    if (!(inp instanceof HTMLInputElement) || inp.dataset.do !== "qty") return;
    const id = Number(inp.dataset.id);
    const qty = Number(inp.value);
    if (!id || !qty || qty < 1) { await load(); return; }
    await updateQty(id, qty);
  });

  ctClear?.addEventListener("click", async () => {
    if (!items.length) { alert("El carrito ya está vacío", "error"); return; }
    const ok = await confirm("Vaciar carrito", "Se eliminarán todos los productos. ¿Continuar?");
    if (ok) await clearAll();
  });

  ctCheckout?.addEventListener("click", async () => {
    if (!items.length) { alert("No hay productos", "error"); return; }
    const user = await checkAuth();
    if (!user) {
      alert("Inicia sesión para continuar", "error");
      setTimeout(() => {
        window.location.href = `/${currentLang}/login?redirect=/${currentLang}/carrito`;
      }, 800);
      return;
    }
    const hasAddr = user.direccion || user.calle || user.ciudad || user.codigoPostal;
    if (!hasAddr) {
      alert("Agrega una dirección en Mi cuenta antes de continuar", "error");
      return;
    }
    window.location.href = `/${currentLang}/checkout`;
  });

  load();
})();
</script>

</BaseLayout>


