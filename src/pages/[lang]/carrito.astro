---
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }];
}
const currentLang = "es";
---

<BaseLayout title={`Carrito | NEXUS`} currentLang={currentLang}>
<div class="ct-root">
<main class="ct">

  <!-- Ambient glow -->
  <div class="ct-ambient"></div>

  {/* ── Header ── */}
  <header class="ct-head">
    <div class="ct-head__left">
      <a href={`/${currentLang}/productos/todos`} class="ct-back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        Seguir comprando
      </a>
      <div class="ct-head__title-group">
        <span class="ct-label">CARRITO DE COMPRAS</span>
        <h1 class="ct-title">Tu Carrito</h1>
      </div>
    </div>
    <div class="ct-head__right">
      <div class="ct-count-badge" id="ctCount">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
        <span>0 productos</span>
      </div>
    </div>
  </header>

  {/* ── Alert inline ── */}
  <div id="ctAlert" class="ct-alert" hidden></div>

  {/* ── Content: items + sidebar ── */}
  <div id="ctContent" class="ct-layout" hidden>

    {/* ── Items list ── */}
    <section id="ctItems" class="ct-items" aria-label="Productos en el carrito"></section>

    {/* ── Sidebar: resumen sticky ── */}
    <aside class="ct-sidebar">
      <div class="ct-summary">
        <div class="ct-summary__header">
          <h2 class="ct-summary__title">Resumen del Pedido</h2>
          <div class="ct-summary__icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          </div>
        </div>

        <div class="ct-summary__row">
          <span>Subtotal</span>
          <strong id="ctSubtotal">$0.00</strong>
        </div>

        <div class="ct-summary__row">
          <span>Envío</span>
          <span class="ct-summary__calc">Se calcula en checkout</span>
        </div>

        <div class="ct-summary__divider ct-summary__divider--glow"></div>

        <div class="ct-summary__row ct-summary__row--total">
          <span>Total estimado</span>
          <strong id="ctTotal">$0.00</strong>
        </div>

        <button id="ctCheckout" class="ct-btn ct-btn--primary" type="button" disabled>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          <span>Continuar al pago</span>
          <span class="ct-btn__arrow">→</span>
        </button>

        <button id="ctClear" class="ct-btn ct-btn--ghost" type="button">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
          Vaciar carrito
        </button>

        <div class="ct-badges">
          <div class="ct-badge">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Pago seguro
          </div>
          <div class="ct-badge">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            Envío rastreable
          </div>
          <div class="ct-badge">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            Garantía
          </div>
        </div>
      </div>
    </aside>
  </div>

  {/* ── Empty state ── */}
  <section id="ctEmpty" class="ct-empty" hidden>
    <div class="ct-empty__glow"></div>
    <div class="ct-empty__icon-wrap">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
    </div>
    <h2 class="ct-empty__title">Tu carrito está vacío</h2>
    <p class="ct-empty__sub">Agrega productos desde el catálogo para comenzar.</p>
    <a href={`/${currentLang}/productos/todos`} class="ct-btn ct-btn--primary ct-btn--inline">
      Ver catálogo
      <span class="ct-btn__arrow">→</span>
    </a>
  </section>

  {/* ── Confirm dialog ── */}
  <dialog id="ctDialog" class="ct-dialog">
    <div class="ct-dialog__card">
      <div class="ct-dialog__icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <h3 id="ctDialogTitle" class="ct-dialog__title"></h3>
      <p id="ctDialogMsg" class="ct-dialog__msg"></p>
      <div class="ct-dialog__actions">
        <button id="ctDialogCancel" class="ct-btn ct-btn--ghost ct-btn--sm" type="button">Cancelar</button>
        <button id="ctDialogOk" class="ct-btn ct-btn--danger ct-btn--sm" type="button">Confirmar</button>
      </div>
    </div>
  </dialog>

</main>
</div>

<style is:global>
  /* ═══════════════════════════════════════════════
     CART — ELITE VERCEL/APPLE/STRIPE AESTHETIC
     Fase 3 & 5: Minimalismo, Glassmorphism & Skeletons
     ═══════════════════════════════════════════════ */

  .ct-root {
    --ct-bg: #000000;
    --ct-surface: rgba(255, 255, 255, 0.02);
    --ct-surface-solid: #0a0a0a;
    --ct-surface-2: rgba(255, 255, 255, 0.05);
    --ct-border: rgba(255, 255, 255, 0.08);
    --ct-border-hover: rgba(255, 255, 255, 0.2);
    --ct-text: #ffffff;
    --ct-text-2: #888888;
    --ct-text-3: #444444;
    --ct-accent: var(--brand-accent, #ff453a);
    --ct-accent-glow: rgba(255, 69, 58, 0.15);
    --ct-danger: #ff453a;
    --ct-success: #32d74b;
    --ct-radius: 24px;
    --ct-radius-sm: 12px;
    --ct-shadow: 0 10px 40px rgba(0,0,0,0.5);
    --ct-shadow-glow: 0 0 30px var(--ct-accent-glow);

    background: var(--ct-bg);
    min-height: 100vh;
    position: relative;
    z-index: 1;
    overflow-x: hidden;
  }

  .ct-ambient {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60vw;
    height: 60vw;
    background: radial-gradient(circle, var(--ct-accent-glow) 0%, transparent 60%);
    pointer-events: none;
    z-index: -1;
    animation: ct-pulse-glow 10s ease-in-out infinite alternate;
  }
  @keyframes ct-pulse-glow {
    0% { transform: translate(-50%, -50%) scale(1); opacity: 0.5; }
    100% { transform: translate(-50%, -50%) scale(1.2); opacity: 1; }
  }

  .ct-root .ct {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 24px 100px;
    color: var(--ct-text);
    font-family: 'Inter', -apple-system, sans-serif;
    position: relative;
    z-index: 10;
  }

  .ct-root .ct-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 40px;
    border-bottom: 1px solid var(--ct-border);
    padding-bottom: 24px;
  }

  .ct-root .ct-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--ct-text-2);
    text-decoration: none;
    font-weight: 500;
    font-size: 14px;
    padding: 8px 16px;
    border-radius: 100px;
    background: transparent;
    border: 1px solid var(--ct-border);
    transition: all .3s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(10px);
  }
  .ct-root .ct-back:hover {
    color: var(--ct-text);
    border-color: var(--ct-border-hover);
    background: var(--ct-surface-2);
    transform: translateX(-4px);
  }

  .ct-root .ct-title {
    margin: 16px 0 0 0;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .ct-root .ct-count-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(20px);
    border: 1px solid var(--ct-border);
    border-radius: 100px;
    font-size: 14px;
    font-weight: 600;
    color: var(--ct-text);
    box-shadow: var(--ct-shadow);
  }
  .ct-root .ct-count-badge svg { color: var(--ct-accent); }

  .ct-root .ct-alert {
    padding: 16px 24px;
    border-radius: var(--ct-radius-sm);
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 24px;
    animation: ct-slideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    align-items: center;
    gap: 12px;
    backdrop-filter: blur(20px);
  }
  .ct-root .ct-alert[hidden] { display: none; }
  .ct-root .ct-alert.is-ok { background: rgba(50,215,75,0.1); border: 1px solid rgba(50,215,75,0.3); color: var(--ct-success); }
  .ct-root .ct-alert.is-error { background: rgba(255,69,58,0.1); border: 1px solid rgba(255,69,58,0.3); color: var(--ct-danger); }
  @keyframes ct-slideIn { from { opacity: 0; transform: translateY(-10px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }

  .ct-root .ct-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 40px;
    align-items: start;
  }

  .ct-root .ct-items {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ct-root .ct-item {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 24px;
    align-items: center;
    padding: 20px;
    background: var(--ct-surface);
    backdrop-filter: blur(20px);
    border: 1px solid var(--ct-border);
    border-radius: var(--ct-radius);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }
  .ct-root .ct-item:hover {
    border-color: var(--ct-border-hover);
    transform: translateY(-4px) scale(1.01);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4), inset 0 0 0 1px rgba(255,255,255,0.05);
    background: rgba(255,255,255,0.04);
  }

  .ct-root .ct-item__img-wrap {
    width: 100px;
    height: 100px;
    border-radius: 16px;
    background: #ffffff;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.1);
  }
  .ct-root .ct-item__img {
    width: 100%; height: 100%; object-fit: contain;
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    mix-blend-mode: multiply;
  }
  .ct-root .ct-item:hover .ct-item__img { transform: scale(1.15) rotate(-2deg); }

  .ct-root .ct-item__noimg {
    width: 100px; height: 100px; border-radius: 16px; background: var(--ct-surface-2); border: 1px solid var(--ct-border); display: flex; align-items: center; justify-content: center; color: var(--ct-text-3);
  }

  .ct-root .ct-item__info { min-width: 0; display: flex; flex-direction: column; gap: 6px; }
  .ct-root .ct-item__name { font-size: 18px; font-weight: 800; color: var(--ct-text); margin: 0; letter-spacing: -0.02em; line-height: 1.2; }
  .ct-root .ct-item__price { font-size: 14px; color: var(--ct-text-2); margin: 0; display: flex; align-items: center; gap: 6px; }
  .ct-root .ct-item__price-tag { font-weight: 700; color: var(--ct-text); font-size: 15px; }

  .ct-root .ct-item__actions { display: flex; align-items: center; gap: 24px; flex-shrink: 0; }

  .ct-root .ct-qty {
    display: flex; align-items: center; border: 1px solid var(--ct-border); border-radius: 100px; overflow: hidden; height: 40px; background: rgba(0,0,0,0.2); transition: border-color .3s;
  }
  .ct-root .ct-qty:hover { border-color: var(--ct-border-hover); }
  .ct-root .ct-qty:focus-within { border-color: var(--ct-accent); box-shadow: 0 0 0 2px var(--ct-accent-glow); }

  .ct-root .ct-qty__btn {
    width: 40px; height: 100%; border: none; background: transparent; color: var(--ct-text-2); font-size: 18px; cursor: pointer; transition: all .2s; display: grid; place-items: center;
  }
  .ct-root .ct-qty__btn:hover { background: var(--ct-surface-2); color: var(--ct-text); }
  .ct-root .ct-qty__btn:active { transform: scale(.9); }

  .ct-root .ct-qty__input {
    width: 40px; height: 100%; border: none; border-left: 1px solid var(--ct-border); border-right: 1px solid var(--ct-border); text-align: center; font-size: 14px; font-weight: 700; color: var(--ct-text); background: transparent; outline: none; -moz-appearance: textfield;
  }
  .ct-root .ct-qty__input::-webkit-inner-spin-button, .ct-root .ct-qty__input::-webkit-outer-spin-button { display: none; }

  .ct-root .ct-item__subtotal {
    font-size: 18px; font-weight: 900; color: var(--ct-text); min-width: 100px; text-align: right; letter-spacing: -0.02em;
  }

  .ct-root .ct-item__remove {
    width: 40px; height: 40px; display: grid; place-items: center; background: none; border: 1px solid transparent; color: var(--ct-text-3); cursor: pointer; border-radius: 50%; transition: all .3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ct-root .ct-item__remove:hover { color: var(--ct-danger); background: rgba(255,69,58,0.1); border-color: rgba(255,69,58,0.3); transform: rotate(10deg); }

  .ct-root .ct-sidebar { position: sticky; top: 120px; }

  .ct-root .ct-summary {
    background: rgba(20, 20, 20, 0.6);
    backdrop-filter: blur(30px);
    border: 1px solid var(--ct-border);
    border-radius: var(--ct-radius);
    padding: 32px;
    box-shadow: 0 30px 60px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.05);
  }

  .ct-root .ct-summary__header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
  .ct-root .ct-summary__title { font-size: 18px; font-weight: 800; margin: 0; color: var(--ct-text); letter-spacing: -0.02em; }
  
  .ct-root .ct-summary__icon {
    width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.05); border-radius: 12px; border: 1px solid var(--ct-border);
  }

  .ct-root .ct-summary__row { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; font-size: 15px; color: var(--ct-text-2); }
  .ct-root .ct-summary__row strong { color: var(--ct-text); font-weight: 800; font-size: 16px; }
  .ct-root .ct-summary__calc { font-size: 12px; color: var(--ct-text-3); }

  .ct-root .ct-summary__divider { height: 1px; background: var(--ct-border); margin: 16px 0; }

  .ct-root .ct-summary__row--total { font-size: 20px; font-weight: 900; padding: 16px 0 24px; }
  .ct-root .ct-summary__row--total span { color: var(--ct-text); }
  .ct-root .ct-summary__row--total strong { font-size: 28px; letter-spacing: -0.04em; }

  .ct-root .ct-badges { display: flex; flex-direction: column; gap: 12px; margin-top: 24px; }
  .ct-root .ct-badge { display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--ct-text-2); font-weight: 500; }
  .ct-root .ct-badge svg { opacity: .5; }

  .ct-root .ct-btn {
    display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; padding: 16px 24px; border: none; border-radius: 100px; font-size: 15px; font-weight: 800; cursor: pointer; transition: all .4s cubic-bezier(0.16, 1, 0.3, 1); text-decoration: none; color: #000; position: relative; overflow: hidden;
  }

  .ct-root .ct-btn--primary { background: #ffffff; box-shadow: 0 10px 30px rgba(255,255,255,0.15); color: #000; }
  .ct-root .ct-btn--primary:hover:not(:disabled) { transform: translateY(-4px) scale(1.02); box-shadow: 0 15px 40px rgba(255,255,255,0.25); }
  .ct-root .ct-btn--primary:active:not(:disabled) { transform: translateY(0) scale(0.98); }
  .ct-root .ct-btn--primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  .ct-root .ct-btn__arrow { font-size: 18px; transition: transform .3s; }
  .ct-root .ct-btn--primary:hover:not(:disabled) .ct-btn__arrow { transform: translateX(6px); }

  .ct-root .ct-btn--ghost { background: transparent; color: var(--ct-text-2); margin-top: 12px; border: 1px solid transparent; font-size: 14px; }
  .ct-root .ct-btn--ghost:hover { color: var(--ct-danger); background: rgba(255,69,58,0.05); }

  .ct-root .ct-empty { text-align: center; padding: 100px 24px; background: transparent; max-width: 500px; margin: 40px auto; position: relative; }
  .ct-root .ct-empty__glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 400px; height: 400px; background: radial-gradient(circle, var(--ct-accent-glow) 0%, transparent 70%); pointer-events: none; z-index: -1; animation: ct-pulse-glow 4s infinite alternate; }
  .ct-root .ct-empty__icon-wrap { width: 100px; height: 100px; margin: 0 auto 24px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.03); border: 1px solid var(--ct-border); border-radius: 50%; color: var(--ct-text); backdrop-filter: blur(20px); }
  .ct-root .ct-empty__icon-wrap svg { width: 40px; height: 40px; }
  .ct-root .ct-empty__title { font-size: 32px; font-weight: 900; margin: 0 0 12px; color: var(--ct-text); letter-spacing: -0.03em; }
  .ct-root .ct-empty__sub { font-size: 16px; color: var(--ct-text-2); margin: 0 0 32px; line-height: 1.5; }
  .ct-root .ct-empty .ct-btn--primary { width: auto; padding: 16px 40px; }

  .ct-skeleton { animation: ct-shimmer 2s infinite linear; background: linear-gradient(90deg, var(--ct-surface-2) 0%, rgba(255,255,255,0.08) 50%, var(--ct-surface-2) 100%); background-size: 200% 100%; border-radius: 8px; }
  @keyframes ct-shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }

  .ct-root .ct-dialog { border: none; border-radius: var(--ct-radius); background: transparent; padding: 0; max-width: 440px; width: calc(100% - 32px); }
  .ct-root .ct-dialog::backdrop { background: rgba(0,0,0,0.8); backdrop-filter: blur(10px); }
  .ct-root .ct-dialog__card { background: #111; border: 1px solid var(--ct-border); border-radius: var(--ct-radius); padding: 32px; text-align: center; box-shadow: 0 40px 80px rgba(0,0,0,0.8); }
  .ct-root .ct-dialog__title { font-size: 20px; font-weight: 800; margin: 0 0 12px; color: #fff; }
  .ct-root .ct-dialog__msg { font-size: 15px; color: #888; margin: 0; line-height: 1.5; }
  .ct-root .ct-dialog__actions { display: flex; justify-content: center; gap: 12px; margin-top: 32px; }
  .ct-root .ct-dialog .ct-btn { width: auto; padding: 12px 24px; font-size: 14px; }
  .ct-root .ct-btn--danger { background: var(--ct-danger); color: #fff; }

  @media (max-width: 900px) {
    .ct-root .ct { padding: 30px 16px 180px; }
    .ct-root .ct-layout { grid-template-columns: 1fr; gap: 24px; }
    .ct-root .ct-item { grid-template-columns: 80px 1fr; grid-template-rows: auto auto; padding: 16px; gap: 16px; }
    .ct-root .ct-item__img-wrap { width: 80px; height: 80px; grid-row: span 2; }
    .ct-root .ct-item__actions { grid-column: 2; justify-content: space-between; width: 100%; gap: 12px; }
    .ct-root .ct-item__subtotal { font-size: 16px; min-width: auto; }
    
    .ct-root .ct-sidebar { position: fixed; bottom: 0; left: 0; width: 100%; z-index: 50; margin: 0; padding: 0; }
    .ct-root .ct-summary { border-radius: 24px 24px 0 0; border: none; border-top: 1px solid var(--ct-border); padding: 20px 24px 30px; background: rgba(10,10,10,0.85); backdrop-filter: blur(40px); }
    .ct-root .ct-summary__header, .ct-root .ct-summary__divider, .ct-root .ct-badges { display: none; }
    .ct-root .ct-summary__row { padding: 4px 0; }
    .ct-root .ct-summary__row--total { padding: 8px 0 16px; }
    .ct-root .ct-btn--ghost { position: absolute; top: -50px; right: 16px; background: rgba(0,0,0,0.6); backdrop-filter: blur(10px); border-radius: 100px; padding: 8px 16px; }
  }
</style>

<script is:inline define:vars={{ currentLang }}>
(function () {
  const $ = (s) => document.getElementById(s);
  const ctItems = $("ctItems");
  const ctContent = $("ctContent");
  const ctEmpty = $("ctEmpty");
  const ctAlert = $("ctAlert");
  const ctCount = $("ctCount");
  const ctSubtotal = $("ctSubtotal");
  const ctTotal = $("ctTotal");
  const ctCheckout = $("ctCheckout");
  const ctClear = $("ctClear");
  const ctDialog = $("ctDialog");
  const ctDialogTitle = $("ctDialogTitle");
  const ctDialogMsg = $("ctDialogMsg");
  const ctDialogCancel = $("ctDialogCancel");
  const ctDialogOk = $("ctDialogOk");

  let items = [];
  let total = 0;
  let dialogCallback = null;

  const money = (v) => `$${Number(v || 0).toLocaleString("es-MX", { minimumFractionDigits: 2, maximumFractionDigits: 2 })} MXN`;

  const esc = (s) => s ? s.replace(/[&<>"]/g, (m) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[m])) : "";

  const imgSrc = (s) => {
    if (!s) return null;
    if (s.startsWith("http") || s.startsWith("/")) return s;
    return `/images/${s}`;
  };

  function alert(msg, type = "ok") {
    if (!ctAlert) return;
    ctAlert.hidden = false;
    ctAlert.textContent = msg;
    ctAlert.className = `ct-alert is-${type}`;
    setTimeout(() => { ctAlert.hidden = true; }, 2500);
  }

  function confirm(title, msg) {
    return new Promise((resolve) => {
      if (!ctDialog || !ctDialogTitle || !ctDialogMsg) { resolve(false); return; }
      ctDialogTitle.textContent = title;
      ctDialogMsg.textContent = msg;
      dialogCallback = resolve;
      ctDialog.showModal();
    });
  }

  ctDialogCancel?.addEventListener("click", () => {
    ctDialog?.close();
    if (dialogCallback) { dialogCallback(false); dialogCallback = null; }
  });
  ctDialogOk?.addEventListener("click", () => {
    ctDialog?.close();
    if (dialogCallback) { dialogCallback(true); dialogCallback = null; }
  });
  ctDialog?.addEventListener("close", () => {
    if (dialogCallback) { dialogCallback(false); dialogCallback = null; }
  });

  /* ── Skeletons ── */
  function renderSkeletons() {
    if (ctContent) ctContent.hidden = false;
    if (ctEmpty) ctEmpty.hidden = true;
    if (ctCheckout) ctCheckout.disabled = true;
    if (ctCount) ctCount.querySelector("span").textContent = "Cargando...";
    if (ctItems) {
      ctItems.innerHTML = Array(3).fill(0).map(() => 
        `<div class="ct-item">
          <div class="ct-skeleton" style="width: 100px; height: 100px; border-radius: 16px;"></div>
          <div class="ct-item__info">
            <div class="ct-skeleton" style="width: 70%; height: 20px; margin-bottom: 8px;"></div>
            <div class="ct-skeleton" style="width: 40%; height: 16px;"></div>
          </div>
          <div class="ct-item__actions">
            <div class="ct-skeleton" style="width: 120px; height: 40px; border-radius: 100px;"></div>
            <div class="ct-skeleton" style="width: 80px; height: 24px;"></div>
            <div class="ct-skeleton" style="width: 40px; height: 40px; border-radius: 50%;"></div>
          </div>
        </div>`
      ).join("");
    }
  }

  /* ── Render ── */
  function render() {
    if (!items.length) {
      if (ctContent) ctContent.hidden = true;
      if (ctEmpty) ctEmpty.hidden = false;
      if (ctCount) ctCount.querySelector("span").textContent = "0 productos";
      return;
    }

    if (ctContent) ctContent.hidden = false;
    if (ctEmpty) ctEmpty.hidden = true;
    if (ctCount) ctCount.querySelector("span").textContent = `${items.length} producto${items.length !== 1 ? "s" : ""}`;
    if (ctSubtotal) ctSubtotal.textContent = money(total);
    if (ctTotal) ctTotal.textContent = money(total);
    if (ctCheckout) ctCheckout.disabled = false;

    if (!ctItems) return;
    ctItems.innerHTML = items.map((it, idx) => {
      const img = imgSrc(it.imagen);
      return `
        <div class="ct-item" data-id="${it.itemId}" style="animation: ct-itemIn .3s ease ${idx * .05}s both;">
          ${img
            ? `<div class="ct-item__img-wrap"><img class="ct-item__img" src="${img}" alt="${esc(it.nombre)}" loading="lazy"/></div>`
            : `<div class="ct-item__noimg"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>`
          }
          <div class="ct-item__info">
            <p class="ct-item__name">${esc(it.nombre)}</p>
            <p class="ct-item__price"><span class="ct-item__price-tag">${money(it.precioUnitario)}</span> <span style="color:var(--ct-text-3);font-size:11px;">c/u</span></p>
          </div>
          <div class="ct-item__actions">
            <div class="ct-qty">
              <button class="ct-qty__btn" data-do="minus" data-id="${it.itemId}" type="button" aria-label="Menos">−</button>
              <input class="ct-qty__input" type="number" min="1" value="${it.cantidad}" data-do="qty" data-id="${it.itemId}" aria-label="Cantidad"/>
              <button class="ct-qty__btn" data-do="plus" data-id="${it.itemId}" type="button" aria-label="Más">+</button>
            </div>
            <span class="ct-item__subtotal">${money(it.subtotal)}</span>
            <button class="ct-item__remove" data-do="remove" data-id="${it.itemId}" type="button" aria-label="Eliminar">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
            </button>
          </div>
        </div>`;
    }).join("");

    // inject animation keyframes if not present
    if (!document.getElementById('ct-item-anim')) {
      const s = document.createElement('style');
      s.id = 'ct-item-anim';
      s.textContent = `@keyframes ct-itemIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }`;
      document.head.appendChild(s);
    }
  }

  /* ── API ── */
  async function load() {
    try {
      const res = await fetch("/api/carrito", { credentials: "include" });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.success) { alert(data.error || "Error al cargar", "error"); return; }
      items = data.items || [];
      total = Number(data.summary?.total || 0);
      render();
    } catch { alert("Error de conexión", "error"); }
  }

  async function updateQty(id, qty) {
    const res = await fetch("/api/carrito", {
      method: "PUT", credentials: "include",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ itemId: id, cantidad: qty }),
    });
    const d = await res.json().catch(() => ({}));
    if (!res.ok || !d.success) alert(d.error || "Error", "error");
    await load();
  }

  async function removeItem(id) {
    const res = await fetch("/api/carrito", {
      method: "DELETE", credentials: "include",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ itemId: id }),
    });
    const d = await res.json().catch(() => ({}));
    if (!res.ok || !d.success) alert(d.error || "Error", "error");
    await load();
  }

  async function clearAll() {
    const res = await fetch("/api/carrito", {
      method: "DELETE", credentials: "include",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ clearAll: true }),
    });
    const d = await res.json().catch(() => ({}));
    if (!res.ok || !d.success) alert(d.error || "Error", "error");
    else alert("Carrito vaciado");
    await load();
  }

  async function checkAuth() {
    try {
      const r = await fetch("/api/me", { credentials: "include" });
      if (!r.ok) return null;
      const d = await r.json().catch(() => ({}));
      return d.success && d.user ? d.user : null;
    } catch { return null; }
  }

  /* ── Events ── */
  document.addEventListener("click", async (e) => {
    const btn = e.target instanceof Element ? e.target.closest("[data-do]") : null;
    if (!btn) return;
    const action = btn.dataset.do;
    const id = Number(btn.dataset.id);

    if (action === "remove") await removeItem(id);
    if (action === "plus") {
      const inp = document.querySelector(`input[data-id="${id}"]`);
      if (inp) await updateQty(id, Number(inp.value || 1) + 1);
    }
    if (action === "minus") {
      const inp = document.querySelector(`input[data-id="${id}"]`);
      if (inp) await updateQty(id, Math.max(1, Number(inp.value || 1) - 1));
    }
  });

  document.addEventListener("change", async (e) => {
    const inp = e.target;
    if (!(inp instanceof HTMLInputElement) || inp.dataset.do !== "qty") return;
    const id = Number(inp.dataset.id);
    const qty = Number(inp.value);
    if (!id || !qty || qty < 1) { await load(); return; }
    await updateQty(id, qty);
  });

  ctClear?.addEventListener("click", async () => {
    if (!items.length) { alert("El carrito ya está vacío", "error"); return; }
    const ok = await confirm("Vaciar carrito", "Se eliminarán todos los productos. ¿Continuar?");
    if (ok) await clearAll();
  });

  ctCheckout?.addEventListener("click", async () => {
    if (!items.length) { alert("No hay productos", "error"); return; }
    const user = await checkAuth();
    if (!user) {
      alert("Inicia sesión para continuar", "error");
      setTimeout(() => {
        window.location.href = `/${currentLang}/login?redirect=/${currentLang}/carrito`;
      }, 800);
      return;
    }
    const hasAddr = user.direccion || user.calle || user.ciudad || user.codigoPostal;
    if (!hasAddr) {
      alert("Agrega una dirección en Mi cuenta antes de continuar", "error");
      return;
    }
    window.location.href = `/${currentLang}/checkout`;
  });

  load();
})();
</script>

</BaseLayout>


