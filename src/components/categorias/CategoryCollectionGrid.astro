---
import type { CategoryProduct } from "./types";

interface Props {
  products: CategoryProduct[];
}

const { products } = Astro.props;
---

<section class="catx-grid premium-shell fade-slide-in" aria-labelledby="catx-grid-title">
  <div class="catx-grid__head">
    <h2 id="catx-grid-title">Explora por categoria</h2>
    <p>Una navegacion clara para acelerar la busqueda de productos y aumentar conversion.</p>
  </div>

  <div class="catx-grid__items">
    {products.map((product) => (
      <article class="catx-product-card premium-card">
        <a href={product.href} class="catx-product-card__link" aria-label={product.title}>
          <div class="catx-product-card__media">
            <img src={product.image} alt={product.title} loading="lazy" decoding="async" />
          </div>
          <div class="catx-product-card__body">
            <p class="catx-product-card__division">{product.division}</p>
            <h3>{product.title}</h3>
            <p>{product.description}</p>
            <div class="catx-product-card__foot">
              <strong>{product.priceLabel || "Cotiza este producto"}</strong>
              <span>Ver detalle</span>
            </div>
          </div>
        </a>
      </article>
    ))}
  </div>
</section>

<style>
  .catx-grid {
    margin-top: 24px;
    padding-bottom: 28px;
  }

  .catx-grid__head h2 {
    margin: 0;
    color: #f8f8fa;
    font-size: clamp(1.3rem, 2.6vw, 2rem);
    letter-spacing: -0.02em;
  }

  .catx-grid__head p {
    margin: 8px 0 0;
    color: rgba(210, 210, 218, 0.8);
    max-width: 62ch;
  }

  .catx-grid__items {
    margin-top: 14px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .catx-product-card {
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: linear-gradient(165deg, rgba(20, 20, 24, 0.92), rgba(10, 10, 14, 0.9));
    overflow: hidden;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .catx-product-card:hover {
    transform: translateY(-3px);
    border-color: rgba(251, 140, 55, 0.46);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .catx-product-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .catx-product-card__media {
    min-height: 190px;
    padding: 14px;
    display: grid;
    place-items: center;
    background: radial-gradient(120% 100% at 50% 0%, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.015));
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .catx-product-card__media img {
    max-width: 100%;
    max-height: 170px;
    object-fit: contain;
    filter: drop-shadow(0 12px 28px rgba(0, 0, 0, 0.38));
  }

  .catx-product-card__body {
    padding: 14px;
    display: grid;
    gap: 8px;
  }

  .catx-product-card__division {
    margin: 0;
    color: rgba(255, 192, 153, 0.86);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }

  .catx-product-card__body h3 {
    margin: 0;
    color: #fff;
    font-size: 1rem;
    line-height: 1.28;
    letter-spacing: -0.01em;
  }

  .catx-product-card__body p {
    margin: 0;
    color: rgba(208, 208, 216, 0.78);
    line-height: 1.58;
    font-size: 0.86rem;
  }

  .catx-product-card__foot {
    margin-top: 4px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .catx-product-card__foot strong {
    color: #ffdfcb;
    font-size: 0.86rem;
  }

  .catx-product-card__foot span {
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 999px;
    min-height: 30px;
    padding: 0 10px;
    display: inline-flex;
    align-items: center;
  }

  @media (max-width: 1120px) {
    .catx-grid__items {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .catx-grid__items {
      grid-template-columns: 1fr;
    }
  }
</style>
