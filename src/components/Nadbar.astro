---
import LoginLogoutButton from "./LoginLogoutButton.jsx";

export interface Props {
  currentLang: "es" | "en";
  moveLogoMobile?: boolean;
}

const { currentLang, moveLogoMobile = false } = Astro.props;
const locals = Astro.locals as any;
const session = locals?.user ?? null;

const navItems = [
  { name: "Inicio", href: `/${currentLang}/` },
  { name: "Productos", href: `/${currentLang}/productos/todos` },
  { name: "Categorías", href: `/${currentLang}/categorias` },
  { name: "Descuentos", href: `/${currentLang}/descuentos` },
  { name: "Flash", href: `/${currentLang}/flash-descuentos` },
];

const { pathname } = Astro.url;

const isRouteActive = (route: string) => {
  if (route === `/${currentLang}/`) {
    return pathname === `/${currentLang}/` || pathname === "/";
  }
  return pathname.startsWith(route);
};
---

<header class="premium-navbar" data-lang={currentLang}>
  <div class="premium-navbar__container">
    <div class="premium-navbar__left">
      <button
        id="mobile-menu-toggle"
        class="premium-navbar__mobile-menu-btn"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 7h16"></path><path d="M4 12h16"></path><path d="M4 17h16"></path>
        </svg>
      </button>
      <a href={`/${currentLang}/`} class="premium-navbar__logo">
        <svg class="nexus-logo" width="100" height="40" viewBox="0 0 100 40" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" style="stop-color:var(--brand-primary-color);stop-opacity:1"></stop>
              <stop offset="100%" style="stop-color:var(--brand-secondary-color);stop-opacity:1"></stop>
            </linearGradient>
          </defs>
          <path class="nexus-logo__n" d="M10 30 L 10 10 L 20 25 L 20 10 L 30 30 L 30 10" stroke="url(#grad1)" stroke-width="4" fill="none"></path>
          <path class="nexus-logo__exus" d="M35 10 L 45 30 M 35 30 L 45 10 M 50 10 L 60 20 L 50 30 M 65 10 L 75 30 M 65 20 L 75 20 M 80 10 C 90 10, 90 30, 80 30 M 80 20 L 85 20" stroke="var(--nadbar-text-color)" stroke-width="3" fill="none"></path>
        </svg>
      </a>
    </div>

    <!-- ═══ SEARCH ═══ -->
    <div class="premium-navbar__center">
      <div class="premium-navbar__search-container">
        <form class="gs" role="search" onsubmit="return false;" data-global-search>
          <div class="gs__bar">
            <svg class="gs__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
            <input
              type="search"
              class="gs__input"
              placeholder="Buscar productos, categorías..."
              aria-label="Buscar en el sitio"
              autocomplete="off"
              data-search-input
            />
            <button type="button" class="gs__clear" data-search-clear aria-label="Limpiar búsqueda" hidden>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>
              </svg>
            </button>
            <div class="gs__spinner" data-search-spinner hidden>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5" opacity="0.2"></circle>
                <path d="M14.5 8a6.5 6.5 0 0 0-6.5-6.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
              </svg>
            </div>
            <kbd class="gs__kbd" data-search-kbd>/</kbd>
          </div>

          <div class="gs__panel" data-search-panel hidden>
            <p class="gs__hint" data-search-hint hidden></p>
            <div class="gs__section" data-search-trending hidden>
              <p class="gs__section-title" data-section-title-trending>Búsquedas populares</p>
              <div class="gs__chips" data-search-trending-list></div>
            </div>
            <div class="gs__section" data-search-products hidden>
              <p class="gs__section-title">Productos</p>
              <div class="gs__results" data-search-products-list></div>
            </div>
            <div class="gs__section" data-search-categories hidden>
              <p class="gs__section-title">Categorías</p>
              <div class="gs__results" data-search-categories-list></div>
            </div>
            <a class="gs__viewall" data-search-view-all href="#">
              <span>Ver todos los resultados</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </form>
      </div>
    </div>

    <div class="premium-navbar__right">
      <nav class="premium-navbar__nav">
        <ul class="premium-navbar__nav-list">
          {
            navItems.map((item) => (
              <li class="premium-navbar__nav-item nav-item-group">
                <a
                  href={item.href}
                  class:list={['premium-navbar__nav-link', { active: isRouteActive(item.href) }]}>
                  {item.name}
                </a>
                {item.name === 'Productos' && (
                  <div class="nav-dropdown">
                    <a class="nav-dropdown__item" href={`/${currentLang}/productos/categoria/vasos`}>Vasos</a>
                    <a class="nav-dropdown__item" href={`/${currentLang}/productos/categoria/figuras`}>Figuras</a>
                    <a class="nav-dropdown__item" href={`/${currentLang}/productos/categoria/accesorios`}>Accesorios</a>
                  </div>
                )}
              </li>
            ))
          }
        </ul>
      </nav>
      <div class="premium-navbar__actions">
        <a href={`/${currentLang}/carrito`} class="premium-navbar__cart-btn" aria-label="Carrito">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 19m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"></path>
            <path d="M17 19m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"></path>
            <path d="M17 17h-11v-14h-2"></path>
            <path d="M6 5l14 1l-1 7h-13"></path>
          </svg>
          <span class="premium-navbar__cart-count">0</span>
        </a>
        <button class="premium-navbar__theme-toggle" aria-label="Cambiar tema">
          <svg class="sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M3 12h1m8 -9v1m8 8h1m-9 8v1m-6.364 -14.364l.707 .707m12.727 0l-.707 .707m0 12.727l.707 .707m-12.727 0l-.707 .707"></path>
          </svg>
          <svg class="moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z"></path>
          </svg>
        </button>
        <LoginLogoutButton client:load initialUser={session} currentLang={currentLang} />
      </div>
    </div>
  </div>

  <!-- ═══ MOBILE PANEL ═══ -->
  <div id="mobile-nav-panel" class="premium-navbar__mobile-panel" hidden>
    <div class="premium-navbar__mobile-panel-content">
      <form class="gs gs--mobile" role="search" onsubmit="return false;" data-global-search>
        <div class="gs__bar">
          <svg class="gs__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          <input
            type="search"
            class="gs__input"
            placeholder="Buscar productos..."
            aria-label="Buscar en el sitio"
            autocomplete="off"
            data-search-input
          />
          <button type="button" class="gs__clear" data-search-clear aria-label="Limpiar" hidden>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>
            </svg>
          </button>
          <div class="gs__spinner" data-search-spinner hidden>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5" opacity="0.2"></circle>
              <path d="M14.5 8a6.5 6.5 0 0 0-6.5-6.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
            </svg>
          </div>
        </div>
        <div class="gs__panel" data-search-panel hidden>
          <p class="gs__hint" data-search-hint hidden></p>
          <div class="gs__section" data-search-trending hidden>
            <p class="gs__section-title" data-section-title-trending>Búsquedas populares</p>
            <div class="gs__chips" data-search-trending-list></div>
          </div>
          <div class="gs__section" data-search-products hidden>
            <p class="gs__section-title">Productos</p>
            <div class="gs__results" data-search-products-list></div>
          </div>
          <div class="gs__section" data-search-categories hidden>
            <p class="gs__section-title">Categorías</p>
            <div class="gs__results" data-search-categories-list></div>
          </div>
          <a class="gs__viewall" data-search-view-all href="#">
            <span>Ver todos los resultados</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </form>
      <nav class="premium-navbar__mobile-nav">
        <ul>
          {
            navItems.map((item) => (
              <li>
                <a href={item.href} class:list={[{ active: isRouteActive(item.href) }]}>{item.name}</a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  // @ts-nocheck
  function initPremiumNavbar() {
    const header = document.querySelector(".premium-navbar");
    if (!(header instanceof HTMLElement)) return;
    if (header.dataset.navReady === "1") return;
    header.dataset.navReady = "1";

    const currentLang = header.dataset.lang || "es";
    const mobileToggle = document.getElementById("mobile-menu-toggle");
    const mobilePanel = document.getElementById("mobile-nav-panel");
    const themeBtn = header.querySelector(".premium-navbar__theme-toggle");

    const applyTheme = (isDark) => {
      if (isDark) {
        document.documentElement.classList.add("dark");
        localStorage.setItem("theme", "dark");
      } else {
        document.documentElement.classList.remove("dark");
        localStorage.setItem("theme", "light");
      }
    };

    const storedTheme = localStorage.getItem("theme");
    applyTheme(storedTheme === "dark");

    if (themeBtn instanceof HTMLButtonElement) {
      themeBtn.addEventListener("click", () => {
        const isDark = document.documentElement.classList.contains("dark");
        applyTheme(!isDark);
      });
    }

    const onScroll = () => {
      if (!(header instanceof HTMLElement)) return;
      header.classList.toggle("is-scrolled", window.scrollY > 8);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    if (mobileToggle instanceof HTMLButtonElement && mobilePanel instanceof HTMLElement) {
      mobileToggle.addEventListener("click", () => {
        const isOpen = !mobilePanel.hidden;
        mobilePanel.hidden = isOpen;
        mobileToggle.setAttribute("aria-expanded", String(!isOpen));
        document.body.classList.toggle("no-scroll", !isOpen);
      });
      mobilePanel.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          mobilePanel.hidden = true;
          mobileToggle.setAttribute("aria-expanded", "false");
          document.body.classList.remove("no-scroll");
        });
      });
    }

    // "/" keyboard shortcut
    document.addEventListener("keydown", (e) => {
      if (e.key === "/" && !["INPUT", "TEXTAREA", "SELECT"].includes(document.activeElement?.tagName || "")) {
        e.preventDefault();
        var fi = header.querySelector(".gs__input");
        if (fi instanceof HTMLInputElement) fi.focus();
      }
    });

    // ── Search ──
    var forms = Array.from(header.querySelectorAll("[data-global-search]")).filter(
      function(f) { return f instanceof HTMLFormElement; }
    );
    if (!forms.length) return;

    var fallbackImg = "https://res.cloudinary.com/dfuzfdrat/image/upload/v1772744553/logob_pw3jsd.png";
    var categoriesCache = null;
    var trendingTerms = ["Película Stretch", "Esquineros", "Bolsa de Malla", "Cinta Adhesiva", "Rafia", "Empaque Flexible"];

    function escapeHtml(v) {
      return String(v || "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }

    function normalize(v) {
      return String(v || "").toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    }

    function debounce(fn, delay) {
      var timer = null;
      return function() {
        var args = arguments;
        if (timer) clearTimeout(timer);
        timer = setTimeout(function() { fn.apply(null, args); }, delay || 220);
      };
    }

    function fetchCategories() {
      if (Array.isArray(categoriesCache)) return Promise.resolve(categoriesCache);
      return fetch("/api/categorias", { credentials: "same-origin" })
        .then(function(r) { return r.json().catch(function() { return {}; }); })
        .then(function(data) {
          categoriesCache = Array.isArray(data?.categorias)
            ? data.categorias.map(function(c) {
                return { id: Number(c.Id_Categoria || 0), nombre: String(c.Nombre || ""), imagen: String(c.Imagen_URL || "").trim() || fallbackImg };
              })
            : [];
          return categoriesCache;
        });
    }

    function closePanels() {
      forms.forEach(function(form) {
        var p = form.querySelector("[data-search-panel]");
        if (p instanceof HTMLElement) p.hidden = true;
        form.classList.remove("gs--open");
      });
    }

    function highlightMatch(text, query) {
      if (!query || query.length < 2) return escapeHtml(text);
      var qNorm = normalize(query);
      var tNorm = normalize(text);
      var idx = tNorm.indexOf(qNorm);
      if (idx === -1) return escapeHtml(text);
      return escapeHtml(text.slice(0, idx)) + '<mark class="gs-mark">' + escapeHtml(text.slice(idx, idx + query.length)) + '</mark>' + escapeHtml(text.slice(idx + query.length));
    }

    forms.forEach(function(form) {
      var input = form.querySelector("[data-search-input]");
      var panel = form.querySelector("[data-search-panel]");
      var hint = form.querySelector("[data-search-hint]");
      var productsSection = form.querySelector("[data-search-products]");
      var categoriesSection = form.querySelector("[data-search-categories]");
      var productsList = form.querySelector("[data-search-products-list]");
      var categoriesList = form.querySelector("[data-search-categories-list]");
      var viewAll = form.querySelector("[data-search-view-all]");
      var clearBtn = form.querySelector("[data-search-clear]");
      var spinner = form.querySelector("[data-search-spinner]");
      var kbd = form.querySelector("[data-search-kbd]");
      var trendingSection = form.querySelector("[data-search-trending]");
      var trendingList = form.querySelector("[data-search-trending-list]");

      if (!(input instanceof HTMLInputElement)) return;
      if (!(panel instanceof HTMLElement)) return;
      if (!(productsSection instanceof HTMLElement)) return;
      if (!(categoriesSection instanceof HTMLElement)) return;
      if (!(productsList instanceof HTMLElement)) return;
      if (!(categoriesList instanceof HTMLElement)) return;
      if (!(viewAll instanceof HTMLAnchorElement)) return;

      var activeIndex = -1;

      // Trending chips
      if (trendingList instanceof HTMLElement) {
        trendingList.innerHTML = trendingTerms.map(function(term) {
          return '<button type="button" class="gs-chip" data-trending-term="' + escapeHtml(term) + '">' + escapeHtml(term) + '</button>';
        }).join("");

        trendingList.addEventListener("click", function(e) {
          var chip = e.target.closest("[data-trending-term]");
          if (!chip) return;
          input.value = chip.dataset.trendingTerm;
          input.dispatchEvent(new Event("input"));
        });
      }

      // Clear
      if (clearBtn instanceof HTMLButtonElement) {
        clearBtn.addEventListener("click", function() {
          input.value = "";
          clearBtn.hidden = true;
          if (kbd instanceof HTMLElement) kbd.hidden = false;
          input.focus();
          showInitialState();
        });
      }

      function updateClearVisibility() {
        var has = input.value.trim().length > 0;
        if (clearBtn instanceof HTMLElement) clearBtn.hidden = !has;
        if (kbd instanceof HTMLElement) kbd.hidden = has;
      }

      function getOptions() {
        return Array.from(panel.querySelectorAll("[data-s-option]")).filter(function(el) { return el instanceof HTMLAnchorElement; });
      }

      function updateKeyboardFocus() {
        var opts = getOptions();
        opts.forEach(function(node, i) {
          var active = i === activeIndex;
          node.classList.toggle("is-active", active);
          if (active) node.scrollIntoView({ block: "nearest" });
        });
      }

      function showInitialState() {
        productsSection.hidden = true;
        categoriesSection.hidden = true;
        if (hint instanceof HTMLElement) { hint.textContent = "Escribe para buscar productos y categorías"; hint.hidden = false; }
        if (trendingSection instanceof HTMLElement) trendingSection.hidden = false;
        viewAll.href = "/" + currentLang + "/productos/todos";
        panel.hidden = false;
        form.classList.add("gs--open");
      }

      function renderResults(rawValue) {
        var q = String(rawValue || "").trim();
        activeIndex = -1;

        if (q.length < 2) { showInitialState(); return; }

        panel.hidden = false;
        form.classList.add("gs--open");
        if (trendingSection instanceof HTMLElement) trendingSection.hidden = true;
        if (spinner instanceof HTMLElement) spinner.hidden = false;
        if (hint instanceof HTMLElement) hint.hidden = true;

        var query = encodeURIComponent(q);
        viewAll.href = "/" + currentLang + "/productos/todos?busqueda=" + query;

        Promise.all([
          fetch("/api/productos/buscar?q=" + query + "&page=1&limit=6", { credentials: "same-origin" }).then(function(r) { return r.json().catch(function() { return {}; }); }),
          fetchCategories()
        ]).then(function(results) {
          var productsData = results[0];
          var categories = results[1];
          var products = Array.isArray(productsData?.productos) ? productsData.productos : [];
          var qNorm = normalize(q);
          var catMatches = categories.filter(function(c) { return normalize(c.nombre).includes(qNorm); }).slice(0, 4);

          productsList.innerHTML = products.map(function(p) {
            var pid = Number(p.id || 0);
            var name = String(p.nombre || "Producto");
            var category = escapeHtml(p.categoria || "Producto");
            var image = escapeHtml(p.imagen || fallbackImg);
            var price = Number(p.precioFinal ?? p.precio ?? 0).toLocaleString("es-MX", { style: "currency", currency: "MXN" });
            var hasDiscount = p.precioFinal && p.precio && Number(p.precioFinal) < Number(p.precio);
            var originalPrice = hasDiscount ? Number(p.precio).toLocaleString("es-MX", { style: "currency", currency: "MXN" }) : null;

            return '<a data-s-option class="gs-item" href="/' + currentLang + '/productos/detalle/' + pid + '">'
              + '<div class="gs-item-img"><img src="' + image + '" alt="' + escapeHtml(name) + '" loading="lazy" decoding="async" /></div>'
              + '<div class="gs-item-info">'
              + '<span class="gs-item-name">' + highlightMatch(name, q) + '</span>'
              + '<span class="gs-item-cat">' + category + '</span>'
              + '</div>'
              + '<div class="gs-item-price">'
              + '<span class="gs-item-amount">' + price + '</span>'
              + (originalPrice ? '<span class="gs-item-original">' + originalPrice + '</span>' : '')
              + '</div></a>';
          }).join("");

          categoriesList.innerHTML = catMatches.map(function(cat) {
            var id = Number(cat.id || 0);
            var name = String(cat.nombre || "Categoría");
            return '<a data-s-option class="gs-item gs-item--cat" href="/' + currentLang + '/productos/categoria/' + id + '">'
              + '<div class="gs-item-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="4" width="6" height="6" rx="1"></rect><rect x="14" y="4" width="6" height="6" rx="1"></rect><rect x="4" y="14" width="6" height="6" rx="1"></rect><rect x="14" y="14" width="6" height="6" rx="1"></rect></svg></div>'
              + '<div class="gs-item-info">'
              + '<span class="gs-item-name">' + highlightMatch(name, q) + '</span>'
              + '<span class="gs-item-cat">Categoría</span>'
              + '</div>'
              + '<svg class="gs-item-arrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"></path></svg>'
              + '</a>';
          }).join("");

          productsSection.hidden = products.length === 0;
          categoriesSection.hidden = catMatches.length === 0;
          if (hint instanceof HTMLElement) {
            var noResults = products.length === 0 && catMatches.length === 0;
            hint.textContent = noResults ? 'Sin resultados para "' + q + '"' : "";
            hint.hidden = !noResults;
          }
        }).catch(function() {
          productsSection.hidden = true;
          categoriesSection.hidden = true;
          if (hint instanceof HTMLElement) { hint.textContent = "Error al buscar. Intenta de nuevo."; hint.hidden = false; }
        }).finally(function() {
          if (spinner instanceof HTMLElement) spinner.hidden = true;
        });
      }

      var debouncedRender = debounce(renderResults, 220);

      form.addEventListener("submit", function(e) {
        e.preventDefault();
        var q = String(input.value || "").trim();
        window.location.href = q
          ? "/" + currentLang + "/productos/todos?busqueda=" + encodeURIComponent(q)
          : "/" + currentLang + "/productos/todos";
      });

      input.addEventListener("focus", function() {
        var q = input.value.trim();
        if (q.length >= 2) { debouncedRender(q); } else { showInitialState(); }
      });

      input.addEventListener("input", function() {
        activeIndex = -1;
        updateKeyboardFocus();
        updateClearVisibility();
        debouncedRender(input.value);
      });

      input.addEventListener("keydown", function(e) {
        var opts = getOptions();
        if (e.key === "ArrowDown") {
          e.preventDefault();
          if (!opts.length) return;
          activeIndex = Math.min(activeIndex + 1, opts.length - 1);
          updateKeyboardFocus();
